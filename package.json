{
  "name": "kira-takip-pro",
  "version": "6.0.0",
  "description": "Kira Takip Pro - Emlak Yönetim Sistemi",
  "main": "src/main.js",
  "author": {
    "name": "Kira Takip Pro",
    "email": "support@kiratakippro.com"
  },
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "syntax-check": "node scripts/check-syntax.js",
    "prebuild": "node scripts/check-syntax.js && node scripts/build-renderer.js",
    "build": "electron-builder build --win --x64",
    "build:dir": "electron-builder build --win --x64 --dir",
    "build:mac": "electron-builder build --mac",
    "build:mac:dir": "electron-builder build --mac --dir",
    "lint": "echo 'No linter configured'",
    "test": "node src/tests/run.js",
    "test:integrity": "node src/tests/integrity.js",
    "test:all": "node src/tests/run.js && node src/tests/integrity.js",
    "license:issue": "node scripts/license-issuer.js"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "clean-css": "^5.3.3",
    "electron": "^29.3.0",
    "electron-builder": "^24.13.3",
    "terser": "^5.48.0"
  },
  "build": {
    "appId": "com.kiratakippro.customer",
    "productName": "KiraTakipPro Customer",
    "copyright": "Copyright © 2026 Kira Takip Pro",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "build/icon.*",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!**/*.map",
      "!src/tests/**",
      "!src/renderer.html",
      "!src/prototypes/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "Kira Takip Pro",
      "legalTrademarks": "Kira Takip Pro",
      "fileAssociations": [
        {
          "ext": "ktpbackup",
          "name": "Kira Takip Backup",
          "description": "Kira Takip Pro Backup File"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kira Takip Pro",
      "menuCategory": "Kira Takip Pro",
      "deleteAppDataOnUninstall": false,
      "license": "build/license.txt",
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "KiraTakipPro-Customer-${version}-portable.exe"
    },
    "artifactName": "KiraTakipPro-Customer-Setup-${version}.exe",
    "_macNote": "ICON REQUIRED before mac build: build/icon.icns is missing. The repo has build/icon.ico (256x256 BMP frame). On macOS: open icon.ico in Preview → export largest frame as PNG → scale to 512x512 with sips → generate icns with iconutil. See MAC-NATIVE-INSTALL-0B docs for exact commands.",
    "mac": {
      "target": [
        { "target": "dmg",  "arch": ["x64", "arm64"] },
        { "target": "zip",  "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.business",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "fileAssociations": [
        {
          "ext": "ktpbackup",
          "name": "Kira Takip Backup",
          "description": "Kira Takip Pro Backup File"
        }
      ]
    }
  }
}
