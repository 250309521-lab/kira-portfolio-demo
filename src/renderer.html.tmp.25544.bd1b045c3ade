function t(key){
  var lang=(DATA&&DATA.settings&&DATA.settings.lang)||'tr';
  return (STRINGS[lang]||STRINGS.tr)[key]||(STRINGS.tr)[key]||key;
}

// ── Apply theme from DATA.settings.theme ───────────────────────────────
function applyTheme(theme){
  document.documentElement.setAttribute('data-theme',theme||'dark');
}

// ── Language pill HTML (used in onboarding welcome step) ────────────────
function _langPill(){
  var lang=(DATA&&DATA.settings&&DATA.settings.lang)||'tr';
  return '<div style="position:absolute;top:12px;right:14px;display:flex;align-items:center;gap:5px">'+
    '<div style="display:flex;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:20px;overflow:hidden;font-size:10px;font-weight:600">'+
    '<button onclick="switchLang(\'tr\')" style="background:'+(lang==='tr'?'rgba(59,130,246,.3)':'none')+';border:none;color:'+(lang==='tr'?'#93c5fd':'rgba(148,163,184,.6)')+';padding:3px 10px;cursor:pointer;letter-spacing:.5px">TR</button>'+
    '<button onclick="switchLang(\'en\')" style="background:'+(lang==='en'?'rgba(59,130,246,.3)':'none')+';border:none;color:'+(lang==='en'?'#93c5fd':'rgba(148,163,184,.6)')+';padding:3px 10px;cursor:pointer;letter-spacing:.5px">EN</button>'+
    '</div>'+
    '</div>';
}

// ── Update static login HTML text nodes from current lang ───────────────
function applyI18nLogin(){
  var sub=document.getElementById('login-sub');
  if(sub) sub.textContent=t('loginSubtitle');
  var pinInp=document.getElementById('pin-inp');
  if(pinInp) pinInp.placeholder=t('pinPlaceholder');
  var safe=document.getElementById('btn-static-safe');
  if(safe) safe.textContent=t('recovery');
  var reset=document.getElementById('btn-static-reset');
  if(reset) reset.textContent=t('resetData');
  try{_applyTopControls();}catch(e){}
}

function _refreshOpenModal(){
  if(!_openModalState) return;
  try{openMod(_openModalState.type,_openModalState.arg);}catch(e){}
}

function switchLang(lang){
  if(!DATA||!DATA.settings) return;
  DATA.settings.lang=lang;
  document.documentElement.lang=lang;
  try{saveLocal();}catch(e){}
  applyI18nLogin();
  renderLogin();
  var obScr=document.getElementById('ob-screen');
  if(obScr&&obScr.style.display!=='none') renderOnboarding();
  try{refreshUIText();}catch(e){}
  // Re-render live page content so all t() calls update instantly
  var content=document.getElementById('content');
  if(content&&content.innerHTML.trim()){
    try{render();}catch(e){}
  }
  _refreshOpenModal();
}

function switchTheme(){
  if(!DATA||!DATA.settings) return;
  DATA.settings.theme=(DATA.settings.theme==='dark'?'light':'dark');
  applyTheme(DATA.settings.theme);
  try{saveLocal();}catch(e){}
  applyI18nLogin();
  try{_applyTopControls();}catch(e){}
  // Re-render charts and open modal with new palette
  try{render();}catch(e){}
  _refreshOpenModal();
}

// ── Refresh static DOM text nodes to current language ──────────────────────
function _applyTopControls(){
  var lang=(DATA&&DATA.settings&&DATA.settings.lang)||'tr';
  var theme=(DATA&&DATA.settings&&DATA.settings.theme)||'dark';
  var trBtn=document.getElementById('top-lang-tr');
  var enBtn=document.getElementById('top-lang-en');
  if(trBtn){trBtn.className='top-lang-btn'+(lang==='tr'?' top-lang-active':'');}
  if(enBtn){enBtn.className='top-lang-btn'+(lang==='en'?' top-lang-active':'');}
  var tBtn=document.getElementById('top-theme-btn');
  if(tBtn) tBtn.textContent=theme==='dark'?'🌙':'☀️';
  // Sync login-screen controls too
  var ltrBtn=document.getElementById('lang-tr-btn');
  var lenBtn=document.getElementById('lang-en-btn');
  if(ltrBtn){ltrBtn.style.background=lang==='tr'?'rgba(59,130,246,.3)':'none';ltrBtn.style.color=lang==='tr'?'#93c5fd':'rgba(148,163,184,.6)';}
  if(lenBtn){lenBtn.style.background=lang==='en'?'rgba(59,130,246,.3)':'none';lenBtn.style.color=lang==='en'?'#93c5fd':'rgba(148,163,184,.6)';}
  var lThemeBtn=document.getElementById('theme-btn');
  if(lThemeBtn) lThemeBtn.textContent=theme==='dark'?'🌙':'☀️';
}

function refreshUIText(){
  if(!document.getElementById('sb-lbl-general')) return; // not in app shell yet
  // Sidebar labels
  var lblG=document.getElementById('sb-lbl-general');
  if(lblG) lblG.textContent=t('navGeneral');
  var lblT=document.getElementById('sb-lbl-tools');
  if(lblT) lblT.textContent=t('navTools');
  // Sidebar nav items (icons preserved via innerHTML rebuild)
  var navRebuild={
    'nb-pay':  ['💳',t('navPay')], 'nb-exp':  ['💸',t('navExp')],
    'nb-alper':['🤝',t('navAlper')],'nb-charts':['📈',t('navCharts')],
    'nb-wa':   ['💬',t('navWA')],  'nb-rep':   ['📄',t('navRep')],
    'nb-hist': ['🕐',t('navHist')],'nb-viz':   ['🌐',t('navViz')],
    'nb-cloud':['🔄',t('navCloud')],'nb-users': ['👥',t('navUsers')],
    'nb-import':['📥',t('navImport')],'nb-imphist':['📋',t('navImportHist')],
    'nb-settings':['⚙',t('navSettings')],'nb-csv':['📋',t('navExportCSV')],
    'nb-json': ['💾',t('navExportJSON')],'nb-excel':['📗',t('navExportExcel')],
    'nb-print':['🖨',t('navPrint')],
  };
  Object.keys(navRebuild).forEach(function(id){
    var el=document.getElementById(id);
    if(el){
      var wasActive=el.classList.contains('active');
      el.innerHTML='<span class="ni">'+navRebuild[id][0]+'</span>'+navRebuild[id][1];
      var bdg=document.getElementById('bdg-'+id.replace('nb-',''));
      // Note: badges are re-inserted by updateBadges(), not needed here
    }
  });
  // Sidebar footer
  var sbSaveBtn=document.getElementById('sb-save-btn');
  if(sbSaveBtn) sbSaveBtn.textContent=t('sbSave');
  var sbToggle=document.getElementById('sb-toggle');
  if(sbToggle){
    var collapsed=document.getElementById('sb').classList.contains('collapsed');
    sbToggle.textContent=collapsed?t('sbExpand'):t('sbCollapse');
  }
  var sbSub=document.querySelector('.sb-brand-sub');
  if(sbSub) sbSub.textContent=t('sbAppSub');
  // Cloud indicator (only update if showing default text)
  var cloudTitle=document.getElementById('cloud-title');
  if(cloudTitle){var ct=cloudTitle.textContent;if(ct==='Bulut Yok'||ct==='No Cloud')cloudTitle.textContent=t('cloudNone');}
  var cloudSub=document.getElementById('cloud-sub');
  if(cloudSub){var cs=cloudSub.textContent;if(cs==='Yerel mod aktif'||cs==='Local mode active')cloudSub.textContent=t('cloudLocal');}
  // Topbar action buttons
  var btnPay=document.getElementById('btn-pay'); if(btnPay) btnPay.textContent=t('addPayment2');
  var btnExp=document.getElementById('btn-exp'); if(btnExp) btnExp.textContent=t('addExpense2');
  var btnTen=document.getElementById('btn-ten'); if(btnTen) btnTen.textContent=t('addTenant2');
  // Search placeholder
  var gsrch=document.getElementById('gsrch'); if(gsrch) gsrch.placeholder=t('searchTenant');
  // FAB labels
  var fabPay=document.getElementById('fab-lbl-pay'); if(fabPay) fabPay.textContent=t('fabPayment');
  var fabExp=document.getElementById('fab-lbl-exp'); if(fabExp) fabExp.textContent=t('fabExpense');
  var fabTen=document.getElementById('fab-lbl-ten'); if(fabTen) fabTen.textContent=t('fabTenant');
  var fabCmd=document.getElementById('fab-lbl-cmd'); if(fabCmd) fabCmd.textContent=t('fabCmd');
  // Import wizard / history titles
  var wizTitle=document.getElementById('wiz-hdr-title'); if(wizTitle) wizTitle.textContent=t('importWizTitle');
  var histTitle=document.getElementById('import-hist-title'); if(histTitle) histTitle.textContent=t('importHistTitle');
  // Command palette placeholder
  var cmdInp=document.getElementById('cmd-input'); if(cmdInp) cmdInp.placeholder=t('cmdPlaceholder');
  // Top controls state
  _applyTopControls();
  // Re-render page content with new language
  try{render();}catch(e){}
  // Re-render building nav (Binalar label)
  try{renderBuildingNav();}catch(e){}
}

// ═══════════════════════════════════════════════
// LOGIN SYSTEM
// ═══════════════════════════════════════════════
function renderLogin(){
  const hasRealUsers=DATA.users&&DATA.users.length>0;
  const users=hasRealUsers?DATA.users:DEFAULT_USERS;
  const c=document.getElementById('login-users');
  if(!c) return;
  c.innerHTML=users.map(u=>`
    <button class="login-user-btn" onclick="selectUser('${u.id}')">
      <div class="login-avatar" style="background:${u.color||'#4a8af4'}">${u.avatar||(u.name?u.name[0]:'?')}</div>
      <div class="login-user-info">
        <div class="login-user-name">${u.name||t('colUser')}</div>
        <div class="login-user-role">${roleLabel(u.role)}</div>
      </div>
      <div style="color:var(--i3);font-size:16px">›</div>
    </button>
  `).join('')+
  (!hasRealUsers?`<button onclick="renderOnboarding()" style="margin-top:14px;width:100%;padding:10px;background:rgba(99,102,241,.12);color:var(--i2);border:1px solid rgba(99,102,241,.3);border-radius:8px;cursor:pointer;font-size:12.5px">${t('setupBack')}</button>`:'');
}

function roleLabel(r){
  return r==='admin'?t('roleAdmin'):r==='manager'?t('roleManager'):t('roleViewer');
}

function selectUser(uid){
  const users=DATA.users&&DATA.users.length?DATA.users:DEFAULT_USERS;
  loginSelectedUser=users.find(u=>u.id===uid);
  if(!loginSelectedUser) return;
  document.getElementById('pin-wrap').style.display='block';
  document.getElementById('pin-inp').value='';
  document.getElementById('login-err').textContent='';
  setTimeout(()=>document.getElementById('pin-inp').focus(),100);
}

function checkPin(){
  const inp=document.getElementById('pin-inp');
  if(!inp) return;
  const val=inp.value;
  if(val.length<4) return;
  if(!loginSelectedUser){
    // Guard: user selection lost — re-render login to recover
    console.warn('[BOOT] checkPin called with null loginSelectedUser — re-rendering login');
    renderLogin();
    return;
  }
  if(val===loginSelectedUser.pin){
    currentUser=loginSelectedUser;
    __boot('login','user: '+loginSelectedUser.id);
    document.getElementById('login-screen').style.display='none';
    initApp();
  } else {
    document.getElementById('login-err').textContent=t('pinError');
    inp.value='';
    setTimeout(()=>document.getElementById('login-err').textContent='',2000);
  }
}

function logout(){
  currentUser=null;
  document.getElementById('login-screen').style.display='flex';
  document.getElementById('pin-wrap').style.display='none';
  document.getElementById('pin-inp').value='';
  renderLogin();
}

function canEdit(){return currentUser&&(currentUser.role==='admin'||currentUser.role==='manager');}
function isAdmin(){return currentUser&&currentUser.role==='admin';}
// User management permission helpers
function _isSelf(i){return DATA.users[i]&&DATA.users[i].id===currentUser?.id;}
function canEditUser(i){return isAdmin()||_isSelf(i);}  // admin edits anyone; others only self
function canChangeRole(){return isAdmin();}              // only admin changes roles
function canDeactivateUser(i){return isAdmin()&&!_isSelf(i);}
function canDeleteUser(i){return isAdmin()&&!_isSelf(i);}

function initApp(){
  // Update UI for user
  const av=document.getElementById('sb-uav');
  const nm=document.getElementById('sb-uname');
  const rl=document.getElementById('sb-urole');
  if(av){av.textContent=currentUser.avatar;av.style.background=currentUser.color;}
  if(nm) nm.textContent=currentUser.name;
  if(rl) rl.textContent=roleLabel(currentUser.role);

  // Hide add buttons for viewer
  if(!canEdit()){
    const btnIds=['btn-addpay','btn-addexp','btn-addten'];
    btnIds.forEach(id=>{const el=document.getElementById(id);if(el)el.style.display='none';});
  }
  // Hide user management for non-admin
  if(!isAdmin()){
    const nb=document.getElementById('nb-users');
    if(nb) nb.style.display='none';
  }

  renderBuildingNav();  // re-render nav with canEdit() now resolved
  updateCloudUI();
  render();
  updateBadges();
  addHist('Giriş yapıldı');
  _startupPull();  // 6B-3: fire-and-forget; silent; runs once per app launch
}

// ═══════════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════════
function currencySymbol(){var cur=(DATA&&DATA.settings&&DATA.settings.currency)||'TRY';return cur==='USD'?'$':'₺';}
function money(v){var sym=currencySymbol();var lang=(DATA&&DATA.settings&&DATA.settings.lang)||'tr';return sym+Number(v||0).toLocaleString(lang==='en'?'en-US':'tr-TR');}
const TL=money; // backward compat alias
// Format ISO date string for current locale: TR → DD.MM.YYYY, EN → MM/DD/YYYY
function formatDate(d){
  if(!d) return '—';
  var lang=(DATA&&DATA.settings&&DATA.settings.lang)||'tr';
  try{
    var dt=new Date(d);
    if(isNaN(dt.getTime())) return d;
    var dd=String(dt.getUTCDate()).padStart(2,'0');
    var mm=String(dt.getUTCMonth()+1).padStart(2,'0');
    var yy=dt.getUTCFullYear();
    return lang==='en'?(mm+'/'+dd+'/'+yy):(dd+'.'+mm+'.'+yy);
  }catch(e){return d;}
}
const sortU=a=>[...a].sort((a,b)=>(parseInt(a.unit.replace(/\D/g,''))||999)-(parseInt(b.unit.replace(/\D/g,''))||999));

function getP(tid,mo){return ((DATA.payments||{})[tid]||{})[mo]||{paid:0,date:'',sekil:'',notes:''};}
function setP(tid,mo,d){if(!DATA.payments[tid])DATA.payments[tid]={};DATA.payments[tid][mo]=d;}

function getStatus(ten,mo){
  if(!ten.active||ten.rent===0) return {lbl:t('statusVacant'),cls:'b-gray'};
  const p=getP(ten.id,mo);
  if(p.paid>=ten.rent) return {lbl:t('statusPaid'),cls:'b-green'};
  if(p.paid>0) return {lbl:t('statusPartial'),cls:'b-orange'};
  return {lbl:t('statusUnpaid'),cls:'b-red'};
}

function safeArr(v){return Array.isArray(v)?v:[];}
function safeTens(bld){return safeArr(DATA.tenants[bld]);}
function safeExps(bld,mo){return safeArr(((DATA.expenses[bld]||{})[mo]));}
function expTotal(bld,mo){return safeExps(bld,mo).reduce((s,e)=>s+(e&&+e.tutar||0),0);}
function paidTotal(bld,mo){return safeTens(bld).filter(t=>t.active&&t.rent>0).reduce((s,t)=>s+getP(t.id,mo).paid,0);}
function rentTotal(bld){return safeTens(bld).filter(t=>t.active&&t.rent>0).reduce((s,t)=>s+t.rent,0);}

function isDue(t,mo){
  if(!t.active||t.rent===0) return false;
  if(getP(t.id,mo).paid>=t.rent) return false;
  const now=new Date();
  const [mName,yr]=mo.split(' ');
  const mi=MONTHS.indexOf(mName);
  if(mi<0) return false;
  const dueDate=new Date(parseInt(yr),mi,t.gun||1);
  const overdue=new Date(parseInt(yr),mi,(t.gun||1)+1);
  return now>=overdue;
}

// ── Building DOM helpers ─────────────────────────────────
function bldDomId(id){
  return String(id)
    .trim()
    .replace(/\s+/g,'-')
    .replace(/[^a-zA-Z0-9\-_]/g,'');
}

function renderBuildingNav(){
  const root=document.getElementById('bld-nav-root');
  if(!root) return;
  const active=safeArr(DATA.buildings).filter(b=>b&&b.active).sort((x,y)=>x.order-y.order);
  const addBtn=canEdit()?'<button id="btn-add-bina" class="nav" type="button" style="color:var(--blue-l);font-weight:500;margin-top:2px"><span class="ni">＋</span>'+t('addBuilding')+'</button>':'';
  root.innerHTML=
    '<div class="sb-section-label">'+t('navBuildings')+'</div>'+
    addBtn+
    active.map(b=>{
      const did=bldDomId(b.id);
      const safeId=b.id.replace(/'/g,"\\'");
      const kebab=canEdit()?`<span class="bld-kebab" onclick="event.stopPropagation();showBldMenu('${safeId}',this)" title="Seçenekler">⋮</span>`:'';
      return `<button class="nav" id="nb-${did}" onclick="goto('bld','${safeId}')">` +
             `<span class="ni">🏢</span>${b.name}` +
             `<span class="nbadge" id="bdg-${did}" style="display:none">0</span>` +
             kebab+
             `</button>`;
    }).join('');
}

function addNewBuilding(){
  openMod('bld-add');
  setTimeout(()=>{ const el=document.getElementById('m-bld-name'); if(el) el.focus(); },60);
}

function commitAddBuilding(){
  const inp=document.getElementById('m-bld-name');
  if(!inp) return;
  const name=inp.value.trim();
  if(!name){ inp.focus(); toast(t('errMinChars'),'red'); return; }
  if(name.length<2){ inp.focus(); toast(t('errMinChars'),'red'); return; }
  const bldId=name.toUpperCase().trim();
  const dup=(DATA.buildings||[]).some(b=>b.id===bldId||b.name.trim().toLowerCase()===name.toLowerCase());
  if(dup){ inp.focus(); toast(t('errBldNameDup'),'red'); return; }
  const bldShort=name.split(/\s+/).map(w=>w.replace(/[^a-zA-ZğüşöçıĞÜŞÖÇİ]/gi,'')[0]||'')
    .join('').toUpperCase().slice(0,3)||name.replace(/[^a-zA-Z]/g,'').toUpperCase().slice(0,3)||'BLD';
  DATA.buildings.push({id:bldId,name,short:bldShort,color:'',active:true,order:(DATA.buildings||[]).length,metadata:{}});
  if(!DATA.tenants[bldId]) DATA.tenants[bldId]=[];
  if(!DATA.expenses[bldId]) DATA.expenses[bldId]={};
  syncBuildingConstants();
  renderBuildingNav();
  updateBadges();
  saveLocal();
  addHist('Bina eklendi: '+name);
  closeMod();
  toast('✅ Bina eklendi: '+name,'green');
}
window.addNewBuilding = addNewBuilding;
window.commitAddBuilding = commitAddBuilding;

if(!window.__addBinaClickBound){
  window.__addBinaClickBound=true;
  document.addEventListener('click',function(e){
    const btn=e.target.closest('#btn-add-bina');
    if(!btn) return;
    e.preventDefault();
    e.stopPropagation();
    window.addNewBuilding();
  },true);
}

// ── BUILDING CONTEXT MENU ─────────────────────────────────────
function showBldMenu(bldId, btn){
  hideBldMenu();
  const rect=btn.getBoundingClientRect();
  const safe=bldId.replace(/'/g,"\\'");
  const menu=document.createElement('div');
  menu.className='bld-ctx-menu';
  menu.id='bld-ctx-menu';
  menu.innerHTML=
    `<button class="bld-ctx-item" onclick="hideBldMenu();openMod('bld-rename','${safe}')">${t('bldRename')}</button>`+
    `<button class="bld-ctx-item" onclick="hideBldMenu();openMod('bld-settings','${safe}')">${t('bldSettingsMenu')}</button>`+
    `<button class="bld-ctx-item ctx-danger" onclick="hideBldMenu();openMod('bld-archive','${safe}')">${t('bldArchive')}</button>`;
  document.body.appendChild(menu);
  const menuW=158;
  let left=rect.right+6;
  let top=rect.top;
  if(left+menuW>window.innerWidth) left=rect.left-menuW-4;
  if(top+120>window.innerHeight) top=window.innerHeight-124;
  menu.style.left=left+'px';
  menu.style.top=top+'px';
  setTimeout(()=>{ document.addEventListener('click',hideBldMenu,{once:true}); },0);
}

function hideBldMenu(){
  const m=document.getElementById('bld-ctx-menu');
  if(m) m.remove();
}
window.showBldMenu=showBldMenu;
window.hideBldMenu=hideBldMenu;

// ═══════════════════════════════════════════════
// ONBOARDING  (Phase 4 — PRODUCTION_MODE=true)
// ═══════════════════════════════════════════════
let _obPin = ''; // transient — cleared immediately after obCommit()
let _obName = ''; // transient — cleared immediately after obCommit()

function needsOnboarding(){
  if(!PRODUCTION_MODE) return false;
  if(!DATA.initialized) return true;
  // Recovery: initialized flag set but data is inconsistent
  const hasBuilding=(DATA.buildings||[]).some(b=>b.active);
  const hasAdmin=(DATA.users||[]).some(u=>u.role==='admin'&&u.pin);
  return !hasBuilding||!hasAdmin;
}

function renderOnboarding(){
  const scr=document.getElementById('ob-screen');
  const box=document.getElementById('ob-box');
  if(!scr||!box) return;
  _obPin=''; _obName='';
  scr.style.display='flex';
  _obSet(_langPill()+`
    <div class="login-logo">🏢</div>
    <div class="login-title">${t('obTitle')}</div>
    <div class="login-sub">${t('obSub')}</div>
    <p style="font-size:12.5px;color:var(--i4);text-align:center;line-height:1.6;margin:0 0 24px">${t('obWelcomeDesc')}</p>
    <button class="btn btn-primary" style="width:100%;font-size:14px"
            onclick="obStepProfile()">${t('obStart')}</button>
    <div class="login-version">${t('obFirstSetup')}</div>
  `);
}

function _obSet(html){
  const box=document.getElementById('ob-box');
  if(!box) return;
  box.style.opacity='0';
  setTimeout(()=>{ box.innerHTML=html; box.style.opacity='1'; },130);
}

function obStepProfile(){
  _obSet(`
    <div class="login-logo">👤</div>
    <div class="login-title">${t('obStep1Title')}</div>
    <div class="login-sub" style="margin-bottom:22px">${t('obStep1Sub')}</div>
    <div style="font-size:11.5px;color:var(--i3);margin-bottom:6px;text-align:left;letter-spacing:.2px">${t('obNameLabel')}</div>
    <input type="text" id="ob-name" class="ob-text-input"
           placeholder="${t('obNamePh')}" maxlength="60"
           oninput="obCheckProfile()"
           onkeydown="if(event.key==='Enter'&&document.getElementById('ob-next-p')?.style.pointerEvents!=='none')obStepPin();"
           autocomplete="off">
    <div class="login-error" id="ob-err-p"></div>
    <div style="margin-top:18px;display:flex;flex-direction:column;gap:8px">
      <button id="ob-next-p" class="btn btn-primary" style="width:100%;opacity:.4;pointer-events:none"
              onclick="obStepPin()">${t('obContinue')}</button>
      <button class="btn btn-ghost" style="width:100%;font-size:12px;color:var(--i4)"
              onclick="renderOnboarding()">${t('obBackBtn')}</button>
    </div>
    <div class="login-version">${t('obFirstSetup')}</div>
  `);
  setTimeout(()=>{ const el=document.getElementById('ob-name'); if(el) el.focus(); },180);
}

function obCheckProfile(){
  const v=(document.getElementById('ob-name')?.value||'').trim();
  const btn=document.getElementById('ob-next-p');
  if(!btn) return;
  const ok=v.length>=2;
  btn.style.opacity=ok?'1':'0.4';
  btn.style.pointerEvents=ok?'auto':'none';
}

function obStepPin(){
  const nm=(document.getElementById('ob-name')?.value||'').trim();
  if(nm.length>=2) _obName=nm;
  _obSet(`
    <div class="login-logo">🔐</div>
    <div class="login-title">${t('obStep2Title')}</div>
    <div class="login-sub" style="margin-bottom:22px">${t('obStep2Sub')}</div>
    <div style="display:flex;flex-direction:column;gap:10px">
      <input type="password" id="ob-pin1" class="login-pin-input" maxlength="6"
             placeholder="• • • •" oninput="obCheckStep1()" autocomplete="new-password">
      <input type="password" id="ob-pin2" class="login-pin-input" maxlength="6"
             placeholder="••••" oninput="obCheckStep1()" autocomplete="new-password">
    </div>
    <div class="login-error" id="ob-err"></div>
    <div style="margin-top:16px;display:flex;flex-direction:column;gap:8px">
      <button id="ob-next1" class="btn btn-primary" style="width:100%;opacity:.4;pointer-events:none"
              onclick="obStep2()">${t('obContinue')}</button>
      <button class="btn btn-ghost" style="width:100%;font-size:12px;color:var(--i4)"
              onclick="obStepProfile()">${t('obBackBtn')}</button>
    </div>
    <div class="login-version">${t('obFirstSetup')}</div>
  `);
  setTimeout(()=>{ const el=document.getElementById('ob-pin1'); if(el) el.focus(); },180);
}

function obCheckStep1(){
  const p1=(document.getElementById('ob-pin1')?.value)||'';
  const p2=(document.getElementById('ob-pin2')?.value)||'';
  const btn=document.getElementById('ob-next1');
  if(!btn) return;
  const ok=p1.length>=4&&/^\d+$/.test(p1)&&p1===p2;
  btn.style.opacity=ok?'1':'0.4';
  btn.style.pointerEvents=ok?'auto':'none';
  const err=document.getElementById('ob-err');
  if(err&&p2.length>=4&&p1!==p2) err.textContent=t('obPinMismatch');
  else if(err) err.textContent='';
}

function obStep2(){
  const p1=(document.getElementById('ob-pin1')?.value)||'';
  const p2=(document.getElementById('ob-pin2')?.value)||'';
  const err=document.getElementById('ob-err');
  if(p1.length<4||!/^\d+$/.test(p1)){ if(err) err.textContent=t('obPinTooShort'); return; }
  if(p1!==p2){ if(err) err.textContent=t('obPinMismatch'); return; }
  _obPin=p1;
  _obSet(`
    <div class="login-logo">🏢</div>
    <div class="login-title">${t('obStep3Title')}</div>
    <div class="login-sub" style="margin-bottom:16px">${t('obStep3Sub')}</div>
    <div style="font-size:11.5px;color:var(--i3);margin-bottom:6px;text-align:left;letter-spacing:.2px">${t('obBldLabel')}</div>
    <input type="text" id="ob-bld" class="ob-text-input"
           placeholder="${t('obBldPh')}"
           oninput="obCheckStep2()"
           onkeydown="if(event.key==='Enter'&&document.getElementById('ob-commit')?.style.pointerEvents!=='none')obCommit();"
           autocomplete="off">
    <div class="login-error" id="ob-err2"></div>
    <div style="margin-top:16px;display:flex;flex-direction:column;gap:8px">
      <button id="ob-commit" class="btn btn-primary" style="width:100%;opacity:.4;pointer-events:none"
              onclick="obCommit()">${t('obFinish')}</button>
      <button class="btn btn-ghost" style="width:100%;font-size:12px;color:var(--i4)"
              onclick="obStepPin()">${t('obBackBtn')}</button>
      <button class="btn btn-ghost" style="width:100%;font-size:12px;color:var(--i4)"
              onclick="obSkipImport()">${t('obImport')}</button>
      <button class="btn btn-ghost" style="width:100%;font-size:12px;color:var(--i4)"
              onclick="obCloudBootstrap()">${t('obCloud')}</button>
    </div>
    <div class="login-version">${t('obFirstSetup')}</div>
  `);
  setTimeout(()=>{ const el=document.getElementById('ob-bld'); if(el) el.focus(); },180);
}

function obCheckStep2(){
  const v=(document.getElementById('ob-bld')?.value||'').trim();
  const btn=document.getElementById('ob-commit');
  if(!btn) return;
  const ok=v.length>=2;
  btn.style.opacity=ok?'1':'0.4';
  btn.style.pointerEvents=ok?'auto':'none';
}

function obSkipImport(){
  importWizard(null, {fromOnboarding:true});
}

// ── 6B-4: Cloud Bootstrap During Onboarding ─────────────────
function obCloudBootstrap(){
  if(DATA.cloud.supabaseUrl && DATA.cloud.supabaseKey){
    _obCloudFetch();
  } else {
    _obShowCloudForm();
  }
}

function _obShowCloudForm(){
  const box=document.getElementById('ob-box');
  box.innerHTML=`
    <div class="login-logo">☁️</div>
    <div class="login-title">${t('obCloudTitle')}</div>
    <div class="login-sub" style="margin-bottom:16px">${t('obCloudSub')}</div>
    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:12px">
      <input type="text" id="ob-supa-url" class="ob-text-input"
             placeholder="https://xxxx.supabase.co" autocomplete="off">
      <input type="text" id="ob-supa-key" class="ob-text-input"
             placeholder="anon / public key" autocomplete="off">
    </div>
    <div class="login-error" id="ob-err2"></div>
    <div style="margin-top:12px;display:flex;flex-direction:column;gap:8px">
      <button class="btn btn-primary" style="width:100%" onclick="_obCloudConnect()">${t('obCloudConnect')}</button>
      <button class="btn btn-ghost" style="width:100%;font-size:12px" onclick="obStep2()">${t('obBackBtn')}</button>
    </div>
    <div class="login-version">${t('obInitSetup')}</div>
  `;
  setTimeout(()=>{ const el=document.getElementById('ob-supa-url'); if(el) el.focus(); },100);
}

async function _obCloudConnect(){
  const url=(document.getElementById('ob-supa-url')?.value||'').trim().replace(/\/+$/,'');
  const key=(document.getElementById('ob-supa-key')?.value||'').trim();
  const err=document.getElementById('ob-err2');
  if(!url||!key){ if(err) err.textContent=t('obErrUrlKey'); return; }
  if(!/^https:\/\/.+\.supabase\.co$/.test(url)){ if(err) err.textContent=t('obErrUrlFmt'); return; }
  // Store temporarily so _supaSelect can use them; cleared on connection error
  DATA.cloud.supabaseUrl=url;
  DATA.cloud.supabaseKey=key;
  DATA.cloud.mode='supabase';
  if(err) err.textContent=t('obConnecting');
  await _obCloudFetch();
}

async function _obCloudFetch(){
  const err=document.getElementById('ob-err2');
  const wsId=DATA.cloud.workspaceId||'ktp_main';
  try{
    const rows=await _supaSelect('ktp_sync','id=eq.'+encodeURIComponent(wsId));
    if(!rows||!rows.length){
      if(err) err.textContent=t('obErrNoData');
      return;
    }
    const d=JSON.parse(rows[0].data_json);
    const validated=_importValidate(d);
    if(!validated.ok){
      if(err) err.textContent=t('obErrInvalid')+validated.errors.join(', ');
      return;
    }
    const result=_importCommit(d,'overwrite');
    if(!result.ok){
      if(err) err.textContent=t('obErrLoad')+(result.error||t('unknownOp'));
      return;
    }
    // Persist cloud metadata — sync disabled until user explicitly enables it
    DATA.cloud.serverVersion=rows[0].version;
    DATA.cloud.lastSync=rows[0].updated_at;
    DATA.cloud.workspaceId=wsId;
    DATA.cloud.enabled=false;
    _obPin=''; _obName='';
    saveLocal();
    const obScr=document.getElementById('ob-screen');
    if(obScr) obScr.style.display='none';
    renderLogin();
    toast(t('obSuccessLoaded'),'green');
  }catch(e){
    if(err) err.textContent=t('obErrConn')+e.message;
    // Credentials remain set if connection reached Supabase — user can retry
  }
}

function obCommit(){
  const bldName=(document.getElementById('ob-bld')?.value||'').trim();
  const err=document.getElementById('ob-err2');
  if(!_obPin||_obPin.length<4){ if(err) err.textContent=t('obErrPinInvalid'); return; }
  if(bldName.length<2){ if(err) err.textContent=t('obErrBldName'); return; }

  const adminName=(_obName||'').trim()||t('defaultAdminName');
  const adminAvatar=adminName.replace(/\s+/g,' ').split(' ').map(w=>w[0]||'').join('').toUpperCase().slice(0,2)||'Y';

  const bldId=bldName.toUpperCase().trim();
  const bldShort=bldName.split(/\s+/).map(w=>w.replace(/[^a-zA-ZğüşöçıĞÜŞÖÇİ]/gi,'')[0]||'')
    .join('').toUpperCase().slice(0,3) || bldName.replace(/[^a-zA-Z]/g,'').toUpperCase().slice(0,3) || 'BLD';

  // Single mutation point — all DATA writes happen here
  DATA.initialized=true;
  DATA.buildings=[{id:bldId,name:bldName,short:bldShort,color:'',active:true,order:0,metadata:{}}];
  DATA.tenants[bldId]=[];
  DATA.payments[bldId]={};
  DATA.expenses[bldId]=[];
  DATA.users=[{id:'admin',name:adminName,role:'admin',pin:_obPin,color:'#4a8af4',avatar:adminAvatar}];
  _obPin=''; _obName=''; // clear transients immediately

  syncBuildingConstants();
  renderBuildingNav();
  saveLocal();

  document.getElementById('ob-screen').style.display='none';
  renderLogin();
}

// ═══════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════
function goto(page,bld){
  S.page=page; S.bld=bld||null; S.search='';
  document.querySelectorAll('.nav').forEach(n=>n.classList.remove('active'));
  const idMap={dash:'nb-dash',pay:'nb-pay',exp:'nb-exp',alper:'nb-alper',
    charts:'nb-charts',wa:'nb-wa',rep:'nb-rep',hist:'nb-hist',viz:'nb-viz',
    bld:bld?'nb-'+bldDomId(bld):''};
  const el=document.getElementById(idMap[page]);
  if(el) el.classList.add('active');
  const titles={dash:t('pageDash'),pay:t('pagePay'),exp:t('pageExp'),
    alper:t('pageAlper'),charts:t('pageCharts'),wa:t('pageWA'),
    rep:t('pageRep'),hist:t('pageHist'),viz:t('pageViz'),
    bld:'🏢 '+(BL[bld]||bld)};
  const ptEl=document.getElementById('topbar-title');
  if(ptEl) ptEl.textContent=titles[page]||page;
  render();updateBadges();
}

function updateBadges(){
  BK.forEach(b=>{
    const cnt=(DATA.tenants[b]||[]).filter(t=>{
      if(!t.active||t.rent===0) return false;
      return getP(t.id,S.month).paid<t.rent;
    }).length;
    const el=document.getElementById('bdg-'+bldDomId(b));
    if(el){el.textContent=cnt;el.style.display=cnt?'':'none';}
  });
}

// Toggle status filter; same key → clear filter
function setFilter(f){
  S.filter=(S.filter===f)?'':f;
  render();
}

// Navigate to a page with a pre-set filter (bypasses goto's filter-clear)
function gotoFiltered(page,filter,bld){
  S.page=page||'dash';
  S.bld=bld||null;
  S.search='';
  S.filter=filter||'';
  document.querySelectorAll('.nav').forEach(n=>n.classList.remove('active'));
  const idMap={dash:'nb-dash',pay:'nb-pay',exp:'nb-exp',alper:'nb-alper',
    charts:'nb-charts',wa:'nb-wa',rep:'nb-rep',hist:'nb-hist',viz:'nb-viz',
    bld:bld?'nb-'+bldDomId(bld):''};
  const el=document.getElementById(idMap[page]);
  if(el) el.classList.add('active');
  const titles={dash:window.t('pageDash'),pay:window.t('pagePay'),exp:window.t('pageExp'),
    alper:window.t('pageAlper'),charts:window.t('pageCharts'),wa:window.t('pageWA'),
    rep:window.t('pageRep'),hist:window.t('pageHist'),viz:window.t('pageViz'),
    bld:'🏢 '+(BL[bld]||bld||'')};
  const ttEl=document.getElementById('topbar-title');
  if(ttEl) ttEl.textContent=titles[page]||page;
  render();updateBadges();
}

// Navigate to first building that has vacant units, filtered to vacant
function gotoVacant(){
  const b=BK.find(b=>safeTens(b).some(t=>!t.active));
  if(b) gotoFiltered('bld','vacant',b);
}

// ═══════════════════════════════════════════════
// MONTH BAR
// ═══════════════════════════════════════════════
function monthBar(){
  const scrollId='mbar-'+Math.random().toString(36).slice(2,7);
  let inner='';
  const _barYears=[...new Set(ALL_MONTHS.map(m=>m.split(' ')[1]))];
  _barYears.forEach(y=>{
    inner+=`<span class="year-tag">${y}</span>`;
    MONTHS.forEach(m=>{
      const ms=m+' '+y;
      if(!ALL_MONTHS.includes(ms)) return;
      inner+=`<button class="mbtn${S.month===ms?' active':''}" data-month="${ms}" onclick="setMo('${ms}')" title="${monthLabel(ms)}">${monthLabelShort(m)}</button>`;
    });
    inner+='<span class="mbar-sep"></span>';
  });

  return `<div class="mbar-outer">
    <button class="mbar-arrow" onclick="stepMo(-1)" aria-label="${t('monthBarPrev')}" title="${t('monthBarPrev')} ( [ )">‹</button>
    <div class="period-bar" id="${scrollId}" role="region" aria-label="${t('monthBarRegion')}"
         onwheel="mbarWheel(event,this)"
         onmousedown="mbarDragStart(event,this)"
         onmousemove="mbarDragMove(event,this)"
         onmouseup="mbarDragEnd(this)"
         onmouseleave="mbarDragEnd(this)">
      <span class="period-label">📅</span>
      ${inner}
    </div>
    <button class="mbar-arrow" onclick="stepMo(1)" aria-label="${t('monthBarNext')}" title="${t('monthBarNext')} ( ] )">›</button>
  </div>`;
}

function setMo(m){
  if(!m) return;
  if(!ALL_MONTHS.includes(m)) ALL_MONTHS=buildAllMonths([m]);
  const prevBar=document.querySelector('.period-bar');
  const savedScroll=prevBar?prevBar.scrollLeft:0;
  S.month=m;
  render();updateBadges();
  const newBar=document.querySelector('.period-bar');
  if(newBar) newBar.scrollLeft=savedScroll;
  setTimeout(()=>{
    const active=document.querySelector('.mbtn.active');
    if(active) active.scrollIntoView({behavior:'instant',block:'nearest',inline:'nearest'});
  },20);
}

// ── Month bar: drag-to-scroll with momentum/inertia ──────────
const _mbar={
  dragging:false,startX:0,scrollLeft:0,el:null,
  velX:0,lastX:0,lastT:0,rafId:null
};

function mbarDragStart(e,el){
  // Cancel any ongoing momentum
  if(_mbar.rafId){cancelAnimationFrame(_mbar.rafId);_mbar.rafId=null;}
  _mbar.dragging=true;_mbar.el=el;
  _mbar.startX=e.pageX-el.offsetLeft;
  _mbar.scrollLeft=el.scrollLeft;
  _mbar.velX=0;_mbar.lastX=e.pageX;_mbar.lastT=Date.now();
  el.classList.add('is-dragging');
  e.preventDefault();
}
function mbarDragMove(e,el){
  if(!_mbar.dragging||_mbar.el!==el) return;
  e.preventDefault();
  const now=Date.now();
  const dt=Math.max(now-_mbar.lastT,1);
  const dx=e.pageX-_mbar.lastX;
  // Exponential moving average velocity (px/ms)
  _mbar.velX=_mbar.velX*0.7+dx/dt*0.3;
  _mbar.lastX=e.pageX;_mbar.lastT=now;
  const x=e.pageX-el.offsetLeft;
  el.scrollLeft=_mbar.scrollLeft-(x-_mbar.startX);
}
function mbarDragEnd(el){
  if(!_mbar.dragging) return;
  _mbar.dragging=false;
  if(el) el.classList.remove('is-dragging');
  // Apply momentum (inertia scroll)
  const vel=_mbar.velX*18; // scale velocity
  if(Math.abs(vel)<0.5) return;
  let v=vel;
  function momentum(){
    if(Math.abs(v)<0.2){_mbar.rafId=null;return;}
    el.scrollLeft-=v;
    v*=0.88; // friction
    _mbar.rafId=requestAnimationFrame(momentum);
  }
  _mbar.rafId=requestAnimationFrame(momentum);
}
function mbarWheel(e,el){
  e.preventDefault();
  // Cancel momentum on wheel
  if(_mbar.rafId){cancelAnimationFrame(_mbar.rafId);_mbar.rafId=null;}
  const delta=(e.deltaY||e.deltaX);
  // Smooth step
  el.scrollBy({left:delta*1.2,behavior:'auto'});
}
function mbarScroll(id,delta){
  const el=document.getElementById(id);
  if(el) el.scrollBy({left:delta,behavior:'smooth'});
}

function stepMo(dir){
  const idx=ALL_MONTHS.indexOf(S.month);
  const nidx=idx+dir;
  if(nidx<0){
    // Extend backward by 1 year
    const fy=parseInt(ALL_MONTHS[0].split(' ')[1])-1;
    ALL_MONTHS.unshift(...MONTHS.map(m=>m+' '+fy));
    setMo(ALL_MONTHS[ALL_MONTHS.indexOf(S.month)+dir]);
  } else if(nidx>=ALL_MONTHS.length){
    // Extend forward by 1 year
    const ly=parseInt(ALL_MONTHS[ALL_MONTHS.length-1].split(' ')[1])+1;
    MONTHS.forEach(m=>ALL_MONTHS.push(m+' '+ly));
    setMo(ALL_MONTHS[nidx]);
  } else {
    setMo(ALL_MONTHS[nidx]);
  }
}

// Keyboard arrow support on month bar (focused mbtn)
document.addEventListener('keydown',e=>{
  const onMbar=document.activeElement&&document.activeElement.classList.contains('mbtn');
  if(!onMbar) return;
  const idx=ALL_MONTHS.indexOf(S.month);
  if(e.key==='ArrowRight'&&idx<ALL_MONTHS.length-1){e.preventDefault();setMo(ALL_MONTHS[idx+1]);}
  if(e.key==='ArrowLeft'&&idx>0){e.preventDefault();setMo(ALL_MONTHS[idx-1]);}
});

// Global [ / ] month stepping — works anywhere except when typing or modal is open
document.addEventListener('keydown',e=>{
  if(['INPUT','TEXTAREA','SELECT'].includes(e.target.tagName)) return;
  if(document.getElementById('modal-overlay')?.classList.contains('open')) return;
  if(e.key==='['){e.preventDefault();stepMo(-1);}
  if(e.key===']'){e.preventDefault();stepMo(1);}
});

// ═══════════════════════════════════════════════
// RENDER DISPATCHER
// ═══════════════════════════════════════════════
function render(){
  const c=document.getElementById('content');
  if(!c) return;
  c.className='fade';void c.offsetWidth;
  const pages={dash:renderDash,pay:renderPay,exp:renderExp,
    alper:renderAlper,charts:renderCharts,wa:renderWA,
    rep:renderRep,hist:renderHist,viz:renderViz,bld:()=>renderBld(S.bld)};
  c.innerHTML=(pages[S.page]||renderDash)();
  if(S.page==='charts') initCharts();
  if(S.page==='viz') initViz();
  if(DATA.settings.autoSave) saveLocal();
}

// ═══════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════
function renderDash(){
  const m=S.month;
  let tRent=0,tPaid=0,tExp=0;

  const brows=BK.map(b=>{
    const ts=(DATA.tenants[b]||[]).filter(t=>t.active&&t.rent>0);
    const rent=ts.reduce((s,t)=>s+t.rent,0);
    const paid=paidTotal(b,m);
    const ex=expTotal(b,m);
    const net=paid-ex;
    const unpaid=ts.filter(t=>getP(t.id,m).paid<t.rent).length;
    tRent+=rent;tPaid+=paid;tExp+=ex;
    const pct=rent>0?Math.min(100,Math.round(paid/rent*100)):0;
    return `<tr class="cp" onclick="goto('bld','${b}')">
      <td><b>${BL[b]}</b></td>
      <td class="c-muted">${ts.length}</td>
      <td class="cb fw7">${TL(rent)}</td>
      <td>
        <div class="${paid>=rent?'c-green':'c-orange'} fw7">${TL(paid)}</div>
        <div class="prog-bar"><div class="prog-fill" style="width:${pct}%;background:${paid>=rent?'var(--emerald)':'var(--amber)'}"></div></div>
      </td>
      <td class="${unpaid?'c-red':'c-green'}">${unpaid?'⚠️ '+unpaid:' ✅'}</td>
      <td class="c-orange">${TL(ex)}</td>
      <td class="${net>=0?'c-green':'c-red'} fw7">${TL(net)}</td>
      <td><span class="badge b-blue">${t('btnView')}</span></td>
    </tr>`;
  }).join('');

  const net=tPaid-tExp;
  const now=new Date();

  // Contract alerts (60 days)
  let alerts='';
  BK.forEach(b=>(DATA.tenants[b]||[]).filter(ten=>ten.active&&ten.bit).forEach(ten=>{
    const bit=new Date(ten.bit);
    const days=Math.ceil((bit-now)/864e5);
    if(days>=0&&days<=60)
      alerts+=`<tr><td><b>${BL[b]}</b></td><td>${ten.unit}</td><td>${ten.name}</td>
        <td>${formatDate(ten.bit)}</td>
        <td class="${days<=30?'c-red':'c-orange'} fw7">${days} ${t('daysLabel')}</td>
        <td class="c-blue">${TL(ten.rent)}</td></tr>`;
  }));

  // Overdue
  let overdue='';
  BK.forEach(b=>(DATA.tenants[b]||[]).filter(ten=>isDue(ten,m)).forEach(ten=>{
    overdue+=`<tr><td><b>${BL[b]}</b></td><td>${ten.unit}</td>
      <td><span class="blink">🔴</span> <b>${ten.name}</b></td>
      <td class="c-orange">${t('dayOfMonth')} ${ten.gun}.</td>
      <td class="cr fw7">${TL(ten.rent)}</td>
      <td>${canEdit()?`<button class="btn btn-xs bsu-" onclick="openMod('pay-add','${b}:${ten.id}')">${t('btnEnter')}</button>`:''}
          <button class="btn btn-xs bg-" onclick="waMsg('${b}','${ten.id}','${m}')">💬 WA</button></td></tr>`;
  }));

  return monthBar()+`
  <div class="kpi-grid">
    <div class="kpi-card" style="--kpi-color:var(--blue-l)"><div class="kpi-icon">💰</div><div class="kpi-value">${TL(tRent)}</div><div class="kpi-label">${t('kpiTotalRent')} — ${monthLabel(m)}</div></div>
    <div class="kpi-card" style="--kpi-color:var(--emerald)"><div class="kpi-icon">✅</div><div class="kpi-value">${TL(tPaid)}</div><div class="kpi-label">${t('kpiCollected')}</div><div class="card-sub cg">${tRent>0?Math.round(tPaid/tRent*100):0}%</div></div>
    <div class="kpi-card" style="--kpi-color:var(--rose)"><div class="kpi-icon">❌</div><div class="kpi-value">${TL(tRent-tPaid)}</div><div class="kpi-label">${t('kpiUncollected')}</div></div>
    <div class="kpi-card" style="--kpi-color:var(--amber)"><div class="kpi-icon">💸</div><div class="kpi-value">${TL(tExp)}</div><div class="kpi-label">${t('kpiTotalExp')}</div></div>
    <div class="kpi-card" style="--kpi-color:${net>=0?'var(--emerald)':'var(--rose)'}"><div class="kpi-icon">📈</div><div class="kpi-value">${TL(net)}</div><div class="kpi-label">${t('kpiNetIncome')}</div></div>
  </div>

  <div class="sec-hdr">${t('dashBldSummary')} — ${m}</div>
  <div class="table-card"><div class="table-scroller"><table>
    <thead><tr><th>${t('colBuilding')}</th><th>${t('colTenant')}</th><th>${t('colRent')}</th><th>${t('colCollection')}</th><th>${t('colDebt')}</th><th>${t('colExpense')||t('kpiGider')}</th><th>${t('colNet')}</th><th></th></tr></thead>
    <tbody>${brows}</tbody>
  </table></div></div>

  ${overdue?`<div class="sec-hdr">${t('dashOverdue')}</div>
  <div class="table-card"><div class="table-scroller"><table>
    <thead><tr><th>${t('colBuilding')}</th><th>${t('colUnit')}</th><th>${t('colTenant')}</th><th>${t('colPayDay')}</th><th>${t('colRent')}</th><th></th></tr></thead>
    <tbody>${overdue}</tbody>
  </table></div></div>`:''}

  ${alerts?`<div class="sec-hdr">${t('dashContracts')}</div>
  <div class="table-card"><div class="table-scroller"><table>
    <thead><tr><th>${t('colBuilding')}</th><th>${t('colUnit')}</th><th>${t('colTenant')}</th><th>${t('colEnd')}</th><th>${t('colRemaining')}</th><th>${t('colRent')}</th></tr></thead>
    <tbody>${alerts}</tbody>
  </table></div></div>`:''}`;
}

// ═══════════════════════════════════════════════
// BUILDING PAGE
// ═══════════════════════════════════════════════
function renderBld(bname){
  if(!bname) return '';
  if(!(DATA.buildings||[]).some(b=>b.id===bname&&b.active)){
    S.page='dash'; S.bld=null; return '';
  }
  const m=S.month;
  const tenants=sortU(safeTens(bname));
  const active=tenants.filter(t=>t.active&&t.rent>0);
  const inactive=tenants.filter(t=>!t.active);
  const rent=active.reduce((s,t)=>s+t.rent,0);
  const paid=paidTotal(bname,m);
  const ex=expTotal(bname,m);
  const net=paid-ex;
  const exps=safeExps(bname,m);
  const q=(S.search||'').toLowerCase();
  const filtered=tenants.filter(t=>{
    const matchQ=!q||t.name.toLowerCase().includes(q)||t.unit.toLowerCase().includes(q)||(t.phone||'').includes(q);
    if(!matchQ) return false;
    if(S.filter==='vacant') return !t.active;
    if(!t.active||t.rent===0) return !S.filter; // show inactive only when no filter
    const p=getP(t.id,m);
    if(S.filter==='overdue') return isDue(t,m);
    if(S.filter==='unpaid') return p.paid===0;
    if(S.filter==='partial') return p.paid>0&&p.paid<t.rent;
    if(S.filter==='paid') return p.paid>=t.rent;
    return true;
  });
  const bldUnpaid=active.filter(t=>getP(t.id,m).paid<t.rent);
  const bldPartial=bldUnpaid.filter(t=>getP(t.id,m).paid>0);
  const bldChips=[];
  if(bldUnpaid.length) bldChips.push(`<span class="op-chip op-chip-red" style="cursor:pointer" onclick="setFilter('overdue')">⚠️ ${bldUnpaid.length} ${t('colDebt')} · ${TL(rent-paid)} ${t('collectShort')}</span>`);
  if(bldPartial.length) bldChips.push(`<span class="op-chip op-chip-orange" style="cursor:pointer" onclick="setFilter('partial')">⋯ ${bldPartial.length} ${t('filterPartial')}</span>`);
  if(inactive.length) bldChips.push(`<span class="op-chip op-chip-gray" style="cursor:pointer" onclick="setFilter('vacant')">◌ ${inactive.length} ${t('filterVacant').replace('◌ ','')}</span>`);
  if(exps.length===0&&active.length) bldChips.push(`<span class="op-chip op-chip-blue" style="cursor:pointer" onclick="openMod('exp-add','${bname}')">📋 ${t('emptyExpenses')}</span>`);
  const bldAlertStrip=bldChips.length?`<div class="op-alerts">${bldChips.join('')}</div>`:'';
  const _fpOpts=[{k:'',l:t('filterAll')},{k:'overdue',l:t('filterOverdue')},{k:'unpaid',l:t('filterUnpaid')},{k:'partial',l:t('filterPartial')},{k:'paid',l:t('filterPaid')},{k:'vacant',l:t('filterVacant')}];
  const bldFilterPills=active.length?`<div class="filter-pills">${_fpOpts.map(({k,l})=>`<button class="fpill${S.filter===k?' fpill-active':''}" onclick="setFilter('${k}')">${l}</button>`).join('')}</div>`:'';

  const rows=filtered.map(t=>{
    const st=getStatus(t,m);
    const p=getP(t.id,m);
    const diff=p.paid-(t.rent||0);
    const late=isDue(t,m);
    return `<tr class="cp" onclick="openPanel('${bname}','${t.id}')">
      <td><b>${t.unit}</b><span class="c-muted" style="font-size:10px;margin-left:4px">${t.fl||''}</span></td>
      <td>${late?'<span class="blink">🔴</span> ':''}<b>${t.name||'—'}</b>${t.notes?` <span style="color:var(--i3);font-size:10px" title="${t.notes}">ⓘ</span>`:''}</td>
      <td class="cb fw7">${t.rent?TL(t.rent):'—'}</td>
      <td class="${p.paid>=(t.rent||0)?'c-green':p.paid>0?'c-orange':'c-red'} fw7">${t.rent?TL(p.paid):'—'}</td>
      <td class="${diff>0?'c-green':diff<0?'c-red':'c-muted'}">${t.rent?(diff>0?'+':'')+TL(diff):'—'}</td>
      <td><span class="badge ${st.cls}">${st.lbl}</span></td>
      <td class="c-muted">${p.date?p.date.slice(0,10):'—'}</td>
      <td class="c-muted">${p.sekil||'—'}</td>
      <td class="nowrap">
        ${canEdit()?`<button class="btn btn-xs bsu- " onclick="event.stopPropagation();openMod('pay-add','${bname}:${t.id}')">💳</button>
        <button class="btn btn-xs bg-" onclick="event.stopPropagation();openMod('ten-edit','${bname}:${t.id}')">✏️</button>`:''}
        <button class="btn btn-xs bg-" onclick="event.stopPropagation();waMsg('${bname}','${t.id}','${m}')">💬</button>
      </td>
    </tr>`;
  }).join('');

  const expRows=exps.map((e,i)=>`<tr>
    <td class="mono ${canEdit()?'editable':''}" ondblclick="if(canEdit())makeEditable(this,v=>{((DATA.expenses['${bname}']||{})['${m}']||[])[${i}].no=v;saveLocal();toast('✅','green');})">${e.no||'—'}</td>
    <td class="fw7 ${canEdit()?'editable':''}" ondblclick="if(canEdit())makeEditable(this,v=>{((DATA.expenses['${bname}']||{})['${m}']||[])[${i}].tur=v.toUpperCase();saveLocal();toast('✅','green');})">${e.tur}</td>
    <td class="co fw7 ${canEdit()?'editable':''}" title="${t('editableTooltip')}" ondblclick="if(canEdit())makeEditable(this,v=>{const n=parseInt(v.replace(/[^0-9]/g,''));if(!isNaN(n)){((DATA.expenses['${bname}']||{})['${m}']||[])[${i}].tutar=n;autoRecalc();saveLocal();render();}});">${TL(e.tutar)}</td>
    <td class="cm ${canEdit()?'editable':''}" ondblclick="if(canEdit())makeEditable(this,v=>{((DATA.expenses['${bname}']||{})['${m}']||[])[${i}].tarih=v;saveLocal();})">${e.tarih||'—'}</td>
    <td class="cm ${canEdit()?'editable':''}" ondblclick="if(canEdit())makeEditable(this,v=>{((DATA.expenses['${bname}']||{})['${m}']||[])[${i}].notlar=v;saveLocal();})">${e.notlar||''}</td>
    <td class="nowrap">${canEdit()?`
      <button class="btn btn-xs bg-" onclick="editExp('${bname}','${m}',${i})">✏️</button>
      <button class="btn btn-xs bd-" onclick="delExp('${bname}','${m}',${i})">🗑</button>`:''}
    </td>
  </tr>`).join('');

  return monthBar()+`
  <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;align-items:center">
    <input type="text" class="form-input" style="width:200px" placeholder="${t('searchBldTenant')}" oninput="S.search=this.value;render()" value="${S.search}">
    <div style="flex:1"></div>
    ${canEdit()?`<button class="btn btn-primary btn-sm" onclick="openMod('ten-add','${bname}')">${t('btnAddTenant')}</button>
    <button class="btn btn-secondary btn-sm" onclick="openMod('pay-add','${bname}')">${t('btnAddPayment')}</button>
    <button class="btn btn-secondary btn-sm" onclick="openMod('exp-add','${bname}')">${t('btnAddExpense')}</button>`:''}
    <button class="btn btn-ghost btn-sm" onclick="window.print()">🖨️</button>
  </div>

  <div class="kpi-grid">
    <div class="kpi-card" style="--kpi-color:var(--teal-l)"><div class="kpi-icon">👤</div><div class="kpi-value">${active.length}</div><div class="kpi-label">${t('kpiActive')}</div></div>
    <div class="kpi-card" style="--kpi-color:var(--blue-l)"><div class="kpi-icon">💰</div><div class="kpi-value">${TL(rent)}</div><div class="kpi-label">${t('kpiTotalRent')}</div></div>
    <div class="kpi-card" style="--kpi-color:var(--emerald)"><div class="kpi-icon">✅</div><div class="kpi-value">${TL(paid)}</div><div class="kpi-label">${t('kpiCollect')}</div></div>
    <div class="kpi-card" style="--kpi-color:var(--amber)"><div class="kpi-icon">💸</div><div class="kpi-value">${TL(ex)}</div><div class="kpi-label">${t('kpiGider')}</div></div>
    <div class="kpi-card" style="--kpi-color:${net>=0?'var(--emerald)':'var(--rose)'}"><div class="kpi-icon">📈</div><div class="kpi-value">${TL(net)}</div><div class="kpi-label">${t('kpiNet')}</div></div>
  </div>
  ${bldAlertStrip}${bldFilterPills}
  <div class="table-card">
    <div class="table-card-header"><h3>${t('sectApartments')} — ${m}</h3><span class="c-muted" style="font-size:11px">${t('clickDetail')}</span></div>
    <div class="table-scroller"><table>
      <thead><tr><th>${t('colUnit')}</th><th>${t('colTenant')}</th><th>${t('colRent')}</th><th>${t('colPaid')}</th><th>${t('colDiff')}</th><th>${t('colStatus')}</th><th>${t('colDate')}</th><th>${t('colMethod')}</th><th></th></tr></thead>
      <tbody>${rows||`<tr><td colspan="9" style="text-align:center;padding:28px 16px;color:var(--i5)">${t('emptyTenants')}${canEdit()?` &nbsp;·&nbsp; <button class="btn btn-primary btn-xs" onclick="openMod('ten-add','${bname}')">${t('addTenantBtn')}</button>`:''}</td></tr>`}
      ${active.length?`<tr class="tfoot-row">
        <td colspan="2">${t('totalAll')} (${active.length})</td>
        <td class="c-blue">${TL(rent)}</td>
        <td class="${paid>=rent?'c-green':'c-orange'}">${TL(paid)}</td>
        <td class="${paid-rent>=0?'c-green':'c-red'}">${TL(paid-rent)}</td>
        <td colspan="4"></td>
      </tr>`:''}
      </tbody>
    </table></div>
  </div>

  <div class="table-card">
    <div class="table-card-header">
      <h3>${t('sectExpenses')} — ${m}</h3>
      ${canEdit()?`<button class="btn btn-primary btn-sm" onclick="openMod('exp-add','${bname}')">${t('btnAdd')}</button>`:''}
    </div>
    <div class="table-scroller"><table>
      <thead><tr><th>${t('colCounter')}</th><th>${t('colExpType')}</th><th>${t('colAmount')}</th><th>${t('colDate')}</th><th>${t('colNote')}</th><th></th></tr></thead>
      <tbody>${expRows||`<tr><td colspan="6" style="text-align:center;padding:22px 16px;color:var(--i5)">${t('emptyExpenses')}${canEdit()?` &nbsp;·&nbsp; <button class="btn btn-ghost btn-xs" onclick="openMod('exp-add','${bname}')">${t('addExpBtn')}</button>`:''}</td></tr>`}
      ${exps.length?`<tr class="tfoot-row"><td colspan="2">${t('totalExp')}</td><td class="c-orange">${TL(ex)}</td><td colspan="3"></td></tr>
      <tr class="tfoot-row"><td colspan="2">${t('netFormula')}</td><td class="${net>=0?'c-green':'c-red'} fw8">${TL(net)}</td><td colspan="3"></td></tr>`:''}
      </tbody>
    </table></div>
  </div>

  ${inactive.length&&canEdit()&&S.filter!=='vacant'?`<div class="table-card" style="margin-top:8px;opacity:.75">
    <div class="table-card-header"><h3 style="color:var(--i4);font-size:12px">${t('sectInactive')} (${inactive.length})</h3></div>
    <div class="table-scroller"><table>
      <thead><tr><th>${t('colUnit')}</th><th>${t('colTenant')}</th><th>${t('colPhone')}</th><th>${t('colNote')}</th><th></th></tr></thead>
      <tbody>${inactive.map(t=>`<tr style="opacity:.75">
        <td><b>${t.unit}</b></td><td style="color:var(--i3)">${t.name}</td>
        <td class="c-muted">${t.phone||'—'}</td><td class="c-muted" style="font-size:11px">${t.notes||'—'}</td>
        <td><button class="btn btn-xs btn-secondary" onclick="restoreTen('${bname}','${t.id}')">${window.t('btnRestore')}</button>
        <button class="btn btn-xs bg-" onclick="openMod('ten-edit','${bname}:${t.id}')">✏️</button></td>
      </tr>`).join('')}</tbody>
    </table></div>
  </div>`:''}`;
}

// ═══════════════════════════════════════════════
// TENANT PANEL
// ═══════════════════════════════════════════════
function openPanel(bname,tid){
  const t=(DATA.tenants[bname]||[]).find(x=>x.id===tid);
  if(!t) return;
  const m=S.month;
  const p=getP(tid,m);
  const st=getStatus(t,m);
  const diff=p.paid-(t.rent||0);

  // Build history
  const histRows=ALL_MONTHS.filter(mo=>{
    const pp=((DATA.payments[tid]||{})[mo]);
    return pp!==undefined;
  }).slice(-18).reverse().map(mo=>{
    const pp=getP(tid,mo);
    const dot=pp.paid>=(t.rent||0)?'var(--emerald)':pp.paid>0?'var(--amber)':'var(--rose)';
    return `<div class="tl-item">
      <div class="tl-dot" style="background:${dot}"></div>
      <div style="flex:1"><div class="fw-600" style="font-size:12px">${monthLabel(mo)}</div>
      <div style="font-size:10.5px;color:var(--i3)">${pp.date?formatDate(pp.date.slice(0,10)):''} ${pp.sekil||''}${pp.notes?' · '+pp.notes:''}</div></div>
      <div class="fw7 ${pp.paid>=(t.rent||0)?'c-green':pp.paid>0?'c-orange':'c-red'}">${TL(pp.paid)}</div>
    </div>`;
  }).join('');

  document.getElementById('panel').innerHTML=`
    <button class="panel-close" onclick="closePanel()">✕</button>
    <div style="font-size:36px;margin-top:6px">🏠</div>
    <div class="panel-name">${t.name||window.t('statusVacant')}</div>
    <div class="panel-sub">${BL[bname]} — ${t.unit}${t.fl?' ('+t.fl+')':''}</div>
    <span class="badge ${st.cls}">${st.lbl}</span>

    <div class="div-line"></div>
    <div class="sec-hdr">${window.t('panelThisMonth')} — ${monthLabel(m)}</div>
    <div class="info-grid">
      <div class="info-item"><div class="info-lbl">${window.t('colRent')}</div><div class="ival cb">${TL(t.rent)}</div></div>
      <div class="info-item"><div class="info-lbl">${window.t('colPaid')}</div><div class="ival ${p.paid>=(t.rent||0)?'c-green':p.paid>0?'c-orange':'c-red'}">${TL(p.paid)}</div></div>
      <div class="info-item"><div class="info-lbl">${window.t('colDiff')}</div><div class="ival ${diff>0?'c-green':diff<0?'c-red':''}">${diff>0?'+':''}${TL(diff)}</div></div>
      <div class="info-item"><div class="info-lbl">${window.t('panelPayDate')}</div><div class="info-val">${p.date?formatDate(p.date.slice(0,10)):'—'}</div></div>
      <div class="info-item"><div class="info-lbl">${window.t('colMethod')}</div><div class="info-val">${p.sekil||'—'}</div></div>
      <div class="info-item"><div class="info-lbl">${window.t('panelDeposit')}</div><div class="info-val">${TL(t.dep)}</div></div>
    </div>

    <div class="sec-hdr">${window.t('panelContract')}</div>
    <div class="info-grid">
      <div class="info-item"><div class="info-lbl">${window.t('panelStart')}</div><div class="info-val">${t.bas?formatDate(t.bas):'—'}</div></div>
      <div class="info-item"><div class="info-lbl">${window.t('panelEnd')}</div><div class="info-val">${t.bit?formatDate(t.bit):'—'}</div></div>
      <div class="info-item"><div class="info-lbl">${window.t('colPayDay')}</div><div class="info-val">${window.t('dayOfMonth')} ${t.gun||1}.</div></div>
      <div class="info-item"><div class="info-lbl">${window.t('colPhone')}</div><div class="info-val">${t.phone||'—'}</div></div>
    </div>
    ${t.notes?`<div class="info-item" style="margin-bottom:12px"><div class="info-lbl">${window.t('panelNotes')}</div><div class="info-val" style="font-size:12px">${t.notes}</div></div>`:''}

    <div class="sec-hdr">${window.t('panelPayHist')}</div>
    <div>${histRows||'<div class="c-muted" style="font-size:12px">'+window.t('emptyRecords')+'</div>'}</div>

    <div class="div-line"></div>
    <div style="display:flex;gap:7px;flex-wrap:wrap">
      ${canEdit()?`<button class="btn btn-primary btn-sm" onclick="openMod('pay-add','${bname}:${tid}');closePanel()">${window.t('panelPayBtn')}</button>
      <button class="btn btn-ghost btn-sm" onclick="openMod('ten-edit','${bname}:${tid}');closePanel()">${window.t('panelEditBtn')}</button>
      <button class="btn btn-danger btn-sm" id="btn-panel-remove-ten" onclick="panelRemoveTenConfirm('${bname}','${tid}')">${window.t('panelRemoveBtn')}</button>`:''}
      <button class="btn btn-ghost btn-sm" onclick="waMsg('${bname}','${tid}','${S.month}')">💬 WA</button>
    </div>
  `;
  document.getElementById('panel-overlay').classList.add('open');
  document.getElementById('panel').classList.add('open');
}
function closePanel(){
  document.getElementById('panel-overlay').classList.remove('open');
  document.getElementById('panel').classList.remove('open');
  document.getElementById('panel').innerHTML='';
}

// ═══════════════════════════════════════════════
// MODALS
// ═══════════════════════════════════════════════
// openModal is the public alias (used in HTML); openMod is internal
function openModal(type,arg){ openMod(type,arg); }

var _openModalState=null;

function openMod(type,arg){
  // Non-edit types allowed for all roles
  const noEditTypes=['cloud','users','settings','dash-prefs','reset-data','restore-confirm'];
  if(!canEdit()&&!noEditTypes.includes(type)) return;
  const md=document.getElementById('modal');
  const t={
    'bld-add':()=>tplBldAdd(),
    'bld-rename':()=>tplBldRename(arg||''),
    'bld-archive':()=>tplBldArchive(arg||''),
    'bld-settings':()=>tplBldSettings(arg||''),
    'pay-add':()=>tplPayAdd(arg||''),
    'exp-add':()=>tplExpAdd(arg||''),
    'ten-add':()=>tplTenAdd(arg||''),
    'ten-edit':()=>tplTenEdit(arg||''),
    'cloud':()=>tplCloud(),
    'users':()=>tplUsers(),
    'settings':()=>tplSettings(),
    'dash-prefs':()=>tplDashPrefs(),
    'reset-data':()=>tplResetData(),
    'restore-confirm':()=>tplRestoreConfirm(arg||''),
    'alper-month':()=>tplAlperMonth(arg||''),
  };
  // Unknown type → show error state instead of silently using pay-add
  const tplFn = t[type];
  if(!tplFn){
    md.innerHTML=`<div class="modal-title">${t('unknownOp')}</div>
      <p style="color:var(--i3);font-size:13px">"${type}" henüz yapılandırılmamış.</p>
      <div class="modal-footer"><button class="btn btn-ghost" onclick="closeMod()">${t('close')}</button></div>`;
  } else {
    md.innerHTML=tplFn();
  }
  _openModalState={type:type,arg:arg};
  document.getElementById('modal-overlay').classList.add('open');
  if(type==='pay-add'){
    setTimeout(()=>{
      refreshTenSel();
      if(arg){const[b,id]=arg.split(':');const sel=document.getElementById('m_b');if(sel&&b)sel.value=b;refreshTenSel();if(id){const ks=document.getElementById('m_t');if(ks)ks.value=id;autoRent();}}
      setTimeout(()=>{const a=document.getElementById('m_amt');if(a)a.select();},100);
    },50);
  } else {
    setTimeout(()=>{const inp=document.querySelector('#modal input:not([type=hidden]):not([disabled])');if(inp)inp.focus();},80);
  }
}
function closeMod(){_openModalState=null;document.getElementById('modal-overlay').classList.remove('open');}
function closeMO(e){if(e.target===document.getElementById('modal-overlay'))closeMod();}

// ── BLD ADD ──────────────────────────────────
function tplBldAdd(){
  return `<div class="modal-title">${t('bldAddTitle')}</div>
  <p style="font-size:12px;color:var(--i3);margin:-8px 0 18px">${t('bldAddDesc')}</p>
  <div class="form-row">
    <label class="form-label">${t('bldAddLabel')}</label>
    <input class="form-input" id="m-bld-name" type="text" placeholder="${t('bldAddPh')}" autocomplete="off" maxlength="40"
           onkeydown="if(event.key==='Enter'){event.preventDefault();window.commitAddBuilding();}else if(event.key==='Escape'){closeMod();}">
  </div>
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('cancel')}</button>
    <button class="btn btn-primary" onclick="window.commitAddBuilding()">${t('save')}</button>
  </div>`;
}

// ── BLD RENAME ───────────────────────────────
function tplBldRename(bldId){
  const b=(DATA.buildings||[]).find(x=>x.id===bldId);
  if(!b) return `<div class="modal-title">❌ ${t('emptyRecords')}</div><div class="modal-footer"><button class="btn btn-ghost" onclick="closeMod()">${t('close')}</button></div>`;
  const safeName=b.name.replace(/"/g,'&quot;');
  const safeId=bldId.replace(/'/g,"\\'");
  return `<div class="modal-title">${t('bldRenameTitle')}</div>
  <div class="form-row">
    <label class="form-label">${t('bldRenameLabel')}</label>
    <input class="form-input" id="m-bld-rename" type="text" value="${safeName}" maxlength="40" autocomplete="off"
           onkeydown="if(event.key==='Enter'){event.preventDefault();commitBldRename('${safeId}');}else if(event.key==='Escape'){closeMod();}">
  </div>
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('cancel')}</button>
    <button class="btn btn-primary" onclick="commitBldRename('${safeId}')">${t('save')}</button>
  </div>`;
}

function commitBldRename(bldId){
  const inp=document.getElementById('m-bld-rename');
  if(!inp) return;
  const newName=inp.value.trim();
  if(!newName||newName.length<2){ inp.focus(); toast(t('errMinChars'),'red'); return; }
  const b=(DATA.buildings||[]).find(x=>x.id===bldId);
  if(!b){ toast(t('bldNotFound'),'red'); return; }
  const dup=(DATA.buildings||[]).some(x=>x.id!==bldId&&x.name.trim().toLowerCase()===newName.toLowerCase());
  if(dup){ inp.focus(); toast(t('errBldNameDup'),'red'); return; }
  const oldName=b.name;
  b.name=newName;
  b.short=newName.split(/\s+/).map(w=>w.replace(/[^a-zA-ZğüşöçıĞÜŞÖÇİ]/gi,'')[0]||'')
    .join('').toUpperCase().slice(0,3)||newName.replace(/[^a-zA-Z]/g,'').toUpperCase().slice(0,3)||'BLD';
  BL[bldId]=newName; BS[bldId]=b.short;
  syncBuildingConstants();
  renderBuildingNav();
  if(S.bld===bldId){ const t=document.getElementById('topbar-title'); if(t) t.textContent='🏢 '+newName; }
  saveLocal();
  addHist('Bina adlandırıldı: '+oldName+' → '+newName);
  closeMod();
  toast(t('bldRenamed'),'green');
}
window.commitBldRename=commitBldRename;

// ── BLD ARCHIVE ──────────────────────────────
function tplBldArchive(bldId){
  const b=(DATA.buildings||[]).find(x=>x.id===bldId);
  if(!b) return `<div class="modal-title">❌ ${t('emptyRecords')}</div><div class="modal-footer"><button class="btn btn-ghost" onclick="closeMod()">${t('close')}</button></div>`;
  const activeCount=(DATA.buildings||[]).filter(x=>x.active).length;
  if(activeCount<=1){
    return `<div class="modal-title">${t('bldArchiveCannotTitle')}</div>
    <p style="font-size:13px;color:var(--i2);margin-bottom:20px">${t('bldArchiveCannotDesc')}</p>
    <div class="modal-footer"><button class="btn btn-primary" onclick="closeMod()">${t('close')}</button></div>`;
  }
  const safeId=bldId.replace(/'/g,"\\'");
  const activeTenCount=(DATA.tenants[bldId]||[]).filter(ten=>ten.active&&ten.rent>0).length;
  return `<div class="modal-title">${t('bldArchiveTitle')}</div>
  <p style="font-size:13px;color:var(--i2);margin-bottom:4px"><b>${b.name}</b> ${t('bldArchiveWillArchive')}</p>
  ${activeTenCount?`<div style="background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25);border-radius:8px;padding:10px 12px;margin-bottom:10px;font-size:12px;color:var(--amber-l)">
    ⚠️ ${activeTenCount} — ${t('bldArchiveActiveTen')}
  </div>`:''}
  <p style="font-size:12px;color:var(--i3);margin-bottom:24px">${t('bldArchiveDesc2')}</p>
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('cancel')}</button>
    <button class="btn btn-primary" style="background:var(--rose);border-color:var(--rose)"
            onclick="commitBldArchive('${safeId}')">${t('bldArchiveBtn')}</button>
  </div>`;
}

function commitBldArchive(bldId){
  const b=(DATA.buildings||[]).find(x=>x.id===bldId);
  if(!b){ toast(t('bldNotFound'),'red'); return; }
  const activeCount=(DATA.buildings||[]).filter(x=>x.active).length;
  if(activeCount<=1){ toast(t('bldLastActive'),'red'); closeMod(); return; }
  b.active=false;
  if(S.bld===bldId){ S.bld=null; S.page='dash'; }
  syncBuildingConstants();
  renderBuildingNav();
  saveLocal();
  addHist('Bina arşivlendi: '+b.name);
  closeMod();
  if(S.page==='dash') render();
  toast('✅ '+b.name,'green');
}
window.commitBldArchive=commitBldArchive;

// ── BLD SETTINGS ─────────────────────────────
function tplBldSettings(bldId){
  const b=(DATA.buildings||[]).find(x=>x.id===bldId);
  if(!b) return `<div class="modal-title">${t('bldNotFound')}</div><div class="modal-footer"><button class="btn btn-ghost" onclick="closeMod()">${t('close')}</button></div>`;
  const m=b.metadata||{};
  const safeId=bldId.replace(/'/g,"\\'");
  const types=[['apartment',t('bldTypeApartment')],['plaza',t('bldTypePlaza')],['villa',t('bldTypeVilla')],['office',t('bldTypeOffice')],['mixed',t('bldTypeMixed')]];
  const typeOpts=types.map(([v,l])=>`<option value="${v}" ${m.type===v?'selected':''}>${l}</option>`).join('');
  return `<div class="modal-title">${t('bldSettingsTitle')}</div>
  <div class="form-row">
    <label class="form-label">${t('bldSettingsName')}</label>
    <input class="form-input" id="m-bs-name" type="text" value="${b.name.replace(/"/g,'&quot;')}" maxlength="40" autocomplete="off">
  </div>
  <div class="form-row">
    <label class="form-label">${t('bldSettingsType')}</label>
    <select class="form-select" id="m-bs-type">${typeOpts}</select>
  </div>
  <div class="form-row">
    <label class="form-label">${t('bldAddLabel')} <span style="color:var(--i4);font-weight:400">${t('labelOptional')}</span></label>
    <input class="form-input" id="m-bs-addr" type="text" value="${(m.address||'').replace(/"/g,'&quot;')}"
           maxlength="120" autocomplete="off">
  </div>
  <div class="form-row">
    <label class="form-label">${t('panelNotes')} <span style="color:var(--i4);font-weight:400">${t('labelOptional')}</span></label>
    <textarea class="form-input" id="m-bs-notes" rows="2" style="resize:vertical;min-height:52px"
              maxlength="300">${(m.notes||'').replace(/</g,'&lt;')}</textarea>
  </div>
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('cancel')}</button>
    <button class="btn btn-primary" onclick="commitBldSettings('${safeId}')">${t('save')}</button>
  </div>`;
}

function commitBldSettings(bldId){
  const b=(DATA.buildings||[]).find(x=>x.id===bldId);
  if(!b){ toast(t('bldNotFound'),'red'); return; }
  const nameInp=document.getElementById('m-bs-name');
  const newName=(nameInp?.value||'').trim();
  if(!newName||newName.length<2){ if(nameInp) nameInp.focus(); toast(t('errMinChars'),'red'); return; }
  const dup=(DATA.buildings||[]).some(x=>x.id!==bldId&&x.name.trim().toLowerCase()===newName.toLowerCase());
  if(dup){ if(nameInp) nameInp.focus(); toast(t('errBldNameDup'),'red'); return; }
  const oldName=b.name;
  b.name=newName;
  b.short=newName.split(/\s+/).map(w=>w.replace(/[^a-zA-ZğüşöçıĞÜŞÖÇİ]/gi,'')[0]||'')
    .join('').toUpperCase().slice(0,3)||newName.replace(/[^a-zA-Z]/g,'').toUpperCase().slice(0,3)||'BLD';
  if(!b.metadata) b.metadata={};
  b.metadata.type=document.getElementById('m-bs-type')?.value||'apartment';
  b.metadata.address=(document.getElementById('m-bs-addr')?.value||'').trim();
  b.metadata.notes=(document.getElementById('m-bs-notes')?.value||'').trim();
  BL[bldId]=newName; BS[bldId]=b.short;
  syncBuildingConstants();
  renderBuildingNav();
  if(S.bld===bldId){ const t=document.getElementById('topbar-title'); if(t) t.textContent='🏢 '+newName; }
  saveLocal();
  addHist(oldName!==newName?'Bina ayarları güncellendi: '+oldName+' → '+newName:'Bina ayarları güncellendi: '+newName);
  closeMod();
  toast(t('bldSettingsSaved'),'green');
}
window.commitBldSettings=commitBldSettings;

// ── PAY ADD ──────────────────────────────────
function tplPayAdd(pre){
  const[pb,pt]=pre.split(':');
  const bOpts=BK.map(b=>`<option value="${b}" ${b===pb?'selected':''}>${BL[b]}</option>`).join('');
  const mOpts=ALL_MONTHS.map(mo=>`<option value="${mo}" ${mo===S.month?'selected':''}>${mo}</option>`).join('');
  return `<div class="modal-title">${t('payAddTitle')}</div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('colBuilding')}</label><select class="form-select" id="m_b" onchange="refreshTenSel()">${bOpts}</select></div>
    <div class="form-row"><label class="form-label">${t('labelPeriod')}</label><select class="form-select" id="m_mo">${mOpts}</select></div>
  </div>
  <div class="form-row"><label class="form-label">${t('colTenant')}</label><select class="form-select" id="m_t" onchange="autoRent()"></select></div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('colPaid')} (${currencySymbol()})</label><input class="form-input" id="m_amt" type="number" placeholder="0" onkeydown="if(event.key==='Enter')savePay()"></div>
    <div class="form-row"><label class="form-label">${t('colDate')}</label><input class="form-input" id="m_dt" type="date" value="${new Date().toISOString().slice(0,10)}"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('labelPayMethod')}</label><select class="form-select" id="m_sk">${SEKIL.map(s=>`<option${s===_lastSekil?' selected':''}>${s}</option>`).join('')}</select></div>
    <div class="form-row"><label class="form-label">${t('colNote')}</label><input class="form-input" id="m_nt" onkeydown="if(event.key==='Enter')savePay()"></div>
  </div>
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('cancel')}</button>
    <button class="btn btn-secondary btn-sm" onclick="savePayRepeat()">${t('labelRepeat')}</button>
    <button class="btn btn-primary" onclick="savePay()">${t('save')}</button>
  </div>`;
}

function refreshTenSel(){
  const b=document.getElementById('m_b')?.value;
  const sel=document.getElementById('m_t');
  if(!sel||!b) return;
  const ts=sortU((DATA.tenants[b]||[]).filter(t=>t.active&&t.rent>0));
  sel.innerHTML=ts.map(t=>`<option value="${t.id}">${t.unit} – ${t.name}</option>`).join('');
  autoRent();
}

function autoRent(){
  const b=document.getElementById('m_b')?.value;
  const tid=document.getElementById('m_t')?.value;
  const amt=document.getElementById('m_amt');
  if(!b||!tid||!amt) return;
  const t=(DATA.tenants[b]||[]).find(x=>x.id===tid);
  if(t) amt.value=t.rent;
}

function savePay(){
  const b=document.getElementById('m_b')?.value;
  const tid=document.getElementById('m_t')?.value;
  const mo=document.getElementById('m_mo')?.value;
  const paid=parseFloat(document.getElementById('m_amt')?.value)||0;
  const date=document.getElementById('m_dt')?.value||'';
  const sekil=document.getElementById('m_sk')?.value||'Banka';
  const notes=document.getElementById('m_nt')?.value||'';
  if(!b||!tid||!mo) return;
  const t=(DATA.tenants[b]||[]).find(x=>x.id===tid);
  setP(tid,mo,{paid,date,sekil,notes});
  addHist(`${BL[b]} ${t?.unit||''} – ${t?.name||''}: ${TL(paid)} ödeme (${mo})`);
  autoRecalc();
  closeMod();render();updateBadges();
  toast(t('paymentSaved'),'green');
  if(DATA.cloud.enabled) cloudSync('push');
}

function savePayRepeat(){
  const b=document.getElementById('m_b')?.value;
  const tid=document.getElementById('m_t')?.value;
  const mo=document.getElementById('m_mo')?.value;
  const paid=parseFloat(document.getElementById('m_amt')?.value)||0;
  const date=document.getElementById('m_dt')?.value||'';
  const sekil=document.getElementById('m_sk')?.value||'Banka';
  const notes=document.getElementById('m_nt')?.value||'';
  if(!b||!tid||!mo){toast(t('payBldTenReq'),'red');return;}
  const t=(DATA.tenants[b]||[]).find(x=>x.id===tid);
  setP(tid,mo,{paid,date,sekil,notes});
  addHist(`${BL[b]} ${t?.unit||''} – ${t?.name||''}: ${TL(paid)} ödeme (${mo})`);
  _lastSekil=sekil;
  autoRecalc();saveLocal();updateBadges();
  // Auto-advance to next tenant in the dropdown
  const sel=document.getElementById('m_t');
  const hasNext=sel&&sel.selectedIndex<sel.options.length-1;
  if(hasNext){sel.selectedIndex++;autoRent();}
  const ntEl=document.getElementById('m_nt');if(ntEl)ntEl.value='';
  const amtEl=document.getElementById('m_amt');
  if(amtEl){if(!hasNext)amtEl.value='';amtEl.focus();amtEl.select();}
  toast(hasNext?t('paymentSavedNext'):t('paymentSaved'),'green');
  if(DATA.cloud.enabled) cloudSync('push');
}

// ── EXP ADD ──────────────────────────────────
function tplExpAdd(pre){
  const pb=pre.split(':')[0]||'';
  const bOpts=BK.map(b=>`<option value="${b}" ${b===pb?'selected':''}>${BL[b]}</option>`).join('');
  const mOpts=ALL_MONTHS.map(mo=>`<option value="${mo}" ${mo===S.month?'selected':''}>${mo}</option>`).join('');
  return `<div class="modal-title">${t('expAddTitle')}</div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('colBuilding')}</label><select class="form-select" id="e_b">${bOpts}</select></div>
    <div class="form-row"><label class="form-label">${t('labelPeriod')}</label><select class="form-select" id="e_mo">${mOpts}</select></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('colExpType')}</label>
      <input class="form-input" id="e_tur" list="el_gk" value="${_lastExpTur}" onkeydown="if(event.key==='Enter'){event.preventDefault();document.getElementById('e_amt')?.focus();}">
      <datalist id="el_gk">${GKAT.map(k=>`<option value="${k}">`).join('')}</datalist>
    </div>
    <div class="form-row"><label class="form-label">${t('colCounter')}</label><input class="form-input" id="e_no" onkeydown="if(event.key==='Enter'){event.preventDefault();document.getElementById('e_amt')?.focus();}"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('colAmount')} (${currencySymbol()})</label><input class="form-input" id="e_amt" type="number" placeholder="0" onkeydown="if(event.key==='Enter')saveExp_()"></div>
    <div class="form-row"><label class="form-label">${t('colDate')}</label><input class="form-input" id="e_dt" type="date" value="${new Date().toISOString().slice(0,10)}"></div>
  </div>
  <div class="form-row"><label class="form-label">${t('colNote')}</label><input class="form-input" id="e_nt" onkeydown="if(event.key==='Enter')saveExp_()"></div>
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('cancel')}</button>
    <button class="btn btn-secondary btn-sm" onclick="saveExpRepeat()">${t('labelRepeat')}</button>
    <button class="btn btn-primary" onclick="saveExp_()">${t('save')}</button>
  </div>`;
}

function saveExp_(eb,emo,eidx){
  const b=eb||document.getElementById('e_b')?.value;
  const mo=emo||document.getElementById('e_mo')?.value;
  const tur=(document.getElementById('e_tur')?.value||'').trim().toUpperCase();
  const no=(document.getElementById('e_no')?.value||'').trim();
  const tutar=parseFloat(document.getElementById('e_amt')?.value)||0;
  const tarih=document.getElementById('e_dt')?.value||'';
  const notlar=document.getElementById('e_nt')?.value||'';
  if(!b||!mo||!tur){toast(t('expTypeReq'),'red');return;}
  if(!DATA.expenses[b]) DATA.expenses[b]={};
  if(!DATA.expenses[b][mo]) DATA.expenses[b][mo]=[];
  const entry={tur,no,tutar,tarih,notlar};
  if(eidx!==undefined) DATA.expenses[b][mo][eidx]=entry;
  else DATA.expenses[b][mo].push(entry);
  addHist(`${BL[b]} gider ${eidx!==undefined?'güncellendi':'eklendi'}: ${tur} ${TL(tutar)} (${mo})`);
  autoRecalc();
  closeMod();render();
  toast(t('expSaved'),'green');
  if(DATA.cloud.enabled) cloudSync('push');
}

function saveExpRepeat(){
  const b=document.getElementById('e_b')?.value;
  const mo=document.getElementById('e_mo')?.value;
  const tur=(document.getElementById('e_tur')?.value||'').trim().toUpperCase();
  const no=(document.getElementById('e_no')?.value||'').trim();
  const tutar=parseFloat(document.getElementById('e_amt')?.value)||0;
  const tarih=document.getElementById('e_dt')?.value||'';
  const notlar=document.getElementById('e_nt')?.value||'';
  if(!b||!mo||!tur){toast('❌ Gider türü gerekli','red');return;}
  if(!DATA.expenses[b]) DATA.expenses[b]={};
  if(!DATA.expenses[b][mo]) DATA.expenses[b][mo]=[];
  DATA.expenses[b][mo].push({tur,no,tutar,tarih,notlar});
  _lastExpTur=tur;
  addHist(`${BL[b]} gider eklendi: ${tur} ${TL(tutar)} (${mo})`);
  autoRecalc();saveLocal();updateBadges();
  toast('✅ Gider eklendi — tekrar girin','green');
  // Keep modal open; clear amount/no/notes; keep category/building/month
  const ntEl=document.getElementById('e_nt');if(ntEl)ntEl.value='';
  const noEl=document.getElementById('e_no');if(noEl)noEl.value='';
  const amtEl=document.getElementById('e_amt');
  if(amtEl){amtEl.value='';amtEl.focus();amtEl.select();}
  if(DATA.cloud.enabled) cloudSync('push');
}

function editExp(bld,mo,idx){
  const e=((DATA.expenses[bld]||{})[mo]||[])[idx];
  if(!e) return;
  openMod('exp-add',bld);
  setTimeout(()=>{
    ['e_b','e_mo','e_tur','e_no','e_amt','e_dt','e_nt'].forEach((id,i)=>{
      const el=document.getElementById(id);
      if(!el) return;
      const vals=[bld,mo,e.tur,e.no||'',e.tutar,e.tarih||'',e.notlar||''];
      el.value=vals[i];
    });
    const sb=document.querySelector('#modal .btn-primary');
    if(sb) sb.onclick=()=>saveExp_(bld,mo,idx);
  },60);
}

function delExp(bld,mo,idx){
  DATA.expenses[bld][mo].splice(idx,1);
  addHist(`${BL[bld]} gider silindi (${mo})`);
  render();toast('🗑 Gider silindi','red');
}

// ── TENANT ADD ───────────────────────────────
function tplTenAdd(bname){
  const bOpts=BK.map(b=>`<option value="${b}" ${b===bname?'selected':''}>${BL[b]}</option>`).join('');
  return `<div class="modal-title">${t('tenAddTitle')}</div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('colBuilding')}</label><select class="form-select" id="nt_b">${bOpts}</select></div>
    <div class="form-row"><label class="form-label">${t('labelUnitNo')}</label><input class="form-input" id="nt_u" placeholder="D1"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('labelFloor')}</label><input class="form-input" id="nt_fl"></div>
    <div class="form-row"><label class="form-label">${t('usersNameLabel')}</label><input class="form-input" id="nt_n"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('colRent')} (${currencySymbol()})</label><input class="form-input" id="nt_r" type="number"></div>
    <div class="form-row"><label class="form-label">${t('panelDeposit')} (${currencySymbol()})</label><input class="form-input" id="nt_d" type="number" value="0"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('labelPhone')}</label><input class="form-input" id="nt_ph" placeholder="905xxxxxxxxx"></div>
    <div class="form-row"><label class="form-label">${t('colPayDay')}</label><input class="form-input" id="nt_g" type="number" value="1" min="1" max="31"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('panelStart')}</label><input class="form-input" id="nt_bs" type="date"></div>
    <div class="form-row"><label class="form-label">${t('panelEnd')}</label><input class="form-input" id="nt_bt" type="date"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('labelPayMethod')}</label><select class="form-select" id="nt_sk">${SEKIL.map(s=>`<option>${s}</option>`).join('')}</select></div>
    <div class="form-row"><label class="form-label">${t('colNote')}</label><input class="form-input" id="nt_nt"></div>
  </div>
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('cancel')}</button>
    <button class="btn btn-primary" onclick="saveTen()">${t('usersAddBtn')}</button>
  </div>`;
}

function saveTen(){
  const b=document.getElementById('nt_b').value;
  const unit=document.getElementById('nt_u').value.trim().toUpperCase();
  const name=document.getElementById('nt_n').value.trim();
  if(!unit||!name){ toast('❌ Daire no ve isim zorunlu!','red'); return; }
  const id=BS[b]+Date.now();
  const t={
    id,unit,
    fl:document.getElementById('nt_fl').value.trim(),
    name,
    rent:parseFloat(document.getElementById('nt_r').value)||0,
    dep:parseFloat(document.getElementById('nt_d').value)||0,
    phone:document.getElementById('nt_ph').value.trim(),
    gun:parseInt(document.getElementById('nt_g').value)||1,
    bas:document.getElementById('nt_bs').value,
    bit:document.getElementById('nt_bt').value,
    sekil:document.getElementById('nt_sk').value,
    notes:document.getElementById('nt_nt').value.trim(),
    active:true,
  };
  if(!DATA.tenants[b]) DATA.tenants[b]=[];
  DATA.tenants[b].push(t);
  addHist(`${BL[b]} ${unit} – ${name} eklendi`);
  closeMod();render();updateBadges();
  toast(t('tenantAdded'),'green');
}

// ── TENANT EDIT ──────────────────────────────
function tplTenEdit(arg){
  const[bname,tid]=arg.split(':');
  const t=(DATA.tenants[bname]||[]).find(x=>x.id===tid);
  if(!t) return '<div>'+window.t('tenNotFound')+'</div>';
  const mo=S.month;
  const p=getP(tid,mo);
  return `<div class="modal-title">${window.t('tenEditTitle')} — ${t.unit}</div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${window.t('labelUnitNo')}</label><input class="form-input" id="et_u" value="${t.unit}"></div>
    <div class="form-row"><label class="form-label">${window.t('labelFloor')}</label><input class="form-input" id="et_fl" value="${t.fl||''}"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${window.t('usersNameLabel').replace(' *','')}</label><input class="form-input" id="et_n" value="${t.name}"></div>
    <div class="form-row"><label class="form-label">${window.t('labelPhone')}</label><input class="form-input" id="et_ph" value="${t.phone||''}" placeholder="905xxxxxxxxx"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${window.t('colRent')} (${currencySymbol()})</label><input class="form-input" id="et_r" type="number" value="${t.rent}"></div>
    <div class="form-row"><label class="form-label">${window.t('panelDeposit')}</label><input class="form-input" id="et_d" type="number" value="${t.dep||0}"></div>
  </div>
  <div class="sec-hdr" style="margin:10px 0 8px">${window.t('labelThisMonth')}: ${monthLabel(mo)}</div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${window.t('colPaid')} (${currencySymbol()})</label><input class="form-input" id="et_p" type="number" value="${p.paid||0}"></div>
    <div class="form-row"><label class="form-label">${window.t('panelPayDate')}</label><input class="form-input" id="et_pd" type="date" value="${p.date||''}"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${window.t('labelPayMethod')}</label><select class="form-select" id="et_ps">${SEKIL.map(s=>`<option ${p.sekil===s?'selected':''}>${s}</option>`).join('')}</select></div>
    <div class="form-row"><label class="form-label">${window.t('labelPayNote')}</label><input class="form-input" id="et_pn" value="${p.notes||''}"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${window.t('labelContractStart')}</label><input class="form-input" id="et_bs" type="date" value="${t.bas||''}"></div>
    <div class="form-row"><label class="form-label">${window.t('labelContractEnd')}</label><input class="form-input" id="et_bt" type="date" value="${t.bit||''}"></div>
  </div>
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${window.t('colPayDay')}</label><input class="form-input" id="et_g" type="number" value="${t.gun||1}" min="1" max="31"></div>
    <div class="form-row"><label class="form-label">${window.t('labelGenPayMethod')}</label><select class="form-select" id="et_sk">${SEKIL.map(s=>`<option ${t.sekil===s?'selected':''}>${s}</option>`).join('')}</select></div>
  </div>
  <div class="form-row"><label class="form-label">${window.t('colNote')}</label><input class="form-input" id="et_nt" value="${t.notes||''}"></div>
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${window.t('cancel')}</button>
    <button class="btn btn-danger btn-sm" id="btn-remove-ten" onclick="removeTenConfirm('${bname}','${tid}')">${window.t('panelRemoveBtn')}</button>
    ${p.paid?`<button class="btn btn-ghost btn-sm" id="btn-del-pay" onclick="delPayConfirm('${bname}','${tid}','${mo}')">🗑</button>`:''}
    <button class="btn btn-primary" onclick="updateTen('${bname}','${tid}','${mo}')">${window.t('labelUpdate')}</button>
  </div>`;
}

function updateTen(bname,tid,mo){
  const t=(DATA.tenants[bname]||[]).find(x=>x.id===tid);
  if(!t) return;
  t.unit=document.getElementById('et_u').value.trim().toUpperCase();
  t.fl=document.getElementById('et_fl').value.trim();
  t.name=document.getElementById('et_n').value.trim();
  t.phone=document.getElementById('et_ph').value.trim();
  t.rent=parseFloat(document.getElementById('et_r').value)||0;
  t.dep=parseFloat(document.getElementById('et_d').value)||0;
  t.bas=document.getElementById('et_bs').value;
  t.bit=document.getElementById('et_bt').value;
  t.gun=parseInt(document.getElementById('et_g').value)||1;
  t.sekil=document.getElementById('et_sk').value;
  t.notes=document.getElementById('et_nt').value.trim();
  setP(tid,mo,{
    paid:parseFloat(document.getElementById('et_p').value)||0,
    date:document.getElementById('et_pd').value||'',
    sekil:document.getElementById('et_ps').value,
    notes:document.getElementById('et_pn').value||'',
  });
  addHist(`${BL[bname]} ${t.unit} – ${t.name} güncellendi`);
  autoRecalc();
  const _sc=document.getElementById('content'),_sy=_sc?_sc.scrollTop:0;
  closeMod();render();updateBadges();
  requestAnimationFrame(()=>{if(_sc)_sc.scrollTop=_sy;});
  setTimeout(()=>{if(_sc)_sc.scrollTop=_sy;},40);
  setTimeout(()=>{if(_sc)_sc.scrollTop=_sy;},100);
  toast(t('tenantUpdated'),'green');
  if(DATA.cloud.enabled) cloudSync('push');
}

function removeTen(bname,tid){
  const t=(DATA.tenants[bname]||[]).find(x=>x.id===tid);
  if(!t) return;
  t.active=false;t.rent=0;
  addHist(`${BL[bname]} ${t.unit} – ${t.name} çıkarıldı`);
  saveLocal();render();updateBadges();toast(t('tenantRemoved'),'red');
  if(DATA.cloud.enabled) cloudSync('push');
}
function restoreTen(bname,tid){
  const t=(DATA.tenants[bname]||[]).find(x=>x.id===tid);
  if(!t) return;
  t.active=true;
  addHist(`${BL[bname]} ${t.unit} – ${t.name} geri alındı`);
  saveLocal();render();updateBadges();toast(t('tenantRestored'),'green');
  if(DATA.cloud.enabled) cloudSync('push');
}

function removeTenConfirm(bname,tid){
  const btn=document.getElementById('btn-remove-ten');
  if(!btn) return;
  if(btn.dataset.step==='1'){
    removeTen(bname,tid);
    closeMod();
  } else {
    btn.dataset.step='1';
    btn.textContent=t('removeConfirmText');
    btn.style.background='var(--rose)';
    setTimeout(()=>{ if(btn.dataset.step==='1'){btn.dataset.step='';btn.textContent=t('panelRemoveBtn');btn.style.background='';} },3000);
  }
}

function delPayConfirm(bname,tid,mo){
  const btn=document.getElementById('btn-del-pay');
  if(!btn) return;
  if(btn.dataset.step==='1'){
    if(DATA.payments[tid]) delete DATA.payments[tid][mo];
    addHist(`${BL[bname]} ${mo} ödemesi silindi`);
    autoRecalc(); saveLocal();
    closeMod(); render(); updateBadges();
    toast(t('paymentDeleted'),'red');
    if(DATA.cloud.enabled) cloudSync('push');
  } else {
    btn.dataset.step='1'; btn.textContent='⚠️ Evet, sil'; btn.style.color='var(--rose-l)';
    setTimeout(()=>{if(btn.dataset.step==='1'){btn.dataset.step='';btn.textContent=t('payDeleteBtn');btn.style.color='';}},3000);
  }
}

function pasteIntoField(id){
  const el=document.getElementById(id);
  if(!el) return toast(window.t('fieldNotFound'),'red');
  el.focus();
  const apply=v=>{
    if(typeof v==='string'&&v.trim()){
      el.value=v.trim();
      el.dispatchEvent(new Event('input',{bubbles:true}));
      el.dispatchEvent(new Event('change',{bubbles:true}));
      toast(window.t('pasted'),'blue');
    }
  };
  if(typeof window.electron!=='undefined'&&window.electron.readClipboard){
    window.electron.readClipboard().then(apply).catch(()=>toast(window.t('pasteManual'),'orange'));
  }else if(navigator.clipboard&&navigator.clipboard.readText){
    navigator.clipboard.readText().then(apply).catch(()=>toast(window.t('pasteManual'),'orange'));
  }else{
    toast(window.t('pasteManual'),'orange');
  }
}

// ── CLOUD MODAL ──────────────────────────────
function tplCloud(){
  const mode      = DATA.cloud.mode || 'supabase';
  const connected = DATA.cloud.enabled;
  const lastSync  = DATA.cloud.lastSync
    ? new Date(DATA.cloud.lastSync).toLocaleString((DATA.settings?.lang||'tr')==='en'?'en-US':'tr-TR') : '—';

  return `<div class="modal-title">${t('cloudTitle')}</div>

  <!-- Status -->
  <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;
    background:${connected?'rgba(16,185,129,.08)':'rgba(244,63,94,.06)'};
    border:1px solid ${connected?'rgba(16,185,129,.2)':'rgba(244,63,94,.15)'};
    border-radius:8px;margin-bottom:14px">
    <div style="width:8px;height:8px;border-radius:50%;flex-shrink:0;
      background:${connected?'#10b981':'#f43f5e'}"></div>
    <div style="flex:1;min-width:0">
      <div style="font-size:12px;font-weight:600;color:var(--i0)">
        ${connected?t('cloudConnected'):t('cloudDisconnected')}
      </div>
      <div style="font-size:10.5px;color:var(--i4)">${t('syncLast')} ${lastSync}</div>
    </div>
    ${connected?'<button class="btn btn-ghost btn-xs" onclick="checkSupabaseStatus()">⚡ Test</button>':''}
  </div>

  <!-- Tabs -->
  <div id="cloud-mode-tabs" style="display:flex;gap:3px;margin-bottom:12px;background:rgba(255,255,255,.04);
    border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:3px;width:fit-content">
    <button class="a-tab ${mode==='supabase'?'active':''}"
      onclick="setCloudMode('supabase',this)">🟢 Supabase</button>
    ${PRODUCTION_MODE?'':(`<button class="a-tab ${mode==='server'?'active':''}"
      onclick="setCloudMode('server',this)">🖥 Sunucu</button>
    <button class="a-tab ${mode==='json'?'active':''}"
      onclick="setCloudMode('json',this)">📦 JSON API</button>`)}
  </div>

  <!-- Supabase Panel -->
  <div id="cp-supabase" style="display:${mode==='supabase'?'block':'none'}">
    <div style="background:rgba(34,197,94,.06);border:1px solid rgba(34,197,94,.18);
      border-radius:7px;padding:10px 12px;margin-bottom:12px;font-size:11.5px;
      color:var(--i2);line-height:1.6">
      <b style="color:var(--i0)">Supabase:</b> ${t('cloudSupabaseDesc')}
      <a href="https://supabase.com" target="_blank" style="color:#60a5fa">supabase.com</a>
      → New Project → Settings → API → Project URL + anon key
    </div>
    <div style="margin-bottom:11px">
      <label style="display:block;font-size:10.5px;color:var(--i4);font-weight:600;
        text-transform:uppercase;letter-spacing:.3px;margin-bottom:4px">
        Project URL *
      </label>
      <div style="display:flex;gap:6px;align-items:center">
        <input id="supa_url" class="form-input" style="flex:1"
          value="${DATA.cloud.supabaseUrl||''}"
          placeholder="https://xxxx.supabase.co" autocomplete="off">
        <button type="button" class="btn btn-ghost btn-sm" onclick="pasteIntoField('supa_url')" title="${t('cloudPasteBtn')}">📋</button>
      </div>
    </div>
    <div style="margin-bottom:12px">
      <label style="display:block;font-size:10.5px;color:var(--i4);font-weight:600;
        text-transform:uppercase;letter-spacing:.3px;margin-bottom:4px">
        Anon / Publishable Key *
      </label>
      <div style="display:flex;gap:6px;align-items:center">
        <input id="supa_key" class="form-input" style="flex:1" type="password"
          value="${DATA.cloud.supabaseKey||''}"
          placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." autocomplete="off">
        <button type="button" class="btn btn-ghost btn-sm" onclick="pasteIntoField('supa_key')" title="${t('cloudPasteBtn')}">📋</button>
      </div>
      <div style="font-size:10px;color:var(--i5);margin-top:3px">
        Settings → API → anon public ${t('cloudKeyHint')}
      </div>
    </div>
    <div style="display:flex;gap:7px;margin-bottom:10px">
      <button class="btn btn-primary btn-sm" onclick="supabaseConnect()">${t('cloudConnect')}</button>
      <button class="btn btn-ghost btn-sm" onclick="checkSupabaseStatus()">${t('cloudTestBtn')}</button>
    </div>
    <div id="supa-msg" style="min-height:20px;font-size:12px;margin-bottom:4px"></div>
  </div>

  <!-- Server Panel -->
  <div id="cp-server" style="display:${PRODUCTION_MODE?'none':mode==='server'?'block':'none'}">
    <div style="margin-bottom:10px">
      <label style="display:block;font-size:10.5px;color:var(--i4);font-weight:600;
        text-transform:uppercase;letter-spacing:.3px;margin-bottom:4px">Sunucu URL</label>
      <input id="c_url" class="form-input"
        value="${DATA.cloud.serverUrl||DATA.cloud.url||''}" placeholder="http://sunucu:8787">
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">
      <div>
        <label style="display:block;font-size:10.5px;color:var(--i4);font-weight:600;
          text-transform:uppercase;letter-spacing:.3px;margin-bottom:4px">Kullanıcı</label>
        <input id="c_user" class="form-input"
          value="${DATA.cloud.username||''}" placeholder="kullanici">
      </div>
      <div>
        <label style="display:block;font-size:10.5px;color:var(--i4);font-weight:600;
          text-transform:uppercase;letter-spacing:.3px;margin-bottom:4px">Şifre</label>
        <input id="c_pass" class="form-input" type="password" placeholder="••••••">
      </div>
    </div>
    <div style="display:flex;gap:7px;margin-bottom:8px">
      <button class="btn btn-primary btn-sm" onclick="cloudLoginAndSave()">🔐 Bağlan</button>
      <button class="btn btn-ghost btn-sm" onclick="checkCloudStatus()">⚡ Test</button>
    </div>
    <div id="cloud-server-msg" style="font-size:12px;min-height:18px;color:var(--i4)"></div>
  </div>

  <!-- JSON Panel -->
  <div id="cp-json" style="display:${PRODUCTION_MODE?'none':mode==='json'?'block':'none'}">
    <div style="background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.2);
      border-radius:7px;padding:8px 12px;font-size:11.5px;color:var(--amber-l);margin-bottom:10px">
      ⚠️ Eski mod — Supabase önerilir.
    </div>
    <div style="margin-bottom:10px">
      <label style="display:block;font-size:10.5px;color:var(--i4);font-weight:600;
        text-transform:uppercase;letter-spacing:.3px;margin-bottom:4px">API URL</label>
      <input id="c_url_json" class="form-input"
        value="${DATA.cloud.url||''}" placeholder="https://api.jsonbin.io/...">
    </div>
    <div style="margin-bottom:10px">
      <label style="display:block;font-size:10.5px;color:var(--i4);font-weight:600;
        text-transform:uppercase;letter-spacing:.3px;margin-bottom:4px">API Key</label>
      <input id="c_key_json" class="form-input" type="password"
        value="${DATA.cloud.key||''}" placeholder="$2a$10$...">
    </div>
    <button class="btn btn-secondary btn-sm" onclick="saveJsonCloud()">💾 Kaydet</button>
  </div>

  <hr style="border:none;border-top:1px solid rgba(255,255,255,.07);margin:12px 0">

  ${connected?`
  <div style="display:flex;gap:7px;flex-wrap:wrap;margin-bottom:8px">
    <button class="btn btn-primary btn-sm" onclick="cloudSync('push');closeMod()">⬆ Push</button>
    <button class="btn btn-secondary btn-sm"
      onclick="cloudSync('pull').then(()=>closeMod())">⬇ Pull</button>
  </div>
  <div style="font-size:11px;color:var(--i4)">${t('cloudAutoSync')} ${lastSync}</div>
  `:`<div style="font-size:12px;color:var(--i5)">${t('cloudConnectFirst')}</div>`}

  <div style="display:flex;justify-content:flex-end;margin-top:14px;padding-top:12px;
    border-top:1px solid rgba(255,255,255,.06)">
    <button class="btn btn-ghost" onclick="closeMod()">${t('close')}</button>
  </div>`;
}

function setCloudMode(mode, el) {
  DATA.cloud.mode = mode;
  ['supabase','server','json'].forEach(m => {
    const d = document.getElementById('cp-'+m);
    if(d) d.style.display = m===mode ? 'block' : 'none';
  });
  document.querySelectorAll('#cloud-mode-tabs .a-tab').forEach(t => t.classList.remove('active'));
  if(el) el.classList.add('active');
  saveLocal();
}


function cloudTab(which, el){
  document.querySelectorAll('#cloud-tabs .a-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('cloud-tab-server').style.display = which==='server'?'':'none';
  document.getElementById('cloud-tab-json').style.display = which==='json'?'':'none';
}

async function cloudLoginAndSave(){
  const url  = (document.getElementById('c_url')?.value||'').trim().replace(/\/+$/,'');
  const user = (document.getElementById('c_user')?.value||'').trim();
  const pass = document.getElementById('c_pass')?.value||'';
  const msg  = document.getElementById('cloud-server-msg');
  if(!url||!user||!pass){ msg.textContent='❌ URL, kullanıcı adı ve şifre gerekli'; return; }
  msg.textContent='🔄 Bağlanıyor...'; msg.style.color='var(--i3)';
  const result = await cloudLogin(url, user, pass);
  if(!result.ok){ msg.textContent='❌ '+result.error; msg.style.color='var(--rose-l)'; return; }
  // Save auth
  DATA.cloud.serverUrl = url;
  DATA.cloud.url = url;
  DATA.cloud.token = result.token;
  DATA.cloud.key = result.token; // backwards compat
  DATA.cloud.username = user;
  DATA.cloud.enabled = true;
  DATA.cloud.user = result.user;
  saveLocal();
  msg.textContent='✅ Bağlandı: '+result.user.name+' ('+result.user.role+')';
  msg.style.color='var(--emerald-l)';
  updateCloudUI();
  toast('✅ Sunucuya bağlandı','green');
  addHist('Bulut sunucu bağlantısı: '+url+' ('+result.user.name+')');
}

async function checkCloudStatus(){
  const url = (DATA.cloud.serverUrl||DATA.cloud.url||'').replace(/\/+$/,'');
  const msg = document.getElementById('cloud-server-msg');
  if(!url){ if(msg) msg.textContent='❌ URL girilmedi'; return; }
  if(msg){ msg.textContent='🔄 Test ediliyor...'; msg.style.color='var(--i3)'; }
  const h = await checkServerHealth(url);
  if(h.ok){
    const txt = `✅ Sunucu aktif · v${h.version} · DB: ${h.db} · Uptime: ${h.uptime}s`;
    if(msg){ msg.textContent=txt; msg.style.color='var(--emerald-l)'; }
    toast('✅ Sunucu bağlantısı OK','green');
  } else {
    const txt = '❌ Sunucu yanıt vermiyor: '+h.error;
    if(msg){ msg.textContent=txt; msg.style.color='var(--rose-l)'; }
    toast('❌ Sunucu bağlantı hatası','red');
  }
}

function saveJsonCloud(){
  DATA.cloud.url = (document.getElementById('c_url_json')?.value||'').trim();
  DATA.cloud.key = (document.getElementById('c_key_json')?.value||'').trim();
  DATA.cloud.token = DATA.cloud.key;
  saveLocal(); updateCloudUI(); closeMod();
  toast('💾 Bağlantı ayarları kaydedildi','green');
}

async function openServerUserMgmt(){
  if(!DATA.cloud.token){ toast('⚠️ Önce sunucuya bağlanın','red'); return; }
  const url = (DATA.cloud.serverUrl||DATA.cloud.url||'').replace(/\/+$/,'');
  closeMod();
  // Fetch users from server
  try{
    const r = await fetch(url+'/users', {headers:{'Authorization':'Bearer '+DATA.cloud.token}});
    if(!r.ok){ toast('❌ Sunucu kullanıcıları alınamadı: '+r.status,'red'); return; }
    const data = await r.json();
    renderServerUserMgmt(data.users, url);
  }catch(e){ toast('❌ '+e.message,'red'); }
}

function renderServerUserMgmt(users, url){
  const content = document.getElementById('content');
  const rows = (users||[]).map(u=>`<tr>
    <td>
      <div style="display:flex;align-items:center;gap:10px">
        <div style="width:30px;height:30px;border-radius:50%;background:${u.color||'#3b82f6'};
          display:flex;align-items:center;justify-content:center;font-weight:700;color:#fff;font-size:12px">${u.avatar||u.name[0]}</div>
        <div>
          <div style="font-weight:600">${u.name}</div>
          <div style="font-size:11px;color:var(--i4)">${u.username}</div>
        </div>
      </div>
    </td>
    <td><span style="padding:3px 9px;border-radius:20px;font-size:11px;font-weight:600;
      background:rgba(255,255,255,.07);color:${u.role==='admin'?'var(--blue-l)':u.role==='editor'?'var(--violet-l)':'var(--i3)'}">
      ${u.role==='admin'?'👑 Admin':u.role==='editor'?'🔑 Editor':'👁 Viewer'}</span></td>
    <td><span style="display:inline-flex;align-items:center;gap:5px;font-size:11px">
      <span style="width:7px;height:7px;border-radius:50%;background:${u.active?'var(--emerald)':'var(--rose)'}"></span>
      ${u.active?'Aktif':'Pasif'}</span></td>
    <td style="font-size:11px;color:var(--i4)">${u.created_at?u.created_at.slice(0,10):'—'}</td>
    <td>
      <div style="display:flex;gap:5px">
        <button class="btn btn-ghost btn-xs" onclick="serverResetPIN('${url}','${u.id}','${u.username}')">🔑 Şifre</button>
        <button class="btn btn-ghost btn-xs" onclick="serverToggleUser('${url}','${u.id}',${u.active})">${u.active?'⏸':'▶'}</button>
      </div>
    </td>
  </tr>`).join('');

  content.innerHTML = `
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px">
    <h3 style="font-size:15px;font-weight:700;flex:1">👥 Sunucu Kullanıcıları</h3>
    <button class="btn btn-ghost btn-sm" onclick="goto('dash')">← Geri</button>
    <button class="btn btn-primary btn-sm" onclick="serverAddUserForm('${url}')">+ Kullanıcı Ekle</button>
  </div>
  <div id="server-user-form"></div>
  <div class="table-card">
    <div class="table-scroller"><table>
      <thead><tr><th>Kullanıcı</th><th>Rol</th><th>Durum</th><th>Oluşturma</th><th>İşlem</th></tr></thead>
      <tbody>${rows}</tbody>
    </table></div>
  </div>`;
}

function serverResetPIN(url, userId, username){
  const f=document.getElementById('server-user-form');
  if(!f) return;
  f.innerHTML=`<div style="background:var(--glass-2);border:1px solid var(--bd-1);border-radius:var(--r2);padding:14px;margin-bottom:12px">
    <div style="font-weight:700;margin-bottom:10px;font-size:12px">🔑 Şifre Sıfırla — ${username}</div>
    <div class="form-grid-2" style="margin-bottom:10px">
      <div class="form-row"><label class="form-label">Yeni Şifre (min 6)</label>
        <input class="form-input" id="svr_np" type="password" placeholder="••••••"
          onkeydown="if(event.key==='Enter')commitServerPIN('${url}','${userId}')"></div>
      <div class="form-row"><label class="form-label">Tekrar</label>
        <input class="form-input" id="svr_nc" type="password" placeholder="••••••"
          onkeydown="if(event.key==='Enter')commitServerPIN('${url}','${userId}')"></div>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-ghost btn-sm" onclick="document.getElementById('server-user-form').innerHTML=''">İptal</button>
      <button class="btn btn-primary btn-sm" onclick="commitServerPIN('${url}','${userId}')">✅ Güncelle</button>
    </div>
  </div>`;
  const inp=document.getElementById('svr_np');
  if(inp) inp.focus();
}
async function commitServerPIN(url, userId){
  const np=(document.getElementById('svr_np')?.value||'').trim();
  const nc=(document.getElementById('svr_nc')?.value||'').trim();
  if(!np){ toast('❌ Şifre boş olamaz','red'); return; }
  if(np.length<6){ toast('❌ Min 6 karakter','red'); return; }
  if(np!==nc){ toast('❌ Şifreler eşleşmiyor','red'); return; }
  try{
    const r=await fetch(url+'/users/'+userId+'/reset-password',{
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':'Bearer '+DATA.cloud.token},
      body:JSON.stringify({newPassword:np})
    });
    const d=await r.json();
    if(d.ok){ toast('✅ Şifre güncellendi','green'); document.getElementById('server-user-form').innerHTML=''; }
    else toast('❌ '+d.error,'red');
  }catch(e){ toast('❌ '+e.message,'red'); }
}

async function serverToggleUser(url, userId, currentActive){
  try{
    const r = await fetch(url+'/users/'+userId,{
      method:'PUT',
      headers:{'Content-Type':'application/json','Authorization':'Bearer '+DATA.cloud.token},
      body:JSON.stringify({active:!currentActive})
    });
    const d = await r.json();
    if(d.ok){ toast(currentActive?'⏸ Pasif yapıldı':'✅ Aktif yapıldı','green'); openServerUserMgmt(); }
    else toast('❌ '+d.error,'red');
  }catch(e){ toast('❌ '+e.message,'red'); }
}

function serverAddUserForm(url){
  const f = document.getElementById('server-user-form');
  f.innerHTML=`<div style="background:var(--glass-2);border:1px solid var(--bd-1);
    border-radius:var(--r2);padding:14px;margin-bottom:12px">
    <div style="font-weight:700;margin-bottom:10px">➕ Yeni Sunucu Kullanıcısı</div>
    <div class="form-grid-2" style="margin-bottom:10px">
      <div class="form-row"><label class="form-label">Kullanıcı Adı *</label>
        <input class="form-input" id="su_un" placeholder="kullanici"></div>
      <div class="form-row"><label class="form-label">Ad Soyad *</label>
        <input class="form-input" id="su_n" placeholder="Ad Soyad"></div>
    </div>
    <div class="form-grid-2" style="margin-bottom:10px">
      <div class="form-row"><label class="form-label">Şifre * (min 6)</label>
        <input class="form-input" id="su_p" type="password" placeholder="••••••"></div>
      <div class="form-row"><label class="form-label">Rol</label>
        <select class="form-select" id="su_r">
          <option value="editor">🔑 Editor</option>
          <option value="viewer">👁 Viewer</option>
          <option value="admin">👑 Admin</option>
        </select></div>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-ghost btn-sm" onclick="document.getElementById('server-user-form').innerHTML=''">İptal</button>
      <button class="btn btn-primary btn-sm" onclick="serverSaveNewUser('${url}')">✅ Ekle</button>
    </div>
  </div>`;
}

async function serverSaveNewUser(url){
  const username = document.getElementById('su_un')?.value.trim();
  const name     = document.getElementById('su_n')?.value.trim();
  const password = document.getElementById('su_p')?.value;
  const role     = document.getElementById('su_r')?.value;
  if(!username||!name||!password){ toast('❌ Tüm alanlar zorunlu','red'); return; }
  if(password.length<6){ toast('❌ Şifre min 6 karakter','red'); return; }
  try{
    const r = await fetch(url+'/users',{
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':'Bearer '+DATA.cloud.token},
      body:JSON.stringify({username,name,password,role})
    });
    const d = await r.json();
    if(d.ok){ toast(t('userAdded'),'green'); openServerUserMgmt(); }
    else toast('❌ '+d.error,'red');
  }catch(e){ toast('❌ '+e.message,'red'); }
}


function tplUsers(){
  const roleMeta={
    admin:{label:'👑 Admin',desc:t('usersRoleDescAdmin'),color:'#3b82f6'},
    manager:{label:'🔑 Editor',desc:t('usersRoleDescManager'),color:'#8b5cf6'},
    viewer:{label:'👁 '+t('roleViewer').replace(/^👁️?\s*/,''),desc:t('usersRoleDescViewer'),color:'#6b7280'},
  };
  const rows=DATA.users.map((u,i)=>{
    const rm=roleMeta[u.role]||roleMeta.viewer;
    const self=_isSelf(i);
    return `<tr>
      <td style="min-width:140px">
        <div style="display:flex;align-items:center;gap:8px">
          <div style="width:30px;height:30px;border-radius:50%;background:${u.color||'#4a8af4'};
            display:flex;align-items:center;justify-content:center;
            font-size:12px;font-weight:700;color:#fff;flex-shrink:0">${u.avatar||u.name[0]||'U'}</div>
          <div style="min-width:0">
            <div style="font-weight:600;color:var(--i0);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${u.name}${self?' 👤':''}</div>
            <div style="font-size:10px;color:var(--i4)">${u.id}</div>
          </div>
        </div>
      </td>
      <td style="white-space:nowrap"><span style="padding:2px 8px;border-radius:20px;font-size:11px;font-weight:600;background:rgba(255,255,255,.07);color:${rm.color}">${rm.label}</span></td>
      <td style="font-size:11px;color:var(--i3);white-space:nowrap">${rm.desc}</td>
      <td style="font-family:var(--mono);color:var(--i4);font-size:11px">${'●'.repeat(u.pin?u.pin.length:4)}</td>
      <td style="white-space:nowrap">
        <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px">
          <span style="width:6px;height:6px;border-radius:50%;background:${u.active!==false?'var(--emerald)':'var(--rose)'}"></span>
          <span style="color:var(--i3)">${u.active!==false?t('usersActive'):t('usersInactive')}</span>
        </span>
      </td>
      <td>
        <div style="display:flex;gap:4px;flex-wrap:wrap;min-width:120px">
          ${canEditUser(i)?`<button class="btn btn-ghost btn-xs" onclick="editUserInline(${i})" title="${t('usersEditBtn')}">${t('usersEditBtn')}</button>`:''}
          ${canEditUser(i)?`<button class="btn btn-ghost btn-xs" onclick="showPINForm(${i})" title="${t('usersPinChange')}">🔑</button>`:''}
          ${canDeactivateUser(i)?`<button class="btn btn-ghost btn-xs" onclick="toggleUserActive(${i})" title="${u.active!==false?t('usersInactive'):t('usersActive')}">${u.active!==false?'⏸':'▶'}</button>`:''}
          ${canDeleteUser(i)?`<button class="btn btn-danger btn-xs" id="btn-del-user-${i}" onclick="delUserConfirm(${i})">🗑</button>`:''}
        </div>
      </td>
    </tr>`;
  }).join('');

  return `<div class="modal-title">${t('usersTitle')}</div>
  <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
    <div style="flex:1;font-size:12px;color:var(--i3)">${DATA.users.length} ${t('usersCount')}</div>
    ${isAdmin()?`<button class="btn btn-primary btn-sm" onclick="showAddUserForm()">+ ${t('btnAdd').replace('+ ','')}</button>`:''}
  </div>
  <div class="table-card" style="margin-bottom:12px;overflow:hidden">
    <div class="table-scroller" style="max-width:100%;overflow-x:auto"><table style="min-width:500px;width:100%">
      <thead><tr>
        <th>${t('usersColUser')}</th>
        <th>${t('usersColRole')}</th>
        <th>${t('usersColPerm')}</th>
        <th>PIN</th>
        <th>${t('usersColStatus')}</th>
        <th style="min-width:130px">${t('usersColAction')}</th>
      </tr></thead>
      <tbody>${rows}</tbody>
    </table></div>
  </div>
  <div id="user-inline-form"></div>
  ${!isAdmin()?`<div style="background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.2);border-radius:var(--r2);padding:8px 12px;font-size:11px;color:var(--amber-l);margin-bottom:8px">
    ${t('usersOwnOnly')}
  </div>`:''}
  <div style="background:rgba(59,130,246,.06);border:1px solid rgba(59,130,246,.12);border-radius:var(--r2);padding:10px 12px;font-size:11px;color:var(--i3);margin-bottom:8px">
    ${t('usersFooter')}
  </div>
  <div class="modal-footer"><button class="btn btn-ghost" onclick="closeMod()">${t('close')}</button></div>`;
}

function showAddUserForm(){
  const f=document.getElementById('user-inline-form');
  f.innerHTML=`<div style="background:var(--glass-2);border:1px solid var(--bd-1);border-radius:var(--r2);padding:14px;margin-bottom:10px">
    <div style="font-size:13px;font-weight:700;margin-bottom:10px">${t('usersNewUser')}</div>
    <div class="form-grid-2" style="margin-bottom:10px">
      <div class="form-row"><label class="form-label">${t('usersNameLabel')}</label><input class="form-input" id="nu_n" placeholder="${t('usersNameLabel').replace(' *','')}"></div>
      <div class="form-row"><label class="form-label">${t('usersAvatarLabel')}</label><input class="form-input" id="nu_av" placeholder="A" maxlength="2"></div>
    </div>
    <div class="form-grid-2" style="margin-bottom:10px">
      <div class="form-row"><label class="form-label">${t('usersRoleLabel')}</label>
        <select class="form-select" id="nu_r">
          <option value="admin">👑 Admin</option>
          <option value="manager" selected>🔑 Editor</option>
          <option value="viewer">👁 ${t('roleViewer').replace(/^👁️?\s*/,'')}</option>
        </select>
      </div>
      <div class="form-row"><label class="form-label">${t('usersPinLabel')}</label><input class="form-input" id="nu_p" type="password" maxlength="6" placeholder="••••"></div>
    </div>
    <div class="form-row"><label class="form-label">${t('usersColorLabel')}</label>
      <input type="color" id="nu_c" value="#4a8af4" style="height:36px;width:100%;border-radius:var(--r1);border:1px solid var(--bd-1);cursor:pointer"></div>
    <div style="display:flex;gap:8px;margin-top:12px">
      <button class="btn btn-ghost btn-sm" onclick="document.getElementById('user-inline-form').innerHTML=''">${t('cancel')}</button>
      <button class="btn btn-primary btn-sm" onclick="saveNewUser()">${t('usersAddBtn')}</button>
    </div>
  </div>`;
}

function addUserForm(){showAddUserForm();}

function saveNewUser(){
  const name=(document.getElementById('nu_n')?.value||'').trim();
  const avatar=(document.getElementById('nu_av')?.value||name[0]||'U').toUpperCase();
  const role=document.getElementById('nu_r')?.value||'viewer';
  const pin=(document.getElementById('nu_p')?.value||'').trim();
  const color=document.getElementById('nu_c')?.value||'#4a8af4';
  if(!name){toast(t('nameRequired'),'red');return;}
  if(pin.length<4){toast('❌ PIN en az 4 haneli','red');return;}
  if(!/^\d+$/.test(pin)){toast('❌ PIN sadece rakam','red');return;}
  DATA.users.push({id:'u_'+Date.now(),name,avatar,role,pin,color,active:true});
  addHist('Kullanıcı eklendi: '+name);
  saveLocal();
  document.getElementById('modal').innerHTML=tplUsers();
  toast(t('userAdded'),'green');
}

function editUserInline(i){
  if(!canEditUser(i)){toast(t('usersNoPermission'),'red');return;}
  const u=DATA.users[i];
  const f=document.getElementById('user-inline-form');
  const roleDisabled=canChangeRole()?'':'disabled';
  f.innerHTML=`<div style="background:var(--glass-2);border:1px solid var(--bd-1);border-radius:var(--r2);padding:14px;margin-bottom:10px">
    <div style="font-size:13px;font-weight:700;margin-bottom:10px">✏️ ${t('usersEditBtn').replace(/^✏️\s*/,'')} — ${u.name}</div>
    <div class="form-grid-2" style="margin-bottom:10px">
      <div class="form-row"><label class="form-label">${t('usersNameLabel').replace(' *','')}</label><input class="form-input" id="eu_n" value="${u.name}"></div>
      <div class="form-row"><label class="form-label">${t('usersAvatarLabel')}</label><input class="form-input" id="eu_av" value="${u.avatar||''}" maxlength="2"></div>
    </div>
    <div class="form-grid-2" style="margin-bottom:10px">
      <div class="form-row"><label class="form-label">${t('usersRoleLabel')}</label>
        <select class="form-select" id="eu_r" ${roleDisabled}>
          <option value="admin" ${u.role==='admin'?'selected':''}>👑 Admin</option>
          <option value="manager" ${u.role==='manager'?'selected':''}>🔑 Editor</option>
          <option value="viewer" ${u.role==='viewer'?'selected':''}>👁 ${t('roleViewer').replace(/^👁️?\s*/,'')}</option>
        </select>
      </div>
      <div class="form-row"><label class="form-label">${t('usersColorLabel')}</label>
        <input type="color" id="eu_c" value="${u.color||'#4a8af4'}" style="height:36px;width:100%;border-radius:var(--r1);border:1px solid var(--bd-1);cursor:pointer"></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:12px">
      <button class="btn btn-ghost btn-sm" onclick="document.getElementById('user-inline-form').innerHTML=''">${t('cancel')}</button>
      <button class="btn btn-primary btn-sm" onclick="saveEditUser2(${i})">${t('save')}</button>
    </div>
  </div>`;
  f.scrollIntoView({behavior:'smooth',block:'nearest'});
}

function saveEditUser2(i){
  if(!canEditUser(i)){toast(t('usersNoPermission'),'red');return;}
  const u=DATA.users[i];
  u.name=document.getElementById('eu_n')?.value.trim()||u.name;
  u.avatar=(document.getElementById('eu_av')?.value||u.name[0]).toUpperCase();
  if(canChangeRole()) u.role=document.getElementById('eu_r')?.value||u.role;
  u.color=document.getElementById('eu_c')?.value||u.color;
  addHist('Kullanıcı güncellendi: '+u.name);
  saveLocal();
  document.getElementById('modal').innerHTML=tplUsers();
  toast('✅ '+t('saved'),'green');
}

function showPINForm(i){
  if(!canEditUser(i)){toast(t('usersNoPermission'),'red');return;}
  const u=DATA.users[i];
  const f=document.getElementById('user-inline-form');
  if(!f) return;
  f.innerHTML=`<div style="background:var(--glass-2);border:1px solid var(--bd-1);border-radius:var(--r2);padding:14px;margin-bottom:10px">
    <div style="font-size:13px;font-weight:700;margin-bottom:10px">${t('usersPinChange')} — ${u.name}</div>
    <div class="form-grid-2" style="margin-bottom:10px">
      <div class="form-row"><label class="form-label">${t('usersPinNew')}</label><input class="form-input" id="pin_new" type="password" maxlength="6" placeholder="••••" autofocus></div>
      <div class="form-row"><label class="form-label">${t('usersPinRepeat')}</label><input class="form-input" id="pin_confirm" type="password" maxlength="6" placeholder="••••"></div>
    </div>
    <div style="display:flex;gap:6px">
      <button class="btn btn-primary btn-sm" onclick="commitPIN(${i})">${t('save')}</button>
      <button class="btn btn-ghost btn-sm" onclick="document.getElementById('user-inline-form').innerHTML=''">${t('cancel')}</button>
    </div>
  </div>`;
  const inp=document.getElementById('pin_new');
  if(inp) inp.focus();
}
function commitPIN(i){
  if(!canEditUser(i)){toast(t('usersNoPermission'),'red');return;}
  const u=DATA.users[i];
  const np=(document.getElementById('pin_new')||{}).value||'';
  const nc=(document.getElementById('pin_confirm')||{}).value||'';
  if(!np){toast(t('pinEmpty'),'red');return;}
  if(np.length<4||!/^\d+$/.test(np)){toast(t('pinInvalid'),'red');return;}
  if(np!==nc){toast(t('pinMismatch'),'red');return;}
  u.pin=np;
  addHist('PIN sıfırlandı: '+u.name);
  saveLocal();
  toast(t('pinUpdated'),'green');
  document.getElementById('modal').innerHTML=tplUsers();
}

function toggleUserActive(i){
  if(!canDeactivateUser(i)){toast(t('usersNoPermission'),'red');return;}
  const u=DATA.users[i];
  u.active=!(u.active!==false);
  addHist((u.active?'Aktifleştirildi':'Devre dışı')+': '+u.name);
  saveLocal();
  document.getElementById('modal').innerHTML=tplUsers();
  toast(u.active?t('userActivated'):t('userDeactivated'),u.active?'green':'red');
}

function delUserConfirm(i){
  if(!canDeleteUser(i)){toast(t('usersNoPermission'),'red');return;}
  const u=DATA.users[i];
  const btn=document.getElementById('btn-del-user-'+i);
  if(!btn) return;
  if(btn.dataset.step==='1'){
    DATA.users.splice(i,1);
    addHist('Kullanıcı silindi: '+u.name);
    saveLocal();
    document.getElementById('modal').innerHTML=tplUsers();
    toast('🗑 '+t('userDeleted'),'red');
  } else {
    btn.dataset.step='1';
    btn.textContent='⚠️ Evet, sil';
    btn.style.background='var(--rose)';
    setTimeout(()=>{ if(btn.dataset.step==='1') document.getElementById('modal').innerHTML=tplUsers(); },3000);
  }
}

function saveUser(){saveNewUser();}
function editUser(i){
  const u=DATA.users[i];
  const roles=['admin','manager','viewer'];
  const rLabels=['👑 Admin','🔑 Manager','👁️ Viewer'];
  const form=`<div style="background:var(--glass-2);border-radius:10px;padding:14px;margin-top:10px" id="edit-user-form-${i}">
    <div style="font-weight:700;margin-bottom:10px;font-size:12px">✏️ Düzenle: ${u.name}</div>
    <div class="form-grid-2" style="margin-bottom:10px">
      <div><label class="form-label">İsim</label><input class="fi ie" id="eu_n_${i}" value="${u.name}"></div>
      <div><label class="form-label">Avatar Harf</label><input class="fi ie" id="eu_av_${i}" value="${u.avatar}" maxlength="2"></div>
    </div>
    <div class="form-grid-2" style="margin-bottom:10px">
      <div><label class="form-label">Rol</label>
        <select class="form-select" id="eu_r_${i}">
          ${roles.map((r,ri)=>'<option value="'+r+'" '+(u.role===r?'selected':'')+'>'+(rLabels[ri])+'</option>').join('')}
        </select>
      </div>
      <div><label class="form-label">Yeni PIN (boş=değişmez)</label><input class="fi ie" id="eu_p_${i}" type="password" placeholder="min 4 hane"></div>
    </div>
    <div class="form-grid-2" style="margin-bottom:0">
      <div><label class="form-label">Renk</label><input class="form-input" id="eu_c_${i}" type="color" value="${u.color}" style="height:36px;cursor:pointer"></div>
      <div style="display:flex;align-items:flex-end;gap:6px">
        <button class="btn btn-primary btn-sm" onclick="saveEditUser(${i})">💾 Kaydet</button>
        <button class="btn btn-ghost btn-sm" onclick="document.getElementById('edit-user-form-${i}').remove()">İptal</button>
      </div>
    </div>
  </div>`;
  const existing=document.getElementById('edit-user-form-'+i);
  if(existing){existing.remove();return;}
  const rows=document.querySelectorAll('#md tbody tr');
  if(rows[i]) rows[i].insertAdjacentHTML('afterend', form);
}
function saveEditUser(i){
  const u=DATA.users[i];
  const nn=document.getElementById('eu_n_'+i)?.value.trim();
  const nav=document.getElementById('eu_av_'+i)?.value.trim();
  const nr=document.getElementById('eu_r_'+i)?.value;
  const np=document.getElementById('eu_p_'+i)?.value.trim();
  const nc=document.getElementById('eu_c_'+i)?.value;
  if(nn) u.name=nn;
  if(nav) u.avatar=nav.toUpperCase();
  if(nr) u.role=nr;
  if(np&&np.length>=4) u.pin=np;
  if(nc) u.color=nc;
  saveLocal();
  document.getElementById('modal').innerHTML=tplUsers();
  toast(t('userUpdated'),'green');
}
function delUser(i){ delUserConfirm(i); }

// ═══════════════════════════════════════════════
// ALL PAYMENTS PAGE
// ═══════════════════════════════════════════════
function renderPay(){
  const m=S.month;
  const q=(S.search||'').toLowerCase();
  let rows='';
  BK.forEach(b=>{
    sortU(safeTens(b)).filter(t=>{
      if(!t.active||t.rent===0) return false;
      const matchQ=!q||t.name.toLowerCase().includes(q)||t.unit.toLowerCase().includes(q)||(t.phone||'').includes(q);
      if(!matchQ) return false;
      const p=getP(t.id,m);
      if(S.filter==='overdue') return isDue(t,m);
      if(S.filter==='unpaid') return p.paid===0;
      if(S.filter==='partial') return p.paid>0&&p.paid<t.rent;
      if(S.filter==='paid') return p.paid>=t.rent;
      return true;
    }).forEach(t=>{
      const p=getP(t.id,m);
      const st=getStatus(t,m);
      const diff=p.paid-(t.rent||0);
      rows+=`<tr class="cp" onclick="openPanel('${b}','${t.id}')">
        <td><b>${BL[b]}</b></td><td><b>${t.unit}</b></td>
        <td>${isDue(t,m)?'<span class="blink">🔴</span> ':''}${t.name}</td>
        <td class="cb fw7">${TL(t.rent)}</td>
        <td class="${p.paid>=(t.rent||0)?'c-green':p.paid>0?'c-orange':'c-red'} fw7">${TL(p.paid)}</td>
        <td class="${diff>0?'c-green':diff<0?'c-red':'c-muted'}">${diff>0?'+':''}${TL(diff)}</td>
        <td><span class="badge ${st.cls}">${st.lbl}</span></td>
        <td class="c-muted">${p.date?p.date.slice(0,10):'—'}</td>
        <td class="c-muted">${p.sekil||'—'}</td>
        <td>${canEdit()?`<button class="btn btn-xs bsu-" onclick="event.stopPropagation();openMod('pay-add','${b}:${t.id}')">${t('btnAddPayment')}</button>`:''}
        </td>
      </tr>`;
    });
  });
  const tRent=BK.reduce((s,b)=>s+rentTotal(b),0);
  const tPaid=BK.reduce((s,b)=>s+paidTotal(b,m),0);
  return monthBar()+`
  <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap">
    <input type="text" class="form-input" style="width:220px" placeholder="${t('searchPayTenant')}" oninput="S.search=this.value;render()" value="${S.search}">
    <div style="flex:1"></div>
    ${canEdit()?`<button class="btn btn-primary btn-sm" onclick="openMod('pay-add')">${t('btnAddPayment')}</button>`:''}
    <button class="btn btn-ghost btn-sm" onclick="window.print()">🖨️</button>
  </div>
  <div class="filter-pills">${[{k:'',l:t('filterAll')},{k:'overdue',l:t('filterOverdue')},{k:'unpaid',l:t('filterUnpaid')},{k:'partial',l:t('filterPartial')},{k:'paid',l:t('filterPaid')}].map(({k,l})=>`<button class="fpill${S.filter===k?' fpill-active':''}" onclick="setFilter('${k}')">${l}</button>`).join('')}</div>
  <div class="table-card">
    <div class="table-card-header">
      <h3>${t('allPayments')} — ${m}</h3>
      ${tRent>0?`<span style="font-size:11px;color:${tPaid>=tRent?'var(--emerald-l)':'var(--amber-l)'}">
        ${tPaid>=tRent?t('collectFull'):'⚠️ '+TL(tRent-tPaid)+' '+t('collectShort')+' · '+Math.round(tPaid/tRent*100)+'%'}
      </span>`:''}
    </div>
    <div class="table-scroller"><table>
      <thead><tr><th>${t('colBuilding')}</th><th>${t('colUnit')}</th><th>${t('colTenant')}</th><th>${t('colRent')}</th><th>${t('colPaid')}</th><th>${t('colDiff')}</th><th>${t('colStatus')}</th><th>${t('colDate')}</th><th>${t('colMethod')}</th><th></th></tr></thead>
      <tbody>${rows||`<tr><td colspan="10" class="empty-state-text">${t('emptyRecords')}</td></tr>`}
      <tr class="tfoot-row"><td colspan="3">${t('totalAll')}</td><td class="c-blue">${TL(tRent)}</td><td class="${tPaid>=tRent?'c-green':'c-orange'}">${TL(tPaid)}</td><td class="${tPaid-tRent>=0?'c-green':'c-red'}">${TL(tPaid-tRent)}</td><td colspan="4"></td></tr>
      </tbody>
    </table></div>
  </div>`;
}

// ═══════════════════════════════════════════════
// ALL EXPENSES PAGE
// ═══════════════════════════════════════════════
function renderExp(){
  const m=S.month;
  const q=(S.search||'').toLowerCase();
  let rows='',grand=0;
  BK.forEach(b=>{
    const exs=safeExps(b,m);
    const sub=exs.reduce((s,e)=>s+(e&&+e.tutar||0),0);
    grand+=sub;
    exs.forEach((e,i)=>{
      if(q&&!(BL[b].toLowerCase().includes(q)||(e.tur||'').toLowerCase().includes(q))) return;
      rows+=`<tr>
        <td><b>${BL[b]}</b></td><td class="mono">${e.no||'—'}</td>
        <td class="fw-600">${e.tur}</td><td class="co fw7">${TL(e.tutar)}</td>
        <td class="c-muted">${e.tarih||'—'}</td><td class="c-muted">${e.notlar||''}</td>
        <td class="nowrap">${canEdit()?`
          <button class="btn btn-xs bg-" onclick="editExp('${b}','${m}',${i})">✏️</button>
          <button class="btn btn-xs bd-" onclick="delExp('${b}','${m}',${i})">🗑</button>`:''}
        </td>
      </tr>`;
    });
    if(sub>0) rows+=`<tr style="background:rgba(74,138,244,.03)"><td colspan="3" class="c-muted">— ${BL[b]} ara toplam</td><td class="c-orange">${TL(sub)}</td><td colspan="3"></td></tr>`;
  });
  const cards=BK.map(b=>{
    const g=expTotal(b,m),p2=paidTotal(b,m),n=p2-g;
    return `<div class="kpi-card" style="--kpi-color:${n>=0?'var(--emerald)':'var(--rose)'}">
      <div class="kpi-icon">🏢</div><div style="font-weight:700;font-size:12px;margin-bottom:6px">${BL[b]}</div>
      <div class="kpi-value">${TL(g)}</div><div class="kpi-label">${t('kpiGider')}</div>
      <div style="margin-top:5px;font-size:11.5px" class="${n>=0?'c-green':'c-red'}">Net: ${TL(n)}</div>
    </div>`;
  }).join('');
  return monthBar()+`<div class="kpi-grid">${cards}</div>
  <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap">
    <input type="text" class="form-input" style="width:200px" placeholder="${t('searchExpType')}" oninput="S.search=this.value;render()" value="${q}">
    <div style="flex:1"></div>
    ${canEdit()?`<button class="btn btn-primary btn-sm" onclick="openMod('exp-add')">${t('addExpense2')}</button>`:''}
    <button class="btn btn-ghost btn-sm" onclick="window.print()">🖨️</button>
  </div>
  <div class="table-card">
    <div class="table-card-header"><h3>${t('allExpenses')} — ${m}</h3></div>
    <div class="table-scroller"><table>
      <thead><tr><th>${t('colBuilding')}</th><th>${t('colCounter')}</th><th>${t('colExpType')}</th><th>${t('colAmount')}</th><th>${t('colDate')}</th><th>${t('colNote')}</th><th></th></tr></thead>
      <tbody>${rows||`<tr><td colspan="7" class="empty-state-text">${t('emptyExpenses')}</td></tr>`}
      ${grand?`<tr class="tfoot-row"><td colspan="3">${t('grandTotal')}</td><td class="co fw8">${TL(grand)}</td><td colspan="3"></td></tr>`:''}
      </tbody>
    </table></div>
  </div>`;
}

// ═══════════════════════════════════════════════
// ALPER PAGE
// ═══════════════════════════════════════════════
function renderAlper(){
  const months=Object.keys(DATA.alper);
  const tNet=months.reduce((s,m)=>s+(DATA.alper[m].net||0),0);
  const tCol=months.reduce((s,m)=>s+(DATA.alper[m].col||0),0);
  const tExp=months.reduce((s,m)=>s+(DATA.alper[m].exp||0),0);

  const rows=months.map(m=>{
    const a=DATA.alper[m];
    return `<tr><td class="fw-600">${m}</td>
      <td class="c-blue">${TL(a.col||0)}</td>
      <td class="c-orange">${TL(a.exp||0)}</td>
      <td class="${(a.net||0)>=0?'c-green':'c-red'} fw7">${TL(a.net||0)}</td>
      <td>${canEdit()?`<button class="btn btn-xs bg-" onclick="editAlperMo('${m}')">✏️</button>`:''}
      </td></tr>`;
  }).join('');

  const m=S.month;
  const mgmtBld=BK.length>0?BK[0]:null;
  const kTens=mgmtBld?sortU((DATA.tenants[mgmtBld]||[]).filter(t=>t.active&&t.rent>0)):[];
  const kRows=kTens.map(t=>{
    const p=getP(t.id,m);const st=getStatus(t,m);
    return `<tr><td><b>${t.unit}</b></td><td>${t.name}</td>
      <td class="c-blue">${TL(t.rent)}</td>
      <td class="${p.paid>=(t.rent||0)?'c-green':p.paid>0?'c-orange':'c-red'}">${TL(p.paid)}</td>
      <td><span class="badge ${st.cls}">${st.lbl}</span></td>
      <td class="c-muted">${p.sekil||'—'}</td></tr>`;
  }).join('');

  return monthBar()+`
  <div class="alper-hero">
    <div style="font-size:15px;font-weight:800;color:var(--accent2)">${t('alperHeroTitle')}</div>
    <div style="font-size:11.5px;color:var(--text2);margin-top:5px;line-height:1.5">${t('alperHeroDesc')}</div>
    <div class="alper-stats">
      <div class="alper-stat"><div class="alper-sv ${tNet>=0?'c-green':'c-red'}">${TL(tNet)}</div><div class="alper-stat-lbl">${t('alperAccumulated')}</div></div>
      <div class="alper-stat"><div class="alper-sv cb">${TL(tCol)}</div><div class="alper-stat-lbl">${t('alperCollection')}</div></div>
      <div class="alper-stat"><div class="alper-sv co">${TL(tExp)}</div><div class="alper-stat-lbl">${t('kpiTotalExp')}</div></div>
      <div class="alper-stat"><div class="alper-sv cp2">${months.length}</div><div class="alper-stat-lbl">${t('alperMonthCount')}</div></div>
    </div>
  </div>

  <div class="sec-hdr">${t('alperMonthlyTable')} ${canEdit()?`<button class="btn btn-primary btn-sm" onclick="addAlperMo()">${t('alperAddMonth')}</button>`:''}</div>
  <div class="table-card"><div class="table-scroller"><table>
    <thead><tr><th>${t('colMonth')}</th><th>${t('colCollection')}</th><th>${t('kpiGider')}</th><th>${t('colNetDebt')}</th><th></th></tr></thead>
    <tbody>${rows}
    <tr class="tfoot-row"><td>${t('totalAll')}</td><td class="c-blue">${TL(tCol)}</td><td class="c-orange">${TL(tExp)}</td><td class="${tNet>=0?'c-green':'c-red'} fw8">${TL(tNet)}</td><td></td></tr>
    </tbody>
  </table></div></div>

  ${mgmtBld?`
  <div class="sec-hdr">🏠 ${BL[mgmtBld]||mgmtBld} — ${monthLabel(m)}</div>
  <div class="table-card"><div class="table-scroller"><table>
    <thead><tr><th>${t('colUnit')}</th><th>${t('colTenant')}</th><th>${t('colRent')}</th><th>${t('colPaid')}</th><th>${t('colStatus')}</th><th>${t('colMethod')}</th></tr></thead>
    <tbody>${kRows}</tbody>
  </table></div></div>`:''}

  ${Object.keys(DATA.tanNet).length>0?`
  <div class="sec-hdr">${t('alperForeignNet')}</div>
  <div class="table-card"><div class="table-scroller"><table>
    <thead><tr><th>${t('colMonth')}</th><th>${t('colCollection')}</th><th>${t('kpiGider')}</th><th>${t('colNetTL')}</th><th>${t('colRate')}</th><th>${t('colNetEur')}</th></tr></thead>
    <tbody>${Object.keys(DATA.tanNet).map(mo=>{
      const d=DATA.tanNet[mo];
      return `<tr><td class="fw-600">${monthLabel(mo)}</td><td class="c-blue">${TL(d.col)}</td><td class="c-orange">${TL(d.exp)}</td><td class="${d.net>=0?'c-green':'c-red'} fw7">${TL(d.net)}</td><td class="c-muted">${d.kur||0}</td><td class="cp2 fw7">€${(d.eur||0).toFixed(2)}</td></tr>`;
    }).join('')}</tbody>
  </table></div></div>`:''}
  `;
}

function editAlperMo(mo){ openMod('alper-month', mo); }
function addAlperMo(){ openMod('alper-month'); }

// ═══════════════════════════════════════════════
// CHARTS
// ═══════════════════════════════════════════════
function renderCharts(){
  return `
  <div class="kpi-grid">
    <div class="kpi-card" style="--kpi-color:var(--blue-l)"><div class="kpi-icon">📊</div><div class="kpi-value">4</div><div class="kpi-label">${t('chartsCount')}</div></div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
    <div class="chart-card"><div class="chart-title">${t('chartAlperMonthly')}</div><canvas id="ch-alper" height="200"></canvas></div>
    <div class="chart-card"><div class="chart-title">${t('chartBldCollection')} — ${monthLabel(S.month)}</div><canvas id="ch-bina" height="200"></canvas></div>
    <div class="chart-card"><div class="chart-title">${t('chartForeignNet')}</div><canvas id="ch-tan" height="200"></canvas></div>
    <div class="chart-card"><div class="chart-title">${t('chartPayStatus')} — ${monthLabel(S.month)}</div><canvas id="ch-durum" height="200"></canvas></div>
  </div>`;
}

let chartInstances={};
function destroyCharts(){Object.values(chartInstances).forEach(c=>{try{c.destroy();}catch(e){}});chartInstances={};}

function initCharts(){
  destroyCharts();
  const theme={grid:'rgba(26,48,84,.4)',text:'#7d9ec8'};
  const co={responsive:true,maintainAspectRatio:true,plugins:{legend:{labels:{color:theme.text,font:{size:11}}}}};

  // Alper bar + line
  const alperMos=Object.keys(DATA.alper);
  const alperVals=alperMos.map(m=>DATA.alper[m].net||0);
  const alperCol=alperMos.map(m=>DATA.alper[m].col||0);
  const c1=document.getElementById('ch-alper');
  if(c1) chartInstances.alper=new Chart(c1,{
    type:'bar',
    data:{
      labels:alperMos.map(m=>m.replace(' ','<br>')),
      datasets:[
        {label:t('chartNetDebt'),data:alperVals,backgroundColor:alperVals.map(v=>v>=0?'rgba(30,214,120,.6)':'rgba(240,84,84,.6)'),borderRadius:4},
        {label:t('kpiCollect'),data:alperCol,type:'line',borderColor:'rgba(74,138,244,.8)',backgroundColor:'rgba(74,138,244,.1)',pointRadius:3,tension:.3,fill:true,yAxisID:'y2'},
      ]
    },
    options:{...co,scales:{
      x:{ticks:{color:theme.text,font:{size:9},maxRotation:45},grid:{color:theme.grid}},
      y:{ticks:{color:theme.text,callback:v=>money(v)},grid:{color:theme.grid}},
      y2:{position:'right',ticks:{color:'rgba(74,138,244,.7)',callback:v=>money(v)},grid:{display:false}},
    }}
  });

  // Bina bar
  const m=S.month;
  const c2=document.getElementById('ch-bina');
  if(c2) chartInstances.bina=new Chart(c2,{
    type:'bar',
    data:{
      labels:BK.map(b=>BL[b]),
      datasets:[
        {label:t('colRent'),data:BK.map(b=>rentTotal(b)),backgroundColor:'rgba(74,138,244,.5)',borderRadius:4},
        {label:t('kpiCollect'),data:BK.map(b=>paidTotal(b,m)),backgroundColor:'rgba(30,214,120,.6)',borderRadius:4},
        {label:t('kpiGider'),data:BK.map(b=>expTotal(b,m)),backgroundColor:'rgba(245,166,35,.6)',borderRadius:4},
      ]
    },
    options:{...co,scales:{
      x:{ticks:{color:theme.text},grid:{color:theme.grid}},
      y:{ticks:{color:theme.text,callback:v=>money(v)},grid:{color:theme.grid}},
    }}
  });

  // Tan sokak line
  const tanMos=Object.keys(DATA.tanNet);
  const c3=document.getElementById('ch-tan');
  if(c3) chartInstances.tan=new Chart(c3,{
    type:'line',
    data:{
      labels:tanMos,
      datasets:[
        {label:t('colNetTL'),data:tanMos.map(m=>(DATA.tanNet[m].net||0)),borderColor:'rgba(6,214,160,.8)',backgroundColor:'rgba(6,214,160,.1)',pointRadius:4,tension:.3,fill:true},
        {label:t('kpiCollect'),data:tanMos.map(m=>(DATA.tanNet[m].col||0)),borderColor:'rgba(74,138,244,.6)',backgroundColor:'transparent',pointRadius:3,tension:.3},
      ]
    },
    options:{...co,scales:{
      x:{ticks:{color:theme.text},grid:{color:theme.grid}},
      y:{ticks:{color:theme.text,callback:v=>money(v)},grid:{color:theme.grid}},
    }}
  });

  // Payment status donut
  let paid=0,partial=0,unpaid=0;
  BK.forEach(b=>(DATA.tenants[b]||[]).filter(t=>t.active&&t.rent>0).forEach(t=>{
    const p=getP(t.id,m);
    if(p.paid>=t.rent) paid++;
    else if(p.paid>0) partial++;
    else unpaid++;
  }));
  const c4=document.getElementById('ch-durum');
  if(c4) chartInstances.durum=new Chart(c4,{
    type:'doughnut',
    data:{
      labels:[t('statusPaid'),t('statusPartial'),t('statusUnpaid')],
      datasets:[{data:[paid,partial,unpaid],backgroundColor:['rgba(30,214,120,.7)','rgba(245,166,35,.7)','rgba(240,84,84,.7)'],borderWidth:0}]
    },
    options:{...co,cutout:'60%',plugins:{legend:{position:'bottom',labels:{color:theme.text}}}}
  });
}

// ═══════════════════════════════════════════════
// WHATSAPP PAGE
// ═══════════════════════════════════════════════
function renderWA(){
  const m=S.month;
  const unpaid=[];
  BK.forEach(b=>(DATA.tenants[b]||[]).filter(t=>{
    if(!t.active||t.rent===0) return false;
    return isDue(t,m)||getP(t.id,m).paid<t.rent;
  }).forEach(t=>unpaid.push({b,t})));

  const rows=unpaid.map(({b,t})=>{
    const p=getP(t.id,m);
    const st=getStatus(t,m);
    const msg=buildWAMsg(b,t,m);
    const phone=(t.phone||'').replace(/\D/g,'');
    return `<div class="wa-reminder-card">
      <div class="wa-reminder-hdr">
        <div style="flex:1">
          <div class="fw-600">${BL[b]} — ${t.unit} <b>${t.name}</b></div>
          <div style="font-size:10.5px;color:var(--i3)">${t.phone?'📱 '+t.phone:window.t('waNoPhone')} · ${window.t('colRent')}: ${TL(t.rent)} · ${window.t('colPaid')}: ${TL(p.paid)}</div>
        </div>
        <span class="badge ${st.cls}">${st.lbl}</span>
      </div>
      <div class="wa-msg-box">${msg}</div>
      <div style="display:flex;gap:7px;margin-top:8px;flex-wrap:wrap">
        ${phone?`<a href="https://wa.me/${phone}?text=${encodeURIComponent(msg)}" target="_blank" class="btn btn-success btn-sm">${window.t('waSendBtn')}</a>`:'<span class="c-muted" style="font-size:11px">'+window.t('waNoPhoneMsg')+'</span>'}
        <button class="btn btn-ghost btn-sm" onclick="logWA('${b}','${t.id}','${m}')">${window.t('waSaveLog')}</button>
      </div>
    </div>`;
  }).join('');

  const logRows=DATA.waLog.slice(-30).reverse().map(l=>`
    <div class="wa-log-item">
      <span class="c-muted">${l.t}</span>
      <span style="flex:1">${l.bina} ${l.unit} – ${l.name}</span>
      <span class="c-muted">${l.mo}</span>
    </div>`).join('');

  return monthBar()+`
  <div style="display:flex;gap:8px;margin-bottom:12px;align-items:center">
    <div style="font-size:13px;font-weight:700;flex:1">💬 ${t('waTitle')} — ${monthLabel(m)}</div>
    ${unpaid.length&&canEdit()?`<button class="btn btn-primary btn-sm" onclick="sendAllWA('${m}')">${t('waSendAll')} (${unpaid.length})</button>`:''}
  </div>

  <div style="background:rgba(37,211,102,.06);border:1px solid rgba(37,211,102,.15);border-radius:10px;padding:12px;margin-bottom:14px;font-size:11.5px;color:var(--text2)">
    <b style="color:var(--text)">${t('waAutoNote')}</b> ${t('waAutoDesc')}<br>
    <b>${t('waManualNote')}</b> ${t('waManualDesc')}
  </div>

  ${rows||`<div style="text-align:center;padding:32px;color:var(--i3)">✅ ${monthLabel(m)} ${t('waNoOverdue')}</div>`}

  ${DATA.waLog.length?`
  <div class="sec-hdr">📋 ${t('waSendHistory')}</div>
  <div class="wa-reminder-card"><div class="wa-log">${logRows}</div></div>`:''}
  `;
}

function buildWAMsg(bname,t,mo){
  return `Merhaba ${t.name} Bey/Hanım, ${BL[bname]} ${t.unit} için ${mo} kira ödemeniz (${TL(t.rent)}) henüz görünmüyor. Rica etsek kontrol edip bilgi verebilir misiniz? Teşekkürler.`;
}

function waMsg(bname,tid,mo){
  const t=(DATA.tenants[bname]||[]).find(x=>x.id===tid);
  if(!t) return;
  const msg=buildWAMsg(bname,t,mo);
  const phone=(t.phone||'').replace(/\D/g,'');
  const url=phone?`https://wa.me/${phone}?text=${encodeURIComponent(msg)}`:`https://wa.me/?text=${encodeURIComponent(msg)}`;
  window.open(url,'_blank');
  logWA(bname,tid,mo);
}

function logWA(bname,tid,mo){
  const t=(DATA.tenants[bname]||[]).find(x=>x.id===tid);
  if(!t) return;
  if(!DATA.waLog) DATA.waLog=[];
  DATA.waLog.push({t:new Date().toLocaleString('tr-TR'),bina:BL[bname],unit:t.unit,name:t.name,mo});
  if(DATA.waLog.length > 500) DATA.waLog.shift();
  addHist(`WA gönderildi: ${BL[bname]} ${t.unit} – ${t.name} (${mo})`);
  saveLocal();toast('📝 Kayıt edildi','blue');
}

function sendAllWA(mo){
  BK.forEach(b=>(DATA.tenants[b]||[]).filter(t=>{
    if(!t.active||t.rent===0) return false;
    return isDue(t,mo)||getP(t.id,mo).paid<t.rent;
  }).forEach((t,i)=>{
    setTimeout(()=>{
      const phone=(t.phone||'').replace(/\D/g,'');
      if(phone){
        const msg=buildWAMsg(b,t,mo);
        window.open(`https://wa.me/${phone}?text=${encodeURIComponent(msg)}`,'_blank');
        logWA(b,t.id,mo);
      }
    },i*800);
  }));
}

// ═══════════════════════════════════════════════
// REPORTS
// ═══════════════════════════════════════════════
function renderRep(){
  const m=S.month;
  const secs=BK.map(b=>{
    const ts=sortU((DATA.tenants[b]||[]).filter(t=>t.active&&t.rent>0));
    const exs=((DATA.expenses[b]||{})[m]||[]);
    const paid=paidTotal(b,m),ex=expTotal(b,m),net=paid-ex;
    return `
    <div class="sec-hdr">🏢 ${BL[b]}</div>
    <div class="kpi-grid" style="margin-bottom:10px">
      <div class="kpi-card" style="--kpi-color:var(--blue-l)"><div class="kpi-icon">💰</div><div class="kpi-value">${TL(ts.reduce((s,t)=>s+t.rent,0))}</div><div class="kpi-label">${t('kpiTotalRent')}</div></div>
      <div class="kpi-card" style="--kpi-color:var(--emerald)"><div class="kpi-icon">✅</div><div class="kpi-value">${TL(paid)}</div><div class="kpi-label">${t('kpiCollect')}</div></div>
      <div class="kpi-card" style="--kpi-color:var(--amber)"><div class="kpi-icon">💸</div><div class="kpi-value">${TL(ex)}</div><div class="kpi-label">${t('kpiGider')}</div></div>
      <div class="kpi-card" style="--kpi-color:${net>=0?'var(--emerald)':'var(--rose)'}"><div class="kpi-icon">📈</div><div class="kpi-value">${TL(net)}</div><div class="kpi-label">${t('kpiNet')}</div></div>
    </div>
    <div class="table-card" style="margin-bottom:14px"><div class="table-scroller"><table>
      <thead><tr><th>${t('colUnit')}</th><th>${t('colTenant')}</th><th>${t('colRent')}</th><th>${t('colPaid')}</th><th>${t('colStatus')}</th><th>${t('colDate')}</th></tr></thead>
      <tbody>${ts.map(ten=>{const p=getP(ten.id,m);const st=getStatus(ten,m);
        return `<tr><td>${ten.unit}</td><td>${ten.name}</td><td class="c-blue">${TL(ten.rent)}</td>
          <td class="${p.paid>=(ten.rent||0)?'c-green':p.paid>0?'c-orange':'c-red'}">${TL(p.paid)}</td>
          <td><span class="badge ${st.cls}">${st.lbl}</span></td>
          <td class="c-muted">${p.date?p.date.slice(0,10):'—'}</td></tr>`;}).join('')}
      </tbody>
    </table></div></div>
    <div class="table-card" style="margin-bottom:20px"><div class="table-scroller"><table>
      <thead><tr><th>${t('colCounter')}</th><th>${t('colExpType')}</th><th>${t('colAmount')}</th><th>${t('colDate')}</th></tr></thead>
      <tbody>${exs.map(e=>`<tr><td class="mono">${e.no||'—'}</td><td>${e.tur}</td><td class="c-orange">${TL(e.tutar)}</td><td class="c-muted">${e.tarih||'—'}</td></tr>`).join('')||`<tr><td colspan="4" class="empty-state-text">${t('repNoExpenses')}</td></tr>`}
      ${exs.length?`<tr class="tfoot-row"><td colspan="2">${t('totalExp')}</td><td class="c-orange">${TL(ex)}</td><td></td></tr>`:''}
      </tbody>
    </table></div></div>`;
  }).join('');
  return monthBar()+`
  <div style="display:flex;align-items:center;margin-bottom:14px">
    <h3 style="font-size:14px;flex:1">${t('repTitle')} — ${monthLabel(m)}</h3>
    <button class="btn btn-ghost btn-sm" onclick="window.print()">${t('repPrint')}</button>
    <button class="btn btn-secondary btn-sm" style="margin-left:6px" onclick="exportCSV()">${t('repExportCSV')}</button>
  </div>
  ${secs}`;
}

