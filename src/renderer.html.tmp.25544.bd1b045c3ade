    obPinMismatch:  "❌ PIN'ler eşleşmiyor",
    obPinTooShort:  'PIN en az 4 rakam olmalıdır.',
    obStep3Title:   'İlk Binanızı Oluşturun',
    obStep3Sub:     'Adım 3/3 — Sistemi başlatmak için ilk binanızı ekleyin',
    obBldLabel:     'Bina adı',
    obBldPh:        'Örn: Merkez Bina',
    obFinish:       'Kurulumu Tamamla ✓',
    obImport:       '📥 Mevcut veri içe aktar',
    obCloud:        '☁️ Bulut verisini yükle',
    // Navigation
    navGeneral:'Genel',navBuildings:'Binalar',navTools:'Araçlar',
    navPay:'Tüm Ödemeler',navExp:'Tüm Giderler',navAlper:'Yönetim Hesabı',
