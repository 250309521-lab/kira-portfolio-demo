    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn btn-sm" style="background:rgba(245,158,11,0.18);border:1px solid rgba(245,158,11,0.4);color:var(--amber-l)" onclick="closeMod();setTimeout(seedDemoData,80)">${t('settingsDemoSeed')}</button>
      <button class="btn btn-sm" style="background:rgba(244,63,94,0.12);border:1px solid rgba(244,63,94,0.3);color:var(--rose-l)" onclick="closeMod();setTimeout(clearDemoData,80)">${t('settingsDemoClear')}</button>
    </div>
  </div>

  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('close')}</button>
    ${isA?`<button class="btn btn-primary" onclick="saveSettings_()">${t('save')}</button>`:''}
  </div>`;
}

function saveSettings_(){
  if(!DATA.settings) DATA.settings={};
  DATA.settings.autoSave=document.getElementById('s_auto')?.value==='1';
  const curEl=document.getElementById('s_currency');
  if(curEl) DATA.settings.currency=curEl.value;
  saveLocal();
  closeMod();
  toast(t('settingsSaved'),'green');
}
function restoreBld(bldId){
  const b=(DATA.buildings||[]).find(x=>x.id===bldId);
  if(!b) return;
  b.active=true;
  syncBuildingConstants();
  renderBuildingNav();
  saveLocal();
  addHist('Bina geri yüklendi: '+b.name);
  document.getElementById('modal').innerHTML=tplSettings();
  toast('✅ '+b.name,'green');
}

function tplDashPrefs(){
  const dp=(DATA.settings||{}).dashboard||{};
  const chk=(k,def)=>dp[k]!==undefined?!!dp[k]:def;
  const row=(label,sub,key,def)=>`<div class="ktp-toggle">
    <div><div class="ktp-toggle-label">${label}</div>${sub?`<div class="ktp-toggle-sub">${sub}</div>`:''}</div>
    <label class="sw-wrap"><input type="checkbox" id="dp_${key}" ${chk(key,def)?'checked':''}><span class="sw-slider"></span></label>
  </div>`;
  return `<div class="modal-title">${t('dashPrefTitle')}</div>
  ${row(t('dashPrefCompact'),t('dashPrefCompactSub'),'compact',false)}
  ${row(t('dashPrefWidgets'),t('dashPrefWidgetsSub'),'showWidgets',true)}
  ${row(t('dashPrefKpi'),t('dashPrefKpiSub'),'showKpi',true)}
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('cancel2')}</button>
    <button class="btn btn-primary" onclick="saveDashPrefs()">${t('dashPrefApply')}</button>
  </div>`;
}

function tplResetData(){
  return `<div class="modal-title" style="color:var(--rose-l)">${t('resetDataTitle')}</div>
  <div style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);border-radius:8px;padding:12px 14px;margin-bottom:14px">
    <div style="font-size:12px;font-weight:600;color:var(--rose-l);margin-bottom:6px">${t('resetWarning')}</div>
    <div style="font-size:12px;color:var(--i2);line-height:1.6">${t('resetDesc')}</div>
  </div>
  <div style="font-size:12px;color:var(--i3);margin-bottom:8px">${t('resetConfirmPrompt')}</div>
  <input class="form-input" id="reset-confirm-inp" placeholder="${t('resetConfirmWord')}" autocomplete="off" style="margin-bottom:14px"
    oninput="document.getElementById('btn-do-reset').disabled=this.value!==t('resetConfirmWord')"
    onkeydown="if(event.key==='Enter'&&this.value===t('resetConfirmWord'))_doResetAllData()">
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('cancel')}</button>
    <button class="btn btn-danger" id="btn-do-reset" disabled onclick="_doResetAllData()">🗑</button>
  </div>`;
}

function tplRestoreConfirm(filePath){
  const fname=filePath.split(/[\\/]/).pop();
  return `<div class="modal-title">${t('restoreTitle')}</div>
  <div style="background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25);border-radius:8px;padding:12px 14px;margin-bottom:14px">
    <div style="font-size:12px;font-weight:600;color:var(--amber-l);margin-bottom:6px">${t('restoreWarning')}</div>
    <div style="font-size:12px;color:var(--i2);line-height:1.6">${t('restoreDesc')}</div>
  </div>
  <div style="font-size:12px;color:var(--i3);margin-bottom:14px">
    ${t('restoreFileLabel')} <code style="font-family:var(--mono);background:rgba(0,0,0,.2);border-radius:4px;padding:2px 6px">${fname}</code>
  </div>
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('cancel')}</button>
    <button class="btn btn-secondary btn-sm" onclick="closeMod();doElectronBackup()">${t('save')}</button>
    <button class="btn btn-danger" onclick="_doRestoreFrom(${JSON.stringify(filePath)})">↩</button>
  </div>`;
}

// ═══════════════════════════════════════════════
// IMPORT PROFILES — storage, rendering, helpers
// ═══════════════════════════════════════════════
const _IMPORT_PROFILES_KEY = 'ktp_import_profiles_v1';

const _FIELD_LABELS = {
  date:    'Payment date',
  rent:    'Expected rent',
  payment: 'Paid amount',
  tenant:  'Tenant',
  unit:    'Unit',
  deposit: 'Deposit',
};

function _loadImportProfiles(){
  try{ return JSON.parse(localStorage.getItem(_IMPORT_PROFILES_KEY)||'[]'); }
  catch{ return []; }
}
function _persistImportProfiles(profiles){
  localStorage.setItem(_IMPORT_PROFILES_KEY, JSON.stringify(profiles.slice(0,20)));
}
function _saveImportProfile(profile){
  const profiles = _loadImportProfiles();
  const idx = profiles.findIndex(p=>p.fingerprint===profile.fingerprint);
  if(idx>=0) profiles.splice(idx,1,{...profiles[idx],...profile,lastUsed:new Date().toISOString()});
  else profiles.unshift({...profile,savedAt:new Date().toISOString(),lastUsed:new Date().toISOString()});
  _persistImportProfiles(profiles);
}
function _deleteImportProfile(fp){
  _persistImportProfiles(_loadImportProfiles().filter(p=>p.fingerprint!==fp));
}

function _generateProfileFingerprint(candidate){
  const parts=[];
  if(candidate._ktpVersion) parts.push('v'+candidate._ktpVersion);
  if(candidate._exportedFrom) parts.push(candidate._exportedFrom);
  const blds=Array.isArray(candidate.buildings)?candidate.buildings:[];
  if(blds.length) parts.push(blds.map(b=>b.id||b.name||'').join(',').slice(0,40));
  const tenKeys=Object.keys(candidate.tenants||{}).slice(0,3).join(',');
  if(tenKeys) parts.push(tenKeys);
  return btoa(parts.join('|')).replace(/[^A-Za-z0-9]/g,'').slice(0,16)||'profile_'+Date.now();
}
function _generateProfileTitle(candidate){
  if(candidate._exportedFrom && candidate._exportedFrom!=='v6')
    return (candidate._exportedFrom+' Import').toUpperCase().slice(0,32);
  const blds=Array.isArray(candidate.buildings)?candidate.buildings:[];
  if(blds.length){
    const name=(blds[0].name||blds[0].id||'').trim();
    if(name) return (name+' TEMPLATE').toUpperCase().slice(0,32);
  }
  const tenKey=Object.keys(candidate.tenants||{})[0]||'';
  if(tenKey) return (tenKey+' IMPORT').toUpperCase().slice(0,32);
  return 'Imported Spreadsheet Profile';
}
function _buildProfileMapping(candidate){
  const mapping={};
  const allTens=Object.values(candidate.tenants||{}).reduce((a,v)=>Array.isArray(v)?a.concat(v):a,[]);
  const s=allTens[0]||{};
  if('name' in s||'tenant' in s) mapping.tenant=s.name||s.tenant||'✓';
  if('unit' in s)    mapping.unit   =s.unit||'✓';
  if('rent' in s)    mapping.rent   =s.rent!=null?String(s.rent):'✓';
  if('dep'  in s)    mapping.deposit=s.dep!=null?String(s.dep):'✓';
  if('bas'  in s||'bit' in s) mapping.date='✓';
  const hasPay=Object.keys(candidate.payments||{}).length>0;
  if(hasPay)         mapping.payment='✓';
  return mapping;
}
function _saveImportProfileFromImport(candidate){
  try{
    if(!candidate||typeof candidate!=='object') return;
    const fp       = _generateProfileFingerprint(candidate);
    const mapping  = _buildProfileMapping(candidate);
    const recCount = Object.keys(mapping).length;
    _saveImportProfile({
      fingerprint   : fp,
      displayTitle  : _generateProfileTitle(candidate),
      mapping,
      recognizedCount : recCount,
      totalMappings   : recCount,
      confidence      : recCount>=4?'high':'low',
    });
  }catch(e){ console.error('[profiles]',e); }
}

function renderImportProfiles(){
  const profiles=_loadImportProfiles();
  const badge=(label,bg,color,border)=>
    `<span style="display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:12px;`+
    `font-size:10px;font-weight:600;background:${bg};color:${color};border:1px solid ${border}">${label}</span>`;
  const RECOGNIZED = badge('✓ Recognized','rgba(16,185,129,.1)','var(--emerald-l)','rgba(16,185,129,.25)');
  const HIGH_CONF  = badge('● High Confidence','rgba(59,130,246,.12)','var(--blue-l)','rgba(59,130,246,.25)');
  const LOW_CONF   = badge('● Low Confidence','rgba(245,158,11,.1)','var(--amber-l)','rgba(245,158,11,.25)');

  if(!profiles.length) return `
    <div style="display:flex;flex-direction:column;align-items:center;padding:32px 16px;
        text-align:center;border:1px dashed rgba(255,255,255,.1);border-radius:10px;color:var(--i4)">
      <div style="font-size:32px;margin-bottom:10px">📋</div>
      <div style="font-size:13px;font-weight:600;color:var(--i3);margin-bottom:4px">No saved import profiles yet.</div>
      <div style="font-size:12px;color:var(--i5)">Import a JSON backup to automatically create a profile.</div>
    </div>`;

  return profiles.map(p=>{
    const lastUsed = p.lastUsed ? formatDate(new Date(p.lastUsed).toISOString().slice(0,10)) : '—';
    const confBadge = p.confidence==='high' ? HIGH_CONF : LOW_CONF;
    const fieldRows = Object.entries(p.mapping||{}).map(([k,v])=>`
      <div style="display:flex;align-items:center;gap:8px;padding:3px 0;
          border-bottom:1px solid rgba(255,255,255,.04);font-size:11px">
        <span style="min-width:108px;color:var(--i3);font-weight:500">${_FIELD_LABELS[k]||k}</span>
        <span style="color:var(--i2);font-family:var(--mono);overflow:hidden;text-overflow:ellipsis;
            white-space:nowrap">${v}</span>
      </div>`).join('');
    return `
    <div style="background:var(--s1);border:1px solid rgba(255,255,255,.07);border-radius:10px;
        padding:14px 16px;margin-bottom:10px">
      <div style="display:flex;align-items:flex-start;gap:8px;margin-bottom:10px">
        <div style="flex:1;min-width:0">
          <div style="font-size:13px;font-weight:700;color:var(--i0);letter-spacing:.2px;
              margin-bottom:5px">${p.displayTitle}</div>
          <div style="display:flex;flex-wrap:wrap;gap:4px">${RECOGNIZED}${confBadge}</div>
        </div>
        <button class="btn btn-xs bd-" title="Profili sil"
          onclick="_deleteImportProfile('${p.fingerprint}');const el=document.getElementById('import-profiles-list');if(el)el.innerHTML=renderImportProfiles()">🗑</button>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:10px">
        <div style="background:var(--glass-2);border-radius:6px;padding:8px 10px;text-align:center">
          <div style="font-size:18px;font-weight:700;color:var(--blue-l)">${p.recognizedCount}</div>
          <div style="font-size:10px;color:var(--i5);margin-top:1px">Recognized Cols</div>
        </div>
        <div style="background:var(--glass-2);border-radius:6px;padding:8px 10px;text-align:center">
          <div style="font-size:12px;font-weight:600;color:var(--i2)">${lastUsed}</div>
          <div style="font-size:10px;color:var(--i5);margin-top:1px">Last Used</div>
        </div>
        <div style="background:var(--glass-2);border-radius:6px;padding:8px 10px;text-align:center">
          <div style="font-size:18px;font-weight:700;color:var(--violet-l)">${p.totalMappings}</div>
          <div style="font-size:10px;color:var(--i5);margin-top:1px">Saved Mappings</div>
        </div>
      </div>
      ${fieldRows?`<div style="font-size:10px;color:var(--i4);font-weight:600;text-transform:uppercase;
          letter-spacing:.5px;margin-bottom:5px">Field Map</div>${fieldRows}`:''}
    </div>`;
  }).join('');
}

function panelRemoveTenConfirm(bname, tid){
  const btn=document.getElementById('btn-panel-remove-ten');
  if(!btn) return;
  if(btn.dataset.step==='1'){
    removeTen(bname,tid); closePanel();
  } else {
    btn.dataset.step='1';
    btn.textContent=t('removeConfirmText'); btn.style.background='var(--rose)';
    setTimeout(()=>{ if(btn.dataset.step==='1'){btn.dataset.step='';btn.textContent=t('panelRemoveBtn');btn.style.background='';} },3000);
  }
}

function tplAlperMonth(mo){
  const a=mo?(DATA.alper[mo]||{}):{};
  const monthOpts=ALL_MONTHS.map(m=>`<option value="${m}"${m===mo?' selected':''}>${m}</option>`).join('');
  return `<div class="modal-title">${mo?t('alperMonthEditTitle'):t('alperMonthNewTitle')} — ${t('alperHeroTitle').replace(/^🤝\s*/,'')}</div>
  ${mo
    ?`<div style="font-size:13px;font-weight:600;color:var(--i1);margin-bottom:14px">${monthLabel(mo)}</div><input type="hidden" id="alp_mo" value="${mo}">`
    :`<div class="form-row"><label class="form-label">${t('colMonth')}</label><select class="form-select" id="alp_mo">${monthOpts}</select></div>`}
  <div class="form-grid-2">
    <div class="form-row"><label class="form-label">${t('kpiCollect')} (${currencySymbol()})</label>
      <input class="form-input" id="alp_col" type="number" step="0.01" value="${a.col||0}" onkeydown="if(event.key==='Enter')saveAlperMonth()"></div>
    <div class="form-row"><label class="form-label">${t('kpiGider')} (${currencySymbol()})</label>
      <input class="form-input" id="alp_exp" type="number" step="0.01" value="${a.exp||0}" onkeydown="if(event.key==='Enter')saveAlperMonth()"></div>
  </div>
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeMod()">${t('cancel')}</button>
    ${mo?`<button class="btn btn-danger btn-sm" id="btn-del-alper-mo" onclick="delAlperMoConfirm('${mo}')">🗑</button>`:''}
    <button class="btn btn-primary" onclick="saveAlperMonth()">${t('save')}</button>
  </div>`;
}
function delAlperMoConfirm(mo){
  const btn=document.getElementById('btn-del-alper-mo');
  if(!btn) return;
  if(btn.dataset.step==='1'){
    delete DATA.alper[mo];
    addHist(`Yönetim Hesabı ${mo} silindi`);
    saveLocal(); closeMod(); render();
    toast('🗑 '+mo+' silindi','red');
  } else {
    btn.dataset.step='1'; btn.textContent='⚠️ Evet, sil'; btn.style.background='var(--rose)';
    setTimeout(()=>{if(btn.dataset.step==='1'){btn.dataset.step='';btn.textContent='🗑 Sil';btn.style.background='';}},3000);
  }
}
function saveAlperMonth(){
  const mo=(document.getElementById('alp_mo')?.value||'').trim();
  if(!mo){toast('❌ Ay seçilmedi','red');return;}
  const col=parseFloat(document.getElementById('alp_col')?.value)||0;
  const exp=parseFloat(document.getElementById('alp_exp')?.value)||0;
  const isNew=!DATA.alper[mo];
  DATA.alper[mo]={col,exp,net:col-exp};
  addHist(`Yönetim Hesabı ${mo} ${isNew?'eklendi':'güncellendi'}`);
  saveLocal();
  closeMod();
  render();
  toast(isNew?`✅ ${mo} eklendi`:`✅ ${mo} güncellendi`,'green');
}

function saveDashPrefs(){
  if(!DATA.settings) DATA.settings={};
  DATA.settings.dashboard={
    compact:!!document.getElementById('dp_compact')?.checked,
    showWidgets:!!document.getElementById('dp_showWidgets')?.checked,
    showKpi:!!document.getElementById('dp_showKpi')?.checked,
  };
  saveLocal();
  closeMod();
  document.body.classList.toggle('dash-compact',DATA.settings.dashboard.compact);
  if(S.page==='dash') render();
  toast('✅ Panel tercihleri kaydedildi','green');
}

function importJSON(inp){
  if(PRODUCTION_MODE){ importWizard(inp); return; }
  const f=inp.files[0];
  if(!f) return;
  const r=new FileReader();
  r.onload=e=>{
    try{
      const d=JSON.parse(e.target.result);
      if(d.tenants) DATA.tenants=d.tenants;
      if(d.payments) DATA.payments=d.payments;
      if(d.expenses) DATA.expenses=d.expenses;
      if(d.alper) DATA.alper=d.alper;
      if(d.history) DATA.history=d.history;
      if(d.users) DATA.users=d.users;
      if(d.waLog) DATA.waLog=d.waLog;
      autoRecalc(); ALL_MONTHS=buildAllMonths(); saveLocal(); render(); updateBadges();
      addHist('JSON yedek yüklendi: '+f.name);
      toast(t('jsonLoaded'),'green');
      closeMod();
    }catch(err){toast(t('jsonError'),'red');}
  };
  r.readAsText(f);
}


// ════════════════════════════════════════════════════════════════
// SUPABASE CLOUD SYNC v2
// Pure fetch() — no npm package needed.
// Anon/publishable key is safe in frontend (RLS controls access).
// ════════════════════════════════════════════════════════════════

function _readSupabaseInputs() {
  // Always read the live modal fields first.  Earlier builds only checked
  // DATA.cloud, so the Test button showed "URL/Key girilmemiş" even when the
  // user had typed both values but had not saved them yet.
  const urlField = document.getElementById('supa_url');
  const keyField = document.getElementById('supa_key');
  const liveUrl = (urlField && typeof urlField.value === 'string') ? urlField.value : '';
  const liveKey = (keyField && typeof keyField.value === 'string') ? keyField.value : '';
  const url = (liveUrl || DATA.cloud.supabaseUrl || DATA.cloud.url || '')
    .trim()
    .replace(/\/+$/, '');
  const key = (liveKey || DATA.cloud.supabaseKey || DATA.cloud.key || '')
    .trim();
  return { url, key };
}

function _supaMsg(text, color) {
  const msg = document.getElementById('supa-msg');
  if (msg) { msg.textContent = text; msg.style.color = color || 'var(--i3)'; }
}

function _validSupabaseUrl(url) {
  try {
    const u = new URL(url);
    return u.protocol === 'https:' && /\.supabase\.co$/.test(u.hostname);
  } catch { return false; }
}

function _supaHdrs() {
  const key = _readSupabaseInputs().key || DATA.cloud.supabaseKey || '';
  return {
    'Content-Type':  'application/json',
    'apikey':        key,
    'Authorization': 'Bearer ' + key,
    'Prefer':        'resolution=merge-duplicates,return=minimal',
  };
}

async function _testSupabaseConnection({ save=false } = {}) {
  const { url, key } = _readSupabaseInputs();
  if (!url || !key) {
    _supaMsg('❌ Project URL ve API key zorunludur', 'var(--rose-l)');
    toast('⚠️ URL/Key girilmemiş', 'red');
    return { ok:false, error:'missing' };
  }
  if (!_validSupabaseUrl(url)) {
    _supaMsg('❌ Project URL geçersiz. Örnek: https://xxxx.supabase.co', 'var(--rose-l)');
    toast('⚠️ Supabase URL geçersiz', 'red');
    return { ok:false, error:'bad_url' };
  }

  _supaMsg('🔄 Supabase bağlantısı test ediliyor...', 'var(--i4)');
  try {
    // Use the real REST table used by the app.  If the table is missing we can
    // distinguish schema setup from credential/network problems.
    const r = await fetch(url + '/rest/v1/ktp_sync?select=id&limit=1', {
      headers: { apikey: key, Authorization: 'Bearer ' + key },
      signal: AbortSignal.timeout(10000)
    });
    if (r.status === 401 || r.status === 403) {
      _supaMsg('❌ API key hatalı veya yetkisiz', 'var(--rose-l)');
      toast('❌ Supabase API key kabul edilmedi', 'red');
      return { ok:false, error:'auth' };
    }
    if (r.status === 404) {
      if (save) {
        DATA.cloud.supabaseUrl = url;
        DATA.cloud.supabaseKey = key;
        DATA.cloud.url = url;
        DATA.cloud.mode = 'supabase';
        DATA.cloud.enabled = false;
        saveLocal();
      }
      _supaMsg('⚠️ Supabase bağlantısı OK; ktp_sync tablosu yok. Supabase SQL Editor’da supabase/schema.sql dosyasını çalıştırın.', 'var(--amber-l)');
      toast('⚠️ Supabase schema eksik', 'orange');
      return { ok:false, error:'schema' };
    }
    if (!r.ok) {
      const body = await r.text().catch(()=>'');
      _supaMsg('⚠️ Supabase HTTP ' + r.status + ': ' + body.slice(0,120), 'var(--amber-l)');
      toast('⚠️ Supabase HTTP ' + r.status, 'orange');
      return { ok:false, error:'http_'+r.status };
    }

    if (save) {
      DATA.cloud.supabaseUrl = url;
      DATA.cloud.supabaseKey = key;
      DATA.cloud.url         = url;
      DATA.cloud.mode        = 'supabase';
      DATA.cloud.enabled     = true;
      DATA.cloud.lastSync    = DATA.cloud.lastSync || new Date().toISOString();
      saveLocal();
      updateCloudUI();
    }
    _supaMsg('✅ Bağlantı başarılı. Supabase hazır.', 'var(--emerald-l)');
    toast('✅ Supabase bağlantısı OK', 'green');
    return { ok:true, url, key };
  } catch(e) {
    _supaMsg('❌ Bağlantı hatası: ' + e.message, 'var(--rose-l)');
    toast('❌ Supabase yanıt vermedi', 'red');
    return { ok:false, error:e.message };
  }
}

async function supabaseConnect() {
  const res = await _testSupabaseConnection({ save:true });
  if (res.ok) {
    addHist('Supabase bağlantısı: ' + res.url);
    // Re-render the cloud modal so status/push/pull buttons update immediately.
    const box = document.getElementById('modal-box');
    if (box) box.innerHTML = tplCloud();
  }
}

async function checkSupabaseStatus() {
  await _testSupabaseConnection({ save:false });
}

async function _supaUpsert(table, rows) {
  const url = DATA.cloud.supabaseUrl;
  const key = DATA.cloud.supabaseKey;
  if(!url || !key || !rows.length) return;
  const r = await fetch(url + '/rest/v1/' + table, {
    method:  'POST',
    headers: _supaHdrs(),
    body:    JSON.stringify(rows),
    signal:  AbortSignal.timeout(15000)
  });
  if(!r.ok) {
    const err = await r.text().catch(() => '');
    throw new Error(table + ' upsert failed ' + r.status + ': ' + err.slice(0,120));
  }
}

async function _supaSelect(table, query) {
  const url = DATA.cloud.supabaseUrl;
  const key = DATA.cloud.supabaseKey;
  if(!url || !key) return [];
  const r = await fetch(url + '/rest/v1/' + table + '?' + (query||''), {
    headers: { ..._supaHdrs(), Prefer: 'return=representation' },
    signal:  AbortSignal.timeout(12000)
  });
  if(!r.ok) throw new Error(table + ' select failed ' + r.status);
  return await r.json();
}

// ── 6A-3: Workspace ID — generated once, identifies this customer's Supabase row ─
function _ensureWorkspaceId(){
  if(!DATA.cloud.workspaceId){
    // Existing configured installs get 'ktp_main' so their row key is unchanged.
    // Fresh installs (no cloud URL yet) get a stable UUID for proper isolation.
    DATA.cloud.workspaceId = (DATA.cloud.supabaseUrl || DATA.cloud.url)
      ? 'ktp_main'
      : ((typeof crypto !== 'undefined' && crypto.randomUUID)
          ? crypto.randomUUID()
          : 'ktp-'+Date.now().toString(36)+'-'+Math.random().toString(36).slice(2,9));
    saveLocal();
  }
  return DATA.cloud.workspaceId;
}

// ── 6A-1 + 6A-3: Push now sends _exportEnvelope() and uses workspace_id row key ─
async function supabasePush() {
  const url = DATA.cloud.supabaseUrl;
  const key = DATA.cloud.supabaseKey;
  if(!url || !key) { toast('⚠️ Supabase bağlı değil', 'red'); return false; }
  const wsId = _ensureWorkspaceId();
  const current = await _supaSelect('ktp_sync', 'id=eq.'+encodeURIComponent(wsId)+'&select=version');
  if(current && current.length && current[0].version > (DATA.cloud.serverVersion || 0)){
    toast('⚠️ Sunucu daha yeni (v'+current[0].version+'). Önce Pull yapın.','red');
    return false;
  }
  const record = {
    id:          wsId,
    data_json:   JSON.stringify(_exportEnvelope()),
    version:     (DATA.cloud.serverVersion || 0) + 1,
    updated_at:  new Date().toISOString(),
    app_version: String(KTP_VERSION),
  };
  await _supaUpsert('ktp_sync', [record]);
  DATA.cloud.serverVersion = record.version;
  DATA.cloud.lastSync      = record.updated_at;
  DATA.cloud.enabled       = true;
  DATA.cloud.pendingPush   = false;
  saveLocal();
  return true;
}

// ── 6A-2 + 6A-3: Pull now routes through _importCommit (merge, with rollback) ─
async function supabasePull() {
  const wsId = _ensureWorkspaceId();
  const rows = await _supaSelect('ktp_sync', 'id=eq.'+encodeURIComponent(wsId));
  if(!rows || !rows.length) return false;
  const d = JSON.parse(rows[0].data_json);
  const result = _importCommit(d, 'merge');
  if(!result.ok){
    toast('❌ Pull birleştirme başarısız: '+(result.error||'Bilinmeyen hata'),'red');
    return false;
  }
  // Update cloud metadata after successful merge (not part of data payload)
  DATA.cloud.serverVersion = rows[0].version;
  DATA.cloud.lastSync      = rows[0].updated_at;
  DATA.cloud.enabled       = true;
  DATA.cloud.lastPullAt    = Date.now();
  saveLocal();
  render(); updateBadges();
  return true;
}

// Override cloudSync to route through Supabase when in supabase mode
(function patchCloudSync(){
  const _orig = cloudSync;
  cloudSync = async function(dir='push'){
    const mode = DATA.cloud.mode || 'supabase';
    if(mode === 'supabase' && DATA.cloud.supabaseUrl){
      S.syncing=true; updateCloudUI();
      try{
        if(dir==='push'){
          const _pushOk = await supabasePush();
          if(_pushOk){
            toast('☁️ Supabase push tamam (v'+DATA.cloud.serverVersion+')','blue');
            addHist('Supabase push v'+DATA.cloud.serverVersion);
          }
        } else {
          const ok = await supabasePull();
          if(ok) { toast('☁️ Supabase pull tamam','blue'); addHist('Supabase pull'); }
          else   { toast('ℹ️ Sunucuda veri yok — önce Push yapın','blue'); }
        }
      }catch(e){
        toast('❌ Supabase: '+e.message,'red');
        addHist('Supabase hata ('+dir+'): '+e.message);
        if(dir==='push'){ DATA.cloud.pendingPush=true; saveLocal(); }
      }finally{
        S.syncing=false; updateCloudUI();
      }
      return;
    }
    return _orig(dir);
  };
})();


// ═══════════════════════════════════════════════
// AUTO TIMERS (30s autosave, 5min cloud sync)
// ═══════════════════════════════════════════════
setInterval(()=>{if(DATA.settings?.autoSave){autoRecalc();saveLocal();}},30000);
setInterval(()=>{
  const _supOk=DATA.cloud?.mode==='supabase'&&DATA.cloud?.supabaseUrl&&DATA.cloud?.supabaseKey;
  const _srvOk=DATA.cloud?.url&&DATA.cloud?.token;
  if(DATA.cloud?.enabled&&(_supOk||_srvOk)){
    cloudSync('push').then(()=>{/* auto-sync logged inside cloudSync */}).catch(()=>{});
  }
},300000);

// ── 6B-1: Focus-triggered pull sync ─────────────────────────
// Silently pulls when the window regains focus, if conditions are met.
// Calls supabasePull() directly (not cloudSync) — no toast, no addHist.
// _importCommit merge + rollback behavior is inherited from supabasePull.
let _focusPullActive = false;

async function _focusPull(){
  if(!PRODUCTION_MODE) return;
  if(!DATA.cloud?.enabled) return;
  if(!DATA.cloud?.supabaseUrl || !DATA.cloud?.supabaseKey) return;
  if(S.syncing || _focusPullActive) return;
  if(!currentUser) return;
  if(!navigator.onLine) return;
  _focusPullActive = true;
  try{
    // 6B-2: if a push was deferred due to offline, retry it first (silent)
    if(DATA.cloud?.pendingPush){
      const pushOk = await supabasePush();
      if(!pushOk) return;  // still failing — stay pending, skip pull
      // supabasePush() cleared pendingPush and called saveLocal() on success
    }
    // Normal pull throttled to once per 60s
    if(Date.now() - (DATA.cloud.lastPullAt || 0) < 60000) return;
    await supabasePull();  // lastPullAt and saveLocal handled inside supabasePull
  }catch(e){
    // Silent — focus pull errors must not spam the user
  }finally{
    _focusPullActive = false;
  }
}

window.addEventListener('focus', _focusPull);

// ── 6B-3: Startup pull before first push ────────────────────
// Fires once per app launch immediately after login.
// Merges remote state before the 5-min auto-push can run.
// Borrows _focusPullActive to block concurrent focus pull.
let _startupSyncDone = false;

async function _startupPull(){
  if(_startupSyncDone) return;
  _startupSyncDone = true;  // set before await — prevents re-entry on rapid login
  if(!PRODUCTION_MODE) return;
  if(!DATA.cloud?.enabled) return;
  if(!DATA.cloud?.supabaseUrl || !DATA.cloud?.supabaseKey) return;
  if(S.syncing || _focusPullActive) return;
  if(!navigator.onLine) return;
  _focusPullActive = true;
  try{
    await supabasePull();  // lastPullAt and saveLocal handled inside supabasePull
  }catch(e){
    // Silent — startup pull must not block the user
  }finally{
    _focusPullActive = false;
  }
}

// ═══════════════════════════════════════════════
// INIT — boot-stage instrumented, fully guarded
// ═══════════════════════════════════════════════

// ── Safe mode gate: if flag set, skip data load entirely ───────────────────
if(window.__KTP_SAFE_MODE__){
  __boot('safeMode','ktp_safe_mode flag active — skipping loadLocal');
  // Ensure clean minimal DATA so onboarding renders
  try{
    DATA.users=JSON.parse(JSON.stringify(DEFAULT_USERS));
    DATA.buildings=[];DATA.tenants={};DATA.payments={};DATA.expenses={};
    DATA.initialized=false;
  }catch(e2){}
} else {
  __boot('loadLocal','reading localStorage');
  try{ loadLocal(); __boot('loadLocal.ok'); }
  catch(e){ console.error('[KTP] loadLocal failed',e); __boot('loadLocal.err',String(e)); }
}

// ── DATA integrity check after hydration ───────────────────────────────────
__boot('dataValidate');
try{
  if(!DATA||typeof DATA!=='object') throw new Error('DATA not an object');
  if(!Array.isArray(DATA.users)||DATA.users.length===0){
    console.warn('[BOOT] DATA.users empty or missing — restoring defaults');
    DATA.users=JSON.parse(JSON.stringify(DEFAULT_USERS));
    if(!window._ktpCorruptWarn) window._ktpCorruptWarn='⚠️ Kullanıcı verisi eksik — varsayılan kullanıcılar geri yüklendi.';
  } else {
    // Ensure every user has a pin field (guard against storage from other formats)
    DATA.users=DATA.users.map(function(u){
      if(!u.pin) u.pin=u.pin_hash||'1234';
      return u;
    });
  }
  if(!Array.isArray(DATA.buildings)) DATA.buildings=[];
  if(!DATA.tenants||typeof DATA.tenants!=='object') DATA.tenants={};
  if(!DATA.payments||typeof DATA.payments!=='object') DATA.payments={};
  if(!DATA.expenses||typeof DATA.expenses!=='object') DATA.expenses={};
  if(!Array.isArray(DATA.importHistory)) DATA.importHistory=[];
  if(!Array.isArray(DATA.importSnapshots)) DATA.importSnapshots=[];
  __boot('dataValidate.ok','users:'+DATA.users.length+' blds:'+DATA.buildings.length);
}catch(e){
  console.error('[BOOT] DATA validation failed — safe fallback',e);
  __boot('dataValidate.fallback',String(e));
  try{
    DATA.users=JSON.parse(JSON.stringify(DEFAULT_USERS));
    if(!DATA.buildings) DATA.buildings=[];
    if(!DATA.tenants) DATA.tenants={};
    if(!DATA.payments) DATA.payments={};
    if(!DATA.expenses) DATA.expenses={};
  }catch(e2){}
  window._ktpCorruptWarn='⚠️ Veri bütünlük hatası — güvenli mod ile başlatıldı.';
}

try{ applyTheme(DATA.settings&&DATA.settings.theme); }catch(e){}
try{ applyI18nLogin(); }catch(e){}
try{ document.documentElement.lang=(DATA.settings&&DATA.settings.lang)||'tr'; }catch(e){}

__boot('buildAllMonths');
try{ ALL_MONTHS=buildAllMonths(); __boot('buildAllMonths.ok',ALL_MONTHS.length+' months'); }
catch(e){ console.error('[KTP] buildAllMonths failed',e); __boot('buildAllMonths.err',String(e)); }

__boot('syncBuildingConstants');
try{ syncBuildingConstants(); }catch(e){ console.error('[BOOT] syncBuildingConstants',e); }

__boot('renderBuildingNav');
try{ renderBuildingNav(); }catch(e){ console.error('[BOOT] renderBuildingNav',e); }

__boot('autoRecalc');
try{ autoRecalc(); }catch(e){ console.error('[BOOT] autoRecalc',e); }

__boot('renderUI');
try{
  if(needsOnboarding()){ __boot('renderOnboarding'); renderOnboarding(); }
  else{ __boot('renderLogin'); renderLogin(); }
}catch(e){
  console.error('[KTP] startup render failed',e);
  __boot('renderUI.err',String(e));
  try{ renderLogin(); }catch(e2){}
}
__boot('ready','init block complete');

// ── Startup watchdog: force login if the login-users list is empty after 4s ─
(function(){
  var _wd=setTimeout(function(){
    try{
      var ls=document.getElementById('login-screen');
      var lu=document.getElementById('login-users');
      if(!ls) return;
      if(ls.style.display==='none') return; // already logged in
      if(!lu||!lu.children.length){
        console.warn('[BOOT watchdog] login-users empty at 4s — forcing renderLogin');
        __boot('watchdog.forceLogin');
        renderLogin();
        ls.style.display='flex';
        if(window._ktpCorruptWarn){
          setTimeout(function(){try{toast(window._ktpCorruptWarn,'red');}catch{}window._ktpCorruptWarn=null;},300);
        }
      }
    }catch(e){ console.error('[BOOT watchdog]',e); }
  },4000);
  window.__BOOT_WATCHDOG__=_wd;
})();

// ════════════════════════════════════════════════════════════
// ELECTRON BRIDGE — integrates with main process
// Falls back gracefully when running in browser (non-Electron)
// ════════════════════════════════════════════════════════════
const isElectron = typeof window.electron !== 'undefined' && window.electron.isElectron === true;

// ── Enhanced saveLocal: also push to SQLite audit log ──────
const _origSaveLocal = saveLocal;
function saveLocal(){
  _origSaveLocal();
  // Persist selected month in Electron settings
  if(isElectron && S && S.month){
    window.electron.setSetting('selected_month', S.month).catch(()=>{});
  }
}

// ── Enhanced addHist: also write to SQLite audit log ───────
const _origAddHist = addHist;
function addHist(desc){
  _origAddHist(desc);
  if(isElectron){
    const user = currentUser ? currentUser.name : 'System';
    window.electron.addAudit({t: new Date().toISOString(), user, desc}).catch(()=>{});
  }
}

// ── Enhanced exportJSON: use native Save dialog in Electron ─
const _origExportJSON = exportJSON;
function exportJSON(){
  if(!isElectron){ _origExportJSON(); return; }
  const dataStr = JSON.stringify(_exportEnvelope(), null, 2);
  window.electron.exportJSON(dataStr).then(result => {
    if(result.ok) toast('💾 JSON yedek kaydedildi: ' + result.path, 'green');
    else if(result.ok === false && !result.path) toast(t('exportCancelled'),'orange');
  }).catch(e => toast(t('exportError') + e.message,'red'));
}

// ═══════════════════════════════════════════════════════════════════
// IMPORT/EXPORT CORE  (Phase 5)
// ═══════════════════════════════════════════════════════════════════

// ── _exportEnvelope ─────────────────────────────────────────────
// Builds the versioned export object. Both exportJSON paths use this.
function _exportEnvelope(){
  return {
    _ktpVersion:  KTP_VERSION,
    _exportedAt:  new Date().toISOString(),
    _exportedFrom:'v6',
    initialized:  DATA.initialized,
    buildings:    DATA.buildings,
    tenants:      DATA.tenants,
    payments:     DATA.payments,
    expenses:     DATA.expenses,
    alper:        DATA.alper,
    tanNet:       DATA.tanNet,
    gayNet:       DATA.gayNet,
    history:      DATA.history,
    waLog:        DATA.waLog,
    users:        DATA.users,
    settings:     DATA.settings,
    importHistory: Array.isArray(DATA.importHistory) ? DATA.importHistory : [],
    // importSnapshots intentionally excluded: transient rollback data, too large for export
  };
}

// ── _importParse ─────────────────────────────────────────────────
// Returns {ok, candidate, version, errors[]}
// Pure — no side effects, no DATA writes.
function _importParse(raw){
  try{
    if(typeof raw !== 'string' || !raw.trim())
      return {ok:false, candidate:null, version:0, errors:['Boş veya geçersiz giriş']};
    const d = JSON.parse(raw);
    if(!d || typeof d !== 'object' || Array.isArray(d))
      return {ok:false, candidate:null, version:0, errors:['JSON nesnesi bekleniyordu']};
    const version = typeof d._ktpVersion === 'number' ? d._ktpVersion : 0; // 0 = v5 / legacy
    return {ok:true, candidate:d, version, errors:[]};
  }catch(e){
    return {ok:false, candidate:null, version:0, errors:['JSON ayrıştırma hatası: '+e.message]};
  }
}

// ── _importValidate ──────────────────────────────────────────────
// Returns {ok, errors[], warnings[]}
// Pure — no side effects, no DATA writes.
function _importValidate(candidate){
  const errors=[], warnings=[];
  if(!candidate || typeof candidate !== 'object')
    return {ok:false, errors:['Geçersiz veri yapısı'], warnings};
  // Fatal: no KTP-recognisable fields
  if(!candidate.tenants && !candidate.payments && !candidate.buildings){
    errors.push('Kira Takip yedek dosyası değil (kiracı/ödeme/bina verisi yok)');
    return {ok:false, errors, warnings};
  }
  // Fatal: future schema version this build cannot handle
  if(typeof candidate._ktpVersion === 'number' && candidate._ktpVersion > KTP_VERSION){
    errors.push('Bu yedek daha yeni bir sürümden (v'+candidate._ktpVersion+'). Lütfen uygulamayı güncelleyin.');
    return {ok:false, errors, warnings};
  }
  // Recoverable warnings
  if(!candidate.tenants)   warnings.push('Kiracı verisi eksik');
  if(!candidate.payments)  warnings.push('Ödeme verisi eksik');
  if(!candidate.expenses)  warnings.push('Gider verisi eksik');
  if(!candidate.buildings) warnings.push('Bina listesi yok — v5 formatı olarak işlenecek, binalar kiracı anahtarlarından türetilecek');
  // Tenant integrity: flag negative rent values (will be zeroed on commit)
  if(candidate.tenants && typeof candidate.tenants === 'object'){
    let badRent=0;
    Object.values(candidate.tenants).forEach(arr=>{
      if(!Array.isArray(arr)) return;
      arr.forEach(t=>{ if(typeof t.rent === 'number' && t.rent < 0) badRent++; });
    });
    if(badRent>0) warnings.push(badRent+' kiracıda negatif kira değeri var — aktarım sırasında sıfırlanacak');
  }
  return {ok:errors.length===0, errors, warnings};
}

// ── _importCommit ────────────────────────────────────────────────
// Atomically applies a validated candidate to DATA.
// mode: 'merge' (safe default) | 'overwrite' (destructive, replaces data)
// Returns {ok, error?}
// saveLocal() fires exactly once per call: once on success, once inside rollback.
function _importCommit(candidate, mode){
  const _snapshot = JSON.stringify(DATA); // in-memory rollback point

  function _rollback(errMsg){
    try{
      const recovered = JSON.parse(_snapshot);
      // In-place restore — DATA reference must stay the same object
      Object.keys(DATA).forEach(k=>{ if(!(k in recovered)) delete DATA[k]; });
      Object.keys(recovered).forEach(k=>{ DATA[k]=recovered[k]; });
      syncBuildingConstants();
      try{renderBuildingNav();}catch(e){}
      saveLocal();
    }catch(re){ console.error('[_importCommit] rollback failed',re); }
    return {ok:false, error:errMsg};
  }

  try{

    if(mode==='overwrite'){
      // Replace each field entirely from candidate
      if(candidate.tenants  !==undefined) DATA.tenants  = candidate.tenants;
      if(candidate.payments !==undefined) DATA.payments = candidate.payments;
      if(candidate.expenses !==undefined) DATA.expenses = candidate.expenses;
      if(candidate.alper    !==undefined) DATA.alper    = candidate.alper;
      if(candidate.tanNet   !==undefined) DATA.tanNet   = candidate.tanNet;
      if(candidate.gayNet   !==undefined) DATA.gayNet   = candidate.gayNet;
      if(candidate.history  !==undefined) DATA.history  = candidate.history;
      if(candidate.waLog    !==undefined) DATA.waLog    = candidate.waLog;
      if(candidate.settings !==undefined) DATA.settings = candidate.settings;
      if(candidate.users        !==undefined) DATA.users        = candidate.users; // only in overwrite
      if(Array.isArray(candidate.importHistory)) DATA.importHistory = candidate.importHistory;
      // buildings: use envelope or migrate from v5 tenant keys
      if(candidate.buildings && Array.isArray(candidate.buildings) && candidate.buildings.length){
        DATA.buildings    = candidate.buildings;
        DATA.initialized  = true;
      } else if(candidate.tenants){
        DATA.buildings = Object.keys(candidate.tenants).map((k,i)=>({
          id:k, name:BL[k]||k,
          short:BS[k]||k.replace(/[^A-Z]/g,'').slice(0,3)||String.fromCharCode(65+i),
          color:'', active:true, order:i, metadata:{}
        }));
        DATA.initialized = DATA.buildings.length > 0;
      }

    } else {
      // MERGE: non-destructive accumulation

      // Tenants: per-building-id, dedup by tenant.id
      if(candidate.tenants && typeof candidate.tenants === 'object'){
        Object.keys(candidate.tenants).forEach(bld=>{
          if(!Array.isArray(DATA.tenants[bld])) DATA.tenants[bld]=[];
          (candidate.tenants[bld]||[]).forEach(t=>{
            const safe = (typeof t.rent==='number' && t.rent<0) ? {...t, rent:0} : t;
            const idx = DATA.tenants[bld].findIndex(e=>e.id===safe.id);
            if(idx>=0) DATA.tenants[bld][idx]=safe; else DATA.tenants[bld].push(safe);
          });
        });
      }

      // Payments: keyed by tenantId → month; conservative (keep higher paid)
      if(candidate.payments && typeof candidate.payments === 'object'){
        Object.keys(candidate.payments).forEach(tid=>{
          if(!DATA.payments[tid]) DATA.payments[tid]={};
          Object.keys(candidate.payments[tid]||{}).forEach(mo=>{
            const incoming=candidate.payments[tid][mo];
            const existing=DATA.payments[tid][mo];
            if(!existing||(incoming.paid||0)>(existing.paid||0))
              DATA.payments[tid][mo]=incoming;
          });
        });
      }

      // Expenses: per-building → per-month → array; append non-exact-duplicates
      if(candidate.expenses && typeof candidate.expenses === 'object'){
        Object.keys(candidate.expenses).forEach(bld=>{
          if(!DATA.expenses[bld]) DATA.expenses[bld]={};
          Object.keys(candidate.expenses[bld]||{}).forEach(mo=>{
            if(!Array.isArray(DATA.expenses[bld][mo])) DATA.expenses[bld][mo]=[];
            (candidate.expenses[bld][mo]||[]).forEach(e=>{
              const dup=DATA.expenses[bld][mo].some(x=>
                x.tur===e.tur && x.tutar===e.tutar && x.tarih===e.tarih
              );
              if(!dup) DATA.expenses[bld][mo].push(e);
            });
          });
        });
      }

      // Buildings: add by id, no duplicates
      if(candidate.buildings && Array.isArray(candidate.buildings)){
        const existingIds=new Set((DATA.buildings||[]).map(b=>b.id));
        candidate.buildings.forEach(b=>{
          if(!existingIds.has(b.id))
            DATA.buildings.push({...b, order:DATA.buildings.length});
        });
      } else if(candidate.tenants){
        // v5 migration: add buildings for any tenant-key not already present
        const existingIds=new Set((DATA.buildings||[]).map(b=>b.id));
        Object.keys(candidate.tenants).forEach((k,i)=>{
          if(!existingIds.has(k)){
            DATA.buildings.push({
              id:k, name:BL[k]||k,
              short:BS[k]||k.replace(/[^A-Z]/g,'').slice(0,3)||String.fromCharCode(65+i),
              color:'', active:true, order:DATA.buildings.length, metadata:{}
            });
          }
        });
      }

      // alper/tanNet/gayNet: month-key merge (incoming wins per month — recalced by autoRecalc anyway)
      if(candidate.alper)  Object.assign(DATA.alper,  candidate.alper);
      if(candidate.tanNet) Object.assign(DATA.tanNet, candidate.tanNet);
      if(candidate.gayNet) Object.assign(DATA.gayNet, candidate.gayNet);

      // history: prepend incoming, cap at 200
      if(Array.isArray(candidate.history))
        DATA.history = candidate.history.concat(DATA.history||[]).slice(0,200);

      // waLog: prepend incoming, cap at 500
      if(Array.isArray(candidate.waLog))
        DATA.waLog = candidate.waLog.concat(DATA.waLog||[]).slice(0,500);

      // settings: existing values win (preserve user config)
      if(candidate.settings && typeof candidate.settings === 'object')
        DATA.settings = {...candidate.settings, ...DATA.settings};

      // importHistory: prepend incoming entries not already present (deduplicate by id), cap at 100
      if(Array.isArray(candidate.importHistory)){
        const existingIds=new Set((DATA.importHistory||[]).map(h=>h.id));
        const incoming=candidate.importHistory.filter(h=>!existingIds.has(h.id));
        DATA.importHistory=(incoming.concat(DATA.importHistory||[])).slice(0,100);
      }

      // initialized: never cleared in merge mode; only ever set to true
      if(candidate.initialized===true || (DATA.buildings||[]).some(b=>b.active))
        DATA.initialized = true;

      // users: NOT merged — security boundary; only overwrite mode may replace
    }

    // Mandatory post-commit sequence — order is load-bearing
    syncBuildingConstants();
    renderBuildingNav();
    try{ALL_MONTHS=buildAllMonths();}catch(e){}  // rebuild month range to cover imported data
    autoRecalc();
    saveLocal(); // ← single persistence call per successful commit

    // Retain snapshot for 30-min undo window
    window._lastImportSnapshot = _snapshot;
    window._lastImportTime     = Date.now();

    return {ok:true};

  }catch(e){
    console.error('[_importCommit] error — rolling back', e);
    return _rollback(e.message);
  }
}

// ── Import Wizard (Phase 5) ─────────────────────────────────
let _importCandidate = null;
let _importWizardOpts = {};

async function importWizard(inp, opts){
  opts = opts || {};
  _importWizardOpts = opts;
  if(isElectron){
    let result;
    try{ result = await window.electron.importJSON(); }
    catch(e){ toast('❌ Dosya hatası: '+e.message,'red'); return; }
    if(!result||!result.ok){ if(!result||!result.canceled) toast('❌ '+(result&&result.error||'Dosya okunamadı'),'red'); return; }
    _importWizardProcess(result.data, opts);
  } else if(inp && inp.files && inp.files[0]){
    const f=inp.files[0];
    const r=new FileReader();
    r.onload=e=>_importWizardProcess(e.target.result, opts);
    r.readAsText(f);
  } else if(opts.fromOnboarding){
    const picker=document.createElement('input');
    picker.type='file'; picker.accept='.json';
    picker.onchange=()=>{
      if(!picker.files||!picker.files[0]) return;
      const r=new FileReader();
      r.onload=e=>_importWizardProcess(e.target.result, opts);
      r.readAsText(picker.files[0]);
    };
    picker.click();
  }
}

function _importWizardProcess(rawStr, opts){
  const parsed=_importParse(rawStr);
  if(!parsed.ok){
    const msg=parsed.errors.join(', ');
    if(opts.fromOnboarding){
      const err=document.getElementById('ob-err2');
      if(err){ err.textContent='❌ '+msg; setTimeout(()=>{ err.textContent=''; },4000); }
    } else { toast('❌ '+msg,'red'); }
    return;
  }
  const validated=_importValidate(parsed.candidate);
  if(!validated.ok){
    const msg=validated.errors.join('; ');
    if(opts.fromOnboarding){
      const err=document.getElementById('ob-err2');
      if(err){ err.textContent='❌ '+msg; setTimeout(()=>{ err.textContent=''; },4000); }
    } else { toast('❌ '+msg,'red'); }
    return;
  }
  _importCandidate=parsed.candidate;
  _importShowPreview(parsed.candidate, parsed.version, validated.warnings, opts);
}

function _importShowPreview(candidate, version, warnings, opts){
  const bldCount=Array.isArray(candidate.buildings)?candidate.buildings.length
               :(candidate.tenants?Object.keys(candidate.tenants).length:0);
  const tenCount=candidate.tenants
    ?Object.values(candidate.tenants).reduce((s,a)=>s+(Array.isArray(a)?a.length:0),0):0;
  const payCount=candidate.payments
    ?Object.values(candidate.payments).reduce((s,a)=>s+Object.keys(a||{}).length,0):0;
  const vLabel=version>=6?'v6 (Yeni format)':version>0?'v'+version:'v5 / Eski format';
  const overlay=document.getElementById('modal-overlay');
  const modal=document.getElementById('modal');
  if(!overlay||!modal) return;
  modal.innerHTML=`
    <div style="padding:24px;max-width:480px;margin:0 auto">
      <div style="font-size:18px;font-weight:700;color:var(--i0);margin-bottom:16px">📥 Veri İçe Aktarma</div>
      <div style="background:var(--s1);border-radius:10px;padding:14px;margin-bottom:14px;
           display:grid;grid-template-columns:1fr 1fr;gap:10px">
        <div><div style="font-size:11px;color:var(--i4)">Format</div>
             <div style="font-weight:600;color:var(--i1)">${vLabel}</div></div>
        <div><div style="font-size:11px;color:var(--i4)">Bina</div>
             <div style="font-weight:600;color:var(--i1)">${bldCount}</div></div>
        <div><div style="font-size:11px;color:var(--i4)">Kiracı</div>
             <div style="font-weight:600;color:var(--i1)">${tenCount}</div></div>
        <div><div style="font-size:11px;color:var(--i4)">Ödeme Kaydı</div>
             <div style="font-weight:600;color:var(--i1)">${payCount}</div></div>
      </div>
      ${warnings.length?`<div style="background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.3);
          border-radius:8px;padding:10px;margin-bottom:14px;font-size:12px;color:var(--amber-l)">
          ⚠️ ${warnings.join('<br>⚠️ ')}</div>`:''}
      <div style="margin-bottom:16px">
        <div style="font-size:12px;color:var(--i3);margin-bottom:8px">Aktarım modu:</div>
        ${opts.fromOnboarding
          ?`<input type="hidden" id="wiz-mode-hidden" value="overwrite">
            <div style="font-size:12px;color:var(--i4)">İlk kurulum: üzerine yazma modu kullanılacak.</div>`
          :`<label style="display:flex;align-items:center;gap:8px;margin-bottom:6px;cursor:pointer">
              <input type="radio" name="wiz-mode" value="merge" checked>
              <span style="font-size:13px">Birleştir <span style="color:var(--i4);font-size:11px">— Mevcut veriyi koru, eksikleri ekle</span></span>
            </label>
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
              <input type="radio" name="wiz-mode" value="overwrite">
              <span style="font-size:13px">Üzerine Yaz <span style="color:var(--rose-l);font-size:11px">— Tüm mevcut veriyi siler</span></span>
            </label>`}
      </div>
      <div style="display:flex;gap:10px">
        <button class="btn btn-ghost" style="flex:1" onclick="_importWizardCancel()">İptal</button>
        <button class="btn btn-primary" style="flex:2" onclick="_importWizardConfirm()">✓ İçe Aktar</button>
      </div>
    </div>
  `;
  overlay.classList.add('open');
}

function _importWizardCancel(){
  _importCandidate=null; _importWizardOpts={};
  closeMod();
}

function _importWizardConfirm(){
  if(!_importCandidate){ closeMod(); return; }
  const opts=_importWizardOpts;
  let mode='merge';
  const hidden=document.getElementById('wiz-mode-hidden');
  if(hidden){ mode=hidden.value; }
  else { const r=document.querySelector('input[name="wiz-mode"]:checked'); if(r) mode=r.value; }
  const result=_importCommit(_importCandidate, mode);
  if(result.ok) _saveImportProfileFromImport(_importCandidate);
  _importCandidate=null; _importWizardOpts={};
  closeMod();
  if(!result.ok){
    toast('❌ İçe aktarma başarısız: '+(result.error||'Bilinmeyen hata'),'red');
    renderBuildingNav();
    return;
  }
  if(opts.fromOnboarding){
    _obPin='';
    const obScr=document.getElementById('ob-screen');
    if(obScr) obScr.style.display='none';
    renderLogin();
    toast('✅ Veri aktarıldı. Giriş yapabilirsiniz.','green');
  } else {
    ALL_MONTHS=buildAllMonths();
    render(); updateBadges();
    toast('✅ Veri aktarıldı ('+mode+')','green');
  }
}

// ── Enhanced importJSON: use native Open dialog in Electron ─
const _origImportJSON_renderer = typeof importJSON === 'function' ? importJSON : null;
function importJSON(inp){
  if(PRODUCTION_MODE){ importWizard(inp); return; }
  if(!isElectron){ if(_origImportJSON_renderer) _origImportJSON_renderer(inp); return; }
  window.electron.importJSON().then(result => {
    if(!result.ok){ if(!result.error) return; toast('❌ ' + result.error,'red'); return; }
    try{
      const d = JSON.parse(result.data);
      // Schema validation before committing
      if(!d||typeof d!=='object'){toast('❌ Geçersiz yedek: JSON nesnesi değil','red');return;}
      if(!d.tenants&&!d.payments&&!d.users){toast('❌ Bu Kira Takip yedek dosyası değil','red');return;}
      const miss=[];
      if(!d.tenants)miss.push('kiracılar');if(!d.payments)miss.push('ödemeler');if(!d.expenses)miss.push('giderler');
      if(miss.length) toast('⚠️ Eksik bölümler: '+miss.join(', '),'orange');
      // Snapshot for recovery
      window._lastImportSnapshot=JSON.stringify(DATA);
      if(d.tenants)  DATA.tenants  = d.tenants;
      if(d.payments) DATA.payments = d.payments;
      if(d.expenses) DATA.expenses = d.expenses;
      if(d.alper)    DATA.alper    = d.alper;
      if(d.history)  DATA.history  = d.history;
      if(d.users)    DATA.users    = d.users;
      if(d.waLog)    DATA.waLog    = d.waLog;
      autoRecalc(); ALL_MONTHS=buildAllMonths(); saveLocal(); render(); updateBadges();
      addHist('JSON yedek yüklendi');
      toast(t('jsonLoaded'),'green');
      closeMod();
    }catch(err){ toast(t('jsonError')+': '+err.message,'red'); }
  });
}

