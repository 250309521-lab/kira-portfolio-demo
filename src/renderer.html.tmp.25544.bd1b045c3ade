    </div>

    <div style="font-size:10.5px;color:var(--i5);line-height:1.8;font-family:var(--mono)">
      ${info.electronVersion?`Electron: ${info.electronVersion} · `:''}
      Node.js: ${info.nodeVersion||'browser'} ·
      Platform: ${info.platform||'web'} ·
      ${info.isDev?'<span style="color:var(--amber-l)">DEV MODE</span>':'Production'}
    </div>
    ${lastSync&&lastSync!=='—'?`<div style="font-size:10.5px;color:var(--i5);margin-top:4px">
      ${t('aboutLastSync')} <span style="font-family:var(--mono)">${lastSync}</span>
    </div>`:''}

    <div style="
      margin-top:20px;
      background:linear-gradient(135deg,rgba(59,130,246,0.05) 0%,rgba(99,102,241,0.03) 100%);
      border:1px solid rgba(59,130,246,0.12);
      border-radius:10px;
      padding:16px 18px;
      display:flex;flex-direction:column;gap:6px;
    ">
      <div style="font-size:12px;font-weight:600;color:var(--i2);margin-bottom:4px">© 2026 Kira Takip Pro — Tüm Hakları Saklıdır</div>
      <div style="font-size:11px;color:var(--i4);line-height:1.7">
        Bu yazılım <strong style="color:var(--i2)">Hamidreza Alizadeh</strong> tarafından tasarlanmış ve geliştirilmiştir.
        Tescilli ticari bir üründür.
      </div>
      <div style="font-size:10.5px;color:var(--i5);line-height:1.7">
        Yazılı izin alınmaksızın kopyalanamaz, dağıtılamaz, değiştirilemez veya alt lisans verilemez.
        Yetkisiz kullanım ve dağıtım hukuki yaptırıma tabidir.
      </div>
      <div style="font-size:10px;color:var(--i5);margin-top:2px;font-family:var(--mono)">support@kiratakippro.com</div>
    </div>
  </div>`;
}

async function doElectronBackup(){
  if(!isElectron) return;
  const result=await window.electron.createBackup('manual');
  if(result){
    const sz=result.size?` (${Math.round(result.size/1024)} KB)`:'';
    toast('💾 Yedek alındı: '+result.filename+sz,'green');
  } else toast('❌ Yedek alınamadı','red');
}

function doRestoreFrom(filePath){
  openMod('restore-confirm', filePath);
}
async function _doRestoreFrom(filePath){
  closeMod();
  const res=await window.electron.restoreBackup(filePath);
  if(res.ok) toast('✅ Geri yüklendi — uygulamayı yeniden başlatın','green');
  else toast('❌ '+res.error,'red');
}

async function restoreElectronState(){
  if(!isElectron) return;
  try{
    __boot('restoreElectronState','awaiting IPC getSetting');
    const _timeout=new Promise(function(res){setTimeout(res,3000);});
    const mo=await Promise.race([window.electron.getSetting('selected_month'),_timeout]);
    if(mo&&MONTHS.some(n=>mo.startsWith(n+' '))){ALL_MONTHS=buildAllMonths([mo]);S.month=mo;}
    __boot('restoreElectronState.ok',mo||'no month');
  }catch(e){ console.warn('[BOOT] restoreElectronState failed',e); }
}

// ── Patch initApp to add About sidebar item ───────────────────────────────────
const _origInitApp2=initApp;
function initApp(){
  _origInitApp2();
  restoreElectronState().then(()=>render());
  addAboutToSidebar();
  if(window._ktpCorruptWarn){ setTimeout(()=>toast(window._ktpCorruptWarn,'red'),500); window._ktpCorruptWarn=null; }
}

function addAboutToSidebar(){
  const footer=document.querySelector('.sb-footer');
  if(!footer||document.getElementById('nb-about')) return;
  const btn=document.createElement('button');
  btn.className='nav';btn.id='nb-about';
  btn.innerHTML=`<span class="ni">ℹ</span>${t('aboutBtn')}`;
  btn.onclick=()=>{
    document.querySelectorAll('.nav').forEach(n=>n.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('topbar-title').textContent=t('aboutPage');
    renderAbout();
  };
  footer.insertBefore(btn,footer.firstChild);
}

// ── Patch render to include analytics ────────────────────────────────────────
const _origRender2=render;
function render(){
  const c=document.getElementById('content');
  if(!c) return;
  c.className='';void c.offsetWidth;c.className='page-enter';
  const pages={
    dash:renderDash,pay:renderPay,exp:renderExp,
    alper:renderAlper,charts:renderCharts,wa:renderWA,
    rep:renderRep,hist:renderHist,viz:renderViz,
    analytics:renderAnalytics,bld:()=>renderBld(S.bld)
  };
  c.innerHTML=(pages[S.page]||renderDash)();
  if(S.page==='charts') initCharts();
  if(S.page==='viz') initViz();
  if(S.page==='analytics') setTimeout(initAnalyticsCharts,100);
  // Scroll active month into view
  setTimeout(()=>{
    const active=document.querySelector('.mbtn.active');
    if(active) active.scrollIntoView({behavior:'instant',block:'nearest',inline:'center'});
  },30);
  if(DATA.settings?.autoSave) saveLocal();
}

// ── Electron bridge status ────────────────────────────────────────────────────
if(isElectron){
  console.log('[Electron] Bridge active. v5.1.0');
} else {
  console.log('[Browser] Running in browser mode');
}



/* ═══════════════════════════════════════════════════════
   HOTFIX v5.1.5 — navigation/init/render stability
   Fixes recursive patched goto/initApp and blank pages.
═══════════════════════════════════════════════════════ */
try{(function(){
  function safePage(fn){
    try { return fn ? fn() : renderDash(); }
    catch(e){
      console.error('[KTP render error]', e);
      return `<div style="padding:24px;border:1px solid rgba(244,63,94,.35);background:rgba(244,63,94,.08);border-radius:14px;color:#fff">
        <h2 style="margin-bottom:8px">⚠️ Sayfa yüklenemedi</h2>
        <p style="color:#a8b8d8;margin-bottom:10px">Bu bölüm render edilirken hata oluştu. Uygulama durmadı; başka menüleri kullanabilirsiniz.</p>
        <pre style="white-space:pre-wrap;color:#fb7185;font-size:12px">${String(e && (e.stack||e.message) || e).replace(/[<>&]/g, ch=>({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]))}</pre>
      </div>`;
    }
  }

  window.goto = goto = function(page,bld){
    S.page = page || 'dash';
    S.bld = bld || null;
    if(S.bld && !(DATA.buildings||[]).some(b=>b.id===S.bld&&b.active)){
      S.page='dash'; S.bld=null;
    }
    S.search = '';
    S.filter = '';
    document.querySelectorAll('.nav').forEach(n=>n.classList.remove('active'));
    const idMap = {
      dash:'nb-dash', pay:'nb-pay', exp:'nb-exp', alper:'nb-alper',
      charts:'nb-charts', wa:'nb-wa', rep:'nb-rep', hist:'nb-hist', viz:'nb-viz',
      analytics:'nb-analytics', bld:bld ? 'nb-'+bldDomId(bld) : ''
    };
    const activeId = idMap[S.page];
    const activeEl = activeId ? document.getElementById(activeId) : null;
    if(activeEl) activeEl.classList.add('active');
    const titles = {
      dash:'📊 Dashboard', pay:'💳 Tüm Ödemeler', exp:'💸 Tüm Giderler',
      alper:'🤝 Yönetim Hesabı', charts:'📈 Grafikler', wa:'💬 WhatsApp',
      rep:'📄 Raporlar', hist:'🕐 Geçmiş', viz:'🌐 3D Görünüm',
      analytics:'◗ Analitik', bld:'🏢 '+(BL[bld]||bld||'')
    };
    const t = document.getElementById('topbar-title');
    if(t) t.textContent = titles[S.page] || S.page;
    render();
    updateBadges();
  };

  window.render = render = function(){
    const c = document.getElementById('content');
    if(!c) return;
    if(S.page==='bld' && S.bld && !(DATA.buildings||[]).some(b=>b.id===S.bld&&b.active)){
      S.page='dash'; S.bld=null;
    }
    if(!S.month||!ALL_MONTHS.includes(S.month)){const _nm=MONTHS[new Date().getMonth()]+' '+new Date().getFullYear();S.month=ALL_MONTHS.includes(_nm)?_nm:(ALL_MONTHS[ALL_MONTHS.length>>1]||ALL_MONTHS[0]);}
    const _pk=S.page+(S.bld||'');
    const _pc=_pk!==(render._pk||''); render._pk=_pk;
    c.className='';
    if(_pc){ void c.offsetWidth; c.className='page-enter'; }
    const pages = {
      dash:renderDash, pay:renderPay, exp:renderExp, alper:renderAlper,
      charts:renderCharts, wa:renderWA, rep:renderRep, hist:renderHist,
      viz:renderViz, analytics: (typeof renderAnalytics==='function'?renderAnalytics:renderCharts),
      bld:()=>renderBld(S.bld)
    };
    c.innerHTML = safePage(pages[S.page] || renderDash);
    const _dpb=document.getElementById('btn-dash-prefs'); if(_dpb) _dpb.style.display=S.page==='dash'?'':'none';
    try { if(S.page==='charts') initCharts(); } catch(e){ console.error(e); }
    try { if(S.page==='viz') initViz(); } catch(e){ console.error(e); }
    try { if(S.page==='analytics' && typeof initAnalyticsCharts==='function') setTimeout(initAnalyticsCharts,100); } catch(e){ console.error(e); }
    setTimeout(()=>{
      const active=document.querySelector('.mbtn.active');
      if(active) active.scrollIntoView({behavior:'instant',block:'nearest',inline:'nearest'});
    },30);
    try { if(DATA.settings && DATA.settings.autoSave) saveLocal(); } catch(e){ console.error(e); }
  };

  window.initApp = initApp = function(){
    if(!currentUser){
      const users = DATA.users && DATA.users.length ? DATA.users : DEFAULT_USERS;
      currentUser = users.find(u=>u.role==='admin') || users[0] || {name:'Admin',role:'admin',avatar:'A',color:'#4a8af4'};
    }
    const login = document.getElementById('login-screen');
    if(login) login.style.display = 'none';
    const av=document.getElementById('sb-uav');
    const nm=document.getElementById('sb-uname');
    const rl=document.getElementById('sb-urole');
    if(av){ av.textContent=currentUser.avatar || (currentUser.name||'U').slice(0,1); av.style.background=currentUser.color||'#4a8af4'; }
    if(nm) nm.textContent=currentUser.name || t('colUser');
    if(rl) rl.textContent=roleLabel(currentUser.role||'viewer');
    ['btn-pay','btn-exp','btn-ten','btn-addpay','btn-addexp','btn-addten'].forEach(id=>{
      const el=document.getElementById(id); if(el) el.style.display = canEdit() ? '' : 'none';
    });
    const nbUsers=document.getElementById('nb-users');
    if(nbUsers) nbUsers.style.display = isAdmin() ? '' : 'none';
    try { updateCloudUI(); } catch(e){ console.error(e); }
    try { addAnalyticsNav && addAnalyticsNav(); } catch(e){}
    try { addAboutToSidebar && addAboutToSidebar(); } catch(e){}
    try { renderBuildingNav(); } catch(e){ console.error('[renderBuildingNav]',e); }
    __boot('initApp.render');
    try { render(); } catch(e){ console.error('[initApp] render failed',e); }
    try { updateBadges(); } catch(e){}
    if(!DATA.history?.length) try{ addHist('Giriş yapıldı'); }catch(e){}
    if(typeof window.__BOOT_WATCHDOG__!=='undefined') clearTimeout(window.__BOOT_WATCHDOG__);
    __boot('initApp.done');
    if(isElectron && typeof restoreElectronState==='function'){
      restoreElectronState().then(function(){ try{ render(); }catch(e){} }).catch(function(){});
    }
  };

  // Start app safely. Show login if no user selected; auto-enter admin if login screen is not usable.
  setTimeout(()=>{
    try{
      const login = document.getElementById('login-screen');
      const content = document.getElementById('content');
      if(login && login.style.display !== 'none'){
        // login remains available; do not force if user list rendered
        if(!document.getElementById('login-users')?.innerHTML){ renderLogin(); }
      }
      // If a previous broken run hid login but content is empty, recover by entering admin.
      if(content && !content.innerHTML.trim() && (!login || login.style.display==='none')) initApp();
    }catch(e){ console.error('[KTP startup recovery]',e); }
  },150);
})();}catch(e){console.error('[KTP HOTFIX v5.1.5 init error — render/goto/initApp may be unprotected]',e);}


/* ═══════════════════════════════════════════════════════
   HOTFIX v5.1.5b — remove recursive save/addHist/renderDash
═══════════════════════════════════════════════════════ */
try{(function(){
  window.saveLocal = saveLocal = function(){
    try{
      localStorage.setItem(LSKEY, JSON.stringify(DATA));
      const t=new Date();
      const lbl=document.getElementById('save-lbl');
      if(lbl){ lbl.textContent=`${window.t('saved')} ${String(t.getHours()).padStart(2,'0')}:${String(t.getMinutes()).padStart(2,'0')}`; lbl.style.color=''; }
      if(typeof window.electron!=='undefined' && window.electron && window.electron.isElectron && S && S.month){
        window.electron.setSetting('selected_month', S.month).catch(()=>{});
      }
    }catch(e){
      console.error('[saveLocal]',e);
      const lbl=document.getElementById('save-lbl');
      if(lbl){ lbl.textContent='⚠ Kayıt başarısız!'; lbl.style.color='var(--rose-l)'; }
      const isQuota=e && (e.name==='QuotaExceededError'||e.code===22||e.code===1014);
      toast(isQuota?'💾 Depolama dolu — veriler kaydedilemedi! JSON Yedek alın.':'💾 Kayıt hatası: '+e.message,'red');
    }
  };

  window.addHist = addHist = function(desc){
    try{
      const user=currentUser?currentUser.name:'Sistem';
      if(!DATA.history) DATA.history=[];
      DATA.history.unshift({t:new Date().toLocaleString('tr-TR'),desc,user});
      if(DATA.history.length>500) DATA.history.length=500;
      saveLocal();
      if(typeof window.electron!=='undefined' && window.electron && window.electron.isElectron){
        window.electron.addAudit({t:new Date().toISOString(),user,desc}).catch(()=>{});
      }
    }catch(e){ console.error('[addHist]',e); }
  };

  window.renderDash = renderDash = function(){
    const m=S.month;
    let tRent=0,tPaid=0,tExp=0;
    const brows=BK.map(b=>{
      const allT=safeTens(b);
      const ts=allT.filter(t=>t.active&&t.rent>0);
      const vacantInBld=allT.filter(t=>!t.active).length;
      const rent=ts.reduce((s,t)=>s+t.rent,0);
      const paid=paidTotal(b,m);
      const ex=expTotal(b,m);
      const net=paid-ex;
      const unpaid=ts.filter(t=>getP(t.id,m).paid<t.rent).length;
      const partial=ts.filter(t=>{const p=getP(t.id,m);return p.paid>0&&p.paid<t.rent;}).length;
      tRent+=rent;tPaid+=paid;tExp+=ex;
      const pct=rent>0?Math.min(100,Math.round(paid/rent*100)):0;
      return `<tr class="cp" onclick="goto('bld','${b}')">
        <td><b>${BL[b]}</b></td>
        <td class="c-muted">${ts.length}${vacantInBld?` <span style="font-size:10px;color:var(--i4)">(+${vacantInBld} ${t('dashVacant')})</span>`:''}</td>
        <td class="c-blue fw-700">${TL(rent)}</td>
        <td><div class="${paid>=rent?'c-green':'c-orange'} fw-700">${TL(paid)}</div><div class="prog-bar"><div class="prog-fill" style="width:${pct}%;background:${paid>=rent?'var(--emerald)':'var(--amber)'}"></div></div></td>
        <td class="${unpaid?'c-red':'c-green'} fw-700">${unpaid?`⚠️ ${unpaid}${partial?` <span style="font-size:10px;color:var(--amber-l)">(${partial}k)</span>`:''}`:'✅'}</td>
        <td class="${ex===0&&ts.length?'c-muted':'c-orange'}">${TL(ex)}${ex===0&&ts.length?` <span style="font-size:10px;color:var(--i4)" title="Bu ay gider girilmedi">—</span>`:''}</td>
        <td class="${net>=0?'c-green':'c-red'} fw-700">${TL(net)}</td>
        <td><span class="badge b-blue">${t('btnView')}</span></td>
      </tr>`;
    }).join('');

    const net=tPaid-tExp;
    let overdue='',overdueCount=0;
    BK.forEach(b=>safeTens(b).filter(t=>isDue(t,m)).forEach(t=>{
      overdueCount++;
      overdue+=`<tr><td><b>${BL[b]}</b></td><td>${t.unit}</td><td><span class="blink">🔴</span> <b>${t.name}</b></td><td class="c-orange">${window.t('dayOfMonth')} ${t.gun}.</td><td class="c-red fw-700">${TL(t.rent)}</td><td>${canEdit()?`<button class="btn btn-xs btn-primary" onclick="openMod('pay-add','${b}:${t.id}')">${window.t('panelPayBtn')}</button>`:''} <button class="btn btn-xs btn-ghost" onclick="waMsg('${b}','${t.id}','${m}')">💬 WA</button></td></tr>`;
    }));

    let alerts='',alertCount=0;
    const now=new Date();
    BK.forEach(b=>safeTens(b).filter(t=>t.active&&t.bit).forEach(t=>{
      const bit=new Date(t.bit); const days=Math.ceil((bit-now)/864e5);
      if(days>=0&&days<=60){ alertCount++; alerts+=`<tr><td><b>${BL[b]}</b></td><td>${t.unit}</td><td>${t.name}</td><td>${formatDate(t.bit)}</td><td class="${days<=30?'c-red':'c-orange'} fw-700">${days} ${window.t('daysLabel')}</td><td class="c-blue">${TL(t.rent)}</td></tr>`; }
    }));

    const partialN=BK.reduce((s,b)=>s+safeTens(b).filter(t=>{const p=getP(t.id,m);return t.active&&t.rent>0&&p.paid>0&&p.paid<t.rent;}).length,0);
    const vacantN=BK.reduce((s,b)=>s+safeTens(b).filter(t=>!t.active).length,0);
    const noExpBlds=BK.filter(b=>safeTens(b).some(t=>t.active&&t.rent>0)&&expTotal(b,m)===0).length;
    const dChips=[];
    if(partialN) dChips.push(`<span class="op-chip op-chip-orange" style="cursor:pointer" onclick="gotoFiltered('pay','partial')">⋯ ${partialN} ${t('dashPartialChip')}</span>`);
    if(vacantN) dChips.push(`<span class="op-chip op-chip-gray" style="cursor:pointer" onclick="gotoVacant()">◌ ${vacantN} ${t('dashVacantChip')}</span>`);
    if(noExpBlds) dChips.push(`<span class="op-chip op-chip-blue" style="cursor:pointer" onclick="goto('exp')">📋 ${noExpBlds} ${t('dashNoExpChip')}</span>`);
    if(alertCount) dChips.push(`<span class="op-chip op-chip-orange">📅 ${alertCount} ${t('dashContractChip')}</span>`);
    const dashAlertStrip=dChips.length?`<div class="op-alerts">${dChips.join('')}</div>`:'';

    const dp=(DATA.settings||{}).dashboard||{};
    const showWidgets=dp.showWidgets!==false;
    const showKpi=dp.showKpi!==false;
    const compact=dp.compact===true;
    document.body.classList.toggle('dash-compact',compact);
    const smart=showWidgets&&(typeof renderSmartWidgets==='function')?renderSmartWidgets(m):'';
    return monthBar()+smart+dashAlertStrip+`
      <div class="kpi-grid"${showKpi?'':' style="display:none"'}>
        <div class="kpi-card" style="--kpi-color:var(--blue-l)"><div class="kpi-icon">💰</div><div class="kpi-value">${TL(tRent)}</div><div class="kpi-label">${t('dashTotalRentLbl')} — ${monthLabel(m)}</div></div>
        <div class="kpi-card" style="--kpi-color:var(--emerald-l)"><div class="kpi-icon">✅</div><div class="kpi-value">${TL(tPaid)}</div><div class="kpi-label">${t('dashCollectedLbl')}</div><div class="card-sub c-green">${tRent>0?Math.round(tPaid/tRent*100):0}% ${t('dashCollectedPct')}</div></div>
        <div class="kpi-card" style="--kpi-color:var(--rose-l)"><div class="kpi-icon">❌</div><div class="kpi-value">${TL(tRent-tPaid)}</div><div class="kpi-label">${t('dashUncollectedLbl')}</div></div>
        <div class="kpi-card" style="--kpi-color:var(--amber-l)"><div class="kpi-icon">💸</div><div class="kpi-value">${TL(tExp)}</div><div class="kpi-label">${t('dashTotalExpLbl')}</div></div>
        <div class="kpi-card" style="--kpi-color:${net>=0?'var(--emerald-l)':'var(--rose-l)'}"><div class="kpi-icon">📈</div><div class="kpi-value">${TL(net)}</div><div class="kpi-label">${t('dashNetLbl')}</div></div>
      </div>
      <div class="sec-hdr">🏢 ${t('dashBldSummaryHdr')} — ${monthLabel(m)}</div>
      <div class="table-card"><div class="table-scroller"><table><thead><tr><th>${t('colBuilding')}</th><th>${t('colTenant')}</th><th>${t('colRent')}</th><th>${t('colCollection')}</th><th>${t('colDebt')}</th><th>${t('kpiGider')}</th><th>${t('colNet')}</th><th></th></tr></thead><tbody>${brows}</tbody></table></div></div>
      ${overdue?`<div class="sec-hdr">${t('dashOverdue')}</div><div class="table-card"><div class="table-scroller"><table><thead><tr><th>${t('colBuilding')}</th><th>${t('colUnit')}</th><th>${t('dashColTenant')}</th><th>${t('dashColPayDay')}</th><th>${t('colRent')}</th><th></th></tr></thead><tbody>${overdue}</tbody></table></div></div>`:''}
      ${alerts?`<div class="sec-hdr">${t('dashContracts')}</div><div class="table-card"><div class="table-scroller"><table><thead><tr><th>${t('colBuilding')}</th><th>${t('colUnit')}</th><th>${t('dashColTenant')}</th><th>${t('dashColEnd')}</th><th>${t('dashColRemaining')}</th><th>${t('colRent')}</th></tr></thead><tbody>${alerts}</tbody></table></div></div>`:''}`;
  };

  // Rerender only if user is already logged in (not on login/onboarding screens).
  // Skips the expensive JSON.stringify during login where it serves no purpose.
  setTimeout(()=>{
    try{
      const ls=document.getElementById('login-screen');
      const ob=document.getElementById('ob-screen');
      const loginVisible=ls&&ls.style.display!=='none';
      const obVisible=ob&&ob.style.display!=='none';
      if(!loginVisible&&!obVisible&&currentUser&&document.getElementById('content')) render();
    }catch(e){ console.error(e); }
  }, 200);
})();}catch(e){console.error('[KTP HOTFIX v5.1.5b init error — saveLocal/addHist/renderDash may be unprotected]',e);}


/* ═══════════════════════════════════════════════════════
   HOTFIX v5.1.9a — CRUD/modal focus/scroll regression fixes
   Minimal patch only: fixes form focus, edit update, duplicate rows, scroll restore.
═══════════════════════════════════════════════════════ */
(function(){
  const modalCss = document.createElement('style');
  modalCss.textContent = `
    #modal-overlay{z-index:10000;pointer-events:auto;}
    #modal-overlay.open{display:flex!important;}
    #modal{position:relative;z-index:10001;pointer-events:auto;}
    #modal input,#modal select,#modal textarea,#modal button{pointer-events:auto;user-select:auto;}
  `;
  document.head.appendChild(modalCss);

  function captureScroll(){
    const c=document.getElementById('content');
    return {x:window.scrollX||0,y:window.scrollY||0,cx:c?c.scrollLeft:0,cy:c?c.scrollTop:0};
  }
  function restoreScroll(pos){
    if(!pos) return;
    const run=()=>{
      try{ window.scrollTo(pos.x,pos.y); }catch{}
      const c=document.getElementById('content');
      if(c){ c.scrollLeft=pos.cx; c.scrollTop=pos.cy; }
    };
    requestAnimationFrame(()=>{ run(); setTimeout(run,0); setTimeout(run,80); });
  }
  function renderKeepScroll(){ const pos=captureScroll(); render(); restoreScroll(pos); }

  const _openModFix=openMod;
  window.openMod=openMod=function(type,arg){
    _openModFix(type,arg);
    const overlay=document.getElementById('modal-overlay');
    const md=document.getElementById('modal');
    if(overlay) overlay.style.pointerEvents='auto';
    if(md){
      md.style.pointerEvents='auto';
      md.addEventListener('click',e=>e.stopPropagation(),{once:true});
    }
    setTimeout(()=>{
      // Existing payment opened from a tenant row should behave as EDIT, not a fresh duplicate-style entry.
      if(type==='pay-add' && arg && String(arg).includes(':')){
        const [b,tid]=String(arg).split(':');
        const mo=document.getElementById('m_mo')?.value || S.month;
        const p=(DATA.payments?.[tid]||{})[mo];
        if(p){
          const amt=document.getElementById('m_amt'); if(amt) amt.value=p.paid||0;
          const dt=document.getElementById('m_dt'); if(dt) dt.value=p.date||'';
          const sk=document.getElementById('m_sk'); if(sk) sk.value=p.sekil||'Banka';
          const nt=document.getElementById('m_nt'); if(nt) nt.value=p.notes||'';
        }
      }
      const first=md?.querySelector('input:not([type=hidden]),select,textarea');
      if(first) first.focus({preventScroll:true});
    },80);
  };

  window.savePay=function(){
    const pos=captureScroll();
    const b=document.getElementById('m_b')?.value;
    const tid=document.getElementById('m_t')?.value;
    const mo=document.getElementById('m_mo')?.value;
    const paid=parseFloat(document.getElementById('m_amt')?.value)||0;
    const date=document.getElementById('m_dt')?.value||'';
    const sekil=document.getElementById('m_sk')?.value||'Banka';
    const notes=document.getElementById('m_nt')?.value||'';
    if(!b||!tid||!mo) return;
    _lastSekil=sekil;
    const t=(DATA.tenants[b]||[]).find(x=>x.id===tid);
    setP(tid,mo,{paid,date,sekil,notes});
    addHist(`${BL[b]} ${t?.unit||''} – ${t?.name||''}: ${TL(paid)} ödeme güncellendi (${mo})`);
    autoRecalc();
    closeMod();
    render(); updateBadges(); restoreScroll(pos);
    toast('✅ Ödeme kaydedildi','green');
    if(DATA.cloud.enabled) cloudSync('push');
  };

  window.saveExp_=function(eb,emo,eidx){
    const pos=captureScroll();
    const originalB=eb||document.getElementById('e_b')?.value;
    const originalMo=emo||document.getElementById('e_mo')?.value;
    const formB=document.getElementById('e_b')?.value || originalB;
    const formMo=document.getElementById('e_mo')?.value || originalMo;
    const tur=(document.getElementById('e_tur')?.value||'').trim().toUpperCase();
    const no=(document.getElementById('e_no')?.value||'').trim();
    const tutar=parseFloat(document.getElementById('e_amt')?.value)||0;
    const tarih=document.getElementById('e_dt')?.value||'';
    const notlar=document.getElementById('e_nt')?.value||'';
    if(!formB||!formMo||!tur) return;
    _lastExpTur=tur;
    if(!DATA.expenses[formB]) DATA.expenses[formB]={};
    if(!DATA.expenses[formB][formMo]) DATA.expenses[formB][formMo]=[];
    const entry={tur,no,tutar,tarih,notlar};
    if(eidx!==undefined && eidx!==null && DATA.expenses[originalB]?.[originalMo]?.[eidx]){
      // If building/month was changed in the edit form, move the existing row instead of leaving a duplicate behind.
      if(originalB!==formB || originalMo!==formMo){
        DATA.expenses[originalB][originalMo].splice(eidx,1);
        DATA.expenses[formB][formMo].push(entry);
      }else{
        DATA.expenses[formB][formMo].splice(eidx,1,entry);
      }
    }else{
      DATA.expenses[formB][formMo].push(entry);
    }
    addHist(`${BL[formB]} gider ${eidx!==undefined?'güncellendi':'eklendi'}: ${tur} ${TL(tutar)} (${formMo})`);
    autoRecalc();
    closeMod();
    render(); restoreScroll(pos);
    toast(t('expSaved'),'green');
    if(DATA.cloud.enabled) cloudSync('push');
  };

  window.editExp=function(bld,mo,idx){
    const e=((DATA.expenses[bld]||{})[mo]||[])[idx];
    if(!e) return;
    openMod('exp-add',bld);
    setTimeout(()=>{
      const vals={e_b:bld,e_mo:mo,e_tur:e.tur||'',e_no:e.no||'',e_amt:e.tutar||0,e_dt:e.tarih||'',e_nt:e.notlar||''};
      Object.entries(vals).forEach(([id,val])=>{ const el=document.getElementById(id); if(el) el.value=val; });
      const btn=document.querySelector('#modal .modal-footer .btn-primary');
      if(btn){ btn.textContent='💾 Güncelle'; btn.onclick=()=>saveExp_(bld,mo,idx); }
      document.getElementById('e_tur')?.focus({preventScroll:true});
    },90);
  };

  window.delExp=function(bld,mo,idx){
    const pos=captureScroll();
    if(DATA.expenses[bld]?.[mo]) DATA.expenses[bld][mo].splice(idx,1);
    addHist(`${BL[bld]} gider silindi (${mo})`);
    autoRecalc();saveLocal();
    render(); restoreScroll(pos);
    toast('🗑 '+t('userDeleted'),'red');
    if(DATA.cloud.enabled) cloudSync('push');
  };
})();

/* ═══════════════════════════════════════════════════════
   HOTFIX v5.1.9b — right-click context menu for form fields
═══════════════════════════════════════════════════════ */
(function(){
  var _cm=null;
  function _closeCM(){if(_cm){_cm.remove();_cm=null;}}

  document.addEventListener('contextmenu',function(e){
    const t=e.target;
    const isField=t.tagName==='INPUT'||t.tagName==='TEXTAREA'||
                  t.tagName==='SELECT'||t.isContentEditable;
    if(!isField){_closeCM();return;}
    e.preventDefault();
    _closeCM();

    const applyPaste=function(text){
      if(typeof text!=='string')return;
      t.focus();
      if(t.isContentEditable){
        document.execCommand('insertText',false,text);
      }else{
        const s=t.selectionStart??0,e2=t.selectionEnd??t.value.length;
        t.value=t.value.slice(0,s)+text+t.value.slice(e2);
        t.selectionStart=t.selectionEnd=s+text.length;
        t.dispatchEvent(new Event('input',{bubbles:true}));
        t.dispatchEvent(new Event('change',{bubbles:true}));
      }
    };

    const items=[
      ['Kes (Cut)',       function(){t.focus();document.execCommand('cut');}],
      ['Kopyala (Copy)',  function(){t.focus();document.execCommand('copy');}],
      ['Yapıştır (Paste)',function(){
        t.focus();
        if(typeof window.electron!=='undefined'&&window.electron.readClipboard){
          window.electron.readClipboard().then(applyPaste).catch(function(){});
        }else if(navigator.clipboard&&navigator.clipboard.readText){
          navigator.clipboard.readText().then(applyPaste).catch(function(){});
        }
      }],
      ['Tümünü Seç (Select All)',function(){t.focus();document.execCommand('selectAll');}],
    ];

    const menu=document.createElement('div');
    menu.style.cssText='position:fixed;z-index:99999;background:#0f1e38;'+
      'border:1px solid rgba(255,255,255,.13);border-radius:8px;padding:4px;'+
      'box-shadow:0 8px 28px rgba(0,0,0,.65);min-width:160px;'+
      'font-family:var(--sans,system-ui,-apple-system,sans-serif);font-size:12px;';

    items.forEach(function(pair){
      const btn=document.createElement('button');
      btn.textContent=pair[0];
      btn.style.cssText='display:block;width:100%;padding:7px 12px;background:transparent;'+
        'border:none;color:#e8edf8;cursor:pointer;text-align:left;border-radius:5px;'+
        'font-size:12px;font-family:inherit;line-height:1.4;';
      btn.addEventListener('mouseover',function(){btn.style.background='rgba(59,130,246,.15)';});
      btn.addEventListener('mouseout', function(){btn.style.background='transparent';});
      btn.addEventListener('mousedown',function(ev){ev.preventDefault();});
      btn.addEventListener('click',function(){pair[1]();_closeCM();});
      menu.appendChild(btn);
    });

    document.body.appendChild(menu);
    var x=e.clientX,y=e.clientY;
    var r=menu.getBoundingClientRect();
    if(x+r.width >window.innerWidth) x=window.innerWidth -r.width -4;
    if(y+r.height>window.innerHeight)y=window.innerHeight-r.height-4;
    menu.style.left=x+'px';menu.style.top=y+'px';
    _cm=menu;
  });

  document.addEventListener('click',_closeCM);
  document.addEventListener('keydown',function(e){if(e.key==='Escape')_closeCM();});
})();

// Startup splash handled by src/splash.html (Phase 2B — separate BrowserWindow)

/* ═══════════════════════════════════════════════════════
   DEMO SEED GENERATOR — v6 Production Stress Test
   Console: window.seedDemoData()  /  window.clearDemoData()
═══════════════════════════════════════════════════════ */
(function(){
  'use strict';

  // ── Micro helpers ─────────────────────────────────────────────
  function _rng(a,b){return Math.floor(Math.random()*(b-a+1))+a;}
  function _pick(arr){return arr[_rng(0,arr.length-1)];}
  function _pad(n){return String(n).padStart(2,'0');}
  function _iso(y,m,d){return y+'-'+_pad(m)+'-'+_pad(d);}
  function _fakePhone(){
    var pfx=_pick(['530','531','532','533','535','537','538','539','541','542',
                   '543','544','545','546','547','548','549','553','554','555']);
    return '0'+pfx+String(_rng(1000000,9999999));
  }

  // ── Turkish name pools ────────────────────────────────────────
  var _MN=['Ahmet','Mehmet','Mustafa','Ali','Hasan','Hüseyin','İbrahim','Osman',
            'Yusuf','İsmail','Ömer','Murat','Emre','Burak','Serkan','Tolga',
            'Fatih','Kemal','Tarık','Berk','Onur','Haluk','Barış','Sinan',
            'Adem','Orhan','Selim','Doğan','Ufuk','Caner'];
  var _FN=['Fatma','Ayşe','Emine','Hatice','Zeynep','Elif','Merve','Selin',
            'Ceren','Büşra','Esra','Gül','Yıldız','Sevgi','Meltem','Sibel',
            'Deniz','Özlem','Pınar','Gamze','Tuğba','Nilüfer','İrem','Aslı',
            'Şule','Filiz','Nurcan','Semra','Leyla','Berna'];
  var _SN=['Yılmaz','Kaya','Demir','Şahin','Çelik','Arslan','Doğan','Kılıç',
            'Aslan','Çetin','Yıldız','Koç','Aydın','Öztürk','Özdemir','Güneş',
            'Aktaş','Tekin','Bulut','Korkmaz','Kaplan','Polat','Güler','Coşkun',
            'Yıldırım','Kurt','Özcan','Ceylan','Acar','Demirtaş'];

  function _name(){
    var m=Math.random()>0.45;
    return _pick(m?_MN:_FN)+' '+_pick(_SN);
  }

  // ── Building definitions ──────────────────────────────────────
  var _BLDG_DEFS=[
    {id:'SD01',name:'Yeşilköy Apartmanı',   short:'YEŞ',type:'konut', unitCount:8},
    {id:'SD02',name:'Çamlık Rezidansı',     short:'ÇAM',type:'konut', unitCount:9},
    {id:'SD03',name:'Boğaziçi Konutları',   short:'BOĞ',type:'konut', unitCount:10},
    {id:'SD04',name:'Akasya Apartmanı',     short:'AKA',type:'konut', unitCount:7},
    {id:'SD05',name:'Moda Konutları',       short:'MOD',type:'konut', unitCount:8},
    {id:'SD06',name:'Tarabya Rezidans',     short:'TAR',type:'konut', unitCount:6},
    {id:'SD07',name:'Nişantaşı Yaşam',      short:'NİŞ',type:'konut', unitCount:9},
    {id:'SD08',name:'Levent İş Merkezi',    short:'LEV',type:'ofis',  unitCount:8},
    {id:'SD09',name:'Maslak Tower Ofis',    short:'MAS',type:'ofis',  unitCount:7},
    {id:'SD10',name:'Şişli Business Center',short:'ŞİŞ',type:'ofis',  unitCount:9},
    {id:'SD11',name:'Gayrettepe İş',        short:'GAY',type:'ofis',  unitCount:7},
    {id:'SD12',name:'Ataşehir Ofis Park',   short:'ATA',type:'ofis',  unitCount:8},
    {id:'SD13',name:'Forum İstanbul Plaza', short:'FOR',type:'plaza', unitCount:9},
    {id:'SD14',name:'MetroPol Plaza',       short:'MET',type:'plaza', unitCount:8},
    {id:'SD15',name:'TeknoPlaza',           short:'TEK',type:'plaza', unitCount:7},
    {id:'SD16',name:'Bahçelievler Residence',short:'BAH',type:'konut',unitCount:8},
    {id:'SD17',name:'Sarıyer Konaklama',    short:'SAR',type:'konut', unitCount:6},
    // archived (3)
    {id:'SD18',name:'Suadiye Site',         short:'SUA',type:'site',  unitCount:5, archived:true},
    {id:'SD19',name:'Fenerbahçe Konutları', short:'FEN',type:'konut', unitCount:5, archived:true},
    {id:'SD20',name:'Kadıköy Çarşı',        short:'KAD',type:'plaza', unitCount:6, archived:true},
  ];

  var _MONTHS_TR=['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran',
                  'Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
  var _EXP_CATS=['ELEKTRİK','SU','DOĞALGAZ','ASANSÖR BAKIM','SİTE AİDATI',
                 'TEMİZLİK','GÜVENLİK','SIHHİ TESİSAT','BOYA BADANA',
                 'VERGİ/HARÇ','SİGORTA','YÖNETİM ÜCRETİ','ORTAK ALAN'];
  var _SEKILLAR=['Banka','Nakit','EFT/Havale','Kredi Kartı','Çek'];
  var _FLOOR_LBL=['Zemin','1.Kat','2.Kat','3.Kat','4.Kat','5.Kat',
                  '6.Kat','7.Kat','8.Kat','9.Kat','10.Kat'];

  function _rentForType(type){
    if(type==='ofis')  return _rng(15,50)*1000;
    if(type==='plaza') return _rng(20,80)*1000;
    if(type==='site')  return _rng(10,22)*1000;
    return _rng(8,28)*1000; // konut
  }

  var _seedBase=0; // set by _execSeed to index of 'Ocak 2025' in ALL_MONTHS

  // Month index → {year:string, monthNum:int, moStr:string}
  function _moInfo(idx){
    var moStr=ALL_MONTHS[idx];
    if(!moStr) moStr=ALL_MONTHS[ALL_MONTHS.length-1]||'Ocak 2025';
    var parts=moStr.split(' ');
    var mn=_MONTHS_TR.indexOf(parts[0])+1;
    return {year:parts[1],monthNum:mn,moStr:moStr};
  }

  // Generate payments for one tenant across months [startIdx .. 23] (relative to _seedBase)
  function _genPays(rent, startIdx){
    var pays={};
    var curIdx=ALL_MONTHS.indexOf(S.month);
    for(var i=_seedBase+startIdx;i<_seedBase+24&&i<ALL_MONTHS.length;i++){
      var mi=_moInfo(i);
      var r=Math.random();
      var paid=0,date='',sekil='',notes='';
      if(i<curIdx-1){
        // past months: 68% full, 12% partial, 15% zero, 5% late-full
        if     (r<0.68){paid=rent;date=_iso(mi.year,mi.monthNum,_rng(1,12));sekil=_pick(_SEKILLAR);}
        else if(r<0.80){paid=Math.round(rent*_pick([0.25,0.5,0.75]));date=_iso(mi.year,mi.monthNum,_rng(8,22));sekil=_pick(_SEKILLAR);notes='Kısmi ödeme';}
        else if(r<0.95){paid=0;} // overdue
        else           {paid=rent;date=_iso(mi.year,mi.monthNum,_rng(20,28));sekil=_pick(_SEKILLAR);notes='Geç ödeme';}
      } else if(i===curIdx){
        // current month: 38% already paid
        if(r<0.38){paid=rent;date=_iso(mi.year,mi.monthNum,_rng(1,8));sekil=_pick(_SEKILLAR);}
      }
      // Always write the slot for past months so history panel shows them
      if(i<=curIdx){
        pays[mi.moStr]={paid:paid,date:date,sekil:sekil,notes:notes};
      }
    }
    return pays;
  }

  // Generate expenses for one building across 24 months (relative to _seedBase)
  function _genExps(bType){
    var exps={};
    for(var i=_seedBase;i<_seedBase+24&&i<ALL_MONTHS.length;i++){
      var mi=_moInfo(i);
      var isWinter=(mi.monthNum>=10||mi.monthNum<=3);
      var isHighMo=(Math.random()<0.10);
      var entries=[];
      // guaranteed: electric + one more
      entries.push({tur:'ELEKTRİK',no:'',
        tutar:_rng(1200,7000)*(isHighMo?_rng(2,3):1),
        tarih:_iso(mi.year,mi.monthNum,_rng(5,20)),notlar:''});
      // 70% chance of water
      if(Math.random()<0.70){
        entries.push({tur:'SU',no:'',tutar:_rng(400,2500),
          tarih:_iso(mi.year,mi.monthNum,_rng(5,20)),notlar:''});
      }
      // winter: gas
      if(isWinter&&Math.random()<0.75){
        entries.push({tur:'DOĞALGAZ',no:'',tutar:_rng(1500,7000),
          tarih:_iso(mi.year,mi.monthNum,_rng(5,20)),notlar:''});
      }
      // 40% chance of a misc expense
      if(Math.random()<0.40){
        var misc=_pick(_EXP_CATS.slice(3));
        entries.push({tur:misc,no:'',tutar:_rng(500,6000),
          tarih:_iso(mi.year,mi.monthNum,_rng(5,25)),notlar:''});
      }
      exps[mi.moStr]=entries;
    }
    return exps;
  }

  // ── Confirmation modal (uses existing modal DOM) ──────────────
  function _showSeedConfirm(){
    var overlay=document.getElementById('modal-overlay');
    var md=document.getElementById('modal');
    if(!overlay||!md){_execSeed();return;}
    md.innerHTML='<div class="modal-title" style="color:var(--amber-l)">🌱 Demo Veri Oluştur</div>'+
      '<div style="background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25);border-radius:8px;padding:12px 14px;margin-bottom:14px">'+
        '<div style="font-size:12px;font-weight:600;color:var(--amber-l);margin-bottom:6px">⚠️ Mevcut Veriler Değişecek</div>'+
        '<div style="font-size:12px;color:var(--i2);line-height:1.6">Tüm kiracı, ödeme ve gider verileri demo veriyle değiştirilecek. Devam etmeden önce JSON Yedek almanız önerilir.</div>'+
      '</div>'+
      '<div style="font-size:12px;color:var(--i3);line-height:1.9;margin-bottom:14px">'+
        'Oluşturulacak:<br>'+
        '• <b style="color:var(--i1)">20 bina</b> — konut, ofis, plaza, site (3 arşiv)<br>'+
        '• <b style="color:var(--i1)">120+ kiracı</b> — gerçekçi Türkçe isim/telefon/kira<br>'+
        '• <b style="color:var(--i1)">24 aylık ödeme geçmişi</b> — karma durumlar<br>'+
        '• <b style="color:var(--i1)">400+ gider kaydı</b> — kategori karışımı'+
      '</div>'+
      '<div class="modal-footer">'+
        '<button class="btn btn-ghost" onclick="closeMod()">Vazgeç</button>'+
        '<button class="btn" style="background:var(--amber);color:#000;font-weight:600" onclick="closeMod();window._execSeedDemo()">🌱 Oluştur</button>'+
      '</div>';
    overlay.classList.add('open');
  }

  function _execSeed(){
    try{
      // Anchor seed data to Ocak 2025 window; if not in range, use 16 months before current
      _seedBase=ALL_MONTHS.indexOf('Ocak 2025');
      if(_seedBase<0) _seedBase=Math.max(0,ALL_MONTHS.indexOf(S.month)-16);
      var buildings=[];
      var tenants={};
      var payments={};
      var expenses={};
      var history=[];
      var tenantCount=0;
      var expCount=0;

      _BLDG_DEFS.forEach(function(bdef,i){
        var isArchived=!!bdef.archived;
        buildings.push({id:bdef.id,name:bdef.name,short:bdef.short,color:'',
          active:!isArchived,order:i,metadata:{type:bdef.type}});

        var bTens=[];
        for(var u=0;u<bdef.unitCount;u++){
          var uNum=u+1;
          var unitLbl=(bdef.type==='ofis')?
            'O'+String(uNum).padStart(3,'0') :
            'D'+String(uNum).padStart(2,'0');
          var flLbl=_FLOOR_LBL[Math.min(Math.floor(u/3),_FLOOR_LBL.length-1)];
          var tid=bdef.id+'_T'+String(uNum).padStart(3,'0');

          if(isArchived){
            // archived building: historical inactive tenants
            bTens.push({id:tid,unit:unitLbl,fl:flLbl,name:_name(),
              rent:_rng(8,20)*1000,dep:0,bas:'2023-01-01',bit:'2025-01-01',
              gun:1,sekil:'Banka',active:false,notes:'',phone:_fakePhone()});
            continue;
          }

          var isVacant=(Math.random()<0.10);
          if(isVacant){
            // vacant slot: active:false, rent:0
            bTens.push({id:tid,unit:unitLbl,fl:flLbl,name:'',
              rent:0,dep:0,bas:'',bit:'',gun:1,sekil:'',
              active:false,notes:'',phone:''});
            continue;
          }

          var rent=_rentForType(bdef.type);
          var startOff=_rng(0,12); // relative offset from _seedBase
          var startMi=_moInfo(_seedBase+startOff);
          var hasEnd=(Math.random()<0.12);
          var bitDate=hasEnd?_iso('2026',_rng(6,12),'01'):'';

          bTens.push({id:tid,unit:unitLbl,fl:flLbl,name:_name(),
            rent:rent,dep:rent,bas:_iso(startMi.year,startMi.monthNum,'01'),bit:bitDate,
            gun:_rng(1,10),sekil:_pick(_SEKILLAR),active:true,notes:'',phone:_fakePhone()});
          payments[tid]=_genPays(rent,startOff);
          tenantCount++;
        }
        tenants[bdef.id]=bTens;

        if(!isArchived){
          expenses[bdef.id]=_genExps(bdef.type);
          Object.values(expenses[bdef.id]).forEach(function(arr){expCount+=arr.length;});
        }
      });

      // Realistic operational history (80 entries, spread over 6 months)
      var _histOps=[
        'Ödeme kaydedildi','Kiracı bilgisi güncellendi','Gider eklendi',
        'Yedek alındı','Ayarlar güncellendi','Bina eklendi',
        'WA mesajı gönderildi','Rapor oluşturuldu','İçe aktarma yapıldı','Geri yükleme yapıldı'];
      var _histUsers=['Yönetici','Müdür','Sistem'];
      for(var h=0;h<80;h++){
        var daysAgo=_rng(0,180);
        var d=new Date(Date.now()-daysAgo*864e5);
        history.push({
          t:d.toLocaleString('tr-TR'),
          desc:_pick(_histOps)+' — '+_pick(_BLDG_DEFS).name,
          user:_pick(_histUsers)
        });
      }
      history.sort(function(a,b){return new Date(b.t)-new Date(a.t);});

      // Patch DATA — preserve cloud/settings/users/waLog/alper/tanNet/gayNet
      DATA.buildings=buildings;
      DATA.tenants=tenants;
      DATA.payments=payments;
      DATA.expenses=expenses;
      DATA.history=history;
      DATA.initialized=true;

      syncBuildingConstants();
      saveLocal();
      S.page='dash';
      S.bld=BK[0]||null;
      S.filter='';
      S.search='';
      render();
      updateBadges();
      renderBuildingNav();
      toast('✓ Demo veri oluşturuldu: '+buildings.length+' bina · '+tenantCount+' kiracı · 24 ay · '+expCount+' gider','green');
      addHist('Demo veri oluşturuldu: '+buildings.length+' bina, '+tenantCount+' kiracı, '+expCount+' gider');
    }catch(err){
      console.error('[seedDemoData]',err);
      toast('⚠ Demo veri hatası: '+err.message,'red');
    }
  }

  function _showClearConfirm(){
    var overlay=document.getElementById('modal-overlay');
    var md=document.getElementById('modal');
    if(!overlay||!md){window._execClearDemo();return;}
    md.innerHTML='<div class="modal-title" style="color:var(--rose-l)">🧹 Demo Veriyi Temizle</div>'+
      '<div style="font-size:13px;color:var(--i2);margin-bottom:16px">Tüm demo veriler silinecek, uygulama boş başlangıç durumuna dönecek.</div>'+
      '<div class="modal-footer">'+
        '<button class="btn btn-ghost" onclick="closeMod()">Vazgeç</button>'+
        '<button class="btn btn-danger" onclick="closeMod();window._execClearDemo()">🧹 Temizle</button>'+
      '</div>';
    overlay.classList.add('open');
  }

  window._execSeedDemo=window._execSeedDemo||function(){_execSeed();};
  window._execClearDemo=function(){
    DATA.buildings=[];DATA.tenants={};DATA.payments={};
    DATA.expenses={};DATA.history=[];DATA.initialized=false;
    syncBuildingConstants();saveLocal();
    toast('🧹 Demo veri temizlendi — yeniden başlatılıyor...','orange');
    setTimeout(function(){location.reload();},900);
  };

  window.seedDemoData=function(){_showSeedConfirm();};
  window.clearDemoData=function(){_showClearConfirm();};

  // reassign so confirm modal can call it after closeMod
  window._execSeedDemo=function(){_execSeed();};
})();

/* ═══════════════════════════════════════════════════════
   SMART IMPORT WIZARD v6.0
   Entry: openImportWizard()  Close: closeImportWizard()
   Supports CSV + XLSX  |  Modes: tenant / payment / expense
   Rollback-safe: snapshots DATA before writing.
═══════════════════════════════════════════════════════ */
try{(function(){

// ── Mode & field definitions ──────────────────────────
var _MODES={
  tenant:{label:'Kiracı',icon:'🏠',fields:{
    name:   {label:'Kiracı Adı',    req:true},
    unit:   {label:'Daire / Birim', req:true},
    rent:   {label:'Kira (₺)',      req:true},
    phone:  {label:'Telefon',       req:false},
    dep:    {label:'Depozito (₺)',  req:false},
    floor:  {label:'Kat',           req:false},
    bas:    {label:'Başlangıç Tar.',req:false},
    bit:    {label:'Bitiş Tar.',    req:false},
    notes:  {label:'Notlar',        req:false},
    building:{label:'Bina',         req:false},
  }},
  payment:{label:'Ödeme',icon:'💳',fields:{
    unit:   {label:'Daire / Birim', req:true},
    name:   {label:'Kiracı Adı',    req:false},
    paid:   {label:'Ödenen Tutar',  req:true},
    month:  {label:'Dönem (Ay)',    req:true},
    date:   {label:'Ödeme Tarihi',  req:false},
    sekil:  {label:'Ödeme Şekli',  req:false},
    notes:  {label:'Notlar',        req:false},
    building:{label:'Bina',         req:false},
  }},
  expense:{label:'Gider',icon:'💸',fields:{
    building:{label:'Bina',         req:true},
    category:{label:'Kategori',     req:false},
    amount:  {label:'Tutar (₺)',    req:true},
    month:   {label:'Dönem (Ay)',   req:true},
    date:    {label:'Tarih',        req:false},
    notes:   {label:'Açıklama',     req:false},
  }},
};

// ── Column name → field auto-detect patterns ──────────
var _DETECT={
  name:    [/kirac/i,/m[üu][sş]teri/i,/\bad\b/i,/\bisim\b/i,/tenant/i,/renter/i,/customer/i,/\bname\b/i,/full.name/i,/ad.soyad/i],
  unit:    [/daire/i,/birim/i,/\bunit\b/i,/\bno\b$/i,/numara/i,/room/i,/\bapartment\b/i,/\bflat\b/i,/kap[ıi]/i],
  rent:    [/\bkira\b/i,/\brent\b/i,/ayl[ıi]k/i,/kirabedel/i,/monthly/i,/beklenen/i,/expected/i],
  phone:   [/telefon/i,/\btel\b/i,/\bphone\b/i,/\bgsm\b/i,/\bcep\b/i,/\bmobile\b/i,/\bcontact\b/i],
  building:[/\bbina\b/i,/\bbuilding\b/i,/\bblok\b/i,/apartman/i,/\bsite\b/i,/property/i],
  paid:    [/[oö]deme/i,/[oö]denen/i,/\bpayment\b/i,/tahsilat/i,/al[ıi]nan/i,/\bpaid\b/i,/tutar/i,/miktar/i,/collection/i],
  month:   [/d[oö]nem/i,/\bay\b/i,/\bmonth\b/i,/\bperiod\b/i],
  date:    [/tarih/i,/\bdate\b/i,/\bdt\b/i],
  // sekil: "Type" claimed here (before category in iteration order) — active only when sekil is in the mode map (payment)
  sekil:   [/[sş]ekil/i,/[sş]ekl[ıi]/i,/metod/i,/y[oö]ntem/i,/method/i,/\btype\b/i],
  dep:     [/depozito/i,/deposit/i,/g[üu]vence/i],
  floor:   [/\bkat\b/i,/\bfloor\b/i],
  bas:     [/ba[sş]lang/i,/\bstart\b/i,/giri[sş]/i],
  bit:     [/biti[sş]/i,/\bend\b/i,/[çc][ıi]k[ıi][sş]/i],
  notes:   [/\bnot\b/i,/\bnote\b/i,/a[cç][ıi]kl/i,/\bnotes\b/i,/remark/i,/detay/i,/descrip/i,/\bdetails\b/i],
  amount:  [/tutar/i,/miktar/i,/\bamount\b/i,/bedel/i,/masraf/i,/\bexpense\b/i,/\bcost\b/i],
  // category: "Type" also here — only activates in expense mode (sekil not in map, so sekil's /\btype\b/i is skipped)
  category:[/kategori/i,/t[üu]r[üu]/i,/\bcategory\b/i,/\btype\b/i,/gider.*t/i],
};

// ── Wizard state ──────────────────────────────────────
var _W={step:1,mode:'tenant',fileType:'',rows:[],headers:[],
        sheetNames:[],workbook:null,selectedSheet:'',
        mapping:{},targetBld:'',valResult:null};

var _STEP_LABELS=['Dosya','Yapılandır','Önizleme','Eşleştir','Doğrula','Onayla'];

// ── CSV parser ────────────────────────────────────────
function _csvLine(line,delim){
  var out=[],cur='',q=false;
  for(var i=0;i<line.length;i++){
    var c=line[i];
    if(c==='"'){if(q&&line[i+1]==='"'){cur+='"';i++;}else q=!q;}
    else if(c===delim&&!q){out.push(cur.trim());cur='';}
    else cur+=c;
  }
  out.push(cur.trim());return out;
}
function _parseCsv(text){
  if(text.charCodeAt(0)===0xFEFF) text=text.slice(1); // strip UTF-8 BOM
  var first=text.split(/\r?\n/)[0]||'';
  var delim=(first.split(';').length>first.split(',').length)?';':',';
  return text.split(/\r?\n/)
    .map(function(l){return _csvLine(l,delim);})
    .filter(function(r){return r.length>0&&r.some(function(c){return c!=='';});});
}

// ── XLSX parser (requires SheetJS global) ─────────────
function _parseXlsx(buf){
  if(typeof XLSX==='undefined') throw new Error('XLSX kütüphanesi yüklenemedi');
  return XLSX.read(buf,{type:'array',cellDates:true,raw:false});
}
function _sheetToRows(wb,name){
  var ws=wb.Sheets[name]; if(!ws) return [];
  return XLSX.utils.sheet_to_json(ws,{header:1,defval:'',raw:false});
}

// ── Auto-detect mapping ───────────────────────────────
function _detectMapping(headers,mode){
  var fields=Object.keys(_MODES[mode].fields);
  var map={};
  fields.forEach(function(f){map[f]=-1;});
  // alias: expense uses 'amount' but detect also matches 'amount'
  if(!map.hasOwnProperty('amount')&&mode==='expense') map.amount=-1;
  headers.forEach(function(h,ci){
    var hn=String(h).toLowerCase().replace(/\s+/g,'');
    Object.keys(_DETECT).forEach(function(field){
      if(map.hasOwnProperty(field)&&map[field]===-1){
        if(_DETECT[field].some(function(re){return re.test(hn)||re.test(String(h));})){
          map[field]=ci;
        }
      }
    });
  });
  return map;
}

// ── Month string parser ───────────────────────────────
var _TKM=['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran',
          'Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
var _ENM=['january','february','march','april','may','june',
          'july','august','september','october','november','december'];
var _EN3=['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'];
function _parseMonth(val){
  if(!val) return null;
  val=String(val).trim();
  for(var i=0;i<_TKM.length;i++){
    if(val.startsWith(_TKM[i]+' ')&&/\d{4}$/.test(val)) return val; // already correct
    var m=val.match(new RegExp('^'+_TKM[i]+'\\s*(\\d{4})$','i'));
    if(m) return _TKM[i]+' '+m[1];
  }
  var lv=val.toLowerCase();
  for(var j=0;j<_ENM.length;j++){
    if(lv.startsWith(_ENM[j])||lv.startsWith(_EN3[j])){
      var ym=val.match(/(\d{4})/); if(ym) return _TKM[j]+' '+ym[1];
    }
  }
  var m2=val.match(/^(\d{1,2})[\/\-\.](\d{4})$/);
  if(m2){var mn=parseInt(m2[1])-1;if(mn>=0&&mn<12) return _TKM[mn]+' '+m2[2];}
  var m3=val.match(/^(\d{4})[\/\-](\d{1,2})$/);
  if(m3){var mn2=parseInt(m3[2])-1;if(mn2>=0&&mn2<12) return _TKM[mn2]+' '+m3[1];}
  return null;
}

// ── Date normaliser ───────────────────────────────────
function _parseDate(val){
  if(!val) return '';
  val=String(val).trim();
  if(/^\d{4}-\d{2}-\d{2}$/.test(val)) return val;
  var m=val.match(/^(\d{1,2})[\/\.](\d{1,2})[\/\.](\d{4})$/);
  if(m) return m[3]+'-'+m[2].padStart(2,'0')+'-'+m[1].padStart(2,'0');
  try{var d=new Date(val);if(!isNaN(d)&&d.getFullYear()>1900) return d.toISOString().slice(0,10);}catch(e){}
  return '';
}

// ── Number parser ─────────────────────────────────────
// Handles: 12000 / 12.000 / 12,000 / 12.000,50 / 12,000.50 / ₺12.000 / TL 12000
function _num(val){
  if(val===null||val===undefined||val==='') return NaN;
  var s=String(val).replace(/[₺TL\s]/gi,'').trim();
  if(!s||!/\d/.test(s)) return NaN;
  var hasDot=s.indexOf('.')>=0,hasCom=s.indexOf(',')>=0;
  if(hasDot&&hasCom){
    // Both separators present: last one is the decimal separator
    if(s.lastIndexOf('.')>s.lastIndexOf(',')) s=s.replace(/,/g,'');         // 12,000.50 (EN)
    else s=s.replace(/\./g,'').replace(',','.');                              // 12.000,50 (TR)
  }else if(hasCom){
    // Comma only: N,NNN pattern → thousands; otherwise → decimal
    if(/^\d{1,3}(,\d{3})+$/.test(s)) s=s.replace(/,/g,'');                  // 12,000 / 1,000,000
    else s=s.replace(',','.');                                                // 12,5 → 12.5
  }else if(hasDot){
    var parts=s.split('.');
    if(parts.length>2) s=s.replace(/\./g,'');                                // 12.000.000 → all thousands
    else if(parts[1]&&parts[1].length===3&&parts[0]!=='0') s=s.replace('.',''); // 12.000 → 12000
    // else 12.5 → keep as decimal
  }
  return parseFloat(s);
}

// ── Cell value helper ─────────────────────────────────
function _cell(row,idx){return idx<0||idx>=row.length?'':String(row[idx]||'').trim();}

// ── Resolve building name → id ────────────────────────
function _bldId(val){
  if(!val) return null;
  var v=String(val).toLowerCase().trim();
  var b=(DATA.buildings||[]).find(function(b){
    return b.active&&(b.id.toLowerCase()===v||b.name.toLowerCase()===v||
           b.name.toLowerCase().includes(v)||(b.short&&b.short.toLowerCase()===v));
  });
  return b?b.id:null;
}

// ── Validation ────────────────────────────────────────
function _validate(rows,mapping,mode,targetBld){
  var data=rows.slice(1),errs=[],warns=[],valid=[];
  var fields=_MODES[mode].fields;
  var seen={};
  data.forEach(function(row,ri){
    var rowN=ri+2,issues=[];
    // Skip entirely blank rows (spacer rows in Excel, mid-file gaps, footer separators)
    if(!row.some(function(c){return String(c||'').trim()!=='';})) return;
    // Required fields
    Object.keys(fields).forEach(function(f){
      if(!fields[f].req) return;
      if(f==='building'&&targetBld) return;
      var ci=mapping[f]; if(ci===undefined||ci<0||!_cell(row,ci))
        issues.push({t:'err',msg:fields[f].label+' boş (satır '+rowN+')'});
    });
    // Type-specific
    if(mode==='tenant'){
      var rv=_num(_cell(row,mapping.rent));
      if(mapping.rent>=0&&(isNaN(rv)||rv<0))
        issues.push({t:'err',msg:'Kira geçersiz sayı (satır '+rowN+')'});
      var bv=mapping.building>=0?_cell(row,mapping.building):'';
      var bid=_bldId(bv||targetBld);
      if(!bid)
        issues.push({t:'err',msg:'Bina bulunamadı: "'+(bv||targetBld)+'" (satır '+rowN+')'});
      var unit=_cell(row,mapping.unit);
      if(bid&&unit){
        var dupKey=bid+'|'+unit;
        if(seen[dupKey]) issues.push({t:'warn',msg:'Toplu tekrar: aynı daire (satır '+rowN+')'});
        else seen[dupKey]=rowN;
        var ex=(DATA.tenants[bid]||[]).find(function(t){return t.active&&t.unit===unit;});
        if(ex) issues.push({t:'warn',msg:'Daire zaten kayıtlı ('+unit+') — güncellenir'});
      }
    } else if(mode==='payment'){
      var pv=_num(_cell(row,mapping.paid));
      if(isNaN(pv)||pv<0)
        issues.push({t:'err',msg:'Tutar geçersiz (satır '+rowN+')'});
      var moStr=_parseMonth(_cell(row,mapping.month));
      if(!moStr)
        issues.push({t:'err',msg:'Dönem geçersiz: "'+_cell(row,mapping.month)+'" (satır '+rowN+')'});
      var bv2=mapping.building>=0?_cell(row,mapping.building):'';
      var bid2=_bldId(bv2||targetBld);
      var unit2=_cell(row,mapping.unit);
      var tname2=mapping.name>=0?_cell(row,mapping.name):'';
      // Resolve tenant at validate-time — rejects unknown units before import
      var pTid=null,pRent=0;
      if(unit2||tname2){
        var pBlds=bid2?[bid2]:Object.keys(DATA.tenants);
        for(var psi=0;psi<pBlds.length;psi++){
          var ptl=(DATA.tenants[pBlds[psi]])||[];
          var pte=ptl.find(function(t){return t.active&&((unit2&&t.unit===unit2)||(tname2&&t.name&&t.name.toLowerCase()===tname2.toLowerCase()));});
          if(pte){pTid=pte.id;pRent=pte.rent||0;break;}
        }
        if(!pTid)
          issues.push({t:'err',msg:'Kiracı bulunamadı: "'+(unit2||tname2)+'" (satır '+rowN+')'});
        else if(!isNaN(pv)&&pRent>0&&pv>pRent)
          issues.push({t:'warn',msg:'Tutar kira bedelini aşıyor: ₺'+pv+' > ₺'+pRent+' (satır '+rowN+')'});
      }
      if(moStr){
        var dpKey=(bid2||'')+'|'+(unit2||tname2)+'|'+moStr;
        if(seen[dpKey]) issues.push({t:'warn',msg:'Toplu tekrar: aynı daire+dönem (satır '+rowN+')'});
        else seen[dpKey]=rowN;
        if(pTid&&DATA.payments[pTid]&&DATA.payments[pTid][moStr]&&DATA.payments[pTid][moStr].paid>0)
          issues.push({t:'warn',msg:'Ödeme zaten mevcut: '+moStr+' — üzerine yazılır'});
      }
    } else if(mode==='expense'){
      var av=_num(_cell(row,mapping.amount));
      if(isNaN(av)||av<0)
        issues.push({t:'err',msg:'Tutar geçersiz (satır '+rowN+')'});
      else if(av===0)
        issues.push({t:'warn',msg:'Tutar sıfır (satır '+rowN+')'});
      var eMo=_parseMonth(_cell(row,mapping.month));
      if(!eMo)
        issues.push({t:'err',msg:'Dönem geçersiz (satır '+rowN+')'});
      var bv3=mapping.building>=0?_cell(row,mapping.building):'';
      var eBid=_bldId(bv3||targetBld);
      if(!eBid)
        issues.push({t:'err',msg:'Bina bulunamadı: "'+(bv3||targetBld||'?')+'" (satır '+rowN+')'});
      if(eBid&&eMo&&!isNaN(av)&&av>0){
        var eDate=mapping.date>=0?_cell(row,mapping.date):'';
        var cat3=_cell(row,mapping.category||(-1));
        var eDupKey=eBid+'|'+eMo+'|'+av+'|'+eDate+'|'+cat3;
        if(seen[eDupKey]) issues.push({t:'warn',msg:'Aynı gider zaten eklenmiş olabilir (satır '+rowN+')'});
        else seen[eDupKey]=rowN;
      }
    }
    var hasErr=issues.some(function(i){return i.t==='err';});
    if(hasErr) errs.push({row:rowN,issues:issues});
    else if(issues.length) warns.push({row:rowN,issues:issues});
    if(!hasErr) valid.push(ri);
  });
  return{errs:errs,warns:warns,valid:valid,total:data.length};
}

// ── Import (atomic with snapshot rollback) ────────────
function _doImport(rows,mapping,mode,targetBld,validIdxs){
  var snap=JSON.parse(JSON.stringify({
    tenants:DATA.tenants,payments:DATA.payments,
    expenses:DATA.expenses,buildings:DATA.buildings,
  }));
  var imported=0,updated=0,skipped=0,data=rows.slice(1);
  try{
    if(mode==='tenant'){
      validIdxs.forEach(function(ri){
        var row=data[ri];
        var bv=mapping.building>=0?_cell(row,mapping.building):'';
        var bid=_bldId(bv||targetBld); if(!bid){skipped++;return;}
        if(!DATA.tenants[bid]) DATA.tenants[bid]=[];
        var list=DATA.tenants[bid];
        var unit=_cell(row,mapping.unit);
        var name=_cell(row,mapping.name);
        var rent=_num(_cell(row,mapping.rent))||0;
        var phone=mapping.phone>=0?_cell(row,mapping.phone):'';
        var dep=mapping.dep>=0?(_num(_cell(row,mapping.dep))||rent):rent;
        var floor=mapping.floor>=0?_cell(row,mapping.floor):'';
        var bas=mapping.bas>=0?_parseDate(_cell(row,mapping.bas)):'';
        var bit=mapping.bit>=0?_parseDate(_cell(row,mapping.bit)):'';
        var notes=mapping.notes>=0?_cell(row,mapping.notes):'';
        var ex=list.find(function(t){return t.active&&t.unit===unit;});
        if(ex){
          if(name) ex.name=name; if(rent) ex.rent=rent;
          if(phone) ex.phone=phone; if(notes) ex.notes=notes;
          updated++;
        } else {
          var tid=bid+'_T'+String(Date.now()).slice(-5)+'_'+String(list.length+1).padStart(3,'0');
          list.push({id:tid,unit:unit,fl:floor,name:name,rent:rent,
            dep:dep,bas:bas,bit:bit,gun:1,sekil:'',active:true,notes:notes,phone:phone});
          imported++;
        }
      });
    } else if(mode==='payment'){
      validIdxs.forEach(function(ri){
        var row=data[ri];
        var bv=mapping.building>=0?_cell(row,mapping.building):'';
        var bid=_bldId(bv||targetBld);
        var unit=_cell(row,mapping.unit);
        var tname=mapping.name>=0?_cell(row,mapping.name):'';
        var moStr=_parseMonth(_cell(row,mapping.month));
        var paid=_num(_cell(row,mapping.paid));
        var date=mapping.date>=0?_parseDate(_cell(row,mapping.date)):'';
        var sekil=mapping.sekil>=0?_cell(row,mapping.sekil):'';
        var notes=mapping.notes>=0?_cell(row,mapping.notes):'';
        if(!moStr||isNaN(paid)){skipped++;return;}
        var tid=null;
        var searchBlds=bid?[bid]:Object.keys(DATA.tenants);
        for(var si=0;si<searchBlds.length;si++){
          var list=(DATA.tenants[searchBlds[si]])||[];
          var t=list.find(function(t){return t.active&&(
            (unit&&t.unit===unit)||(tname&&t.name&&t.name.toLowerCase()===tname.toLowerCase()));
          });
          if(t){tid=t.id;break;}
        }
        if(!tid){skipped++;return;}
        var wasPayment=DATA.payments[tid]&&DATA.payments[tid][moStr]&&DATA.payments[tid][moStr].paid>0;
        if(!DATA.payments[tid]) DATA.payments[tid]={};
        DATA.payments[tid][moStr]={paid:paid,date:date,sekil:sekil,notes:notes};
        if(wasPayment) updated++; else imported++;
      });
    } else if(mode==='expense'){
      validIdxs.forEach(function(ri){
        var row=data[ri];
        var bv=mapping.building>=0?_cell(row,mapping.building):'';
        var bid=_bldId(bv||targetBld); if(!bid){skipped++;return;}
        var moStr=_parseMonth(_cell(row,mapping.month));
        var amount=_num(_cell(row,mapping.amount));
        var cat=(_cell(row,mapping.category)||'DİĞER').toUpperCase();
        var date=mapping.date>=0?_parseDate(_cell(row,mapping.date)):'';
        var notes=mapping.notes>=0?_cell(row,mapping.notes):'';
        if(!moStr||isNaN(amount)||amount<0){skipped++;return;}
        if(!DATA.expenses[bid]) DATA.expenses[bid]={};
        if(!DATA.expenses[bid][moStr]) DATA.expenses[bid][moStr]=[];
        var dup=(DATA.expenses[bid][moStr]||[]).find(function(e){
          return e.tutar===amount&&e.tur===cat&&e.tarih===date;
        });
        if(dup){updated++;return;}
        DATA.expenses[bid][moStr].push({tur:cat,no:'',tutar:amount,tarih:date,notlar:notes});
        imported++;
      });
    }
    try{ALL_MONTHS=buildAllMonths();}catch(e){}
    try{syncBuildingConstants();}catch(e){}
    try{autoRecalc();}catch(e){}
    saveLocal();render();updateBadges();
    try{addHist('İçe aktarma: '+imported+' eklendi, '+updated+' güncellendi ('+_MODES[mode].label+')');}catch(e){}
    return{ok:true,imported:imported,updated:updated,skipped:skipped};
  }catch(err){
    DATA.tenants=snap.tenants;DATA.payments=snap.payments;
    DATA.expenses=snap.expenses;DATA.buildings=snap.buildings;
    return{ok:false,error:err.message};
  }
}

// ── Public: open / close ──────────────────────────────
// ── Lazy XLSX loader — script injected on first wizard open only ──────────
var _xlsxLoading=false,_xlsxLoaded=typeof XLSX!=='undefined';
function _loadXlsx(cb){
  if(_xlsxLoaded){cb(null);return;}
  if(_xlsxLoading){setTimeout(function(){_loadXlsx(cb);},80);return;}
  _xlsxLoading=true;
  var s=document.createElement('script');
  s.src='../node_modules/xlsx/dist/xlsx.full.min.js';
  s.onload=function(){_xlsxLoaded=true;_xlsxLoading=false;cb(null);};
  s.onerror=function(){_xlsxLoading=false;cb(new Error('XLSX kütüphanesi yüklenemedi — xlsx.full.min.js bulunamadı'));};
  document.head.appendChild(s);
}

window.openImportWizard=function(){
  _W={step:1,mode:'tenant',fileType:'',rows:[],headers:[],
      sheetNames:[],workbook:null,selectedSheet:'',
      mapping:{},targetBld:'',valResult:null};
  var overlay=document.getElementById('import-wiz-overlay');
  if(!overlay) return;
  overlay.classList.add('open');
  // Show loading state while XLSX library loads (first open only; instant on subsequent opens)
  var body=document.getElementById('wiz-body');
  if(body&&!_xlsxLoaded) body.innerHTML='<div style="text-align:center;padding:40px 20px;color:var(--i4)">⏳ İçe aktarma motoru yükleniyor…</div>';
  _loadXlsx(function(err){
    if(err){
      var b=document.getElementById('wiz-body');
      if(b) b.innerHTML='<div style="padding:20px;color:var(--rose-l)">❌ '+err.message+'<br><small style="color:var(--i4)">CSV dosyaları her zaman çalışır.</small></div>';
      // Still render wizard — CSV mode works without XLSX
      _wizRender();
      return;
    }
    _wizRender();
  });
};
window.closeImportWizard=function(){
  document.getElementById('import-wiz-overlay').classList.remove('open');
};

// ── File handling ─────────────────────────────────────
window.wizHandleFile=function(file){
  if(!file) return;
  _W.filename=file.name||'';
  var ext=file.name.toLowerCase().split('.').pop();
  _W.fileType=ext==='csv'?'csv':(ext==='xlsx'||ext==='xls')?'xlsx':'';
  if(!_W.fileType){toast('❌ CSV veya XLSX dosyası seçin','red');return;}
  var reader=new FileReader();
  reader.onload=function(e){
    try{
      if(_W.fileType==='csv'){
        _W.rows=_parseCsv(e.target.result);
        _W.headers=_W.rows[0]||[];
        _W.sheetNames=[];_W.workbook=null;_W.selectedSheet='';
      } else {
        if(typeof XLSX==='undefined'){toast('❌ XLSX kütüphanesi yüklenemedi','red');return;}
        var wb=_parseXlsx(new Uint8Array(e.target.result));
        _W.workbook=wb;_W.sheetNames=wb.SheetNames;
        _W.selectedSheet=wb.SheetNames[0]||'';
        _wizLoadSheet(_W.selectedSheet);
      }
      _W.mapping=_detectMapping(_W.headers,_W.mode);
      _W.step=2;
      _wizRender();
    }catch(err){toast('❌ Dosya okunamadı: '+err.message,'red');}
  };
  if(_W.fileType==='csv') reader.readAsText(file,'UTF-8');
  else reader.readAsArrayBuffer(file);
};
function _inferMode(sheetName,headers){
  var n=String(sheetName||'').toLowerCase();
  if(/[oö]deme|payment|tahsilat|collection/.test(n)) return 'payment';
  if(/gider|masraf|expense|\bcost/.test(n)) return 'expense';
  if(/kirac|tenant|m[üu][sş]teri|customer/.test(n)) return 'tenant';
  // Score each mode by how many of its required fields match headers
  var best='tenant',bestScore=-1;
  Object.keys(_MODES).forEach(function(mode){
    var fields=_MODES[mode].fields;
    var req=Object.keys(fields).filter(function(f){return fields[f].req;});
    var testMap=_detectMapping(headers,mode);
    var score=req.filter(function(f){return testMap[f]>=0;}).length;
    if(score>bestScore){bestScore=score;best=mode;}
  });
  return best;
}
function _wizLoadSheet(name){
  if(!_W.workbook) return;
  var rows=_sheetToRows(_W.workbook,name);
  _W.rows=rows;_W.headers=rows[0]||[];
  _W.mode=_inferMode(name,_W.headers);
  _W.mapping=_detectMapping(_W.headers,_W.mode);
  _W.valResult=null;
}
window.wizSelectSheet=function(name){_W.selectedSheet=name;_wizLoadSheet(name);_wizRender();};
window.wizSetMode=function(mode){
  _W.mode=mode;
  if(_W.headers.length) _W.mapping=_detectMapping(_W.headers,mode);
  _wizRender();
};
window.wizSetBld=function(id){_W.targetBld=id;};
window.wizSetMapping=function(field,idx){_W.mapping[field]=parseInt(idx,10);};
window.wizNext=function(){
  if(_W.step===4) _W.valResult=_validate(_W.rows,_W.mapping,_W.mode,_W.targetBld);
  if(_W.step<6){_W.step++;_wizRender();}
};
window.wizBack=function(){if(_W.step>1){_W.step--;_wizRender();}};
window.wizImport=function(){
  if(!_W.valResult) return;
  var warnCount=(_W.valResult.warns||[]).length;
  var errCount=(_W.valResult.errs||[]).length;
  if(typeof window.electron!=='undefined'&&window.electron&&window.electron.createBackup){
    try{window.electron.createBackup('pre-import');}catch(e){}
  }
  var snapId=_createSnapshot(_W.mode);
  var res=_doImport(_W.rows,_W.mapping,_W.mode,_W.targetBld,_W.valResult.valid);
  res.warnCount=warnCount;
  res.errCount=errCount;
  res.mode=_W.mode;
  if(res.ok){
    var _histEntry={
      id:'ih_'+Date.now()+'_'+(Math.random()*1e6|0),
      ts:new Date().toISOString(),
      mode:_W.mode,
      filename:_W.filename||'',
      sheet:_W.selectedSheet||'',
      imported:res.imported||0,
      updated:res.updated||0,
      skipped:res.skipped||0,
      warnCount:warnCount,
      errCount:errCount,
      snapshotId:snapId,
      user:(typeof currentUser!=='undefined'&&currentUser)?(currentUser.name||currentUser.id||''):'',
      rolledBack:false,
    };
    _recordImport(_histEntry);
    res.histId=_histEntry.id;
  }
  _wizShowResult(res);
};

function _kpi(label,color,val){
  return '<div style="min-width:82px;padding:10px 14px;background:rgba(0,0,0,.2);border:1px solid rgba(255,255,255,.07);border-radius:8px;text-align:center">'+
    '<div style="font-size:22px;font-weight:700;color:'+color+'">'+val+'</div>'+
    '<div style="font-size:10.5px;color:var(--i5);margin-top:3px">'+label+'</div>'+
    '</div>';
}

function _wizShowResult(res){
  var body=document.getElementById('wiz-body');
  var ftr=document.getElementById('wiz-ftr');
  if(!body) return;
  var _ML={
    tenant:{add:'Eklenen Kiracı',upd:'Güncellenen Kiracı'},
    payment:{add:'Eklenen Ödeme',upd:'Güncellenen Ödeme'},
    expense:{add:'Eklenen Gider',upd:'Güncellenen Gider'},
  };
  var ml=_ML[res.mode]||{add:'Eklenen',upd:'Güncellenen'};
  if(res.ok){
    body.innerHTML=
      '<div style="text-align:center;padding:16px 0 10px">'+
      '<div style="font-size:36px;margin-bottom:10px">✅</div>'+
      '<div style="font-size:17px;font-weight:700;color:var(--i1);margin-bottom:18px">İçe aktarma tamamlandı</div>'+
      '<div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:20px">'+
      _kpi(ml.add,'#22c55e',res.imported||0)+
      _kpi(ml.upd,'#60a5fa',res.updated||0)+
      _kpi('Atlanan','#f59e0b',(res.skipped||0)+(res.errCount||0))+
      (res.warnCount?_kpi('Uyarı','#f59e0b',res.warnCount):'')+
      (res.errCount?_kpi('Hata (atlandı)','#ef4444',res.errCount):'')+
      '</div>'+
      '<div style="font-size:11px;color:var(--i5);line-height:1.7">'+
      '💾 Yedek alındı'+
      (_W.filename?'&nbsp;·&nbsp;'+_W.filename:'')+
      (_W.selectedSheet?'&nbsp;/&nbsp;'+_W.selectedSheet:'')+
      '<br>↩ Araçlar &rarr; Import Geçmişi üzerinden geri alınabilir</div>'+
      '</div>';
    if(ftr) ftr.innerHTML='<div></div><button class="btn" onclick="window.closeImportWizard()">Kapat</button>';
  } else {
    body.innerHTML=
      '<div style="text-align:center;padding:20px 0">'+
      '<div style="font-size:36px;margin-bottom:10px">❌</div>'+
      '<div style="font-size:15px;font-weight:700;color:#fb7185;margin-bottom:12px">İçe aktarma başarısız</div>'+
      '<div style="padding:10px 14px;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.3);border-radius:8px;font-size:12px;color:#fca5a5;text-align:left;margin-bottom:14px;word-break:break-word">'+
      (res.error||'Bilinmeyen hata')+'</div>'+
      '<div style="font-size:11.5px;color:var(--i4)">Veriler otomatik olarak geri alındı.</div>'+
      '</div>';
    if(ftr) ftr.innerHTML=
      '<button class="btn btn-ghost" onclick="window.closeImportWizard()">Kapat</button>'+
      '<span></span>'+
      '<button class="btn" onclick="_W.step=6;_wizRender()">← Geri Dön</button>';
  }
}

// ── Render ────────────────────────────────────────────
function _wizRender(){
  var stepsEl=document.getElementById('wiz-steps');
  var body=document.getElementById('wiz-body');
  var ftr=document.getElementById('wiz-ftr');
  var sub=document.getElementById('wiz-hdr-sub');
  if(!body||!ftr) return;

  // Step bar
  if(stepsEl){
    stepsEl.innerHTML=_STEP_LABELS.map(function(lbl,i){
      var n=i+1;
      var cls='wiz-stp'+(n<_W.step?' done':n===_W.step?' active':'');
      return '<span class="'+cls+'">'+(_W.step>n?'✓ ':n+'. ')+lbl+'</span>'+
             (i<_STEP_LABELS.length-1?'<span class="wiz-stp-arrow">›</span>':'');
    }).join('');
  }
  if(sub) sub.textContent=_MODES[_W.mode].icon+' '+_MODES[_W.mode].label;
  body.innerHTML=_stepHTML();
  ftr.innerHTML=_ftrHTML();
  if(_W.step===1) _setupDrop();

  // Auto-select single building
  if(_W.step===2&&!_W.targetBld){
    var active=(DATA.buildings||[]).filter(function(b){return b.active;});
    if(active.length===1) _W.targetBld=active[0].id;
  }
}

function _stepHTML(){
  switch(_W.step){
    case 1: return _s1();
    case 2: return _s2();
    case 3: return _s3();
    case 4: return _s4();
    case 5: return _s5();
    case 6: return _s6();
    default:return '';
  }
}

function _ftrHTML(){
  var back=_W.step>1?'<button class="btn btn-ghost" onclick="wizBack()">← Geri</button>':'<div></div>';
  var next='';
  if(_W.step===1){
    next='<span style="font-size:11px;color:var(--i4)">Dosya yükleyince ilerler</span>';
  } else if(_W.step===4){
    var canNext=_W.rows.length>1&&Object.values(_W.mapping).some(function(v){return v>=0;});
    next='<button class="btn" '+(canNext?'':'disabled style="opacity:.4"')+' onclick="wizNext()">Doğrula →</button>';
  } else if(_W.step===5){
    var vc=_W.valResult?_W.valResult.valid.length:0;
    next=vc>0?'<button class="btn" onclick="wizNext()">İleri ('+vc+' kayıt) →</button>':
              '<button class="btn" disabled style="opacity:.4">Geçerli kayıt yok</button>';
  } else if(_W.step===6){
    var vc2=_W.valResult?_W.valResult.valid.length:0;
    next=vc2>0?'<button class="btn" style="background:#22c55e;color:#000;font-weight:700" onclick="wizImport()">✅ Onayla ve İçe Aktar</button>':
               '<button class="btn" disabled style="opacity:.4">İçe aktarılacak kayıt yok</button>';
  } else {
    var can=_W.rows.length>1;
    next='<button class="btn" '+(can?'':'disabled style="opacity:.4"')+' onclick="wizNext()">İleri →</button>';
  }
  return back+'<span style="font-size:11px;color:var(--i4)">'+_W.step+' / 6</span>'+next;
}

// ── Step 1: Upload ────────────────────────────────────
function _s1(){
  return '<div style="text-align:center;padding:10px 0 16px">'+
    '<p style="font-size:12.5px;color:var(--i3);margin-bottom:20px;line-height:1.6">'+
    'Kiracı, ödeme veya gider verilerini CSV ya da XLSX dosyasından içe aktarın.<br>'+
    '<span style="color:var(--i5);font-size:11px">Kayıtlar önizlenir, doğrulanır ve onayınızla eklenir.</span></p>'+
    '<div class="wiz-drop" id="wiz-drop" onclick="document.getElementById(\'wiz-file\').click()">'+
      '<div style="font-size:38px;margin-bottom:12px">📁</div>'+
      '<div style="font-size:13px;font-weight:600;color:var(--i1)">CSV veya XLSX dosyası seçin</div>'+
      '<div style="font-size:11px;color:var(--i4);margin-top:6px">Tıklayın veya sürükleyin</div>'+
      '<input type="file" id="wiz-file" accept=".csv,.xlsx,.xls" style="display:none"'+
      ' onchange="wizHandleFile(this.files[0])">'+
    '</div>'+
    '<div style="margin-top:18px;font-size:11px;color:var(--i5);line-height:1.9">'+
    '<b style="color:var(--i3)">Kiracı:</b> ad, daire, kira &nbsp;·&nbsp; '+
    '<b style="color:var(--i3)">Ödeme:</b> daire, tutar, dönem &nbsp;·&nbsp; '+
    '<b style="color:var(--i3)">Gider:</b> bina, kategori, tutar, dönem</div></div>';
}

// ── Step 2: Configure ─────────────────────────────────
function _s2(){
  var modes=Object.keys(_MODES).map(function(k){
    var m=_MODES[k];
    var sel=k===_W.mode;
    return '<button class="btn'+(sel?'':' btn-ghost')+'" style="flex:1;padding:10px 8px;font-size:12px"'+
           ' onclick="wizSetMode(\''+k+'\')">'+m.icon+' '+m.label+'</button>';
  }).join('');

  var sheetSel='';
  if(_W.sheetNames.length>1){
    sheetSel='<div style="margin-top:18px">'+
      '<div style="font-size:11.5px;font-weight:600;color:var(--i3);margin-bottom:8px">Sayfa Seçimi</div>'+
      '<div style="display:flex;gap:8px;flex-wrap:wrap">'+
      _W.sheetNames.map(function(s){
        return '<button class="btn'+(s===_W.selectedSheet?'':' btn-ghost')+'" style="font-size:12px;padding:6px 14px"'+
               ' onclick="wizSelectSheet(\''+s.replace(/'/g,"\\'")+'\')" >'+s+'</button>';
      }).join('')+'</div></div>';
  }

  var active=(DATA.buildings||[]).filter(function(b){return b.active;});
  var bldSel='';
  if(active.length>1){
    bldSel='<div style="margin-top:18px">'+
      '<div style="font-size:11.5px;font-weight:600;color:var(--i3);margin-bottom:6px">'+
      'Hedef Bina <span style="font-weight:400;color:var(--i5)">(sütunda belirtilmemişse)</span></div>'+
      '<select class="form-select" style="max-width:320px" onchange="wizSetBld(this.value)">'+
      '<option value="">— Sütundan oku —</option>'+
      active.map(function(b){
        return '<option value="'+b.id+'"'+(b.id===_W.targetBld?' selected':'')+'>'+b.name+'</option>';
      }).join('')+
      '</select></div>';
  }

  var rowCount=Math.max(0,_W.rows.length-1);
  return '<div>'+
    '<div style="font-size:11.5px;font-weight:600;color:var(--i3);margin-bottom:10px">İçe Aktarma Türü</div>'+
    '<div style="display:flex;gap:8px;flex-wrap:wrap">'+modes+'</div>'+
    sheetSel+bldSel+
    '<div style="margin-top:18px;padding:12px 14px;background:rgba(59,130,246,.06);border:1px solid rgba(59,130,246,.18);border-radius:8px;font-size:12px;color:var(--i3)">'+
    '📄 <b style="color:var(--i2)">'+_W.fileType.toUpperCase()+'</b> yüklendi — '+
    '<b style="color:#60a5fa">'+rowCount+'</b> veri satırı, '+
    '<b style="color:#60a5fa">'+_W.headers.length+'</b> sütun</div></div>';
}

// ── Step 3: Preview ───────────────────────────────────
function _s3(){
  var preview=_W.rows.slice(0,11);
  var MAX=8,cols=_W.headers.length,show=Math.min(cols,MAX);
  // Reverse map: col index → field label for highlights
  var colMap={};
  Object.keys(_W.mapping).forEach(function(f){
    var ci=_W.mapping[f];
    if(ci>=0) colMap[ci]=(_MODES[_W.mode].fields[f]||{}).label||f;
  });
  // Detection hint list
  var detected=Object.keys(_W.mapping).filter(function(f){return _W.mapping[f]>=0;})
    .map(function(f){
      var ci=_W.mapping[f];
      var hdr=_W.headers[ci]||('Sütun '+(ci+1));
      var lbl=(_MODES[_W.mode].fields[f]||{}).label||f;
      return '<span style="color:#60a5fa">'+lbl+'</span>→<span style="color:var(--i3)">'+hdr+'</span>';
    });
  return '<div>'+
    '<div style="font-size:11px;color:var(--i4);margin-bottom:10px">'+
    'İlk '+(preview.length-1)+' satır gösteriliyor ('+Math.max(0,_W.rows.length-1)+' toplam)</div>'+
    '<div style="overflow-x:auto"><table class="wiz-tbl"><thead><tr>'+
    '<th style="color:var(--i5);width:28px">#</th>'+
    _W.headers.slice(0,show).map(function(h,i){
      var mapped=colMap[i];
      return '<th style="'+(mapped?'color:#60a5fa;':'')+'">'+
        (mapped?'✓ ':''+(h||'Sütun '+(i+1)))+
        (mapped?'<br><span style="font-size:9px;opacity:.7">'+mapped+'</span>':'')+
        '</th>';
    }).join('')+
    (cols>MAX?'<th style="color:var(--i5)">+'+(cols-MAX)+'…</th>':'')+
    '</tr></thead><tbody>'+
    preview.slice(1).map(function(row,ri){
      return '<tr><td style="color:var(--i5)">'+(ri+2)+'</td>'+
        row.slice(0,show).map(function(c,i){
          return '<td style="'+(colMap[i]?'background:rgba(59,130,246,.06)':'')+'">'+String(c||'').slice(0,35)+'</td>';
        }).join('')+
        (cols>MAX?'<td style="color:var(--i5)">…</td>':'')+
        '</tr>';
    }).join('')+
    '</tbody></table></div>'+
    (detected.length?
      '<div style="margin-top:10px;padding:8px 12px;background:rgba(59,130,246,.06);border-radius:6px;font-size:11px;color:var(--i4)">'+
      '🔍 Otomatik eşleşme: '+detected.join(' &nbsp;·&nbsp; ')+'</div>':'')
    +'</div>';
}

// ── Step 4: Map columns ───────────────────────────────
function _s4(){
  var fields=_MODES[_W.mode].fields;
  var baseOpts='<option value="-1">— Kullanılmıyor —</option>'+
    _W.headers.map(function(h,i){return '<option value="'+i+'">'+(h||'Sütun '+(i+1))+'</option>';}).join('');

  var rows=Object.keys(fields).map(function(field){
    var def=fields[field];
    var cur=(_W.mapping[field]!==undefined)?_W.mapping[field]:-1;
    var ex=cur>=0&&_W.rows[1]?String(_W.rows[1][cur]||'').slice(0,28):'';
    var opts=baseOpts.replace('value="'+cur+'"','value="'+cur+'" selected');
    return '<tr>'+
      '<td><span style="color:var(--i2)">'+def.label+'</span>'+
      (def.req?'<span style="color:#ef4444;font-size:10px"> *</span>':'')+
      '</td>'+
      '<td><select class="wiz-sel" onchange="wizSetMapping(\''+field+'\',this.value)">'+opts+'</select></td>'+
      '<td style="color:var(--i5);font-size:11px">'+ex+'</td>'+
      '</tr>';
  }).join('');

  return '<div>'+
    '<div style="font-size:11.5px;color:var(--i3);margin-bottom:12px">'+
    'Dosya sütunlarını KTP alanlarıyla eşleştirin. <span style="color:#ef4444">*</span> zorunlu</div>'+
    '<table class="wiz-tbl"><thead><tr><th>KTP Alanı</th><th>Dosya Sütunu</th><th>Örnek</th></tr></thead>'+
    '<tbody>'+rows+'</tbody></table></div>';
}

// ── Step 5: Validate ──────────────────────────────────
function _s5(){
  var vr=_W.valResult;
  if(!vr) return '<div style="color:var(--i4);padding:20px">Doğrulanıyor…</div>';
  var allIssues=[].concat(vr.errs,vr.warns).slice(0,25);
  var issueRows=allIssues.map(function(group){
    return group.issues.map(function(iss){
      return '<tr><td style="color:var(--i5)">'+group.row+'</td>'+
        '<td>'+iss.msg+'</td>'+
        '<td><span class="'+(iss.t==='err'?'val-err':'val-warn')+'">'+
        (iss.t==='err'?'Hata':'Uyarı')+'</span></td></tr>';
    }).join('');
  }).join('');

  return '<div>'+
    '<div style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:16px">'+
    '<div style="font-size:13px"><span class="val-ok" style="font-size:16px">✓</span> '+
    '<b>'+vr.valid.length+'</b> geçerli</div>'+
    (vr.warns.length?'<div style="font-size:13px"><span class="val-warn" style="font-size:16px">⚠</span> '+
    '<b>'+vr.warns.length+'</b> uyarı (dahil edilecek)</div>':'')+
    (vr.errs.length?'<div style="font-size:13px"><span class="val-err" style="font-size:16px">✗</span> '+
    '<b>'+vr.errs.length+'</b> hata (atlanacak)</div>':'')+
    '</div>'+
    (vr.valid.length===0?'<div style="text-align:center;padding:20px;color:var(--i4)">'+
    '⚠ Geçerli satır bulunamadı. Sütun eşleştirmesini kontrol edin.</div>':'')+
    (issueRows?'<div style="font-size:11.5px;font-weight:600;color:var(--i3);margin-bottom:8px">Sorunlar</div>'+
    '<table class="wiz-tbl"><thead><tr><th>Satır</th><th>Açıklama</th><th>Tür</th></tr></thead>'+
    '<tbody>'+issueRows+'</tbody></table>':'')+
    '</div>';
}

// ── Step 6: Confirm ───────────────────────────────────
function _s6(){
  var vr=_W.valResult,m=_MODES[_W.mode];
  var bld=_W.targetBld?(DATA.buildings||[]).find(function(b){return b.id===_W.targetBld;}):null;
  var vc=vr?vr.valid.length:0;
  return '<div style="text-align:center;padding:10px 0">'+
    '<div style="font-size:36px;margin-bottom:14px">'+m.icon+'</div>'+
    '<div style="font-size:18px;font-weight:700;color:var(--i1);margin-bottom:8px">'+
    vc+' kayıt içe aktarılacak</div>'+
    '<div style="font-size:12.5px;color:var(--i3);line-height:2;margin-bottom:18px">'+
    'Tür: <b style="color:var(--i2)">'+m.label+'</b><br>'+
    (bld?'Bina: <b style="color:var(--i2)">'+bld.name+'</b><br>':'')+
    (vr&&vr.errs.length?'<span class="val-warn">⚠ '+vr.errs.length+' hatalı satır atlanacak</span><br>':'')+
    (vr&&vr.warns.length?'<span class="val-warn">'+vr.warns.length+' uyarılı satır dahil edilecek</span><br>':'')+
    '</div>'+
    '<div style="padding:12px 16px;background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.25);border-radius:8px;font-size:12px;color:var(--i3);margin-bottom:10px">'+
    '💾 İçe aktarma öncesi otomatik yedek alınır.</div>'+
    '<div style="padding:10px 16px;background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.2);border-radius:8px;font-size:11.5px;color:var(--i4)">'+
    '⚠ Bu işlem mevcut kiracı/ödeme verilerini değiştirebilir. Hata durumunda otomatik geri alınır.</div>'+
    '</div>';
}

// ── Drag & drop setup ─────────────────────────────────
function _setupDrop(){
  var el=document.getElementById('wiz-drop'); if(!el) return;
  el.ondragover=function(e){e.preventDefault();el.classList.add('drag-over');};
  el.ondragleave=function(){el.classList.remove('drag-over');};
  el.ondrop=function(e){
    e.preventDefault();el.classList.remove('drag-over');
    var f=e.dataTransfer&&e.dataTransfer.files[0]; if(f) wizHandleFile(f);
  };
}

// ── Import Snapshots ──────────────────────────────────
var _SNAP_MAX=20;
function _createSnapshot(mode){
  if(!Array.isArray(DATA.importSnapshots)) DATA.importSnapshots=[];
  var id='snap_'+Date.now()+'_'+(Math.random()*1e6|0);
  var snap={id:id,ts:new Date().toISOString(),mode:mode,data:{}};
  try{
    if(mode==='tenant'){
      snap.data.tenants=JSON.parse(JSON.stringify(DATA.tenants));
      snap.data.buildings=JSON.parse(JSON.stringify(DATA.buildings||[]));
    } else if(mode==='payment'){
      snap.data.payments=JSON.parse(JSON.stringify(DATA.payments));
    } else if(mode==='expense'){
      snap.data.expenses=JSON.parse(JSON.stringify(DATA.expenses));
    }
  }catch(e){return null;}
  DATA.importSnapshots.unshift(snap);
  DATA.importSnapshots=DATA.importSnapshots.slice(0,_SNAP_MAX);
  saveLocal();
  return id;
}
function _recordImport(entry){
  if(!Array.isArray(DATA.importHistory)) DATA.importHistory=[];
  DATA.importHistory.unshift(entry);
  DATA.importHistory=DATA.importHistory.slice(0,100);
  saveLocal();
}

// ── Import History Modal ──────────────────────────────
window.openImportHistory=function(){
  var ov=document.getElementById('import-hist-overlay');
  if(!ov) return;
  ov.style.display='flex';
  _renderImportHistory();
};
window.closeImportHistory=function(){
  var ov=document.getElementById('import-hist-overlay');
  if(ov) ov.style.display='none';
};
function _renderImportHistory(){
  var body=document.getElementById('import-hist-body');
  if(!body) return;
  var hist=Array.isArray(DATA.importHistory)?DATA.importHistory:[];
  if(!hist.length){
    body.innerHTML='<div style="text-align:center;padding:40px 20px;color:var(--i5);font-size:13px">Henüz import yapılmadı.</div>';
    return;
  }
  var mIcon={tenant:'🏠',payment:'💳',expense:'💸'};
  var snaps=Array.isArray(DATA.importSnapshots)?DATA.importSnapshots:[];
  body.innerHTML=hist.map(function(h){
    var hasSnap=!!(h.snapshotId&&snaps.some(function(s){return s.id===h.snapshotId;}));
    var rolledBack=!!h.rolledBack;
    var ts=h.ts?new Date(h.ts).toLocaleString('tr-TR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}):'';
    var bgc=rolledBack?'rgba(100,116,139,.08)':h.errCount>0?'rgba(239,68,68,.06)':h.warnCount>0?'rgba(245,158,11,.06)':'rgba(34,197,94,.04)';
    var bdc=rolledBack?'rgba(100,116,139,.2)':h.errCount>0?'rgba(239,68,68,.25)':h.warnCount>0?'rgba(245,158,11,.25)':'rgba(34,197,94,.2)';
    return '<div style="background:'+bgc+';border:1px solid '+bdc+';border-radius:8px;padding:10px 12px;margin-bottom:8px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">'
      +'<span style="font-size:16px">'+(mIcon[h.mode]||'📦')+'</span>'
      +'<div style="flex:1;min-width:0">'
        +'<div style="font-size:12px;font-weight:600;color:'+(rolledBack?'var(--i4)':'var(--i2)')+';white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+(h.filename||'—')+(h.sheet?' · '+h.sheet:'')+(rolledBack?' <span style="color:var(--i5)">(geri alındı)</span>':'')+'</div>'
        +'<div style="font-size:11px;color:var(--i4);margin-top:2px">'+ts
          +' · <b style="color:#22c55e">+'+h.imported+'</b>'
          +(h.updated?' <b style="color:#60a5fa">~'+h.updated+'</b>':'')
          +(h.skipped?' <span style="color:#f59e0b">∅'+h.skipped+'</span>':'')
          +(h.errCount?' <span style="color:#ef4444">✗'+h.errCount+'</span>':'')
          +(h.user?' · '+h.user:'')
        +'</div>'
      +'</div>'
      +(!rolledBack&&hasSnap
        ?'<button onclick="rollbackImport(\''+h.id+'\',\''+h.snapshotId+'\')" style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);color:#fca5a5;font-size:11px;padding:5px 10px;border-radius:6px;cursor:pointer;white-space:nowrap;flex-shrink:0">↩ Geri Al</button>'
        :'<span style="font-size:10.5px;color:var(--i5);padding:4px 8px;flex-shrink:0">'+(rolledBack?'—':' Snapshot yok')+'</span>')
      +'</div>';
  }).join('');
}
window.rollbackImport=function(histId,snapshotId){
  if(!confirm('Bu import geri alınacak. Etkilenen veriler önceki duruma döner.\n\nEmin misiniz?')) return;
  var snaps=Array.isArray(DATA.importSnapshots)?DATA.importSnapshots:[];
  var snap=snaps.find(function(s){return s.id===snapshotId;});
  if(!snap){try{toast('❌ Snapshot bulunamadı — geri alma iptal','red');}catch(e){}return;}
  try{
    if(snap.data.tenants!==undefined)   DATA.tenants   =JSON.parse(JSON.stringify(snap.data.tenants));
    if(snap.data.buildings!==undefined) DATA.buildings =JSON.parse(JSON.stringify(snap.data.buildings));
    if(snap.data.payments!==undefined)  DATA.payments  =JSON.parse(JSON.stringify(snap.data.payments));
    if(snap.data.expenses!==undefined)  DATA.expenses  =JSON.parse(JSON.stringify(snap.data.expenses));
    var rec=(DATA.importHistory||[]).find(function(h){return h.id===histId;});
    if(rec) rec.rolledBack=true;
    try{syncBuildingConstants();}catch(e){}
    try{autoRecalc();}catch(e){}
    saveLocal();
    try{render();}catch(e){}
    try{updateBadges();}catch(e){}
    try{toast('↩ Import geri alındı','green');}catch(e){}
    _renderImportHistory();
  }catch(err){
    try{toast('❌ Geri alma başarısız: '+err.message,'red');}catch(e){}
  }
};

})();}catch(e){console.error('[ImportWizard]',e);}

</script>
</body>
</html>
