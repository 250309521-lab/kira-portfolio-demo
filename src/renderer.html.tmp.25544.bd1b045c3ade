  <div class="form-row">
    <label class="form-label">${t('settingsAutoSave')}</label>
    <select class="form-select" id="s_auto" ${!isA?'disabled':''}>
      <option value="1" ${DATA.settings?.autoSave?'selected':''}>${t('settingsAutoOn')}</option>
      <option value="0" ${!DATA.settings?.autoSave?'selected':''}>${t('settingsAutoOff')}</option>
    </select>
  </div>

  <div class="form-row">
    <label class="form-label">${t('settingsCurrency')}</label>
    <select class="form-select" id="s_currency" ${!isA?'disabled':''}>
      <option value="TRY" ${(DATA.settings?.currency||'TRY')==='TRY'?'selected':''}>₺ TRY — Türk Lirası</option>
      <option value="USD" ${DATA.settings?.currency==='USD'?'selected':''}>$ USD — US Dollar</option>
    </select>
  </div>

  <div class="div-line"></div>
  <div style="font-size:12px;font-weight:700;color:var(--i2);margin-bottom:10px">${t('settingsDataSection')}</div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px">
    <button class="btn btn-ghost btn-sm" onclick="exportJSON()">📤 JSON ${t('navExportJSON').replace('JSON ','')}</button>
