      <div class="fab-item-icon" style="background:rgba(245,158,11,.15)">💸</div><span id="fab-lbl-exp">Gider Ekle</span>
    </button>
    <button class="fab-item" onclick="openModal('ten-add','');closeFAB()">
      <div class="fab-item-icon" style="background:rgba(16,185,129,.15)">👤</div><span id="fab-lbl-ten">Kiracı Ekle</span>
    </button>
    <button class="fab-item" onclick="openCMD();closeFAB()">
      <div class="fab-item-icon" style="background:rgba(139,92,246,.15)">⌘</div><span id="fab-lbl-cmd">Komut Paleti</span>
    </button>
  </div>
  <button id="fab-main" onclick="toggleFAB()" title="Hızlı İşlem">+</button>
</div>

<!-- TOAST -->
<div id="toast"></div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
'use strict';
// ═══════════════════════════════════════════════
// CONSTANTS
// ═══════════════════════════════════════════════
const MONTHS=['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
const MONTHS_EN=['January','February','March','April','May','June','July','August','September','October','November','December'];
const MONTHS_EN_SHORT=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

// Convert internal TR month key ("Nisan 2026") to display label in current language
function monthLabel(mKey){
  if(!mKey) return mKey;
  var parts=mKey.split(' ');
  if(parts.length!==2) return mKey;
  var trName=parts[0],year=parts[1];
  var idx=MONTHS.indexOf(trName);
  if(idx<0) return mKey;
  var lang=(DATA&&DATA.settings&&DATA.settings.lang)||'tr';
  return lang==='en'?(MONTHS_EN[idx]+' '+year):mKey;
}
// Short 3-letter label for month bar buttons
function monthLabelShort(trName){
  var idx=MONTHS.indexOf(trName);
  if(idx<0) return trName.slice(0,3);
  var lang=(DATA&&DATA.settings&&DATA.settings.lang)||'tr';
  return lang==='en'?MONTHS_EN_SHORT[idx]:trName.slice(0,3);
}

// ── Boot stage tracker ─────────────────────────────────────────────────────
window.__BOOT_STAGE__={stage:'parse',ts:Date.now(),detail:''};
function __boot(stage,detail){
  window.__BOOT_STAGE__={stage:stage,ts:Date.now(),detail:detail||''};
  console.log('[BOOT]',stage,detail||'');
}
__boot('parse','script evaluation started');

// ── Dynamic month range: 5 years back · 10 years forward · all DATA months ──
function buildAllMonths(extra){
  const now=new Date();
  const sy=now.getFullYear()-5, ey=now.getFullYear()+10;
  const set=new Set();
  for(let y=sy;y<=ey;y++) MONTHS.forEach(m=>set.add(m+' '+y));
  // Scan DATA for months outside the base range (import/restore compatibility)
  try{
    if(typeof DATA!=='undefined'&&DATA){
      const scan=o=>{if(o&&typeof o==='object')Object.keys(o).forEach(k=>{
        if(/^[A-Za-zÀ-ɏ]+ \d{4}$/.test(k)) set.add(k);
        else if(k&&typeof o[k]==='object') scan(o[k]);
      });};
      scan(DATA.payments);scan(DATA.expenses);
      scan(DATA.alper);scan(DATA.tanNet);scan(DATA.gayNet);
    }
  }catch(e){}
  if(extra) extra.forEach(m=>{if(m&&typeof m==='string') set.add(m);});
  try{ if(typeof S!=='undefined'&&S&&S.month) set.add(S.month); }catch(e){}
  const midx=m=>{const p=m.split(' ');return parseInt(p[1]||0)*12+MONTHS.indexOf(p[0]);};
  return [...set].sort((a,b)=>midx(a)-midx(b));
}
let ALL_MONTHS=buildAllMonths();
const SEKIL=['Banka','Elden','IBAN','Global','Nakit','Diğer'];
const GKAT=['Elektrik','Doğalgaz','Su (İSKİ)','İnternet','Merdiven Temizlik','Asansör Servis','DASK','Depozito İade','Tamirat','Diğer'];

// false = demo data (v5 behaviour); true = empty production start
const PRODUCTION_MODE = true;
const KTP_VERSION = 6;

let BK=['BINA1','BINA2','BINA3'];
const BL={BINA1:'Bina 1',BINA2:'Bina 2',BINA3:'Bina 3'};
const BS={BINA1:'B1',BINA2:'B2',BINA3:'B3'};
let _lastSekil='Banka';  // persists last payment method across modal opens
let _lastExpTur='';      // persists last expense category across modal opens

// ═══════════════════════════════════════════════
// USERS (multi-user with PIN)
// ═══════════════════════════════════════════════
const DEFAULT_USERS=[
  {id:'admin', name:'Yönetici',  role:'admin',   pin:'1234', color:'#4a8af4', avatar:'Y'},
  {id:'mudur', name:'Müdür',     role:'manager', pin:'5678', color:'#7b6cf6', avatar:'M'},
  {id:'gorucu',name:'Görüntüleyici', role:'viewer', pin:'9999', color:'#06d6a0', avatar:'G'},
];
let USERS=[];
let currentUser=null;
let loginSelectedUser=null;

// ═══════════════════════════════════════════════
// DATA
// ═══════════════════════════════════════════════

const BASE_PAYMENTS={'D1':{'Ocak 2025':{paid:20000,date:'2025-01-05',sekil:'',notes:''}},'D2':{'Ocak 2025':{paid:18000,date:'2025-01-06',sekil:'',notes:''}},'D3':{'Ocak 2025':{paid:15000,date:'2025-01-07',sekil:'',notes:''}},'D4':{'Ocak 2025':{paid:15000,date:'2025-01-08',sekil:'',notes:''}}};
const BASE_EXPENSES={'BINA1':{'Ocak 2025':[{tur:'ELEKTRİK',no:'',tutar:2000,tarih:'2025-01-15',notlar:''}]},'BINA2':{'Ocak 2025':[{tur:'ELEKTRİK',no:'',tutar:1500,tarih:'2025-01-15',notlar:''}]},'BINA3':{'Ocak 2025':[{tur:'ELEKTRİK',no:'',tutar:1000,tarih:'2025-01-15',notlar:''}]}};
const BASE_TENANTS={'BINA1':[{id:'D1',unit:'D1',fl:'1.KAT',name:'Demo Kiracı 1',rent:20000,dep:20000,bas:'2025-01-01',bit:'',gun:1,sekil:'',active:true,notes:'',phone:''},{id:'D2',unit:'D2',fl:'2.KAT',name:'Demo Kiracı 2',rent:18000,dep:18000,bas:'2025-01-01',bit:'',gun:1,sekil:'',active:true,notes:'',phone:''}],'BINA2':[{id:'D3',unit:'D1',fl:'',name:'Demo Kiracı 3',rent:18000,dep:18000,bas:'2025-01-01',bit:'',gun:1,sekil:'',active:true,notes:'',phone:''}],'BINA3':[{id:'D4',unit:'D1',fl:'',name:'Demo Kiracı 4',rent:15000,dep:15000,bas:'2025-01-01',bit:'',gun:1,sekil:'',active:true,notes:'',phone:''}]};

// ── Alper table (demo) ───────────────────────────────────
const BASE_ALPER={
  'Ocak 2025':  {net:30000, col:38000, exp:8000},
};

// ── TAN SOKAK net (demo) ─────────────────────────────────
const BASE_TANNET={
  'Ocak 2025':  {net:14000, col:15000, exp:1000, kur:30.0, eur:466.67},
};

// ── GAYRETTEPE net (demo) ────────────────────────────────
const BASE_GAYNET={
  'Ocak 2025':  {net:36000, col:40000, exp:4000, kur:30.0, eur:1200.0},
};

// ── WA LOG ───────────────────────────────────────────────
let WA_LOG=[];

// ── LIVE DATA ────────────────────────────────────────────
function initData(){
  if(!PRODUCTION_MODE){
    return {
      buildings: BK.map((b,i)=>({id:b,name:BL[b],short:BS[b],color:'',active:true,order:i,metadata:{}})),
      tenants:   JSON.parse(JSON.stringify(BASE_TENANTS)),
      payments:  JSON.parse(JSON.stringify(BASE_PAYMENTS)),
      expenses:  JSON.parse(JSON.stringify(BASE_EXPENSES)),
      alper:     JSON.parse(JSON.stringify(BASE_ALPER)),
      tanNet:    JSON.parse(JSON.stringify(BASE_TANNET)),
      gayNet:    JSON.parse(JSON.stringify(BASE_GAYNET)),
      history:   [],
      cloud:{
        url:'',key:'',token:'',enabled:false,lastSync:'',
        serverUrl:'',username:'',serverVersion:0,
        supabaseUrl:'',supabaseKey:'',
        mode:'supabase',
      },
      settings:  {autoSave:true,lang:'tr',theme:'dark',currency:'TRY'},
      waLog:     [],
      users:     JSON.parse(JSON.stringify(DEFAULT_USERS)),
    };
  }
  return {
    initialized: false,
    buildings: [],
    tenants:   {},
    payments:  {},
    expenses:  {},
    alper:     {},
    tanNet:    {},
    gayNet:    {},
    history:   [],
    cloud:{
      url:'',key:'',token:'',enabled:false,lastSync:'',
      serverUrl:'',username:'',serverVersion:0,
      supabaseUrl:'',supabaseKey:'',
      mode:'supabase',
    },
    settings:  {autoSave:true,lang:'tr',theme:'dark',currency:'TRY'},
    waLog:     [],
    users:     [],
  };
}
let DATA=initData();

// ═══════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════
let S={
  page:'dash', bld:null,
  month:'Nisan 2026',
  search:'',
  filter:'',   // status filter: ''|'overdue'|'unpaid'|'partial'|'paid'|'vacant'
  syncing:false,
};

// ═══════════════════════════════════════════════
// PERSISTENCE
// ═══════════════════════════════════════════════
const LSKEY='ktp_v5';

function loadLocal(){
  try{
    const raw=localStorage.getItem(LSKEY);
    if(!raw) return;
    const p=JSON.parse(raw);
    if(p.tenants)  DATA.tenants  = p.tenants;
    if(p.payments) DATA.payments = p.payments;
    if(p.expenses) DATA.expenses = p.expenses;
    if(p.alper)    DATA.alper    = p.alper;
    if(p.tanNet)   DATA.tanNet   = p.tanNet;
    if(p.gayNet)   DATA.gayNet   = p.gayNet;
    if(p.history)         DATA.history         = p.history;
    if(p.importHistory)   DATA.importHistory   = p.importHistory;
    if(p.importSnapshots) DATA.importSnapshots = p.importSnapshots;
    if(p.cloud)    DATA.cloud    = p.cloud;
    if(p.settings) DATA.settings = p.settings;
    if(p.waLog)    DATA.waLog    = p.waLog;
    if(p.users)    DATA.users    = p.users;
    if(p.initialized!==undefined) DATA.initialized = p.initialized;
    // Phase 3: restore buildings or migrate from legacy tenant keys
    if(p.buildings){
      DATA.buildings = p.buildings;
    } else {
      DATA.buildings = Object.keys(DATA.tenants).map((k,i)=>({
        id:    k,
        name:  BL[k]||k,
        short: BS[k]||k.replace(/[^A-Z]/g,'').slice(0,3)||String.fromCharCode(65+i),
        color: '',
        active:true,
        order: i,
        metadata:{}
      }));
    }
  }catch(e){
    console.error('loadLocal',e);
    try{localStorage.setItem('ktp_v5_corrupt_backup',raw);}catch{}
    window._ktpCorruptWarn='⚠️ Kayıtlı veri bozuk — ktp_v5_corrupt_backup anahtarına kopyalandı. Uygulama boş veriyle başlatıldı.';
  }
}

function syncBuildingConstants(){
  const active=safeArr(DATA.buildings).filter(b=>b&&b.active).sort((a,b)=>a.order-b.order);
  BK.length=0;
  BK.push(...active.map(b=>b.id));
  active.forEach(b=>{ BL[b.id]=b.name; BS[b.id]=b.short||b.id; });
}

function saveLocal(){
  try{
    localStorage.setItem(LSKEY, JSON.stringify(DATA));
    const t=new Date();
    const lbl=document.getElementById('save-lbl');
    if(lbl) lbl.textContent=`Kaydedildi ${t.getHours().toString().padStart(2,'0')}:${t.getMinutes().toString().padStart(2,'0')}`;
  }catch(e){console.error('saveLocal',e);}
}

function manualSave(){saveLocal();toast('💾 Kaydedildi','green');}

function resetAllData(){
  openMod('reset-data');
}
function _doResetAllData(){
  const inp=document.getElementById('reset-confirm-inp');
  if(!inp||inp.value!==t('resetConfirmWord')) return;
  window._lastResetSnapshot = JSON.stringify(DATA);
  localStorage.removeItem(LSKEY);
  closeMod();
  toast('🗑 Veriler silindi — yeniden başlatılıyor...','red');
  setTimeout(()=>location.reload(), 900);
}

function toggleSidebar(){
  const collapsed=document.body.classList.toggle('sb-collapsed');
  const btn=document.getElementById('sb-toggle');
  if(btn)btn.innerHTML=collapsed?'▶':'◀ Daralt';
}

function addHist(desc){
  const user=currentUser?currentUser.name:'Sistem';
  DATA.history.unshift({t:new Date().toLocaleString('tr-TR'),desc,user});
  if(DATA.history.length>500) DATA.history.length=500;
  saveLocal();
}

// ═══════════════════════════════════════════════
// CLOUD SYNC
// ═══════════════════════════════════════════════
async function cloudSync(dir='push'){
  const url = DATA.cloud.url;
  const token = DATA.cloud.token || DATA.cloud.key; // support both auth methods
  if(!url){ toast('⚠️ Bulut URL eksik','red'); return; }
  S.syncing=true; updateCloudUI();

  try{
    // ── v2: token-based auth (new server) ──────────────────
    const headers = {
      'Content-Type':'application/json',
      'Authorization': token ? 'Bearer '+token : ''
    };

    if(dir==='push'){
      const payload = {
        tenants:DATA.tenants, payments:DATA.payments,
        expenses:DATA.expenses, alper:DATA.alper,
        history:DATA.history, waLog:DATA.waLog,
        users:DATA.users, settings:DATA.settings
      };
      const body = JSON.stringify({
        payload,
        clientVersion: DATA.cloud.serverVersion || 0
      });
      const r = await fetchWithRetry(url+'/sync', {
        method:'POST', headers, body
      });
      if(r.status===409){
        // Conflict — pull first, then user can retry
        const conflictData = await r.json();
        toast('⚠️ Çakışma: sunucu daha yeni (v'+conflictData.serverVersion+'). Pull ile güncelle.','red');
        addHist('Bulut çakışma: sunucu v'+conflictData.serverVersion+', istemci v'+conflictData.clientVersion);
        S.syncing=false; updateCloudUI(); return;
      }
      if(!r.ok) throw new Error('HTTP '+r.status+' '+(await r.text().catch(()=>'')));
      const res = await r.json();
      DATA.cloud.serverVersion = res.version;
      DATA.cloud.lastSync = new Date().toISOString();
      DATA.cloud.enabled = true;
      saveLocal();
      toast('☁️ Push tamam (v'+res.version+')','blue');
      addHist('Bulut push: v'+res.version+' ('+Math.round(res.bytes/1024)+'KB)');

    } else { // pull
      const r = await fetchWithRetry(url+'/sync', { headers });
      if(!r.ok) throw new Error('HTTP '+r.status);
      const remote = await r.json();
      if(!remote.payload) { toast('☁️ Sunucuda veri yok','orange'); S.syncing=false; updateCloudUI(); return; }
      const d = remote.payload;
      window._lastPullSnapshot = JSON.stringify(DATA);
      if(d.tenants)  DATA.tenants  = d.tenants;
      if(d.payments) DATA.payments = d.payments;
      if(d.expenses) DATA.expenses = d.expenses;
      if(d.alper)    DATA.alper    = d.alper;
      if(d.history)  DATA.history  = d.history;
      if(d.waLog)    DATA.waLog    = d.waLog;
      // Don't overwrite local users from server — use server /users endpoint
      DATA.cloud.serverVersion = remote.version;
      DATA.cloud.lastSync = new Date().toISOString();
      DATA.cloud.enabled = true;
      autoRecalc(); ALL_MONTHS=buildAllMonths(); saveLocal(); render(); updateBadges();
      toast('☁️ Pull tamam (v'+remote.version+') — önceki veri anlık görüntüsü alındı','blue');
      addHist('Bulut pull: v'+remote.version+' ('+(remote.updatedBy||'?')+')');
    }

  }catch(e){
    const msg = e.message || 'Bilinmeyen hata';
    toast('⚠️ Bulut hatası: '+msg,'red');
    addHist('Bulut hatası ('+dir+'): '+msg);
    // Don't lose local data on server failure
  }finally{
    S.syncing=false;
    updateCloudUI();
  }
}

// ── Fetch with retry (1 retry on network error) ──────────────
async function fetchWithRetry(url, opts, retries=1){
  try{ return await fetch(url, opts); }
  catch(e){
    if(retries<=0) throw e;
    await new Promise(r=>setTimeout(r,1500));
    return fetchWithRetry(url, opts, retries-1);
  }
}

// ── Login to server ───────────────────────────────────────────
async function cloudLogin(url, username, password){
  try{
    const r = await fetch(url+'/auth/login', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({username, password})
    });
    const data = await r.json();
    if(!r.ok) return {ok:false, error: data.error||'Login failed'};
    return {ok:true, token: data.token, user: data.user};
  }catch(e){ return {ok:false, error: e.message}; }
}

// ── Check server health ───────────────────────────────────────
async function checkServerHealth(url){
  try{
    const r = await fetch(url+'/health', {signal: AbortSignal.timeout(5000)});
    if(!r.ok) return {ok:false, error:'HTTP '+r.status};
    return {ok:true, ...(await r.json())};
  }catch(e){ return {ok:false, error: e.message}; }
}


function updateCloudUI(){
  const dot=document.getElementById('cloud-dot');
  const lbl=document.getElementById('cloud-title');
  const sub=document.getElementById('cloud-sub');
  if(!dot) return;
  const lang=(DATA&&DATA.settings&&DATA.settings.lang)||'tr';
  if(S.syncing){
    dot.className='cloud-dot sync';lbl.textContent=t('cloudSyncing');if(sub) sub.textContent=t('cloudWait');
  } else if(DATA.cloud.enabled&&DATA.cloud.url){
    dot.className='cdot ok';lbl.textContent=t('syncConnected');
    const d=DATA.cloud.lastSync?new Date(DATA.cloud.lastSync).toLocaleTimeString(lang==='en'?'en-US':'tr-TR',{hour:'2-digit',minute:'2-digit'}):'';
    sub.textContent=d?t('syncLast')+' '+d:t('cloudActiveShort');
  } else {
    dot.className='cdot off';lbl.textContent=t('cloudNone');sub.textContent=t('cloudLocal');
  }
}

// ═══════════════════════════════════════════════
// i18n FOUNDATION — t(key) translation helper
// Add strings here as UI is progressively translated.
// DATA.settings.lang = 'tr' | 'en'  (default: 'tr')
// ═══════════════════════════════════════════════
var STRINGS={
  tr:{
