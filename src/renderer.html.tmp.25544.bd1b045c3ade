  <div id="cmd-box">
    <div id="cmd-input-wrap">
      <span class="cmd-icon">⌘</span>
      <input id="cmd-input" type="text" placeholder="Kiracı, bina, işlem ara..." autocomplete="off" oninput="cmdSearch(this.value)" onkeydown="cmdKey(event)">
