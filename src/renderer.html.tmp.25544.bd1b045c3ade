<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Kira Takip Pro</title>
<style>
/* ═══════════════════════════════════════════════════════════════════
   KIRA TAKİP PRO v5.1 — PREMIUM UI POLISH
   Design: Linear × Vercel × Apple iOS 18
   Fonts: DM Sans (UI) + JetBrains Mono (data)
═══════════════════════════════════════════════════════════════════ */
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=JetBrains+Mono:wght@400;500;600&display=swap');

/* ── DESIGN TOKENS ─────────────────────────────────────────────── */
:root {
  /* Base layers */
  --bg-base:      #060d1a;
  --bg-elevated:  #0a1628;
  --bg-overlay:   #0f1e38;
  --bg-subtle:    #132040;
  --bg-muted:     #192a52;

  /* Glass system */
  --glass-1: rgba(255,255,255,0.03);
  --glass-2: rgba(255,255,255,0.055);
  --glass-3: rgba(255,255,255,0.09);
  --glass-4: rgba(255,255,255,0.13);

  /* Borders */
  --bd-1: rgba(255,255,255,0.055);
  --bd-2: rgba(255,255,255,0.095);
  --bd-3: rgba(255,255,255,0.16);
  --bd-focus: rgba(59,130,246,0.55);

  /* Accents */
  --blue:      #3b82f6;
  --blue-l:    #60a5fa;
  --blue-d:    #2563eb;
  --blue-glow: rgba(59,130,246,0.22);
  --violet:    #8b5cf6;
  --violet-l:  #a78bfa;
  --teal:      #14b8a6;
  --teal-l:    #2dd4bf;
  --emerald:   #10b981;
  --emerald-l: #34d399;
  --amber:     #f59e0b;
  --amber-l:   #fbbf24;
  --rose:      #f43f5e;
  --rose-l:    #fb7185;

  /* Semantic */
  --ok:         var(--emerald);
  --ok-bg:      rgba(16,185,129,0.09);
  --ok-bd:      rgba(16,185,129,0.18);
  --warn:       var(--amber);
  --warn-bg:    rgba(245,158,11,0.09);
  --warn-bd:    rgba(245,158,11,0.18);
  --err:        var(--rose);
  --err-bg:     rgba(244,63,94,0.09);
  --err-bd:     rgba(244,63,94,0.18);
  --info:       var(--blue);
  --info-bg:    rgba(59,130,246,0.09);
  --info-bd:    rgba(59,130,246,0.18);

  /* Ink (text) */
  --i0: #ffffff;
  --i1: #e8edf8;
  --i2: #a8b8d8;
  --i3: #637594;
  --i4: #3d4f6e;
  --i5: #1e2d45;

  /* Layout */
  --sb-w: 248px;          /* sidebar width */
  --tb-h: 52px;           /* topbar height */

  /* Radii */
  --r1:  6px;
  --r2:  9px;
  --r3: 13px;
  --r4: 17px;
  --r5: 22px;

  /* Shadows */
  --sh1: 0 1px 3px rgba(0,0,0,.45), 0 1px 2px rgba(0,0,0,.5);
  --sh2: 0 4px 14px rgba(0,0,0,.5), 0 2px 6px rgba(0,0,0,.4);
  --sh3: 0 12px 40px rgba(0,0,0,.6), 0 4px 12px rgba(0,0,0,.45);
  --sh4: 0 24px 64px rgba(0,0,0,.72), 0 8px 24px rgba(0,0,0,.5);
  --sh-blue: 0 0 0 1px var(--blue-glow), 0 0 22px rgba(59,130,246,.12);

  /* Easing */
  --ease-out:    cubic-bezier(0.16,1,0.3,1);
  --ease-spring: cubic-bezier(0.34,1.56,0.64,1);
  --ease-in:     cubic-bezier(0.4,0,1,1);
  --ease-std:    cubic-bezier(0.4,0,0.2,1);

  /* Fonts */
  --sans: 'DM Sans', system-ui, -apple-system, sans-serif;
  --mono: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
}

/* ── LIGHT THEME ─────────────────────────────────────────────────── */
[data-theme="light"] {
  --bg-base:     #eef2f9;
  --bg-elevated: #e4eaf5;
  --bg-overlay:  #d8e0ef;
  --bg-subtle:   #c8d4e8;
  --bg-muted:    #b8c6dc;
  --glass-1: rgba(255,255,255,0.55);
  --glass-2: rgba(255,255,255,0.75);
  --glass-3: rgba(255,255,255,0.90);
  --glass-4: rgba(255,255,255,0.98);
  --bd-1: rgba(30,50,100,0.13);
  --bd-2: rgba(30,50,100,0.20);
  --bd-3: rgba(30,50,100,0.30);
  --bd-focus: rgba(37,99,235,0.55);
  --i0: #080f1e;
  --i1: #0f1f3c;
  --i2: #1e3a6a;
  --i3: #3a5a8a;
  --i4: #5a7aa8;
  --i5: #8098bc;
  --sh1: 0 1px 4px rgba(0,0,0,.12), 0 1px 2px rgba(0,0,0,.08);
  --sh2: 0 4px 16px rgba(0,0,0,.14), 0 2px 6px rgba(0,0,0,.09);
  --sh3: 0 12px 40px rgba(0,0,0,.18), 0 4px 12px rgba(0,0,0,.11);
  --sh4: 0 24px 64px rgba(0,0,0,.22), 0 8px 24px rgba(0,0,0,.13);
}
[data-theme="light"] body { background:#eef2f9; color:#0f1f3c; }
[data-theme="light"] body::before { opacity:.08; }
[data-theme="light"] body::after { background:radial-gradient(ellipse,rgba(59,130,246,.06) 0%,transparent 72%); }
[data-theme="light"] #sb {
  background:linear-gradient(180deg,#dce8f8 0%,#d2e2f5 100%);
  border-right:1.5px solid rgba(30,50,100,.14);
}
[data-theme="light"] #sb .nav { color:#1e3a6a; }
[data-theme="light"] #sb .nav:hover { background:rgba(37,99,235,.1); color:#0f1f3c; }
[data-theme="light"] #sb .nav.active { background:rgba(37,99,235,.16); color:#1e40af; }
[data-theme="light"] #sb .sb-section-label { color:#5a7aa8; }
[data-theme="light"] #sb .sb-brand-name { color:#0f1f3c; }
[data-theme="light"] #sb .sb-save-btn { background:rgba(37,99,235,.12); border-color:rgba(37,99,235,.25); color:#1e40af; }
[data-theme="light"] #topbar {
  background:rgba(232,240,252,.96);
  border-bottom:1.5px solid rgba(30,50,100,.12);
}
[data-theme="light"] #topbar-title { color:#0f1f3c; }
[data-theme="light"] .save-indicator { color:#5a7aa8; }
[data-theme="light"] #modal {
  background:#e8edf8;
  border:1.5px solid rgba(30,50,100,.18);
  box-shadow:0 24px 64px rgba(0,0,0,.18),0 8px 24px rgba(0,0,0,.12);
}
[data-theme="light"] .modal-title { color:#080f1e; }
[data-theme="light"] .form-label { color:#1e3a6a; }
[data-theme="light"] .form-input,
[data-theme="light"] .form-select,
[data-theme="light"] .form-textarea {
  background:rgba(255,255,255,.88);
  border-color:rgba(30,50,100,.18);
  color:#080f1e;
}
[data-theme="light"] .form-input::placeholder,
[data-theme="light"] .form-textarea::placeholder { color:#8098bc; }
[data-theme="light"] .form-select option { background:#e8edf8; color:#080f1e; }
[data-theme="light"] .search-input {
  background:rgba(255,255,255,.75);
  border-color:rgba(30,50,100,.15);
  color:#080f1e;
}
[data-theme="light"] .search-input:focus { background:rgba(255,255,255,.98); border-color:rgba(37,99,235,.5); }
[data-theme="light"] .search-input::placeholder { color:#8098bc; }
[data-theme="light"] .period-bar {
  background:rgba(255,255,255,.6);
  border:1px solid rgba(30,50,100,.12);
}
[data-theme="light"] .mbar-outer { background:transparent; }
[data-theme="light"] .mbar-arrow { color:#1e3a6a; background:rgba(255,255,255,.6); border-color:rgba(30,50,100,.14); }
[data-theme="light"] .mbar-arrow:hover { background:rgba(255,255,255,.95); }
[data-theme="light"] .mbtn { color:#3a5a8a; }
[data-theme="light"] .mbtn:hover { background:rgba(37,99,235,.12); color:#1e3a6a; }
[data-theme="light"] .mbtn.active { background:rgba(37,99,235,.2); color:#1e40af; font-weight:700; }
[data-theme="light"] .year-tag { color:#8098bc; }
[data-theme="light"] .kpi-card {
  background:rgba(255,255,255,.82);
  border:1.5px solid rgba(30,50,100,.12);
  box-shadow:0 2px 8px rgba(0,0,0,.07);
}
[data-theme="light"] .kpi-value { color:#080f1e; }
[data-theme="light"] .kpi-label { color:#3a5a8a; }
[data-theme="light"] .table-card {
  background:rgba(255,255,255,.78);
  border:1.5px solid rgba(30,50,100,.12);
  box-shadow:0 2px 8px rgba(0,0,0,.06);
}
[data-theme="light"] .table-card-header { border-bottom-color:rgba(30,50,100,.1); }
[data-theme="light"] thead th {
  background:rgba(220,232,248,.95);
  color:#1e3a6a;
  border-bottom:1.5px solid rgba(30,50,100,.14);
}
[data-theme="light"] tbody tr:nth-child(even) td { background:rgba(230,238,252,.35); }
[data-theme="light"] tbody tr:hover td { background:rgba(37,99,235,.06); }
[data-theme="light"] tbody td { border-bottom-color:rgba(30,50,100,.07); color:#0f1f3c; }
[data-theme="light"] .tfoot-row td { background:rgba(220,232,248,.7); color:#0f1f3c; }
[data-theme="light"] .badge { border:1px solid rgba(30,50,100,.12); }
[data-theme="light"] .sec-hdr { color:#1e3a6a; border-bottom-color:rgba(30,50,100,.1); }
[data-theme="light"] .div-line { border-color:rgba(30,50,100,.1); }
[data-theme="light"] .btn-ghost { color:#1e3a6a; border-color:rgba(30,50,100,.2); background:rgba(255,255,255,.6); }
[data-theme="light"] .btn-ghost:hover { background:rgba(255,255,255,.95); color:#080f1e; }
[data-theme="light"] .btn-secondary { background:rgba(37,99,235,.1); color:#1e40af; border-color:rgba(37,99,235,.25); }
[data-theme="light"] .top-lang-seg { background:rgba(255,255,255,.6); border-color:rgba(30,50,100,.15); }
[data-theme="light"] .top-lang-btn { color:#3a5a8a; }
[data-theme="light"] .top-lang-btn:hover { background:rgba(37,99,235,.1); color:#1e3a6a; }
[data-theme="light"] .top-theme-btn { background:rgba(255,255,255,.6); border-color:rgba(30,50,100,.15); }
[data-theme="light"] .top-theme-btn:hover { background:rgba(255,255,255,.95); }
[data-theme="light"] .empty-state-text { color:#5a7aa8; }
[data-theme="light"] .c-muted { color:#5a7aa8 !important; }
[data-theme="light"] ::-webkit-scrollbar-thumb { background:rgba(30,50,100,.2); }
[data-theme="light"] ::-webkit-scrollbar-thumb:hover { background:rgba(30,50,100,.32); }
/* Light theme depth improvements */
[data-theme="light"] .kpi-card {
  box-shadow:0 2px 10px rgba(30,50,100,.10),0 1px 3px rgba(30,50,100,.07);
}
[data-theme="light"] .kpi-card:hover {
  box-shadow:0 6px 20px rgba(30,50,100,.14),0 2px 6px rgba(30,50,100,.09);
  border-color:rgba(37,99,235,.35);
}
[data-theme="light"] .kpi-card::after {
  background:radial-gradient(ellipse at 0% 0%,rgba(255,255,255,.5),transparent 70%);
}
[data-theme="light"] .table-card {
  box-shadow:0 2px 10px rgba(30,50,100,.09),inset 0 1px 0 rgba(255,255,255,.8);
}
[data-theme="light"] .prog-bar { background:rgba(30,50,100,.1); }
[data-theme="light"] .cg { color:var(--emerald); }
[data-theme="light"] .cr { color:var(--rose); }
[data-theme="light"] .card-sub { color:var(--i2); }
[data-theme="light"] .panel-name { color:var(--i0); }
[data-theme="light"] .panel-sub  { color:var(--i3); }
[data-theme="light"] .panel-close { color:var(--i2); background:rgba(255,255,255,.6); border-color:rgba(30,50,100,.14); }
[data-theme="light"] .panel-close:hover { background:rgba(255,255,255,.95); color:var(--i0); }
[data-theme="light"] .sec-hdr { color:var(--i2); }
[data-theme="light"] .table-card-title { color:var(--i1); }
[data-theme="light"] .modal-footer { border-top-color:rgba(30,50,100,.1); }

/* ── LIGHT THEME — enterprise quality additions ─────────────────── */
/* Semantic colors — brighter tints for white background */
[data-theme="light"] { --ok-bg:rgba(16,185,129,.10); --ok-bd:rgba(16,185,129,.28); --warn-bg:rgba(245,158,11,.10); --warn-bd:rgba(245,158,11,.28); --err-bg:rgba(244,63,94,.10); --err-bd:rgba(244,63,94,.28); --info-bg:rgba(59,130,246,.10); --info-bd:rgba(59,130,246,.28); }
/* Semantic text colors readable on light */
[data-theme="light"] .b-green  { color:#047857; }
[data-theme="light"] .b-red    { color:#be123c; }
[data-theme="light"] .b-orange { color:#b45309; }
[data-theme="light"] .b-blue   { color:#1d4ed8; }
/* Op-chips */
[data-theme="light"] .op-chip-red    { color:#be123c; }
[data-theme="light"] .op-chip-orange { color:#b45309; }
[data-theme="light"] .op-chip-blue   { color:#1d4ed8; }
/* Login box */
[data-theme="light"] .login-box {
  background:rgba(255,255,255,.97);
  border-color:rgba(30,50,100,.18);
  box-shadow:0 24px 64px rgba(30,50,100,.16),0 8px 24px rgba(30,50,100,.10),0 0 0 1px rgba(255,255,255,.8) inset;
  animation:loginIn .4s var(--ease-out) both;
}
[data-theme="light"] .login-title { color:#080f1e; }
[data-theme="light"] .login-sub   { color:#5a7aa8; }
[data-theme="light"] .login-user-btn {
  background:rgba(248,250,255,.9);
  border-color:rgba(30,50,100,.14);
  color:#0f1f3c;
}
[data-theme="light"] .login-user-btn:hover {
  border-color:rgba(37,99,235,.4);
  background:rgba(239,246,255,.95);
}
[data-theme="light"] .login-user-name { color:#080f1e; }
[data-theme="light"] .login-user-role { color:#5a7aa8; }
[data-theme="light"] .login-pin-input {
  background:rgba(248,250,255,.95);
  border-color:rgba(30,50,100,.18);
  color:#080f1e;
}
[data-theme="light"] .login-version { color:#8098bc; }
/* Sidebar: logout + cloud */
[data-theme="light"] .sb-logout-btn { color:#3a5a8a; border-color:rgba(30,50,100,.18); }
[data-theme="light"] .sb-logout-btn:hover { background:rgba(244,63,94,.08); border-color:rgba(244,63,94,.3); color:#be123c; }
[data-theme="light"] .cloud-indicator { background:rgba(255,255,255,.7); border-color:rgba(30,50,100,.14); }
[data-theme="light"] .cloud-indicator:hover { background:rgba(255,255,255,.95); border-color:rgba(37,99,235,.3); }
[data-theme="light"] .cloud-title  { color:#1e3a6a; }
[data-theme="light"] .cloud-sub    { color:#5a7aa8; }
[data-theme="light"] .cloud-dot.off { background:#8098bc; }
/* FAB */
[data-theme="light"] .fab-item { background:rgba(255,255,255,.97); border-color:rgba(30,50,100,.15); color:#0f1f3c; box-shadow:0 4px 16px rgba(30,50,100,.12); }
[data-theme="light"] .fab-item:hover { background:#fff; border-color:rgba(37,99,235,.35); }
/* Sidebar building nav items */
[data-theme="light"] .bld-nav-item { color:#1e3a6a; border-color:rgba(30,50,100,.12); background:rgba(255,255,255,.4); }
[data-theme="light"] .bld-nav-item:hover { background:rgba(255,255,255,.75); border-color:rgba(37,99,235,.25); }
[data-theme="light"] .bld-nav-item.active { background:rgba(37,99,235,.12); border-color:rgba(37,99,235,.3); color:#1e40af; }
[data-theme="light"] .bld-nav-item .bld-bdg { background:rgba(244,63,94,.12); color:#be123c; border-color:rgba(244,63,94,.25); }
/* Panel (tenant detail) */
[data-theme="light"] #panel {
  background:linear-gradient(180deg,#f0f5ff 0%,#e8f0fc 100%);
  border-left:1.5px solid rgba(30,50,100,.14);
  box-shadow:-4px 0 24px rgba(30,50,100,.08);
}
[data-theme="light"] .panel-name  { color:#080f1e; }
[data-theme="light"] .panel-sub   { color:#3a5a8a; }
[data-theme="light"] .panel-section { border-top-color:rgba(30,50,100,.1); }
[data-theme="light"] .panel-section-title { color:#3a5a8a; }
[data-theme="light"] .detail-row    { color:#1e3a6a; }
[data-theme="light"] .detail-label  { color:#5a7aa8; }
[data-theme="light"] .pay-hist-row  { border-bottom-color:rgba(30,50,100,.08); }
[data-theme="light"] .pay-hist-row:hover { background:rgba(37,99,235,.04); }
/* Month buttons in pay-history */
[data-theme="light"] .pay-hist-row td { color:#0f1f3c; }
/* Trend chips */
[data-theme="light"] .trend-up   { color:#047857; }
[data-theme="light"] .trend-down { color:#be123c; }
/* Tab / filter pills */
[data-theme="light"] .filter-pill { background:rgba(255,255,255,.65); border-color:rgba(30,50,100,.15); color:#3a5a8a; }
[data-theme="light"] .filter-pill.active { background:rgba(37,99,235,.14); border-color:rgba(37,99,235,.35); color:#1e40af; }
/* Settings sections */
[data-theme="light"] .settings-section { background:rgba(255,255,255,.7); border-color:rgba(30,50,100,.12); }
[data-theme="light"] .settings-label { color:#1e3a6a; }
/* Danger button */
[data-theme="light"] .btn-danger  { color:#be123c; }
[data-theme="light"] .btn-success { color:#047857; }
/* Toast */
[data-theme="light"] #toast { box-shadow:0 8px 32px rgba(30,50,100,.18),0 2px 8px rgba(30,50,100,.12); }
/* Progress / sync bars */
[data-theme="light"] .sync-bar         { background:rgba(30,50,100,.08); }
[data-theme="light"] .sync-bar.offline { background:rgba(244,63,94,.1); border-color:rgba(244,63,94,.25); }
/* Analytics / charts container */
[data-theme="light"] .chart-card { background:rgba(255,255,255,.85); border-color:rgba(30,50,100,.12); box-shadow:0 2px 10px rgba(30,50,100,.08); }
/* Polished print QR line for light */
[data-theme="light"] @media print { body { background:#fff; color:#000; } }
/* KPI card hover accent gradient */
[data-theme="light"] .kpi-card {
  background:linear-gradient(145deg,rgba(255,255,255,.96) 0%,rgba(235,245,255,.7) 100%);
}
[data-theme="light"] .kpi-card:hover { transform:translateY(-1px); }
/* Table striping — stronger contrast */
[data-theme="light"] tbody tr:nth-child(even) td { background:rgba(224,234,252,.5); }
[data-theme="light"] tbody tr:hover td { background:rgba(37,99,235,.07); }
/* Modal title accent border */
[data-theme="light"] .modal-title {
  border-bottom:1.5px solid rgba(30,50,100,.1);
  padding-bottom:12px;
  margin-bottom:16px;
}

/* ── RESET ──────────────────────────────────────────────────────── */
*,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }

html {
  width:100vw; height:100vh; overflow:hidden;
  font-size:13px;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
  text-rendering:optimizeLegibility;
}

body {
  width:100vw; height:100vh; overflow:hidden;
  display:flex; flex-direction:row;
  font-family:var(--sans);
  background:var(--bg-base);
  color:var(--i1);
  line-height:1.5;
}

/* Subtle noise grain */
body::before {
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;opacity:.35;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
}
/* Ambient blue glow top-center */
body::after {
  content:'';position:fixed;top:-40vh;left:10%;width:80vw;height:60vh;
  background:radial-gradient(ellipse,rgba(59,130,246,.055) 0%,transparent 72%);
  pointer-events:none;z-index:0;
}

/* ── SCROLLBARS ──────────────────────────────────────────────────── */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:10px}
::-webkit-scrollbar-thumb:hover{background:rgba(255,255,255,.18)}
* { scrollbar-width:thin; scrollbar-color:rgba(255,255,255,.1) transparent; }

/* ═══════════════════════════════════════════════════════════════════
   LOGIN
═══════════════════════════════════════════════════════════════════ */
#login-screen {
  position:fixed;inset:0;z-index:9999;
  display:flex;align-items:center;justify-content:center;
  background:var(--bg-base);
}
#login-screen::before {
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 20% 45%,rgba(59,130,246,.1) 0%,transparent 55%),
             radial-gradient(ellipse at 80% 60%,rgba(139,92,246,.07) 0%,transparent 50%);
}
.login-box {
  position:relative;z-index:1;
  background:rgba(10,22,40,.88);
  backdrop-filter:blur(40px) saturate(200%);
  -webkit-backdrop-filter:blur(40px) saturate(200%);
  border:1px solid rgba(59,130,246,.18);
  border-radius:var(--r5);
  padding:44px 48px;
  width:min(420px,92vw);
  box-shadow:var(--sh4),0 0 0 1px rgba(255,255,255,.04) inset;
  animation:loginIn .4s var(--ease-out) both, loginGlow 5s ease-in-out 0.4s infinite;
}
@keyframes loginIn { from{opacity:0;transform:translateY(18px) scale(.97)} to{opacity:1;transform:none} }
@keyframes loginGlow{
  0%,100%{box-shadow:var(--sh4),0 0 0 1px rgba(255,255,255,.04) inset,0 0 32px rgba(59,130,246,.08);}
  50%    {box-shadow:var(--sh4),0 0 0 1px rgba(255,255,255,.04) inset,0 0 48px rgba(59,130,246,.18),0 0 80px rgba(139,92,246,.07);}
}
.login-logo {
  width:52px;height:52px;
  background:linear-gradient(135deg,var(--blue),var(--violet));
  border-radius:var(--r3);margin:0 auto 22px;
  display:flex;align-items:center;justify-content:center;font-size:24px;
  box-shadow:0 8px 24px rgba(59,130,246,.35);
}
.login-title {
  font-size:22px;font-weight:700;text-align:center;color:var(--i0);
  letter-spacing:-.5px;margin-bottom:4px;
}
.login-sub{font-size:12px;color:var(--i4);text-align:center;margin-bottom:30px}
.login-users{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
.login-user-btn {
  display:flex;align-items:center;gap:14px;
  padding:12px 16px;border-radius:var(--r3);
  border:1px solid var(--bd-1);background:var(--glass-1);
  cursor:pointer;width:100%;text-align:left;color:var(--i1);
  transition:border-color .18s,background .18s,transform .2s var(--ease-spring);
}
.login-user-btn:hover {
  border-color:rgba(59,130,246,.4);background:rgba(59,130,246,.07);
  transform:translateX(5px);
}
.login-avatar {
  width:38px;height:38px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:14px;font-weight:700;color:#fff;
}
.login-user-name{font-weight:600;font-size:13px;color:var(--i0)}
.login-user-role{font-size:10.5px;color:var(--i4);margin-top:1px}
.login-arrow{margin-left:auto;color:var(--i4);font-size:16px;opacity:.5}
.login-pin-wrap{display:none;margin-top:12px}
.login-pin-input {
  width:100%;background:rgba(0,0,0,.28);
  border:1px solid var(--bd-2);border-radius:var(--r2);color:var(--i0);
  padding:13px;font-size:22px;letter-spacing:10px;text-align:center;
  outline:none;font-family:var(--mono);
  transition:border-color .15s,box-shadow .15s;
}
.login-pin-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px var(--blue-glow)}
.login-error{color:var(--rose-l);font-size:12px;text-align:center;margin-top:10px;min-height:20px}
.login-version{font-size:11px;color:var(--i5);text-align:center;margin-top:20px}

/* ── ONBOARDING overlay (Phase 4 — PRODUCTION_MODE=true) ─────── */
#ob-screen {
  position:fixed;inset:0;z-index:9999;
  display:flex;align-items:center;justify-content:center;
  background:var(--bg-base);
}
#ob-screen::before {
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 20% 45%,rgba(59,130,246,.1) 0%,transparent 55%),
             radial-gradient(ellipse at 80% 60%,rgba(139,92,246,.07) 0%,transparent 50%);
}
.ob-text-input {
  width:100%;padding:12px;border-radius:var(--r2);
  border:1px solid var(--bd-2);background:rgba(0,0,0,.28);
  color:var(--i0);font-size:14px;outline:none;box-sizing:border-box;
  transition:border-color .15s,box-shadow .15s;
}
.ob-text-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px var(--blue-glow)}
#ob-box{transition:opacity .15s ease;}

/* ── BUILDING NAV ACTIONS ─────────────────────────────────────── */
.bld-kebab {
  flex-shrink:0; width:20px; height:20px;
  display:flex; align-items:center; justify-content:center;
  border-radius:4px; font-size:15px; line-height:1;
  color:var(--i4); opacity:0;
  transition:opacity .12s, background .12s, color .12s;
  margin-left:2px;
}
.nav:hover .bld-kebab { opacity:.65; }
.bld-kebab:hover { opacity:1 !important; background:rgba(255,255,255,.1); color:var(--i2); }
.bld-ctx-menu {
  position:fixed; z-index:99999;
  background:rgba(10,22,40,.97);
  backdrop-filter:blur(24px);
  border:1px solid var(--bd-2);
  border-radius:var(--r2);
  box-shadow:0 8px 32px rgba(0,0,0,.45);
  padding:4px; min-width:158px;
  animation:ctxIn .13s var(--ease-out) both;
}
@keyframes ctxIn { from{opacity:0;transform:scale(.95) translateY(-5px)} to{opacity:1;transform:none} }
.bld-ctx-item {
  display:flex; align-items:center; gap:9px;
  padding:7px 12px; border-radius:var(--r1);
  font-size:12px; font-weight:500; color:var(--i2);
  cursor:pointer; border:none; background:none;
  width:100%; text-align:left; font-family:var(--sans);
  transition:background .1s, color .1s;
}
.bld-ctx-item:hover { background:rgba(255,255,255,.07); color:var(--i0); }
.bld-ctx-item.ctx-danger { color:var(--rose-l); }
.bld-ctx-item.ctx-danger:hover { background:rgba(244,63,94,.1); }

/* ═══════════════════════════════════════════════════════════════════
   APP SHELL
═══════════════════════════════════════════════════════════════════ */
#sb {
  width:var(--sb-w);min-width:var(--sb-w);max-width:var(--sb-w);
  flex:0 0 var(--sb-w);height:100vh;
  display:flex;flex-direction:column;
  background:rgba(5,11,22,.96);
  border-right:1px solid var(--bd-1);
  overflow-y:auto;overflow-x:hidden;
  position:relative;z-index:10;
}
#main {
  flex:1 1 0;min-width:0;width:0;height:100vh;
  display:flex;flex-direction:column;overflow:hidden;position:relative;z-index:1;
}

/* ── SIDEBAR BRAND ──────────────────────────────────────────────── */
.sb-brand {
  padding:18px 16px 14px;
  border-bottom:1px solid var(--bd-1);flex-shrink:0;
}
.sb-brand-logo{display:flex;align-items:center;gap:10px;margin-bottom:2px}
.sb-brand-icon {
  width:30px;height:30px;
  background:linear-gradient(135deg,var(--blue),var(--violet));
  border-radius:var(--r2);
  display:flex;align-items:center;justify-content:center;font-size:15px;
  box-shadow:0 3px 10px rgba(59,130,246,.3);flex-shrink:0;
}
.sb-brand-name{font-size:14px;font-weight:700;color:var(--i0);letter-spacing:-.2px}
.sb-brand-sub{font-size:10px;color:var(--i5);margin-top:1px;margin-left:40px}

/* ── SIDEBAR USER ───────────────────────────────────────────────── */
.sb-user {
  display:flex;align-items:center;gap:9px;
  padding:10px 14px;border-bottom:1px solid var(--bd-1);flex-shrink:0;
}
.sb-user-av {
  width:28px;height:28px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:700;color:#fff;
}
.sb-user-info{flex:1;min-width:0}
.sb-user-name{font-size:12px;font-weight:600;color:var(--i0);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sb-user-role{font-size:10px;color:var(--i4)}
.sb-logout-btn {
  width:26px;height:26px;border-radius:var(--r1);flex-shrink:0;
  background:transparent;border:1px solid var(--bd-1);
  color:var(--i4);cursor:pointer;font-size:13px;
  display:flex;align-items:center;justify-content:center;
  transition:background .15s,border-color .15s,color .15s;
  font-family:var(--sans);
}
.sb-logout-btn:hover{background:var(--err-bg);border-color:var(--err-bd);color:var(--rose-l)}

/* ── SIDEBAR NAV ────────────────────────────────────────────────── */
.sb-section{padding:12px 8px 3px;flex-shrink:0}
.sb-section-label {
  font-size:9.5px;font-weight:600;color:var(--i5);
  text-transform:uppercase;letter-spacing:1.4px;
  padding:0 8px;margin-bottom:3px;
  display:flex;align-items:center;gap:6px;
}
.sb-section-label::after{content:'';flex:1;height:1px;background:var(--bd-1)}

.nav {
  display:flex;align-items:center;gap:9px;
  width:100%;padding:7px 10px;
  border:none;background:transparent;
  color:var(--i4);border-radius:var(--r2);
  cursor:pointer;font-size:12px;font-weight:500;
  text-align:left;font-family:var(--sans);
  position:relative;overflow:hidden;
  white-space:nowrap;
  margin-bottom:1px;
  /* GPU-composited transition — no layout change */
  transition:color .14s var(--ease-std), background .14s var(--ease-std);
  /* Subtle press feedback */
  -webkit-tap-highlight-color:transparent;
}
.nav:hover {
  background:rgba(255,255,255,.05);
  color:var(--i2);
}
.nav:active { background:rgba(255,255,255,.08) }
.nav.active {
  background:rgba(59,130,246,.11);
  color:var(--blue-l);
  font-weight:600;
}
/* Active indicator line */
.nav.active::before {
  content:'';position:absolute;
  left:0;top:22%;bottom:22%;
  width:2.5px;border-radius:0 2px 2px 0;
  background:var(--blue);
  box-shadow:0 0 8px rgba(59,130,246,.5);
}
.nav .ni {
  font-size:14px;width:19px;text-align:center;flex-shrink:0;
  display:inline-block;opacity:.75;
  /* Only transform — no layout reflow */
  transition:transform .22s var(--ease-spring),opacity .14s;
}
.nav:hover .ni { transform:scale(1.2) rotate(-5deg);opacity:1 }
.nav.active .ni { transform:scale(1.08);opacity:1 }
.nbadge {
  margin-left:auto;background:var(--rose);color:#fff;
  font-size:9.5px;font-weight:700;padding:1px 5px;border-radius:20px;flex-shrink:0;
  font-variant-numeric:tabular-nums;
}

/* ── SIDEBAR FOOTER ─────────────────────────────────────────────── */
.sb-footer {
  margin-top:auto;padding:10px 8px;
  border-top:1px solid var(--bd-1);flex-shrink:0;
}
.cloud-indicator {
  display:flex;align-items:center;gap:9px;
  padding:8px 12px;border-radius:var(--r2);
  background:var(--glass-1);border:1px solid var(--bd-1);
  cursor:pointer;margin-bottom:7px;font-size:12px;
  transition:border-color .15s,background .15s;
}
.cloud-indicator:hover{border-color:rgba(59,130,246,.3);background:var(--glass-2)}
.cloud-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;transition:background .3s,box-shadow .3s}
.cloud-dot.ok  {background:var(--emerald);box-shadow:0 0 6px var(--emerald)}
.cloud-dot.off {background:var(--i5)}
.cloud-dot.sync{background:var(--amber);animation:dotPulse .9s ease infinite}
@keyframes dotPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.85)}}
.cloud-label{flex:1;min-width:0}
.cloud-label-title{font-size:11.5px;font-weight:600;color:var(--i1)}
.cloud-label-sub{font-size:10px;color:var(--i5)}
.sb-save-btn {
  width:100%;padding:7px;border-radius:var(--r2);
  background:var(--glass-1);border:1px solid var(--bd-1);
  color:var(--i4);font-size:12px;font-weight:500;
  cursor:pointer;font-family:var(--sans);
  transition:background .15s,color .15s;
}
.sb-save-btn:hover{background:var(--glass-2);color:var(--i1)}

/* ═══════════════════════════════════════════════════════════════════
   TOPBAR
═══════════════════════════════════════════════════════════════════ */
#topbar {
  width:100%;height:var(--tb-h);
  min-height:var(--tb-h);max-height:var(--tb-h);
  flex-shrink:0;
  background:rgba(6,13,26,.85);
  backdrop-filter:blur(24px) saturate(160%);
  -webkit-backdrop-filter:blur(24px) saturate(160%);
  border-bottom:1px solid var(--bd-1);
  display:flex;align-items:center;
  padding:0 18px;gap:10px;
  position:relative;z-index:20;overflow:hidden;
}
#topbar-title {
  flex:1;min-width:0;
  font-size:14.5px;font-weight:600;color:var(--i0);
  letter-spacing:-.2px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
  -webkit-app-region:drag;
}
.topbar-actions{display:flex;align-items:center;gap:6px;flex-shrink:0;-webkit-app-region:no-drag;padding-right:148px;}
.search-wrap{position:relative;flex-shrink:1}
.search-icon{
  position:absolute;left:9px;top:50%;transform:translateY(-50%);
  pointer-events:none;color:var(--i4);font-size:12px;
}
.search-input {
  background:var(--glass-2);border:1px solid var(--bd-1);
  border-radius:20px;padding:5.5px 11px 5.5px 28px;
  color:var(--i1);font-size:12px;
  width:120px;min-width:64px;outline:none;font-family:var(--sans);
  transition:width .2s var(--ease-out),border-color .15s,background .15s;
}
.search-input:focus{border-color:var(--bd-focus);width:155px;background:var(--glass-3)}
.search-input::placeholder{color:var(--i5)}
.save-indicator{font-size:10.5px;color:var(--i5);white-space:nowrap;font-family:var(--mono)}
.top-controls{display:flex;align-items:center;gap:6px;flex-shrink:0}
.top-lang-seg{display:flex;align-items:center;background:var(--glass-1);border:1px solid var(--bd-1);border-radius:8px;overflow:hidden}
.top-lang-btn{background:none;border:none;color:var(--i4);font-size:11px;font-weight:600;font-family:var(--sans);padding:4px 9px;cursor:pointer;transition:background .15s,color .15s;letter-spacing:.5px}
.top-lang-btn:hover{background:var(--glass-2);color:var(--i2)}
.top-lang-active{background:rgba(59,130,246,.22)!important;color:#93c5fd!important}
.top-theme-btn{background:var(--glass-1);border:1px solid var(--bd-1);border-radius:8px;width:30px;height:26px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;transition:background .15s,box-shadow .15s;line-height:1}
.top-theme-btn:hover{background:var(--glass-2);box-shadow:0 0 8px rgba(59,130,246,.3)}

/* ═══════════════════════════════════════════════════════════════════
   CONTENT
═══════════════════════════════════════════════════════════════════ */
#content {
  flex:1 1 0;min-height:0;min-width:0;width:100%;
  overflow-y:auto;overflow-x:hidden;
  padding:20px;
  /* JS controls scroll — browser smooth-scroll fights scrollIntoView */
  scroll-behavior:auto;
}

/* ═══════════════════════════════════════════════════════════════════
   MONTH BAR — premium drag-scroll with momentum feel
═══════════════════════════════════════════════════════════════════ */
.mbar-outer{
  display:flex;align-items:center;gap:5px;
  margin-bottom:16px;
}
.mbar-arrow {
  width:28px;height:28px;border-radius:var(--r2);flex-shrink:0;
  border:1px solid var(--bd-1);background:var(--glass-1);color:var(--i3);
  font-size:15px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:background .14s,border-color .14s,color .14s,transform .14s;
  font-family:var(--sans);user-select:none;
}
.mbar-arrow:hover{background:var(--glass-3);color:var(--i0);border-color:rgba(59,130,246,.35);transform:scale(1.08)}
.mbar-arrow:active{transform:scale(.95)}
.period-bar {
  flex:1;min-width:0;
  display:flex;align-items:center;gap:3px;
  padding:7px 14px;
  background:var(--glass-1);border:1px solid var(--bd-1);
  border-radius:var(--r3);
  overflow-x:auto;overflow-y:hidden;flex-wrap:nowrap;
  /* Hide scrollbar */
  scrollbar-width:none;
  /* Smooth inertia scrolling on macOS / iOS */
  -webkit-overflow-scrolling:touch;
  /* Gradient mask — shows bar is scrollable */
  -webkit-mask:linear-gradient(90deg,transparent 0,#000 28px,#000 calc(100% - 28px),transparent 100%);
  mask:linear-gradient(90deg,transparent 0,#000 28px,#000 calc(100% - 28px),transparent 100%);
  cursor:default;
  /* Smooth momentum */
  scroll-behavior:auto; /* override for JS controlled scroll */
}
.period-bar::-webkit-scrollbar{display:none}
.period-bar.is-dragging{cursor:grabbing;user-select:none}
.period-label{
  font-size:10.5px;color:var(--i5);font-weight:600;
  white-space:nowrap;flex-shrink:0;margin-right:5px;
  letter-spacing:.3px;
}
.year-tag {
  padding:2px 8px;font-size:9.5px;font-weight:600;
  color:var(--i5);background:rgba(255,255,255,.04);
  border-radius:20px;border:1px solid var(--bd-1);
  white-space:nowrap;flex-shrink:0;font-family:var(--mono);
  margin-right:2px;
}
.mbar-sep{width:6px;flex-shrink:0}

.mbtn {
  padding:4px 9px;border-radius:20px;
  border:1px solid transparent;
  background:transparent;color:var(--i4);
  font-size:11px;font-weight:500;cursor:pointer;
  white-space:nowrap;flex-shrink:0;
  font-family:var(--sans);
  /* Only opacity+bg+color — no transform on month btns (they move the bar) */
  transition:background .12s,color .12s,border-color .12s;
  -webkit-tap-highlight-color:transparent;
}
.mbtn:hover{background:var(--glass-3);color:var(--i1);border-color:var(--bd-1)}
.mbtn.active {
  background:rgba(59,130,246,.16);color:var(--blue-l);
  border-color:rgba(59,130,246,.32);font-weight:600;
  box-shadow:0 0 10px rgba(59,130,246,.12);
}
.mbtn:focus{outline:2px solid var(--blue);outline-offset:2px}

/* ═══════════════════════════════════════════════════════════════════
   KPI CARDS
═══════════════════════════════════════════════════════════════════ */
.kpi-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(155px,1fr));
  gap:12px;margin-bottom:18px;
  width:100%;min-width:0;
}
.kpi-card {
  min-width:0;
  background:var(--glass-1);border:1px solid var(--bd-1);
  border-radius:var(--r3);padding:16px 15px;
  position:relative;overflow:hidden;
  transition:transform .2s var(--ease-spring),box-shadow .2s var(--ease-std),border-color .2s;
  cursor:default;
}
.kpi-card::before {
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--kpi-color,var(--blue)),transparent);
  opacity:.6;
}
/* Subtle shimmer on hover */
.kpi-card::after {
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 0% 0%,rgba(255,255,255,.04),transparent 70%);
  opacity:0;transition:opacity .2s;pointer-events:none;
}
.kpi-card:hover {
  transform:translateY(-2px) scale(1.005);
  border-color:var(--bd-2);
  box-shadow:var(--sh2);
}
.kpi-card:hover::after{opacity:1}
.kpi-icon{font-size:18px;margin-bottom:9px;display:block}
.kpi-value {
  font-size:19px;font-weight:700;
  color:var(--kpi-color,var(--blue-l));
  letter-spacing:-.5px;line-height:1;
  overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
}
.kpi-label{font-size:10.5px;color:var(--i4);margin-top:5px;font-weight:500;letter-spacing:.1px}
.kpi-sub{font-size:10.5px;margin-top:2px;font-weight:600}
.card-sub{font-size:10.5px;margin-top:4px;font-weight:600;color:var(--i3)}
.cg{color:var(--emerald-l)}.cr{color:var(--rose-l)}

/* ═══════════════════════════════════════════════════════════════════
   SECTION HEADERS
═══════════════════════════════════════════════════════════════════ */
.sec-hdr {
  display:flex;align-items:center;gap:8px;
  margin-bottom:10px;font-size:12px;font-weight:600;
  color:var(--i3);letter-spacing:.15px;
}
.sec-hdr::after{content:'';flex:1;height:1px;background:var(--bd-1)}
.sec-hdr .sec-count {
  font-size:10px;color:var(--i5);background:var(--glass-1);
  border:1px solid var(--bd-1);border-radius:20px;
  padding:1px 7px;font-family:var(--mono);
}

/* ═══════════════════════════════════════════════════════════════════
   TABLES — sticky headers, smooth scroll, polished rows
═══════════════════════════════════════════════════════════════════ */
.table-card {
  width:100%;background:var(--glass-1);border:1px solid var(--bd-1);
  border-radius:var(--r3);overflow:hidden;margin-bottom:16px;
  /* Subtle inset highlight */
  box-shadow:inset 0 1px 0 rgba(255,255,255,.04);
}
.table-card-header {
  display:flex;align-items:center;gap:10px;
  padding:11px 16px;border-bottom:1px solid var(--bd-1);
  background:rgba(255,255,255,.02);
}
.table-card-title{font-size:12.5px;font-weight:600;color:var(--i1);flex:1;min-width:0}
.table-scroller {
  width:100%;overflow-x:auto;overflow-y:visible;
  -webkit-overflow-scrolling:touch;
}

table{width:100%;border-collapse:collapse;font-size:12px}

thead{position:sticky;top:0;z-index:5}
thead th {
  background:rgba(5,10,22,.98); /* fully opaque — no backdrop-filter needed; saves GPU resample on scroll */
  color:var(--i5);font-weight:600;
  padding:8px 14px;text-align:left;
  border-bottom:1px solid var(--bd-1);
  white-space:nowrap;
  font-size:10px;text-transform:uppercase;letter-spacing:.7px;
}

tbody tr {
  border-bottom:1px solid rgba(255,255,255,.03);
  transition:background .1s var(--ease-std);
}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:rgba(59,130,246,.04)}
tbody tr.clickable{cursor:pointer}
tbody tr.clickable:hover{background:rgba(59,130,246,.06)}
tbody td {
  padding:9px 14px;vertical-align:middle;
  color:var(--i2);min-width:0;
}
tbody td:first-child{color:var(--i1)}

.tfoot-row td {
  background:rgba(255,255,255,.02);font-weight:600;color:var(--i1);
  border-top:1px solid var(--bd-1);padding:9px 14px;
}

/* Empty state */
.empty-state {
  text-align:center;padding:48px 20px;
}
.empty-state-icon{font-size:36px;display:block;margin-bottom:10px;opacity:.35}
.empty-state-text{font-size:13px;color:var(--i5)}

/* ═══════════════════════════════════════════════════════════════════
   BADGES / STATUS
═══════════════════════════════════════════════════════════════════ */
.badge {
  display:inline-flex;align-items:center;gap:3.5px;
  padding:2.5px 9px;border-radius:20px;
  font-size:10.5px;font-weight:600;white-space:nowrap;
  font-variant-numeric:tabular-nums;
}
/* Dot indicator */
.badge::before{content:'●';font-size:7px;opacity:.9}
.b-green  {background:var(--ok-bg);  color:var(--emerald-l);border:1px solid var(--ok-bd)}
.b-red    {background:var(--err-bg); color:var(--rose-l);   border:1px solid var(--err-bd)}
.b-orange {background:var(--warn-bg);color:var(--amber-l);  border:1px solid var(--warn-bd)}
.b-blue   {background:var(--info-bg);color:var(--blue-l);   border:1px solid var(--info-bd)}
.b-gray   {background:rgba(255,255,255,.05);color:var(--i4);border:1px solid var(--bd-1)}
.b-violet {background:rgba(139,92,246,.1);color:var(--violet-l);border:1px solid rgba(139,92,246,.2)}

/* ═══════════════════════════════════════════════════════════════════
   BUTTONS — consistent, springy, accessible
═══════════════════════════════════════════════════════════════════ */
.btn {
  display:inline-flex;align-items:center;justify-content:center;gap:5px;
  padding:7px 14px;border-radius:var(--r2);
  border:none;font-size:12px;font-weight:600;
  cursor:pointer;white-space:nowrap;flex-shrink:0;
  font-family:var(--sans);
  transition:transform .18s var(--ease-spring), box-shadow .18s var(--ease-std), background .14s;
  -webkit-tap-highlight-color:transparent;
  position:relative;overflow:hidden;
}
/* Ripple hint on click */
.btn::after {
  content:'';position:absolute;inset:0;
  background:rgba(255,255,255,.1);
  opacity:0;border-radius:inherit;
  transition:opacity .14s;
}
.btn:active::after{opacity:1}
.btn:hover{transform:translateY(-1px) scale(1.025)}
.btn:active{transform:scale(.97)}
.btn:focus-visible{outline:2px solid var(--blue);outline-offset:2px}

.btn-primary {
  background:var(--blue);color:#fff;
  box-shadow:0 2px 8px rgba(59,130,246,.3);
}
.btn-primary:hover{background:var(--blue-d);box-shadow:0 4px 16px rgba(59,130,246,.4)}
.btn-secondary{background:var(--glass-2);color:var(--i2);border:1px solid var(--bd-1)}
.btn-secondary:hover{background:var(--glass-3);color:var(--i0)}
.btn-danger   {background:var(--err-bg);color:var(--rose-l);border:1px solid var(--err-bd)}
.btn-danger:hover{background:rgba(244,63,94,.16)}
.btn-success  {background:var(--ok-bg);color:var(--emerald-l);border:1px solid var(--ok-bd)}
.btn-success:hover{background:rgba(16,185,129,.16)}
.btn-ghost    {background:transparent;color:var(--i4);border:1px solid var(--bd-1)}
.btn-ghost:hover{background:var(--glass-2);color:var(--i1)}
.btn-sm{padding:5px 10px;font-size:11.5px}
.btn-xs{padding:3px 8px;font-size:10.5px;border-radius:var(--r1)}
.btn-icon{padding:6px 7px}

/* ═══════════════════════════════════════════════════════════════════
   FORMS — consistent, validated look
═══════════════════════════════════════════════════════════════════ */
.form-row{margin-bottom:14px}
.form-label{
  font-size:11px;color:var(--i4);font-weight:600;margin-bottom:5px;
  display:block;letter-spacing:.2px;text-transform:uppercase;
}
.form-input,.form-select,.form-textarea {
  width:100%;background:rgba(0,0,0,.22);
  border:1px solid var(--bd-2);border-radius:var(--r2);
  color:var(--i1);font-size:12.5px;padding:8.5px 12px;
  outline:none;font-family:var(--sans);
  transition:border-color .15s,box-shadow .15s,background .15s;
}
.form-input:hover,.form-select:hover{border-color:var(--bd-3)}
.form-input:focus,.form-select:focus,.form-textarea:focus {
  border-color:var(--blue);
  box-shadow:0 0 0 3px var(--blue-glow);
  background:rgba(0,0,0,.28);
}
.form-input::placeholder,.form-textarea::placeholder{color:var(--i5)}
.form-select{cursor:pointer}
.form-select option{background:var(--bg-overlay)}
.form-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.form-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}

/* ═══════════════════════════════════════════════════════════════════
   MODAL — polished dialog
═══════════════════════════════════════════════════════════════════ */
#modal-overlay {
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,.68);z-index:300;
  align-items:center;justify-content:center;
  backdrop-filter:blur(5px);
  -webkit-backdrop-filter:blur(5px);
}
#modal-overlay.open{display:flex}
#modal {
  background:rgba(8,18,36,.97);
  border:1px solid var(--bd-2);
  border-radius:var(--r4);padding:26px;
  width:min(540px,94vw);max-height:90vh;overflow-y:auto;
  box-shadow:var(--sh4),0 0 0 1px rgba(255,255,255,.03) inset;
  animation:modalIn .22s var(--ease-out) both;
  font-family:var(--sans);
}
@keyframes modalIn{from{transform:scale(.94) translateY(8px);opacity:0}to{transform:none;opacity:1}}
.modal-title{font-size:15px;font-weight:700;color:var(--i0);margin-bottom:18px;display:flex;align-items:center;gap:9px;letter-spacing:-.2px}
.modal-footer{display:flex;justify-content:flex-end;gap:8px;margin-top:20px;padding-top:16px;border-top:1px solid var(--bd-1)}

/* ═══════════════════════════════════════════════════════════════════
   PANEL (slide-over)
═══════════════════════════════════════════════════════════════════ */
#panel-overlay {
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,.58);z-index:200;
  backdrop-filter:blur(3px);
  -webkit-backdrop-filter:blur(3px);
}
#panel-overlay.open{display:block}
#panel {
  display:none;position:fixed;right:0;top:0;bottom:0;
  width:min(500px,90vw);
  background:rgba(6,14,28,.98);
  border-left:1px solid var(--bd-1);
  overflow-y:auto;padding:24px;z-index:201;
  box-shadow:-4px 0 40px rgba(0,0,0,.6);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
}
#panel.open{display:block;animation:slidePanel .26s var(--ease-out) both}
@keyframes slidePanel{from{transform:translateX(100%)}to{transform:none}}
.panel-close {
  position:absolute;top:16px;right:16px;
  width:30px;height:30px;border-radius:var(--r2);
  background:var(--glass-2);border:1px solid var(--bd-1);
  color:var(--i4);cursor:pointer;font-size:15px;
  display:flex;align-items:center;justify-content:center;
  font-family:var(--sans);
  transition:background .14s,color .14s;
}
.panel-close:hover{background:var(--glass-3);color:var(--i0)}
.panel-name{font-size:21px;font-weight:700;color:var(--i0);margin:30px 0 4px;letter-spacing:-.4px}
.panel-sub{font-size:12.5px;color:var(--i4);margin-bottom:14px}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.info-item{background:var(--glass-1);border:1px solid var(--bd-1);border-radius:var(--r2);padding:11px}
.info-lbl{font-size:9.5px;color:var(--i5);text-transform:uppercase;letter-spacing:.8px;font-weight:600}
.info-val{font-size:13.5px;font-weight:600;color:var(--i0);margin-top:4px}

/* ═══════════════════════════════════════════════════════════════════
   TOAST
═══════════════════════════════════════════════════════════════════ */
#toast {
  position:fixed;bottom:22px;right:22px;z-index:2000;
  background:rgba(8,18,36,.96);border:1px solid var(--bd-2);
  border-radius:var(--r3);padding:10px 18px;
  font-size:12.5px;font-weight:600;font-family:var(--sans);
  box-shadow:var(--sh3);
  opacity:0;transform:translateY(10px) scale(.97);
  transition:opacity .24s var(--ease-out),transform .24s var(--ease-out);
  display:flex;align-items:center;gap:9px;pointer-events:none;max-width:360px;
  backdrop-filter:blur(16px);
  -webkit-backdrop-filter:blur(16px);
}
#toast.show{opacity:1;transform:translateY(0) scale(1)}

/* ═══════════════════════════════════════════════════════════════════
   COMMAND PALETTE
═══════════════════════════════════════════════════════════════════ */
#cmd-overlay{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,.75);z-index:5000;
  align-items:flex-start;justify-content:center;
  padding-top:14vh;
  backdrop-filter:blur(8px);
  -webkit-backdrop-filter:blur(8px);
}
#cmd-overlay.open{display:flex;animation:fadeUp .18s var(--ease-out) both}
@keyframes fadeUp{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
#cmd-box{
  background:rgba(7,16,30,.98);
  border:1px solid var(--bd-2);
  border-radius:var(--r4);width:min(600px,92vw);
  box-shadow:var(--sh4);overflow:hidden;
}
#cmd-input-wrap{
  display:flex;align-items:center;gap:10px;
  padding:13px 18px;border-bottom:1px solid var(--bd-1);
}
#cmd-input-wrap .cmd-icon{font-size:16px;color:var(--i5);flex-shrink:0}
#cmd-input{
  flex:1;background:transparent;border:none;outline:none;
  font-size:15px;color:var(--i0);font-family:var(--sans);
  caret-color:var(--blue);
}
#cmd-input::placeholder{color:var(--i5)}
.cmd-kbd{
  background:rgba(255,255,255,.06);border:1px solid var(--bd-2);
  border-radius:5px;padding:2px 7px;font-size:11px;
  color:var(--i4);font-family:var(--mono);flex-shrink:0;
}
#cmd-results{max-height:380px;overflow-y:auto;padding:6px}
.cmd-group-label{
  font-size:9.5px;font-weight:700;color:var(--i5);
  text-transform:uppercase;letter-spacing:1.2px;
  padding:8px 12px 4px;
}
.cmd-item{
  display:flex;align-items:center;gap:12px;
  padding:9px 12px;border-radius:var(--r2);cursor:pointer;
  transition:background .1s;
}
.cmd-item:hover,.cmd-item.selected{background:rgba(59,130,246,.1)}
.cmd-item-icon{
  width:30px;height:30px;border-radius:var(--r2);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:14px;
  background:var(--glass-2);
}
.cmd-item-label{flex:1;min-width:0}
.cmd-item-title{font-size:12.5px;font-weight:500;color:var(--i0)}
.cmd-item-sub{font-size:11px;color:var(--i5);margin-top:1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cmd-item-tag{font-size:10px;color:var(--i5);background:var(--glass-2);padding:2px 7px;border-radius:20px;flex-shrink:0}
.cmd-empty{text-align:center;padding:32px;color:var(--i5);font-size:13px}
#cmd-footer{
  padding:8px 18px;border-top:1px solid var(--bd-1);
  display:flex;gap:14px;font-size:11px;color:var(--i5);
}
#cmd-footer span{display:flex;align-items:center;gap:4px}

/* ═══════════════════════════════════════════════════════════════════
   FAB
═══════════════════════════════════════════════════════════════════ */
#fab{position:fixed;bottom:26px;right:26px;z-index:400}
#fab-main{
  width:50px;height:50px;border-radius:50%;border:none;
  background:linear-gradient(135deg,var(--blue),var(--violet));color:#fff;
  font-size:22px;cursor:pointer;
  box-shadow:0 6px 22px rgba(59,130,246,.4);
  display:flex;align-items:center;justify-content:center;
  transition:transform .22s var(--ease-spring),box-shadow .2s;
  font-family:var(--sans);
}
#fab-main:hover{transform:scale(1.1);box-shadow:0 10px 30px rgba(59,130,246,.5)}
#fab-main:active{transform:scale(.95)}
#fab-main.open{transform:rotate(45deg)}
#fab-menu{
  display:none;position:absolute;bottom:60px;right:0;
  flex-direction:column;gap:7px;align-items:flex-end;
}
#fab-menu.open{display:flex;animation:fadeInUp .18s var(--ease-out) both}
.fab-item{
  display:flex;align-items:center;gap:10px;
  background:rgba(7,16,30,.96);border:1px solid var(--bd-2);
  border-radius:24px;padding:8px 16px 8px 12px;cursor:pointer;
  box-shadow:var(--sh2);font-family:var(--sans);font-size:12.5px;font-weight:500;
  color:var(--i1);white-space:nowrap;
  transition:background .14s,border-color .14s,transform .18s var(--ease-spring);
}
.fab-item:hover{background:rgba(59,130,246,.12);border-color:rgba(59,130,246,.3);transform:translateX(-4px)}
.fab-item-icon{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px}

/* ═══════════════════════════════════════════════════════════════════
   FILTER BAR
═══════════════════════════════════════════════════════════════════ */
.filter-bar{display:flex;gap:7px;margin-bottom:14px;flex-wrap:wrap;align-items:center}
.filter-chip {
  display:flex;align-items:center;gap:5px;
  padding:4.5px 11px;border-radius:20px;border:1px solid var(--bd-1);
  background:var(--glass-1);color:var(--i4);
  font-size:11.5px;font-weight:500;cursor:pointer;
  font-family:var(--sans);
  transition:border-color .14s,background .14s,color .14s;
}
.filter-chip:hover{border-color:rgba(59,130,246,.4);color:var(--i1)}
.filter-chip.active{background:rgba(59,130,246,.12);border-color:rgba(59,130,246,.3);color:var(--blue-l)}

/* ═══════════════════════════════════════════════════════════════════
   SMART WIDGETS
═══════════════════════════════════════════════════════════════════ */
.smart-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
  gap:14px;margin-bottom:16px;
}
.widget{
  background:var(--glass-1);border:1px solid var(--bd-1);
  border-radius:var(--r3);padding:17px;
  position:relative;overflow:hidden;
  transition:border-color .2s,box-shadow .2s;
}
.widget:hover{border-color:var(--bd-2);box-shadow:var(--sh1)}
.widget-title{
  font-size:11px;font-weight:600;color:var(--i5);
  margin-bottom:13px;text-transform:uppercase;letter-spacing:.7px;
  display:flex;align-items:center;gap:6px;
}
.widget-value{font-size:26px;font-weight:700;color:var(--i0);letter-spacing:-.8px}
.widget-sub{font-size:11.5px;color:var(--i5);margin-top:4px}
.widget-trend{
  display:inline-flex;align-items:center;gap:4px;
  font-size:11.5px;font-weight:600;padding:2px 8px;border-radius:20px;margin-top:9px;
}
.trend-up  {background:var(--ok-bg);  color:var(--emerald-l)}
.trend-down{background:var(--err-bg); color:var(--rose-l)}
.trend-flat{background:var(--glass-2);color:var(--i4)}

/* Rank list */
.rank-list{display:flex;flex-direction:column;gap:8px}
.rank-item{display:flex;align-items:center;gap:10px}
.rank-num{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
.rank-bar-wrap{flex:1;height:5px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden}
.rank-bar{height:100%;border-radius:3px;transition:width .5s var(--ease-out)}
.rank-label{font-size:11px;color:var(--i4);min-width:40px;text-align:right}

/* Heatmap */
.heatmap{display:grid;grid-template-columns:repeat(12,1fr);gap:3px;margin-top:8px}
.hm-cell{aspect-ratio:1;border-radius:3px;transition:transform .15s;cursor:default}
.hm-cell:hover{transform:scale(1.15)}

/* Gauge */
.gauge-wrap{display:flex;align-items:center;gap:16px;margin-top:10px}
.gauge{width:80px;height:80px;flex-shrink:0;position:relative;display:flex;align-items:center;justify-content:center}
.gauge-val{font-size:18px;font-weight:700;color:var(--i0)}

/* Sparkline */
.sparkline-wrap{height:48px;margin-top:10px;position:relative}

/* ═══════════════════════════════════════════════════════════════════
   ANALYTICS TABS
═══════════════════════════════════════════════════════════════════ */
.analytics-tabs{
  display:flex;gap:3px;margin-bottom:18px;
  background:var(--glass-1);border:1px solid var(--bd-1);
  border-radius:var(--r3);padding:4px;width:fit-content;
}
.a-tab{
  padding:6px 15px;border-radius:var(--r2);border:none;
  background:transparent;color:var(--i4);
  font-size:12px;font-weight:500;cursor:pointer;
  font-family:var(--sans);
  transition:background .14s,color .14s;
}
.a-tab:hover:not(.active){background:rgba(255,255,255,.05);color:var(--i1)}
.a-tab.active{background:rgba(59,130,246,.14);color:var(--blue-l);font-weight:600}

/* ═══════════════════════════════════════════════════════════════════
   CHARTS
═══════════════════════════════════════════════════════════════════ */
.chart-card{
  background:var(--glass-1);border:1px solid var(--bd-1);
  border-radius:var(--r3);padding:16px;margin-bottom:14px;overflow:hidden;
}
.chart-title{font-size:12px;font-weight:600;color:var(--i4);margin-bottom:14px;text-transform:uppercase;letter-spacing:.4px}

/* Progress bar */
.prog-wrap{display:flex;align-items:center;gap:8px}
.prog-bar{flex:1;max-width:80px;height:4px;background:rgba(255,255,255,.07);border-radius:2px;overflow:hidden}
.prog-fill{height:100%;border-radius:2px;transition:width .4s var(--ease-out)}

/* ═══════════════════════════════════════════════════════════════════
   WHATSAPP
═══════════════════════════════════════════════════════════════════ */
.wa-reminder-card{
  background:var(--glass-1);border:1px solid var(--bd-1);
  border-radius:var(--r3);padding:15px;margin-bottom:9px;
  transition:border-color .15s;
}
.wa-reminder-card:hover{border-color:rgba(37,211,102,.2)}
.wa-reminder-hdr{display:flex;align-items:center;gap:12px;margin-bottom:10px}
.wa-msg-box{
  background:rgba(37,211,102,.04);border:1px solid rgba(37,211,102,.13);
  border-radius:var(--r2);padding:10px 12px;font-size:11.5px;
  color:var(--i3);line-height:1.6;margin:9px 0;
}
.wa-send-btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:9px 18px;border-radius:24px;
  background:linear-gradient(135deg,#25d366,#128c7e);
  color:#fff;font-weight:700;font-size:12.5px;
  border:none;cursor:pointer;font-family:var(--sans);
  transition:transform .18s var(--ease-spring),box-shadow .18s;
  box-shadow:0 4px 14px rgba(37,211,102,.25);
}
.wa-send-btn:hover{transform:translateY(-1.5px);box-shadow:0 6px 20px rgba(37,211,102,.35)}
.wa-send-btn:active{transform:scale(.97)}
.wa-stat-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:9px;margin-bottom:14px}
.wa-stat-card{background:var(--glass-1);border:1px solid var(--bd-1);border-radius:var(--r2);padding:11px 14px;text-align:center}
.wa-stat-num{font-size:21px;font-weight:700;color:var(--i0)}
.wa-stat-lbl{font-size:11px;color:var(--i5);margin-top:3px}
.wa-phone-row{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.wa-phone-edit{
  background:var(--glass-1);border:1px solid var(--bd-1);
  border-radius:var(--r1);color:var(--i1);padding:4px 10px;
  font-size:11.5px;outline:none;font-family:var(--mono);
  transition:border-color .15s;width:170px;
}
.wa-phone-edit:focus{border-color:rgba(59,130,246,.45)}
.wa-sent-badge{display:inline-flex;align-items:center;gap:4px;font-size:10.5px;color:var(--emerald-l);background:var(--ok-bg);border:1px solid var(--ok-bd);border-radius:20px;padding:2px 7px}

/* ═══════════════════════════════════════════════════════════════════
   OVERDUE CARDS
═══════════════════════════════════════════════════════════════════ */
.overdue-card{
  display:flex;align-items:center;gap:13px;
  padding:13px 15px;margin-bottom:7px;
  background:rgba(244,63,94,.05);border:1px solid rgba(244,63,94,.16);
  border-radius:var(--r3);border-left:2.5px solid var(--rose);
}
.overdue-pulse{
  width:9px;height:9px;border-radius:50%;
  background:var(--rose);flex-shrink:0;
  box-shadow:0 0 7px var(--rose);
  animation:dotPulse 1.6s ease infinite;
}
.overdue-info{flex:1;min-width:0}
.overdue-name{font-size:12.5px;font-weight:600;color:var(--i0);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.overdue-meta{font-size:10.5px;color:var(--i4);margin-top:1px}
.overdue-amount{font-size:12.5px;font-weight:700;color:var(--rose-l);white-space:nowrap}

/* ═══════════════════════════════════════════════════════════════════
   ALPER HERO
═══════════════════════════════════════════════════════════════════ */
.alper-hero{
  background:linear-gradient(135deg,rgba(139,92,246,.09),rgba(20,184,166,.05));
  border:1px solid rgba(139,92,246,.18);border-radius:var(--r3);
  padding:18px 22px;margin-bottom:16px;position:relative;overflow:hidden;
}
.alper-hero::before{
  content:'';position:absolute;top:-50px;right:-50px;
  width:180px;height:180px;border-radius:50%;
  background:radial-gradient(circle,rgba(139,92,246,.08),transparent 70%);
}
.alper-hero-title{font-size:14.5px;font-weight:700;color:var(--violet-l);margin-bottom:4px}
.alper-hero-desc{font-size:12px;color:var(--i4);line-height:1.6;margin-bottom:14px}
.alper-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.alper-stat{background:rgba(0,0,0,.18);border-radius:var(--r2);padding:11px;text-align:center}
.alper-stat-val{font-size:16px;font-weight:700}
.alper-stat-lbl{font-size:10px;color:var(--i4);margin-top:3px}

/* ═══════════════════════════════════════════════════════════════════
   3D VISUALIZATION
═══════════════════════════════════════════════════════════════════ */
#viz-wrap{
  width:100%;height:calc(100vh - 148px);
  position:relative;border-radius:var(--r3);overflow:hidden;
  background:var(--glass-1);border:1px solid var(--bd-1);
}
.viz-toolbar{display:flex;gap:8px;margin-bottom:11px;flex-wrap:wrap;align-items:center}
.viz-legend{display:flex;gap:13px;flex-wrap:wrap;font-size:11px;color:var(--i4)}
.viz-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:3px}
.viz-select{
  background:var(--glass-2);border:1px solid var(--bd-1);
  border-radius:var(--r2);color:var(--i1);padding:6px 10px;
  font-size:12px;font-family:var(--sans);outline:none;
}
.viz-tooltip{
  position:absolute;background:rgba(7,16,30,.95);border:1px solid var(--bd-2);
  border-radius:var(--r3);padding:12px 16px;font-size:12px;
  pointer-events:none;z-index:100;box-shadow:var(--sh3);
  min-width:190px;display:none;font-family:var(--sans);
  backdrop-filter:blur(16px);
}
.viz-tip-title{font-size:13px;font-weight:700;color:var(--i0);margin-bottom:8px}
.viz-tip-row{display:flex;justify-content:space-between;gap:16px;margin-bottom:4px;color:var(--i3)}
.viz-tip-val{font-weight:600;color:var(--i1)}

/* ═══════════════════════════════════════════════════════════════════
   EDITABLE CELLS
═══════════════════════════════════════════════════════════════════ */
.editable{
  cursor:text;border-bottom:1px dashed rgba(255,255,255,.1);
  padding-bottom:1px;transition:border-color .14s;
}
.editable:hover{border-color:rgba(59,130,246,.45)}
.editable:focus{
  outline:none;border-bottom:1px solid var(--blue);
  background:rgba(59,130,246,.06);border-radius:3px;padding:1px 3px;
}

/* ═══════════════════════════════════════════════════════════════════
   SYNC BAR
═══════════════════════════════════════════════════════════════════ */
.sync-bar{
  display:flex;align-items:center;gap:10px;
  padding:7px 14px;margin-bottom:14px;
  background:rgba(59,130,246,.05);border:1px solid rgba(59,130,246,.14);
  border-radius:var(--r2);font-size:12px;
}
.sync-bar.offline{background:var(--err-bg);border-color:var(--err-bd)}
.sync-spinner{
  width:14px;height:14px;border:2px solid rgba(59,130,246,.2);
  border-top-color:var(--blue);border-radius:50%;
  animation:spin .7s linear infinite;flex-shrink:0;
}
@keyframes spin{to{transform:rotate(360deg)}}
.sync-status-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.sync-bar .sync-actions{margin-left:auto;display:flex;gap:6px}

/* ═══════════════════════════════════════════════════════════════════
   TIMELINE
═══════════════════════════════════════════════════════════════════ */
.timeline{padding-left:18px;border-left:2px solid var(--bd-1)}
.tl-entry{position:relative;margin-bottom:16px;padding-left:16px}
.tl-entry::before{
  content:'';position:absolute;left:-25px;top:4px;
  width:9px;height:9px;border-radius:50%;
  border:2px solid var(--bg-elevated);background:var(--tl-color,var(--i5));
}
.tl-entry-time{font-size:10px;color:var(--i5);margin-bottom:2px;font-family:var(--mono)}
.tl-entry-text{font-size:12.5px;color:var(--i2)}
.tl-entry-user{font-size:11px;color:var(--i5);margin-top:2px}

/* ═══════════════════════════════════════════════════════════════════
   RECEIPT PRINT
═══════════════════════════════════════════════════════════════════ */
.receipt-preview{background:#fff;color:#111;border-radius:var(--r2);padding:32px;max-width:580px;margin:0 auto;font-family:var(--sans);box-shadow:var(--sh3)}
.receipt-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;padding-bottom:16px;border-bottom:2px solid #1a365d}
.receipt-logo{font-size:20px;font-weight:800;color:#1a365d}
.receipt-meta{font-size:11px;color:#666;text-align:right}
.receipt-title{font-size:22px;font-weight:700;color:#1a365d;margin-bottom:20px;text-align:center}
.receipt-table{width:100%;border-collapse:collapse;font-size:13px;margin-bottom:20px}
.receipt-table th{background:#f0f4f8;padding:8px 12px;text-align:left;font-weight:600;color:#444}
.receipt-table td{padding:8px 12px;border-bottom:1px solid #eee;color:#333}
.receipt-total{font-size:18px;font-weight:700;text-align:right;color:#1a365d;margin-top:16px;padding-top:12px;border-top:2px solid #1a365d}
.receipt-footer{font-size:11px;color:#999;text-align:center;margin-top:24px}

/* ═══════════════════════════════════════════════════════════════════
   UTILITIES
═══════════════════════════════════════════════════════════════════ */
.div-line{height:1px;background:var(--bd-1);margin:14px 0}
.c-blue   {color:var(--blue-l)}   .c-green {color:var(--emerald-l)}
.c-red    {color:var(--rose-l)}   .c-orange{color:var(--amber-l)}
.c-violet {color:var(--violet-l)} .c-teal  {color:var(--teal-l)}
.c-muted  {color:var(--i4)}       .c-faint {color:var(--i5)}
.c-bright {color:var(--i0)}
.fw-600{font-weight:600}.fw-700{font-weight:700}
.mono{font-family:var(--mono);font-size:11px}
.nowrap{white-space:nowrap}

/* ═══════════════════════════════════════════════════════════════════
   PAGE TRANSITIONS
═══════════════════════════════════════════════════════════════════ */
.page-enter{animation:pageIn .22s var(--ease-out) both}
@keyframes pageIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.fade{animation:pageIn .22s var(--ease-out) both}
.blink{animation:dotPulse 1.4s step-start infinite}

/* ═══════════════════════════════════════════════════════════════════
   PRINT
═══════════════════════════════════════════════════════════════════ */

/* ── ANALYTICS RESPONSIVE LAYOUT ─────────────────────────────── */
.analytics-chart-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  margin-bottom: 14px;
}
@media (max-width: 1400px) {
  .analytics-chart-row { grid-template-columns: 1fr; }
  .smart-grid { grid-template-columns: repeat(auto-fill, minmax(180px,1fr)); }
}

/* ── SAFE OVERFLOW GUARDS ─────────────────────────────────────── */
#content > * { max-width: 100%; min-width: 0; }
.widget      { min-width: 0; }
canvas       { max-width: 100%; }
.alper-stats { grid-template-columns: repeat(auto-fill, minmax(110px,1fr)) !important; }
#analytics-content{width:100%;max-width:100%;min-width:0;}
#analytics-content > .smart-grid{
  width:100%;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
  gap:14px;
}
#analytics-content .widget,#analytics-content .chart-card{min-width:0;max-width:100%;}

/* ── MBAR NO PAGE OVERFLOW ────────────────────────────────────── */
.mbar-outer { min-width: 0; }

@media print{
  #sb,#topbar,.btn,.mbar-outer,#toast,#login-screen,
  #panel-overlay,#panel,#modal-overlay,#fab,#cmd-overlay{display:none!important}
  body,html{overflow:visible!important;height:auto!important;width:auto!important;background:#fff!important}
  #main{overflow:visible!important;height:auto!important}
  #content{overflow:visible!important;padding:0!important;color:#111}
  .table-card{break-inside:avoid;border:1px solid #ddd}
  .kpi-card{break-inside:avoid;border:1px solid #ddd;background:#f8f8f8}
  table{font-size:10px}
  .i0,.i1,.i2{color:#111!important}
  .badge{border:1px solid #ccc!important;background:#f0f0f0!important;color:#333!important}
}

/* ═══════════════════════════════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════════════════════════════ */
@media (max-width:1400px){
  :root{--sb-w:236px}
  .search-input{width:130px}
  .kpi-grid{grid-template-columns:repeat(auto-fill,minmax(140px,1fr))}
}
@media (max-width:1366px){
  .search-input{width:110px}
  .search-input:focus{width:150px}
  .btn-sm{padding:4.5px 9px;font-size:11px}
  .kpi-grid{grid-template-columns:repeat(auto-fill,minmax(130px,1fr))}
}

/* ─── 1100 px — small laptop / partial snap ──────────────────── */
@media (max-width:1100px){
  :root{ --sb-w:212px }
  #content{ padding:16px }
  .search-input{ width:88px }
  .search-input:focus{ width:120px }
  .kpi-grid{ grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:10px }
  .kpi-card{ padding:14px 12px }
}

/* ─── 960 px — Windows half-snap on 1920 px display ──────────── */
@media (max-width:960px){
  :root{ --sb-w:198px }
  #content{ padding:14px }
  .search-input{ width:72px }
  .search-input:focus{ width:98px }
  .save-indicator{ display:none }
  .topbar-actions{ gap:4px }
  .kpi-grid{ grid-template-columns:repeat(auto-fill,minmax(108px,1fr));gap:8px }
  .kpi-card{ padding:12px 10px }
  .kpi-value{ font-size:17px }
  .period-bar{ padding:5px 10px }
  .mbar-outer{ margin-bottom:12px }
}

/* ─── 860 px — very tight, approaching Electron minWidth ─────── */
@media (max-width:860px){
  :root{ --sb-w:180px }
  #content{ padding:12px }
  .sb-brand{ padding:14px 12px 10px }
  .sb-brand-sub{ display:none }
  .nav{ padding:6px 8px;font-size:11.5px }
  .nav .ni{ width:16px;font-size:13px }
  .search-wrap{ display:none }
  .topbar-actions{ gap:3px }
  .btn-sm{ padding:3.5px 7px;font-size:10.5px }
  .kpi-grid{ grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:7px }
  .kpi-card{ padding:10px 9px }
  .kpi-value{ font-size:15px }
  .kpi-icon{ font-size:15px;margin-bottom:6px }
  .kpi-label{ font-size:10px }
  tbody td{ padding:7px 10px }
  thead th{ padding:6px 10px }
  #modal{ padding:20px }
  .modal-footer{ gap:6px }
  .form-grid-2{ grid-template-columns:1fr }
  .cloud-label-sub{ display:none }
}

/* ─── 780 px — Electron minWidth floor ───────────────────────── */
@media (max-width:780px){
  :root{ --sb-w:166px }
  #content{ padding:10px }
  .sb-section{ padding:8px 6px 2px }
  .kpi-grid{ grid-template-columns:1fr 1fr;gap:7px }
  .kpi-value{ font-size:14px }
  .cloud-indicator{ padding:6px 8px }
}

/* ── RESPONSIVE BUG FIXES ─────────────────────────────────────── */
/* Action buttons: never shrink or clip */
.btn-xs{ flex-shrink:0;white-space:nowrap }
/* User management modal: action cell wraps gracefully */
@media (max-width:960px){
  #modal .table-scroller table{ min-width:640px }
  .top-controls{ gap:4px }
  .top-lang-btn{ padding:3px 7px;font-size:10.5px }
  .top-theme-btn{ width:26px;height:24px;font-size:12px }
}
@media (max-width:860px){
  #modal{ max-width:calc(100vw - 32px);padding:16px }
  .top-controls{ gap:3px }
  .top-lang-seg{ display:none }
}
/* Sidebar collapsed edge: breathing room on the right */
body.sb-collapsed #content{ padding-left:12px }
/* Topbar: prevent overflow when window is very narrow */
#topbar{ min-width:0;overflow:hidden }

/* ── SIDEBAR TOGGLE BUTTON ──────────────────────────────────────── */
.sb-toggle-btn {
  width:100%;padding:7px;border-radius:var(--r2);
  background:var(--glass-1);border:1px solid var(--bd-1);
  color:var(--i4);font-size:13px;font-weight:600;
  cursor:pointer;font-family:var(--sans);
  transition:background .15s,color .15s,border-color .15s;
  display:flex;align-items:center;justify-content:center;gap:6px;
  margin-top:6px;
}
.sb-toggle-btn:hover{background:var(--glass-2);color:var(--i1);border-color:var(--bd-2)}

/* ── SIDEBAR COLLAPSED (manual toggle) ─────────────────────────── */
body.sb-collapsed #sb{width:84px;min-width:84px;max-width:84px;flex:0 0 84px}
body.sb-collapsed .sb-brand{padding:12px 0;display:flex;flex-direction:column;align-items:center}
body.sb-collapsed .sb-brand-logo{justify-content:center}
body.sb-collapsed .sb-brand-name,
body.sb-collapsed .sb-brand-sub,
body.sb-collapsed .sb-section-label,
body.sb-collapsed .sb-user-info,
body.sb-collapsed .sb-logout-btn,
body.sb-collapsed .cloud-label,
body.sb-collapsed .sb-save-btn{display:none}
body.sb-collapsed .sb-section{padding:6px 4px 2px}
body.sb-collapsed .sb-user{justify-content:center;padding:8px 0}
body.sb-collapsed .nav{font-size:0;justify-content:center;padding:8px 0;gap:0}
body.sb-collapsed .nav .ni{font-size:14px}
body.sb-collapsed .nav .nbadge{font-size:9px;margin-left:0}
body.sb-collapsed .nav.active::before{top:18%;bottom:18%}
body.sb-collapsed .bld-kebab{display:none}
body.sb-collapsed .sb-footer{padding:6px}
body.sb-collapsed .cloud-indicator{justify-content:center;padding:8px 4px}
body.sb-collapsed .sb-toggle-btn{width:auto;padding:6px 10px;margin:6px auto 0}

@media (min-width:1920px){
  :root{--sb-w:260px;--tb-h:54px}
  #content{padding:24px}
  .kpi-grid{grid-template-columns:repeat(auto-fill,minmax(170px,1fr))}
}



/* ═══════════════════════════════════════════════════════════════════
   v5.1.6 READABILITY + PREMIUM POLISH OVERRIDES
   Safe visual-only pass: contrast, depth, motion, accessibility.
═══════════════════════════════════════════════════════════════════ */
:root {
  --bg-base: #081427;
  --bg-elevated: #0d1c33;
  --bg-overlay: #132641;
  --bg-subtle: #1a3152;
  --bg-muted: #203a61;
  --glass-1: rgba(255,255,255,0.055);
  --glass-2: rgba(255,255,255,0.082);
  --glass-3: rgba(255,255,255,0.125);
  --glass-4: rgba(255,255,255,0.17);
  --bd-1: rgba(170,200,255,0.105);
  --bd-2: rgba(170,200,255,0.17);
  --bd-3: rgba(170,200,255,0.24);
  --i0: #ffffff;
  --i1: #f1f6ff;
  --i2: #c8d6ee;
  --i3: #9db0ce;
  --i4: #7890b3;
  --i5: #5e769b;
  --sh1: 0 2px 8px rgba(0,0,0,.34), 0 1px 1px rgba(255,255,255,.02) inset;
  --sh2: 0 10px 26px rgba(0,0,0,.38), 0 1px 0 rgba(255,255,255,.04) inset;
  --sh3: 0 18px 52px rgba(0,0,0,.48), 0 1px 0 rgba(255,255,255,.055) inset;
  --sh-blue: 0 0 0 1px rgba(96,165,250,.22), 0 0 28px rgba(59,130,246,.18);
}
body {
  background:
    radial-gradient(900px 520px at 18% -8%, rgba(59,130,246,.16), transparent 64%),
    radial-gradient(780px 520px at 96% 22%, rgba(139,92,246,.11), transparent 62%),
    linear-gradient(135deg,#081427 0%,#0b1730 45%,#0a1125 100%);
}
body::after {
  top:-24vh;left:24%;width:54vw;height:48vh;
  background:radial-gradient(ellipse,rgba(96,165,250,.12) 0%,rgba(139,92,246,.055) 45%,transparent 72%);
}
#sb {
  background:linear-gradient(180deg,rgba(10,22,40,.98),rgba(6,14,27,.965));
  box-shadow:16px 0 46px rgba(0,0,0,.30), inset -1px 0 rgba(255,255,255,.025);
}
.sb-brand, .sb-user, .sb-footer { border-color:rgba(160,190,255,.12); }
.sb-brand-sub,.sb-user-role,.sb-section-label,.cloud-label-sub,.save-indicator { color:var(--i4); }
.nav {
  color:var(--i3);
  border:1px solid transparent;
}
.nav:hover {
  background:linear-gradient(90deg,rgba(96,165,250,.105),rgba(255,255,255,.032));
  border-color:rgba(96,165,250,.12);
  color:var(--i1);
}
.nav.active {
  background:linear-gradient(90deg,rgba(59,130,246,.22),rgba(59,130,246,.075));
  border-color:rgba(96,165,250,.26);
  color:#dbeafe;
  box-shadow:0 10px 24px rgba(0,0,0,.18), inset 0 1px 0 rgba(255,255,255,.055);
}
.nav .ni { opacity:.88; filter:drop-shadow(0 0 8px rgba(96,165,250,.16)); }
#topbar {
  background:linear-gradient(180deg,rgba(11,25,45,.92),rgba(7,15,30,.82));
  border-bottom-color:rgba(155,185,230,.13);
  box-shadow:0 12px 34px rgba(0,0,0,.18);
}
#content {
  background:
    radial-gradient(700px 360px at 58% -90px,rgba(59,130,246,.085),transparent 65%),
    linear-gradient(180deg,rgba(255,255,255,.012),transparent 34%);
}
.search-input,.form-input,.form-select,.form-textarea {
  background:rgba(12,27,49,.78)!important;
  border-color:rgba(160,190,255,.15)!important;
  color:var(--i1)!important;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.035);
}
.search-input::placeholder,.form-input::placeholder,.form-textarea::placeholder { color:#8298b8; }
.search-input:focus,.form-input:focus,.form-select:focus,.form-textarea:focus {
  border-color:rgba(96,165,250,.56)!important;
  box-shadow:0 0 0 3px rgba(59,130,246,.18), inset 0 1px 0 rgba(255,255,255,.04)!important;
}
.mbar-outer {
  padding:8px;
  border-radius:18px;
  background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.02));
  border:1px solid rgba(170,200,255,.105);
  box-shadow:var(--sh1);
}
.period-bar {
  background:rgba(12,27,49,.68);
  border-color:rgba(170,200,255,.13);
  min-height:36px;
  cursor:grab;
}
.period-bar.is-dragging { cursor:grabbing; }
.period-label,.year-tag { color:var(--i3); }
.year-tag { background:rgba(96,165,250,.09);border-color:rgba(96,165,250,.14); }
.mbtn { color:var(--i3); padding:5px 10px; }
.mbtn:hover { background:rgba(96,165,250,.13);color:#eaf2ff;border-color:rgba(96,165,250,.22); }
.mbtn.active {
  background:linear-gradient(135deg,rgba(59,130,246,.38),rgba(139,92,246,.24));
  color:#ffffff;
  border-color:rgba(147,197,253,.48);
  box-shadow:0 8px 22px rgba(59,130,246,.22), inset 0 1px 0 rgba(255,255,255,.12);
}
.mbar-arrow {
  background:rgba(12,27,49,.76); color:#b9c8e3; border-color:rgba(170,200,255,.14);
}
.kpi-card,.table-card,.modal,.panel,.cmd-box,.analytics-card,.rank-item,.timeline-item,.cloud-indicator {
  background:linear-gradient(180deg,rgba(255,255,255,.075),rgba(255,255,255,.035));
  border-color:rgba(170,200,255,.13);
  box-shadow:var(--sh1);
}
.kpi-card {
  transform-style:preserve-3d;
  box-shadow:var(--sh2);
}
.kpi-card:hover {
  transform:translateY(-4px) scale(1.01);
  border-color:rgba(96,165,250,.28);
  box-shadow:var(--sh3),0 0 34px rgba(59,130,246,.08);
}
.kpi-value { text-shadow:0 0 18px color-mix(in srgb, var(--kpi-color,var(--blue-l)) 40%, transparent); }
.kpi-label,.empty-state-text { color:var(--i3); }
.sec-hdr { color:var(--i2); }
.table-card-header {
  background:linear-gradient(180deg,rgba(255,255,255,.065),rgba(255,255,255,.025));
}
.table-card-title { color:#f6f8ff; }
thead th {
  background:rgba(14,30,54,.96);
  color:#9fb4d5;
  border-bottom-color:rgba(170,200,255,.12);
}
tbody tr { border-bottom-color:rgba(170,200,255,.055); }
tbody tr:hover { background:rgba(96,165,250,.075); }
tbody tr.clickable:hover { background:rgba(96,165,250,.105); }
tbody td { color:#c7d5ed; }
tbody td:first-child { color:#f1f6ff; }
.badge { box-shadow:inset 0 1px 0 rgba(255,255,255,.06); }
.b-gray { color:#9fb4d5; border-color:rgba(170,200,255,.12); }
.btn {
  box-shadow:0 4px 14px rgba(0,0,0,.18), inset 0 1px 0 rgba(255,255,255,.055);
  transition:transform .18s var(--ease-spring),box-shadow .18s var(--ease-std),background .18s,border-color .18s,color .18s;
}
.btn:hover { transform:translateY(-2px) scale(1.018); box-shadow:0 10px 24px rgba(0,0,0,.26), inset 0 1px 0 rgba(255,255,255,.08); }
.btn-secondary,.btn-ghost { color:#c4d3ec; border-color:rgba(170,200,255,.13); background:rgba(255,255,255,.055); }
.btn-secondary:hover,.btn-ghost:hover { color:#fff; border-color:rgba(96,165,250,.24); background:rgba(96,165,250,.11); }
.btn-primary { background:linear-gradient(135deg,#3b82f6,#2563eb); box-shadow:0 10px 24px rgba(59,130,246,.24), inset 0 1px 0 rgba(255,255,255,.14); }
.fab {
  background:linear-gradient(135deg,#3b82f6,#8b5cf6)!important;
  box-shadow:0 18px 46px rgba(59,130,246,.34),0 0 0 1px rgba(255,255,255,.12) inset!important;
}
#toast { box-shadow:var(--sh3); }
.page-enter,.fade { animation:polishedPageIn .28s var(--ease-out) both; }
@keyframes polishedPageIn {
  from { opacity:0; transform:translateY(8px) scale(.999); }
  to   { opacity:1; transform:none; }
}
/* softRise removed — re-animating every card on month change was expensive */
@keyframes softRise { from{opacity:.001; transform:translateY(8px)} to{opacity:1; transform:none} }
button:focus-visible,.nav:focus-visible,.mbtn:focus-visible,.mbar-arrow:focus-visible,.btn:focus-visible {
  outline:2px solid rgba(147,197,253,.86)!important;
  outline-offset:2px;
}
@media (prefers-reduced-motion:reduce) {
  *,*::before,*::after { animation-duration:.01ms!important; animation-iteration-count:1!important; scroll-behavior:auto!important; transition-duration:.01ms!important; }
}

/* ── SCROLL & PAINT PERFORMANCE ─────────────────────────────────── */
/* hint scroll-position compositor on the main scroll container */
#content        { will-change:scroll-position; }
/* scope horizontal table scroll to its own paint layer */
.table-scroller { will-change:scroll-position; }
/* scope month bar scroll — avoids repainting page content on drag */
.period-bar     { will-change:scroll-position; }
/* contain paint to each card — invalidating one card doesn't repaint siblings */
.table-card     { contain:paint; }
/* sidebar and topbar on their own layers — page scroll doesn't repaint them */
#sb             { will-change:transform; }
#topbar         { will-change:transform; }

/* ── DASHBOARD PREFERENCES ──────────────────────────────────────── */
.btn-dash-prefs-topbar{
  flex-shrink:0;
  padding:3px 9px;border-radius:var(--r1);
  background:rgba(255,255,255,.06);border:1px solid var(--bd-1);
  color:var(--i3);font-size:12px;font-family:var(--sans);
  cursor:pointer;-webkit-app-region:no-drag;
  transition:background .12s,color .12s,border-color .12s;
}
.btn-dash-prefs-topbar:hover{background:rgba(255,255,255,.11);color:var(--i1);border-color:var(--bd-2)}

/* Compact mode */
body.dash-compact .kpi-card{padding:10px 12px}
body.dash-compact .kpi-icon{font-size:16px;margin-bottom:4px}
body.dash-compact .kpi-value{font-size:15px}
body.dash-compact .kpi-label{font-size:10px}
body.dash-compact .widget{padding:12px 14px}
body.dash-compact .smart-grid{gap:8px;margin-bottom:10px}
body.dash-compact .sec-hdr{margin-top:10px;padding:4px 0 6px}
body.dash-compact .mbar-outer{margin-bottom:10px}
body.dash-compact .table-card{margin-bottom:10px}

/* Toggle switch */
.sw-wrap{position:relative;display:inline-block;width:38px;height:22px;flex-shrink:0;cursor:pointer}
.sw-wrap input{opacity:0;width:0;height:0;position:absolute}
.sw-slider{position:absolute;inset:0;background:rgba(255,255,255,.12);border-radius:11px;transition:background .2s}
.sw-slider::before{content:'';position:absolute;width:16px;height:16px;left:3px;top:3px;background:white;border-radius:50%;transition:transform .2s;box-shadow:0 1px 4px rgba(0,0,0,.3)}
.sw-wrap input:checked+.sw-slider{background:var(--blue)}
.sw-wrap input:checked+.sw-slider::before{transform:translateX(16px)}

/* Pref row */
.ktp-toggle{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid var(--bd-1)}
.ktp-toggle:last-of-type{border-bottom:none}
.ktp-toggle-label{font-size:13px;font-weight:500;color:var(--i1)}
.ktp-toggle-sub{font-size:11px;color:var(--i4);margin-top:2px}

/* ── Operational alert chips ──────────────────────────── */
.op-alerts{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;}
.op-chip{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap;}
.op-chip-red   {background:var(--err-bg);  color:var(--rose-l);  border:1px solid var(--err-bd);}
.op-chip-orange{background:var(--warn-bg); color:var(--amber-l); border:1px solid var(--warn-bd);}
.op-chip-gray  {background:rgba(255,255,255,.04);color:var(--i3);border:1px solid var(--bd-1);}
.op-chip-blue  {background:var(--info-bg); color:var(--blue-l);  border:1px solid var(--info-bd);}
/* ── Status filter pills ──────────────────────────────── */
.filter-pills{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px;}
.fpill{padding:3px 11px;border-radius:20px;font-size:11px;font-weight:600;
       background:rgba(255,255,255,.04);color:var(--i3);border:1px solid var(--bd-1);
       cursor:pointer;transition:all .15s var(--ease-std);}
.fpill:hover{background:rgba(255,255,255,.08);color:var(--i1);}
.fpill-active{background:rgba(59,130,246,.12);color:var(--blue-l);border-color:rgba(59,130,246,.35);}

/* ── Import Wizard ──────────────────────────────── */
#import-wiz-overlay{display:none;position:fixed;inset:0;z-index:9500;
  background:rgba(0,0,0,.72);align-items:center;justify-content:center;}
#import-wiz-overlay.open{display:flex;}
#import-wiz{background:#0a1628;border:1px solid rgba(59,130,246,.2);border-radius:16px;
  width:min(900px,95vw);max-height:90vh;display:flex;flex-direction:column;overflow:hidden;
  box-shadow:0 24px 80px rgba(0,0,0,.6);}
.wiz-hdr{padding:18px 24px 14px;border-bottom:1px solid rgba(255,255,255,.07);
  display:flex;align-items:flex-start;justify-content:space-between;flex-shrink:0;}
.wiz-steps{display:flex;align-items:center;gap:0;padding:0 24px;
  border-bottom:1px solid rgba(255,255,255,.07);flex-shrink:0;overflow-x:auto;}
.wiz-stp{padding:9px 12px;font-size:11px;color:var(--i5);white-space:nowrap;
  border-bottom:2px solid transparent;transition:color .2s,border-color .2s;}
.wiz-stp.active{color:var(--blue-l,#60a5fa);border-bottom-color:#3b82f6;}
.wiz-stp.done{color:var(--i3);}
.wiz-stp-arrow{color:var(--i5);font-size:10px;padding:0 2px;}
.wiz-body{flex:1;overflow-y:auto;padding:20px 24px;}
.wiz-ftr{padding:14px 24px;border-top:1px solid rgba(255,255,255,.07);
  display:flex;justify-content:space-between;align-items:center;flex-shrink:0;}
.wiz-drop{border:2px dashed rgba(59,130,246,.3);border-radius:12px;padding:40px 20px;
  text-align:center;cursor:pointer;transition:border-color .2s,background .2s;}
.wiz-drop:hover,.wiz-drop.drag-over{border-color:rgba(59,130,246,.7);
  background:rgba(59,130,246,.06);}
.wiz-tbl{width:100%;border-collapse:collapse;font-size:12px;}
.wiz-tbl th{background:rgba(255,255,255,.04);color:var(--i3);padding:7px 10px;
  border:1px solid rgba(255,255,255,.07);font-weight:600;text-align:left;}
.wiz-tbl td{padding:6px 10px;border:1px solid rgba(255,255,255,.06);color:var(--i2);
  max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.wiz-tbl tr:nth-child(even) td{background:rgba(255,255,255,.02);}
.wiz-sel{background:#07101f;border:1px solid rgba(59,130,246,.25);color:var(--i2);
  border-radius:6px;padding:4px 8px;font-size:11.5px;width:100%;max-width:220px;}
.val-ok{color:#22c55e;}.val-warn{color:#f59e0b;}.val-err{color:#ef4444;}

</style>
<script>
/* ── KTP Safe-Boot & Recovery ── runs before ALL app JS ── */
(function(){
  // ── Global error overlay (works even if main script crashes mid-way) ──
  function _showErr(msg,stage){
    var el=document.getElementById('ktp-err-overlay');
    if(!el){
      el=document.createElement('div');el.id='ktp-err-overlay';
      el.style.cssText='position:fixed;inset:0;z-index:99999;display:flex;align-items:center;justify-content:center;background:rgba(6,13,26,.96);font-family:system-ui,sans-serif;padding:20px';
      if(document.body){document.body.appendChild(el);}
      else{document.addEventListener('DOMContentLoaded',function(){document.body.appendChild(el);});}
    }
    el.innerHTML='<div style="max-width:460px;width:100%;background:#0d1a2e;border:1px solid rgba(244,63,94,.5);border-radius:14px;padding:26px 24px 20px">'
      +'<div style="font-size:15px;font-weight:700;color:#fb7185;margin-bottom:8px">⚠️ Uygulama Başlatılamadı</div>'
      +'<div style="font-size:11.5px;color:#94a3b8;margin-bottom:6px">Aşama: <b style="color:#e2e8f0">'+(stage||'bilinmiyor')+'</b></div>'
      +'<pre style="font-size:10.5px;color:#fca5a5;white-space:pre-wrap;word-break:break-all;max-height:100px;overflow:auto;background:rgba(0,0,0,.3);border-radius:6px;padding:8px;margin-bottom:14px">'+String(msg||'').replace(/[<>&]/g,function(c){return{'<':'&lt;','>':'&gt;','&':'&amp;'}[c]||c;})+'</pre>'
      +'<div style="display:flex;gap:8px;flex-wrap:wrap">'
        +'<button onclick="window.__ktpRecover(true)" style="padding:8px 14px;background:#7f1d1d;border:1px solid rgba(244,63,94,.5);border-radius:8px;color:#fca5a5;cursor:pointer;font-size:12px">🗑 Verileri yedekle ve sıfırla</button>'
        +'<button onclick="window.__ktpSafeReload()" style="padding:8px 14px;background:rgba(59,130,246,.15);border:1px solid rgba(59,130,246,.4);border-radius:8px;color:#93c5fd;cursor:pointer;font-size:12px">🛡 Kuruluma dön</button>'
      +'</div>'
      +'</div>';
  }
  window.onerror=function(msg,src,line,col,err){
    var stage=(window.__BOOT_STAGE__&&window.__BOOT_STAGE__.stage)||'unknown';
    _showErr((err&&(err.stack||err.message))||msg,stage);
    return false; // don't suppress — let Electron also log it
  };
  window.onunhandledrejection=function(ev){
    var stage=(window.__BOOT_STAGE__&&window.__BOOT_STAGE__.stage)||'unknown';
    _showErr(ev.reason?(ev.reason.stack||ev.reason.message||String(ev.reason)):'Unhandled rejection',stage);
  };

  // ── Recovery: back up data then wipe + reload ──────────────
  window.__ktpRecover=function(backup){
    try{
      if(backup){
        var raw=localStorage.getItem('ktp_v5');
        if(raw) try{localStorage.setItem('ktp_v5_emrg_'+Date.now(),raw.slice(0,500000));}catch(e){}
      }
      localStorage.removeItem('ktp_v5');
      localStorage.removeItem('ktp_safe_mode');
    }catch(e){}
    location.reload();
  };

  // ── Safe reload: set flag + reload — skips loadLocal next boot
  window.__ktpSafeReload=function(){
    try{localStorage.setItem('ktp_safe_mode','1');}catch(e){}
    location.reload();
  };

  // ── Safe mode: consume flag immediately so it doesn't persist ─
  var _safe=false;
  try{
    if(localStorage.getItem('ktp_safe_mode')==='1'){
      _safe=true;
      localStorage.removeItem('ktp_safe_mode');
    }
  }catch(e){}
  window.__KTP_SAFE_MODE__=_safe;

  // ── Ctrl+Alt+R — hard recovery reset, works on login screen ──
  document.addEventListener('keydown',function(e){
    if(e.ctrlKey&&e.altKey&&(e.key==='r'||e.key==='R')){
      e.preventDefault();
      if(confirm('Kurtarma: yerel veriler yedeklenip silinecek ve uygulama yeniden başlatılacak. Devam?')){
        window.__ktpRecover(true);
      }
    }
  },true);
})();
</script>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">🏢</div>
    <div class="login-title">Kira Takip Pro</div>
    <div id="login-sub" class="login-sub">Emlak Yönetim Sistemi — Giriş yapın</div>
    <div class="login-users" id="login-users"></div>
    <div class="login-pin-wrap" id="pin-wrap">
      <input type="password" class="login-pin-input" id="pin-inp" maxlength="6"
             placeholder="• • • •" oninput="checkPin()" autocomplete="off">
    </div>
    <div class="login-error" id="login-err"></div>
    <div class="login-version">v6.0 · © 2026</div>
    <div style="margin-top:18px;text-align:center;display:flex;align-items:center;justify-content:center;gap:4px">
      <button id="btn-static-safe" onclick="window.__ktpSafeReload&&window.__ktpSafeReload()"
        style="background:none;border:none;color:rgba(148,163,184,.45);font-size:10.5px;cursor:pointer;padding:4px 8px;border-radius:6px"
        onmouseover="this.style.color='rgba(147,197,253,.8)'" onmouseout="this.style.color='rgba(148,163,184,.45)'">🛡 Kurtarma Modu</button>
      <span style="color:rgba(100,116,139,.3);font-size:10px">·</span>
      <button id="btn-static-reset" onclick="window.__ktpRecover&&window.__ktpRecover(true)"
        style="background:none;border:none;color:rgba(148,163,184,.45);font-size:10.5px;cursor:pointer;padding:4px 8px;border-radius:6px"
        onmouseover="this.style.color='rgba(252,165,165,.8)'" onmouseout="this.style.color='rgba(148,163,184,.45)'">Verileri Sıfırla</button>
    </div>
    <div id="login-lang-pill" style="position:absolute;top:12px;right:14px;display:flex;align-items:center;gap:5px">
      <div style="display:flex;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:20px;overflow:hidden;font-size:10px;font-weight:600">
        <button id="lang-tr-btn" onclick="switchLang('tr')" style="background:rgba(59,130,246,.3);border:none;color:#93c5fd;padding:3px 10px;cursor:pointer;letter-spacing:.5px">TR</button>
        <button id="lang-en-btn" onclick="switchLang('en')" style="background:none;border:none;color:rgba(148,163,184,.6);padding:3px 10px;cursor:pointer;letter-spacing:.5px">EN</button>
      </div>
      <button id="theme-btn" onclick="switchTheme()" style="background:none;border:1px solid rgba(255,255,255,.1);border-radius:50%;width:24px;height:24px;cursor:pointer;font-size:12px;line-height:1;padding:0;color:rgba(148,163,184,.7)">🌙</button>
    </div>
  </div>
</div>

<!-- ONBOARDING (Phase 4 — PRODUCTION_MODE=true only) -->
<div id="ob-screen" style="display:none">
  <div class="login-box" id="ob-box"></div>
</div>

<!-- IMPORT WIZARD -->
<div id="import-hist-overlay" style="display:none;position:fixed;inset:0;z-index:9400;background:rgba(0,0,0,.65);align-items:center;justify-content:center">
  <div style="background:#0a1628;border:1px solid rgba(59,130,246,.2);border-radius:16px;width:min(700px,95vw);max-height:80vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.5)">
    <div style="padding:16px 20px 12px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,.06);flex-shrink:0">
      <div id="import-hist-title" style="font-size:14px;font-weight:700;color:var(--i1)">📋 Import Geçmişi</div>
      <button onclick="closeImportHistory()" style="background:none;border:none;color:var(--i4);font-size:18px;cursor:pointer;padding:4px 8px;border-radius:6px;line-height:1">✕</button>
    </div>
    <div id="import-hist-body" style="overflow-y:auto;flex:1;padding:12px 16px 16px"></div>
  </div>
</div>

<div id="import-wiz-overlay">
  <div id="import-wiz">
    <div class="wiz-hdr">
      <div>
        <div id="wiz-hdr-title" style="font-size:15px;font-weight:700;color:var(--i1)">📥 Akıllı İçe Aktarma</div>
        <div style="font-size:11px;color:var(--i4);margin-top:2px" id="wiz-hdr-sub"></div>
      </div>
      <button onclick="closeImportWizard()" style="background:none;border:none;color:var(--i4);font-size:18px;cursor:pointer;padding:4px 8px;border-radius:6px;line-height:1" title="Kapat">✕</button>
    </div>
    <div class="wiz-steps" id="wiz-steps"></div>
    <div class="wiz-body" id="wiz-body"></div>
    <div class="wiz-ftr" id="wiz-ftr"></div>
  </div>
</div>

<!-- SIDEBAR -->
<div id="sb">
  <div class="sb-brand">
    <div class="sb-brand-logo">
      <div class="sb-brand-icon">🏢</div>
      <div class="sb-brand-name">Kira Takip Pro</div>
    </div>
    <div class="sb-brand-sub">Emlak Yönetim Sistemi v6.0</div>
  </div>

  <div class="sb-user" id="sb-user">
    <div class="sb-user-av" id="sb-uav"></div>
    <div class="sb-user-info">
      <div class="sb-user-name" id="sb-uname"></div>
      <div class="sb-user-role" id="sb-urole"></div>
    </div>
    <button class="sb-logout-btn" onclick="logout()" title="Çıkış">⇠</button>
  </div>

  <div class="sb-section">
    <div class="sb-section-label" id="sb-lbl-general">Genel</div>
    <button class="nav active" id="nb-dash" onclick="goto('dash')"><span class="ni">📊</span>Dashboard</button>
    <button class="nav" id="nb-pay" onclick="goto('pay')"><span class="ni">💳</span>Tüm Ödemeler</button>
    <button class="nav" id="nb-exp" onclick="goto('exp')"><span class="ni">💸</span>Tüm Giderler</button>
    <button class="nav" id="nb-alper" onclick="goto('alper')"><span class="ni">🤝</span>Yönetim Hesabı</button>
    <button class="nav" id="nb-charts" onclick="goto('charts')"><span class="ni">📈</span>Grafikler</button>
    <button class="nav" id="nb-wa" onclick="goto('wa')"><span class="ni">💬</span>WhatsApp</button>
    <button class="nav" id="nb-rep" onclick="goto('rep')"><span class="ni">📄</span>Raporlar</button>
    <button class="nav" id="nb-hist" onclick="goto('hist')"><span class="ni">🕐</span>Geçmiş</button>
    <button class="nav" id="nb-viz" onclick="goto('viz')"><span class="ni">🌐</span>3D Görünüm</button>
  </div>

  <div class="sb-section" id="bld-nav-root">
    <div class="sb-section-label">Binalar</div>
  </div>

  <div class="sb-section">
    <div class="sb-section-label" id="sb-lbl-tools">Araçlar</div>
    <button class="nav" id="nb-cloud" onclick="openModal('cloud')"><span class="ni">🔄</span>Bulut Sync</button>
    <button class="nav" onclick="openModal('users')" id="nb-users"><span class="ni">👥</span>Kullanıcılar</button>
    <button class="nav" onclick="openImportWizard()" id="nb-import"><span class="ni">📥</span>İçe Aktar</button>
    <button class="nav" onclick="openImportHistory()" id="nb-imphist"><span class="ni">📋</span>Import Geçmişi</button>
    <button class="nav" id="nb-settings" onclick="openModal('settings')"><span class="ni">⚙</span>Ayarlar</button>
    <button class="nav" id="nb-csv" onclick="exportCSV()"><span class="ni">📋</span>CSV İndir</button>
    <button class="nav" id="nb-json" onclick="exportJSON()"><span class="ni">💾</span>JSON Yedek</button>
    <button class="nav" id="nb-excel" onclick="exportExcel()"><span class="ni">📗</span>Excel İndir</button>
    <button class="nav" id="nb-print" onclick="window.print()"><span class="ni">🖨</span>Yazdır</button>
  </div>

  <div class="sb-footer">
    <div class="cloud-indicator" onclick="openModal('cloud')" id="cloud-btn">
      <div class="cloud-dot off" id="cloud-dot"></div>
      <div class="cloud-label">
        <div class="cloud-label-title" id="cloud-title">Bulut Yok</div>
        <div class="cloud-label-sub" id="cloud-sub">Yerel mod aktif</div>
      </div>
    </div>
    <button class="sb-save-btn" id="sb-save-btn" onclick="manualSave()">💾 Kaydet</button>
    <button class="sb-toggle-btn" id="sb-toggle" onclick="toggleSidebar()" title="Kenar çubuğunu daralt/genişlet">◀ Daralt</button>
  </div>
</div>

<!-- MAIN -->
<div id="main">
  <div id="topbar">
    <div id="topbar-title">Dashboard</div>
    <button id="btn-dash-prefs" class="btn-dash-prefs-topbar" style="display:none" onclick="openMod('dash-prefs')" title="Panel Tercihleri">⚙️</button>
    <div class="topbar-actions">
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input type="text" class="search-input" id="gsrch"
               placeholder="Kiracı ara..." oninput="globalSearch(this.value)">
      </div>
      <button class="btn btn-primary btn-sm" id="btn-pay" onclick="openModal('pay-add')">+ Ödeme</button>
      <button class="btn btn-secondary btn-sm" id="btn-exp" onclick="openModal('exp-add')">+ Gider</button>
      <button class="btn btn-ghost btn-sm" id="btn-ten" onclick="openModal('ten-add','')">+ Kiracı</button>
      <span class="save-indicator" id="save-lbl"></span>
      <div class="top-controls">
        <div class="top-lang-seg">
          <button id="top-lang-tr" class="top-lang-btn top-lang-active" onclick="switchLang('tr')">TR</button>
          <button id="top-lang-en" class="top-lang-btn" onclick="switchLang('en')">EN</button>
        </div>
        <button id="top-theme-btn" class="top-theme-btn" onclick="switchTheme()" title="Toggle theme">🌙</button>
      </div>
    </div>
  </div>
  <div id="content" class="page-enter"></div>
</div>

